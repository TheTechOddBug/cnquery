// Represents egress routing intent or observed compiled routing state from
// HBN network CRDs, Coil Egress resources, and compatible integrations.
// Kubernetes-only clusters without those integrations expose an empty list.
private k8s.egressRoute @defaults("sourceRef vrf network classification confidence") {
  // Source object reference in kind:namespace:name or kind:name form

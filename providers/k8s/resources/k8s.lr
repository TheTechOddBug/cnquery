  // Public CIDRs included in the route
  publicCidrs []string
  // Whether NAT is configured or inferred for this route
  nat bool
  // Node status references that reported this route
  nodeStatuses []string
  // BGP peering references associated with this route
  bgpPeerings []string
  // Route classification
  classification string
  // Explicit classification metadata from the source object
  metadataClassification string
  // Explicit owner metadata from the source object
  owner string
  // Static-analysis confidence: high, medium, or low
  confidence string
}

// Normalized Kubernetes egress NAT
//

  // Network associated with this NAT entry
  network string
  // NAT addresses
  addresses []string
  // NAT CIDRs
  cidrs []string
  // Public CIDRs included in the NAT entry
  publicCidrs []string
  // Node status references that reported this NAT entry
  nodeStatuses []string
  // NAT classification

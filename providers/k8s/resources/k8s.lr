  // Policy object reference
  policyRef string
  // Policy namespace
  namespace string
  // Pod selector covered by the policy
  podSelector dict
  // Interfaces covered by this summary, for example primary or secondary network names
  interfaces []string
  // Native Kubernetes NetworkPolicy references
  nativeNetworkPolicies []string
  // Kubernetes AdminNetworkPolicy and BaselineAdminNetworkPolicy references
  adminNetworkPolicies []string
  // MultiNetworkPolicy references
  multiNetworkPolicies []string
  // Calico policy references
  calicoPolicies []string
  // Cilium policy references
  ciliumPolicies []string
  // Whether selected pods have ingress default-deny semantics
  defaultDenyIngress bool
  // Whether selected pods have egress default-deny semantics
  defaultDenyEgress bool
  // Whether admin network policy coverage supplies ingress catch-all deny semantics
  adminDefaultDenyIngress bool
  // Whether admin network policy coverage supplies egress catch-all deny semantics
  adminDefaultDenyEgress bool
  // Whether secondary interface ingress is covered
  secondaryInterfaceIngressCovered bool
  // Whether secondary interface egress is covered
  secondaryInterfaceEgressCovered bool
  // Coverage gaps that should be shown to users
  coverageGaps []string
}


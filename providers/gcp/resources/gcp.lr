  enablementConfig string
  // Current scanning state (SCANNING_ACTIVE, SCANNING_DISABLED, SCANNING_UNSUPPORTED)
  enablementState string
  // Explanation of the current scanning state
  enablementStateReason string
  // Time scanning was last enabled
  lastEnableTime time
}

// Google Cloud (GCP) Artifact Registry repository cleanup policy
//
// Examine a cleanup policy attached to an Artifact Registry repository.
// Each policy has an `action` (DELETE or KEEP) and a `policyType` that
// selects between a condition-based filter (`condition`) or a most-recent-
// versions retention rule (`mostRecentVersions`).
private gcp.project.artifactRegistryService.repository.cleanupPolicy @defaults("id action policyType") {
  // Internal ID
  id string
  // Policy action (DELETE or KEEP)
  action string
  // Policy type: "condition" or "mostRecentVersions"
  policyType string
  // Condition filter details; fields are non-empty only when policyType == "condition"
  condition gcp.project.artifactRegistryService.repository.cleanupPolicy.condition
  // Most-recent-version details; fields are non-empty only when policyType == "mostRecentVersions"
  mostRecentVersions gcp.project.artifactRegistryService.repository.cleanupPolicy.mostRecentVersions
}

// Google Cloud (GCP) Artifact Registry cleanup policy condition
private gcp.project.artifactRegistryService.repository.cleanupPolicy.condition {
  // Internal ID
  id string
  // Tag state filter (TAGGED, UNTAGGED, ANY)
  tagState string
  // Tag prefix filters
  tagPrefixes []string
  // Version name prefix filters
  versionNamePrefixes []string
  // Package name prefix filters
  packageNamePrefixes []string
  // Match versions older than this duration (e.g., "2592000s" for 30 days)
  olderThan string
  // Match versions newer than this duration
  newerThan string
}

// Google Cloud (GCP) Artifact Registry cleanup policy most recent versions config
private gcp.project.artifactRegistryService.repository.cleanupPolicy.mostRecentVersions {
  // Internal ID
  id string
  // Number of recent versions to keep
  keepCount int
  // Package name prefix filters
  packageNamePrefixes []string
}

// Google Cloud (GCP) Artifact Registry repository format-specific configuration
private gcp.project.artifactRegistryService.repository.formatConfig {
  // Internal ID
  id string
  // Repository format (e.g., DOCKER, MAVEN, NPM, PYTHON, APT, YUM, GO, KFP)
  format string
  // Whether Docker image tags are immutable (Docker repos only)
  immutableTags bool
  // Whether Maven snapshot overwrites are allowed (Maven repos only)
  allowSnapshotOverwrites bool
  // Maven version policy: RELEASE, SNAPSHOT, or VERSION_POLICY_UNSPECIFIED (Maven repos only)
  mavenVersionPolicy string
}

// Google Cloud (GCP) Artifact Registry repository mode-specific configuration
private gcp.project.artifactRegistryService.repository.modeConfig {
  // Internal ID
  id string
  // Upstream policies for virtual repositories (ordered by priority)
  upstreamPolicies []gcp.project.artifactRegistryService.repository.upstreamPolicy
  // Remote repository description
  remoteRepositoryDescription string
  // Whether upstream validation is disabled (remote repos)
  disableUpstreamValidation bool
}

// Google Cloud (GCP) Artifact Registry virtual repository upstream policy
private gcp.project.artifactRegistryService.repository.upstreamPolicy @defaults("id priority") {
  // Internal ID
  id string
  // Full resource name of the upstream repository
  repository string
  // Priority (lower value = higher priority)
  priority int
}


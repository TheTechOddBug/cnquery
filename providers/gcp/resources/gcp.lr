  selfLink string
  // Source instance URL (if created from an existing instance)
  sourceInstance string
  // Existing instance this template was created from
  sourceInstanceRef() gcp.project.computeService.instance
  // Instance properties (machine type, disks, network interfaces, etc.)
  properties dict
  // Creation timestamp
  creationTimestamp time
}

// Google Cloud (GCP) Cloud Deploy
//
// Cloud Deploy in the project, the root for continuous-delivery audits. It
// hosts the `deliveryPipelines` (the promotion sequences for releases) and
// the `targets` they deploy to, exposing execution configuration and
// per-target settings.
private gcp.project.cloudDeployService {
  // Project ID
  projectId string
  // Delivery pipelines
  deliveryPipelines() []gcp.project.cloudDeployService.deliveryPipeline
  // Targets
  targets() []gcp.project.cloudDeployService.target
}

// Google Cloud (GCP) Cloud Deploy delivery pipeline
//
// Delivery pipeline defining an ordered promotion sequence for releases. The
// `serialPipeline` stages, whether the pipeline is `suspended`, the readiness
// `condition`, resource labels, annotations, and the `releases` created from
// this pipeline support continuous-delivery configuration audits.
private gcp.project.cloudDeployService.deliveryPipeline @defaults("name") {
  // Project ID
  projectId string
  // Full resource name
  name string
  // User-assigned unique identifier
  uid string
  // Human-readable description of the resource
  description string
  // Resource annotations
  annotations map[string]string
  // Resource labels
  labels map[string]string
  // Creation time
  createTime time
  // Last update time
  updateTime time
  // Whether the pipeline is suspended
  suspended bool
  // Ordered pipeline stages
  //
  // Deployment stages under the `stages` key, each with `targetId`, the
  // `profiles` (Skaffold profiles) applied, a promotion `strategy`, and
  // `deployParameters`.
  serialPipeline dict
  // Pipeline readiness conditions
  //
  // Keyed by `pipelineReadyCondition` ({status, updateTime}),
  // `targetsPresentCondition` ({status, missingTargets, updateTime}), and
  // `targetsTypeCondition` ({status, errorDetails}).
  condition dict
  // Releases created from this pipeline
  releases() []gcp.project.cloudDeployService.release
}

// Google Cloud (GCP) Cloud Deploy target
//
// Deployment target that a delivery pipeline promotes releases to. Whether
// approval is required before promotion (`requireApproval`), the runtime the
// target represents (`gke` cluster, Cloud Run `run`, or `customTarget`), the
// `executionConfigs`, resource labels, and annotations support
// deployment-target audits.
private gcp.project.cloudDeployService.target @defaults("name") {
  // Project ID
  projectId string
  // Full resource name
  name string
  // User-assigned unique identifier
  uid string
  // Human-readable description of the resource
  description string
  // Resource annotations
  annotations map[string]string
  // Resource labels
  labels map[string]string
  // Creation time
  createTime time
  // Last update time
  updateTime time
  // Whether approval is required for this target
  requireApproval bool
  // GKE cluster target
  //
  // Keys: `cluster` (cluster resource name), `internalIp` (whether to reach
  // the cluster over its internal IP), `proxyUrl`, and `dnsEndpoint`.
  gke dict
  // Cloud Run target
  //
  // Holds the `location` key: the Cloud Run region the target deploys to.
  run dict
  // Custom target type
  //
  // Holds the `customTargetType` key: the resource name of the custom target
  // type that defines how this target is rendered and deployed.
  customTarget dict
  // Execution environment configs
  //
  // Each config carries `usages` (any of RENDER, DEPLOY, VERIFY, PREDEPLOY,
  // POSTDEPLOY), the `workerPool`, `serviceAccount`, `artifactStorage` bucket,
  // `executionTimeout`, and `verbose` logging.
  executionConfigs []dict
}

// Google Cloud (GCP) Cloud Deploy release
//
// Release rendered from a delivery pipeline for promotion to targets. The
// Skaffold configuration (`skaffoldConfigUri`, `skaffoldVersion`), the overall
// `renderState`, whether the release was `abandoned`, render timestamps, the
// readiness `condition`, resource labels, and annotations support release
// audits.
private gcp.project.cloudDeployService.release @defaults("name") {
  // Full resource name
  name string
  // Unique identifier
  uid string
  // Human-readable description of the resource
  description string
  // Whether the release was abandoned
  abandoned bool
  // Skaffold config URI
  skaffoldConfigUri string
  // Skaffold version
  skaffoldVersion string
  // Render state (SUCCEEDED, FAILED, IN_PROGRESS)
  renderState string
  // Resource annotations
  annotations map[string]string
  // Resource labels
  labels map[string]string
  // Creation time
  createTime time
  // Render start time
  renderStartTime time
  // Render end time
  renderEndTime time
  // Release readiness conditions
  //
  // Keyed by `releaseReadyCondition` ({status}) and
  // `skaffoldSupportedCondition` ({status, skaffoldSupportState,
  // maintenanceModeTime, supportExpirationTime}).
  condition dict
}

// Google Cloud (GCP) Dataflow
//
// Dataflow service for the project, the access point to the project's
// `jobs`. Each job exposes its pipeline type, current state, environment
// configuration, and worker settings for stream and batch processing
// audits.
private gcp.project.dataflowService {
  // Project ID
  projectId string
  // Dataflow jobs
  jobs() []gcp.project.dataflowService.job
}

// Google Cloud (GCP) Dataflow job
//
// Dataflow pipeline job, covering its pipeline type (JOB_TYPE_BATCH,
// JOB_TYPE_STREAMING), current state (JOB_STATE_RUNNING, JOB_STATE_DONE,
// and the other JOB_STATE_* values), the environment configuration for
// worker settings and SDK pipeline options, region or location of
// execution, resource labels, and creation timestamp.
private gcp.project.dataflowService.job @defaults("name currentState") {
  // Project ID
  projectId string
  // Unique job identifier
  id string
  // User-assigned job name
  name string
  // Type of job (JOB_TYPE_BATCH, JOB_TYPE_STREAMING)
  type string
  // Current state of the job
  //
  // One of JOB_STATE_UNKNOWN, JOB_STATE_STOPPED, JOB_STATE_RUNNING,
  // JOB_STATE_DONE, JOB_STATE_FAILED, JOB_STATE_CANCELLED,
  // JOB_STATE_UPDATED, JOB_STATE_DRAINING, JOB_STATE_DRAINED,
  // JOB_STATE_PENDING, JOB_STATE_CANCELLING, JOB_STATE_QUEUED, or
  // JOB_STATE_RESOURCE_CLEANING_UP.
  currentState string
  // Timestamp when the job was created
  createTime time
  // Region/location of the job
  location string
  // Resource labels
  labels map[string]string
  // Execution environment the job runs in
  //
  // Raw environment configuration, with keys including
  // `serviceAccountEmail`, `serviceKmsKeyName`, `workerPools`,
  // `workerRegion`, `workerZone`, `tempStoragePrefix`, `experiments`,
  // `serviceOptions`, `shuffleMode`, `streamingMode`, `usePublicIps`,
  // `sdkPipelineOptions`, and `flexResourceSchedulingGoal`. See `kmsKey`
  // for the resolved encryption key and `workerIpConfiguration` for the
  // resolved worker IP setting.
  environment dict
  // Customer-managed Cloud KMS key protecting pipeline state and shuffle data at rest
  kmsKey() gcp.project.kmsService.keyring.cryptokey
  // VM IP configuration of the job's worker pools (WORKER_IP_PUBLIC, WORKER_IP_PRIVATE, or WORKER_IP_UNSPECIFIED)
  workerIpConfiguration string
  // SDK pipeline description
  //
  // Description of the compiled pipeline, with keys `displayData`
  // (pipeline-level display data), `executionPipelineStage` (per-stage
  // execution descriptions), `originalPipelineTransform` (per-transform
  // descriptions and the collections between them), and `stepNamesHash`
  // (hash of the submitted pipeline step names).
  pipelineDescription dict
  // Timestamp of the current state
  currentStateTime time
}

// Google Cloud (GCP) Artifact Registry
//
// Artifact Registry in the project, exposing the project's `repositories`.
// Each repository carries its package format, mode, encryption
// configuration, cleanup policies, and IAM policy, so this resource is the
// entry point for auditing container-image and package storage across the
// project.
private gcp.project.artifactRegistryService {
  // Project ID
  projectId string
  // List of Artifact Registry repositories in the project
  repositories() []gcp.project.artifactRegistryService.repository
}

// Google Cloud (GCP) Artifact Registry repository
//
// Single Artifact Registry repository: its package format (DOCKER, MAVEN,
// NPM, PYTHON, APT, YUM, GO, GENERIC), mode (STANDARD, VIRTUAL, REMOTE),
// encryption key, cleanup policies, format- and mode-specific
// configuration, and IAM policy bindings. The `vulnerabilityScanningConfig`
// field reports whether container-image scanning is active or inherited,
// and `public` flags a repository whose IAM policy makes its artifacts
// anonymously pullable.
private gcp.project.artifactRegistryService.repository @defaults("name format location") {
  // Project ID
  projectId string
  // Full resource path
  resourcePath string
  // Repository name
  name string
  // Repository location
  location string
  // Repository description
  description string
  // Package format (DOCKER, MAVEN, NPM, PYTHON, APT, YUM, GO, GENERIC, etc.)
  format string
  // Repository mode (STANDARD_REPOSITORY, VIRTUAL_REPOSITORY, REMOTE_REPOSITORY)
  mode string
  // User-assigned labels
  labels map[string]string
  // Cloud KMS encryption key name (empty means Google-managed encryption)
  //
  // Deprecated in favor of kmsKey().
  kmsKeyName @maturity("deprecated") string
  // Customer-managed Cloud KMS key used to encrypt the repository's artifacts at rest
  kmsKey() gcp.project.kmsService.keyring.cryptokey
  // Creation time
  createTime time
  // Last update time
  updateTime time
  // Total storage size in bytes
  sizeBytes int
  // Registry endpoint URI (e.g., us-docker.pkg.dev/project/repo)
  registryUri string
  // Whether the repository satisfies Physical Zone Separation
  satisfiesPzs bool
  // Whether the repository satisfies Physical Zone Isolation
  satisfiesPzi bool
  // Whether cleanup policy dry-run mode is enabled
  cleanupPolicyDryRun bool
  // Vulnerability scanning configuration
  vulnerabilityScanningConfig gcp.project.artifactRegistryService.repository.vulnScanConfig
  // Cleanup policies for artifact retention
  cleanupPolicies []gcp.project.artifactRegistryService.repository.cleanupPolicy
  // Format-specific configuration (Docker immutable tags, Maven version policy)
  formatConfig gcp.project.artifactRegistryService.repository.formatConfig
  // Mode-specific configuration (virtual upstream policies, remote repo config)
  modeConfig gcp.project.artifactRegistryService.repository.modeConfig
  // IAM policy bindings for this repository
  iamPolicy() []gcp.resourcemanager.binding
  // Whether the repository's IAM policy grants any role to allUsers or allAuthenticatedUsers, making its artifacts anonymously pullable
  public() bool
  // Packages stored in the repository
  packages() []gcp.project.artifactRegistryService.repository.package
  // Infrastructure-management system that provisioned the resource
  //
  // Value derived from the provenance labels and annotations Google and IaC
  // tools apply: "terraform", "config-connector", or "cloud-composer". Empty
  // when the resource carries no management signal.
  managedBy() string
}

// Google Cloud (GCP) Artifact Registry package
//
// Package stored in an Artifact Registry repository, identified by `name`
// (for example a container image name or a Maven/npm/PyPI package name).
// The `createTime` field records when the package first appeared and
// `updateTime` the most recent push, while `versions` lists the individual
// published versions, their tags, and their content digests, the
// per-artifact provenance of what was published and when.
private gcp.project.artifactRegistryService.repository.package @defaults("name updateTime") {
  // Project ID
  projectId string
  // Full resource path
  resourcePath string
  // Package name (last path segment, e.g. the image or library name)
  name string
  // Time the package was created
  createTime time
  // Time the package was last updated
  updateTime time
  // Client-specified annotations
  annotations map[string]string
  // Published versions of the package
  versions() []gcp.project.artifactRegistryService.repository.package.version
}

// Google Cloud (GCP) Artifact Registry package version
//
// Published version of an Artifact Registry package, identified by `name`
// (the version's digest or version string). The `createTime` field records
// when the version was pushed, `relatedTags` the human-readable tags (such
// as `latest`) that point at it, `fingerprints` the content hashes that
// uniquely pin the bytes, and `metadata` the format-specific details like
// the image manifest media type and build time.
private gcp.project.artifactRegistryService.repository.package.version @defaults("name createTime") {
  // Project ID
  projectId string
  // Full resource path
  resourcePath string
  // Version name (last path segment, typically a digest or version string)
  name string
  // Optional description of the version
  description string
  // Time the version was created (pushed)
  createTime time
  // Time the version was last updated
  updateTime time
  // Tags that point at this version (e.g. latest, v1.2.3)
  relatedTags []string
  // Content hashes that uniquely pin the version's bytes
  //
  // Each entry is a dict with `type` (the hash algorithm, for example
  // SHA256) and `value` (the hex-encoded hash).
  fingerprints []dict
  // Format-specific metadata (e.g. image manifest media type, image size, build time)
  metadata dict
}

// Google Cloud (GCP) Artifact Registry repository vulnerability scanning configuration
private gcp.project.artifactRegistryService.repository.vulnScanConfig {
  // Internal ID
  id string
  // Scanning enablement config (INHERITED, DISABLED, ENABLEMENT_CONFIG_UNSPECIFIED)
  enablementConfig string
  // Current scanning state (SCANNING_ACTIVE, SCANNING_DISABLED, SCANNING_UNSUPPORTED)
  enablementState string
  // Explanation of the current scanning state
  enablementStateReason string
  // Time scanning was last enabled
  lastEnableTime time
}

// Google Cloud (GCP) Artifact Registry repository cleanup policy
//
// Cleanup policy attached to an Artifact Registry repository. Each policy
// has an `action` (DELETE or KEEP) and a `policyType` that selects between
// a condition-based filter (`condition`) or a most-recent-versions
// retention rule (`mostRecentVersions`).
private gcp.project.artifactRegistryService.repository.cleanupPolicy @defaults("id action policyType") {
  // Internal ID
  id string
  // Policy action (DELETE or KEEP)
  action string
  // Policy type: "condition" or "mostRecentVersions"
  policyType string
  // Condition filter details; fields are non-empty only when policyType == "condition"
  condition gcp.project.artifactRegistryService.repository.cleanupPolicy.condition
  // Most-recent-version details; fields are non-empty only when policyType == "mostRecentVersions"
  mostRecentVersions gcp.project.artifactRegistryService.repository.cleanupPolicy.mostRecentVersions
}

// Google Cloud (GCP) Artifact Registry cleanup policy condition
private gcp.project.artifactRegistryService.repository.cleanupPolicy.condition {
  // Internal ID
  id string
  // Tag state filter (TAGGED, UNTAGGED, ANY)
  tagState string
  // Tag prefix filters
  tagPrefixes []string
  // Version name prefix filters
  versionNamePrefixes []string
  // Package name prefix filters
  packageNamePrefixes []string
  // Match versions older than this duration (e.g., "2592000s" for 30 days)
  olderThan string
  // Match versions newer than this duration
  newerThan string
}

// Google Cloud (GCP) Artifact Registry cleanup policy most recent versions config
private gcp.project.artifactRegistryService.repository.cleanupPolicy.mostRecentVersions {
  // Internal ID
  id string
  // Number of recent versions to keep
  keepCount int
  // Package name prefix filters
  packageNamePrefixes []string
}

// Google Cloud (GCP) Artifact Registry repository format-specific configuration
private gcp.project.artifactRegistryService.repository.formatConfig {
  // Internal ID
  id string
  // Repository format (e.g., DOCKER, MAVEN, NPM, PYTHON, APT, YUM, GO, KFP)
  format string
  // Whether Docker image tags are immutable (Docker repos only)
  immutableTags bool
  // Whether Maven snapshot overwrites are allowed (Maven repos only)
  allowSnapshotOverwrites bool
  // Maven version policy: RELEASE, SNAPSHOT, or VERSION_POLICY_UNSPECIFIED (Maven repos only)
  mavenVersionPolicy string
}

// Google Cloud (GCP) Artifact Registry repository mode-specific configuration
private gcp.project.artifactRegistryService.repository.modeConfig {
  // Internal ID
  id string
  // Upstream policies for virtual repositories (ordered by priority)
  upstreamPolicies []gcp.project.artifactRegistryService.repository.upstreamPolicy
  // Remote repository description
  remoteRepositoryDescription string
  // Whether upstream validation is disabled (remote repos)
  disableUpstreamValidation bool
}

// Google Cloud (GCP) Artifact Registry virtual repository upstream policy
private gcp.project.artifactRegistryService.repository.upstreamPolicy @defaults("id priority") {
  // Internal ID
  id string
  // Full resource name of the upstream repository
  repository string
  // Priority (lower value = higher priority)
  priority int
}

// Google Cloud (GCP) Backup and DR Service
//
// Backup and DR Service configuration for the project, the entry point to
// the `managementServers`, the `backupVaults` that store immutable backups,
// and the `backupPlans` that schedule them. Retention and enforcement
// settings surface here for data-protection audits.
private gcp.project.backupdrService {
  // Project ID
  projectId string
  // List of management servers
  managementServers() []gcp.project.backupdrService.managementServer
  // List of backup vaults
  backupVaults() []gcp.project.backupdrService.backupVault
  // List of backup plans
  backupPlans() []gcp.project.backupdrService.backupPlan
}

// Google Cloud (GCP) Backup and DR management server
//
// Backup and DR management server, covering its current lifecycle state,
// network configuration, management URI, OAuth2 client ID, and whether
// Physical Zone Separation is satisfied.
private gcp.project.backupdrService.managementServer @defaults("name state") {
  // Full resource name
  name string
  // Human-readable description of the resource
  description string
  // Current state (CREATING, READY, UPDATING, DELETING, REPAIRING, MAINTENANCE, ERROR)
  state string
  // Type of the management server (BACKUP_RESTORE)
  type string
  // Networks the management server is attached to
  //
  // Each entry has `network` (the VPC network resource name) and
  // `peeringMode` (currently PRIVATE_SERVICE_ACCESS).
  networks []dict
  // Management server AGM/RD web and API URLs
  //
  // Keys: `webUi` (the management server WebUI URL) and `api` (the
  // management server API URL).
  managementUri dict
  // OAuth2 client ID
  oauth2ClientId string
  // Whether the resource satisfies PZS
  satisfiesPzs bool
  // ETag used for concurrency control on resource updates
  etag string
  // User-defined key/value labels for organizing the resource
  labels map[string]string
  // Creation time
  createdAt time
  // Last update time
  updatedAt time
}

// Google Cloud (GCP) Backup and DR backup vault
//
// Backup and DR backup vault, a storage location that holds immutable
// backups. Fields cover the minimum enforced retention duration, the
// access restriction setting, whether the vault is deletable, the service
// account, total stored bytes, backup count, and the `dataSources`
// protected within it, letting you verify immutability and data-protection
// policy compliance.
private gcp.project.backupdrService.backupVault @defaults("name state") {
  // Full resource name
  name string
  // Human-readable description of the resource
  description string
  // Current lifecycle state
  //
  // One of CREATING, ACTIVE, DELETING, ERROR, or UPDATING.
  state string
  // Minimum enforced retention duration
  backupMinimumEnforcedRetentionDuration string
  // Whether the vault is deletable
  deletable bool
  // ETag used for concurrency control on resource updates
  etag string
  // Effective time
  effectiveTime time
  // Backup count
  backupCount int
  // Service account
  serviceAccount string
  // Total stored bytes
  totalStoredBytes int
  // Scope from which backups in the vault can be accessed and restored
  //
  // One of WITHIN_PROJECT, WITHIN_ORGANIZATION, UNRESTRICTED, or
  // WITHIN_ORG_BUT_UNRESTRICTED_FOR_BA.
  accessRestriction string
  // Cloud KMS key name encrypting backups at rest (empty when Google-managed encryption is used)
  kmsKeyName string
  // System-managed annotation metadata on the resource
  annotations map[string]string
  // User-defined key/value labels for organizing the resource
  labels map[string]string
  // Creation time
  createdAt time
  // Last update time
  updatedAt time
  // Data sources in this backup vault
  dataSources() []gcp.project.backupdrService.dataSource
}

// Google Cloud (GCP) Backup and DR data source
//
// Data source protected within a Backup and DR backup vault, covering its
// current state, configuration state, total stored bytes, backup count,
// and the GCP resource or Backup Appliance application it represents.
private gcp.project.backupdrService.dataSource @defaults("name state") {
  // Full resource name
  name string
  // Current lifecycle state
  //
  // One of CREATING, ACTIVE, DELETING, or ERROR.
  state string
  // User-defined key/value labels for organizing the resource
  labels map[string]string
  // GCP resource backed up by this data source
  //
  // Keys: `gcpResourcename` (the full resource name), `location`, and
  // `type` (the resource type, for example compute.googleapis.com/Instance).
  dataSourceGcpResource dict
  // Backup Appliance application backed up by this data source
  //
  // Keys: `applicationName`, `backupAppliance`, `applianceId`, `type`,
  // `applicationId`, `hostname`, and `hostId`.
  dataSourceBackupApplianceApplication dict
  // Total stored bytes
  totalStoredBytes int
  // Backup count
  backupCount int
  // ETag used for concurrency control on resource updates
  etag string
  // Backup configuration state
  //
  // One of ACTIVE (a backup configuration protects this resource) or
  // PASSIVE (no active backup configuration).
  configState string
  // Creation time
  createdAt time
  // Last update time
  updatedAt time
}

// Google Cloud (GCP) Backup and DR backup plan
//
// Backup and DR backup plan, covering its target resource type, lifecycle
// state, associated backup vault, vault service account, and the backup
// rules that define schedules and retention windows for automated
// protection.
private gcp.project.backupdrService.backupPlan @defaults("name state") {
  // Full resource name
  name string
  // Human-readable description of the resource
  description string
  // Current lifecycle state
  //
  // One of CREATING, ACTIVE, DELETING, INACTIVE, or UPDATING.
  state string
  // Resource type
  resourceType string
  // Backup vault
  backupVault() gcp.project.backupdrService.backupVault
  // Backup vault service account
  backupVaultServiceAccount string
  // User-defined key/value labels for organizing the resource
  labels map[string]string
  // Rules defining backup schedules and retention
  //
  // Each entry has `ruleId`, `backupRetentionDays` (days backups are kept),
  // and `standardSchedule` (the automated backup schedule, with recurrence,
  // backup window, and time zone).
  backupRules []dict
  // ETag used for concurrency control on resource updates
  etag string
  // Creation time
  createdAt time
  // Last update time
  updatedAt time
}

// Google Cloud (GCP) Vertex AI
//
// Vertex AI resources in a project: models, serving endpoints and their
// deployments, datasets, pipeline and training jobs, tuning and
// hyperparameter tuning jobs, batch prediction jobs, feature stores and
// groups, vector search indexes and index endpoints, Colab Enterprise
// notebook runtimes, Agent Engine agents, RAG corpora, and deployment
// monitoring jobs. Query these collections to audit the machine-learning
// footprint of a project, including run-as identity, network exposure, and
// encryption posture.
private gcp.project.vertexaiService {
  // Project ID
  projectId string
  // List of models
  models() []gcp.project.vertexaiService.model
  // List of endpoints
  endpoints() []gcp.project.vertexaiService.endpoint
  // List of pipeline jobs
  pipelineJobs() []gcp.project.vertexaiService.pipelineJob
  // List of datasets
  datasets() []gcp.project.vertexaiService.dataset
  // List of feature online stores
  featureOnlineStores() []gcp.project.vertexaiService.featureOnlineStore
  // Tensorboard instances
  tensorboards() []gcp.project.vertexaiService.tensorboard
  // Custom training jobs
  customJobs() []gcp.project.vertexaiService.customJob
  // Vector search indexes
  indexes() []gcp.project.vertexaiService.index
  // Vector search index endpoints
  indexEndpoints() []gcp.project.vertexaiService.indexEndpoint
  // Metadata stores
  metadataStores() []gcp.project.vertexaiService.metadataStore
  // Colab Enterprise notebook runtimes
  notebookRuntimes() []gcp.project.vertexaiService.notebookRuntime
  // Colab Enterprise notebook runtime templates
  notebookRuntimeTemplates() []gcp.project.vertexaiService.notebookRuntimeTemplate
  // Colab Enterprise notebook execution jobs
  notebookExecutionJobs() []gcp.project.vertexaiService.notebookExecutionJob
  // Deployed Agent Engine agents (reasoning engines)
  reasoningEngines() []gcp.project.vertexaiService.reasoningEngine
  // RAG Engine corpora
  ragCorpora() []gcp.project.vertexaiService.ragCorpus
  // Feature groups
  featureGroups() []gcp.project.vertexaiService.featureGroup
  // Persistent resources (managed Ray clusters)
  persistentResources() []gcp.project.vertexaiService.persistentResource
  // Schedules
  schedules() []gcp.project.vertexaiService.schedule
  // Deployment resource pools
  deploymentResourcePools() []gcp.project.vertexaiService.deploymentResourcePool
  // Context caches
  cachedContents() []gcp.project.vertexaiService.cachedContent
  // Batch prediction jobs
  batchPredictionJobs() []gcp.project.vertexaiService.batchPredictionJob
  // Managed fine-tuning jobs
  tuningJobs() []gcp.project.vertexaiService.tuningJob
  // Training pipelines
  trainingPipelines() []gcp.project.vertexaiService.trainingPipeline
  // Hyperparameter tuning jobs
  hyperparameterTuningJobs() []gcp.project.vertexaiService.hyperparameterTuningJob
  // Model deployment monitoring jobs
  modelDeploymentMonitoringJobs() []gcp.project.vertexaiService.modelDeploymentMonitoringJob
}

// Google Cloud (GCP) Vertex AI metadata store
//
// Metadata store that tracks ML artifacts, executions, and lineage for
// reproducibility and governance audits. Reports the current state, the
// encryption specification, the customer-managed encryption key, and the
// Dataplex integration configuration.
private gcp.project.vertexaiService.metadataStore @defaults("name state") {
  // Full resource name
  name string
  // Human-readable description of the resource
  description string
  // State information of the metadata store
  state dict
  // Encryption spec
  encryptionSpec dict
  // Customer-managed Cloud KMS key used to encrypt this resource at rest
  kmsKey() gcp.project.kmsService.keyring.cryptokey
  // Dataplex integration config
  dataplexConfig dict
  // Creation time
  created time
  // Last update time
  updated time
}

// Google Cloud (GCP) Vertex AI model
//
// Machine-learning model registered in the Model Registry, whether trained
// on Vertex AI or imported. Reports the version ID and aliases, the
// container serving spec, supported deployment resource types, input and
// output storage formats, artifact URI, training pipeline reference, and
// customer-managed encryption. Audit these to verify model provenance,
// encryption posture, and deployment readiness.
private gcp.project.vertexaiService.model @defaults("name displayName") {
  // Full resource name
  name string
  // Display name
  displayName string
  // Human-readable description of the resource
  description string
  // Version ID
  versionId string
  // Version aliases
  versionAliases []string
  // Version description
  versionDescription string
  // Model source info
  modelSourceInfo dict
  // Container spec for serving
  containerSpec dict
  // Supported deployment resources types
  supportedDeploymentResourcesTypes []string
  // Supported input storage formats
  supportedInputStorageFormats []string
  // Supported output storage formats
  supportedOutputStorageFormats []string
  // Training pipeline resource name
  trainingPipeline string
  // Artifact URI
  artifactUri string
  // Encryption spec (CMEK)
  encryptionSpec dict
  // Customer-managed Cloud KMS key used to encrypt this resource at rest
  kmsKey() gcp.project.kmsService.keyring.cryptokey
  // User-defined key/value labels for organizing the resource
  labels map[string]string
  // ETag used for concurrency control on resource updates
  etag string
  // Base model this model was tuned or copied from (Model Garden publisher model name or Genie base-model URI)
  baseModelSource dict
  // Source Vertex AI model this model was copied from
  originalModel() gcp.project.vertexaiService.model
  // Pipeline job that produced this model
  pipelineJob() gcp.project.vertexaiService.pipelineJob
  // Whether the model satisfies Physical Zone Separation
  satisfiesPzs bool
  // Whether the model satisfies Physical Zone Isolation
  satisfiesPzi bool
  // Resource-level IAM policy bindings governing who can access this model
  iamPolicy() []gcp.resourcemanager.binding
  // Whether the IAM policy grants access to allUsers or allAuthenticatedUsers
  public() bool
  // Creation time
  createdAt time
  // Last update time
  updatedAt time
}

// Google Cloud (GCP) Vertex AI endpoint
//
// Serving endpoint that hosts one or more deployed models behind a stable
// address. Reports the model deployments and their traffic split, the VPC
// network attachment for private endpoints, whether Private Service Connect
// is enabled, and customer-managed encryption. Audit these to review model
// serving configuration and network exposure.
private gcp.project.vertexaiService.endpoint @defaults("name displayName") {
  // Full resource name
  name string
  // Display name
  displayName string
  // Human-readable description of the resource
  description string
  // Deployed models
  //
  // Deprecated in favor of deployments, which exposes each model deployment
  // as a queryable gcp.project.vertexaiService.endpoint.deployment with a
  // model() reference.
  deployedModels @maturity("deprecated") []dict
  // Models deployed to this endpoint
  deployments []gcp.project.vertexaiService.endpoint.deployment
  // Encryption spec (CMEK)
  encryptionSpec dict
  // Customer-managed Cloud KMS key used to encrypt this resource at rest
  kmsKey() gcp.project.kmsService.keyring.cryptokey
  // Network for private endpoints
  //
  // Deprecated in favor of `networkRef`, which resolves the VPC network resource.
  network @maturity("deprecated") string
  // VPC network used for private endpoints (resolved from network)
  networkRef() gcp.project.computeService.network
  // Whether private service connect is enabled
  enablePrivateServiceConnect bool
  // Projects allowed to reach the endpoint over Private Service Connect
  pscProjectAllowlist []string
  // Service attachment for the endpoint's Private Service Connect
  pscServiceAttachment string
  // Whether prediction request/response logging to BigQuery is enabled
  predictionLoggingEnabled bool
  // Fraction of prediction requests logged (0.0 to 1.0)
  predictionLoggingSamplingRate float
  // BigQuery destination URI where prediction requests and responses are logged
  predictionLoggingBigqueryDestination string
  // Whether the endpoint is a dedicated endpoint with its own public DNS
  dedicatedEndpointEnabled bool
  // Public DNS of the dedicated endpoint
  dedicatedEndpointDns string
  // Whether private model serving is enabled
  privateModelServerEnabled bool
  // Whether the endpoint satisfies Physical Zone Separation
  satisfiesPzs bool
  // Whether the endpoint satisfies Physical Zone Isolation
  satisfiesPzi bool
  // Traffic split (model ID to traffic percentage)
  trafficSplit map[string]int
  // User-defined key/value labels for organizing the resource
  labels map[string]string
  // ETag used for concurrency control on resource updates
  etag string
  // Creation time
  createdAt time
  // Last update time
  updatedAt time
}

// Google Cloud (GCP) Vertex AI model deployment
//
// Single model deployment on a Vertex AI endpoint. `model` resolves to the
// deployed model, `serviceAccount` resolves the identity the deployment
// runs as, and `disableContainerLogging` and `enableAccessLogging` report
// the prediction-logging posture. The `id` selects the deployment within
// its endpoint. Audit these to review which models serve traffic and the
// identity and logging configuration of each deployment.
private gcp.project.vertexaiService.endpoint.deployment @defaults("id displayName") {
  // ID of the deployment within the endpoint
  id string
  // Display name
  displayName string
  // Version ID of the deployed model
  modelVersionId string
  // Deployed Vertex AI model
  model() gcp.project.vertexaiService.model
  // Service account email the deployment runs as
  serviceAccountEmail string
  // Service account the deployment runs as
  serviceAccount() gcp.project.iamService.serviceAccount
  // Whether container request/response logging is disabled
  disableContainerLogging bool
  // Whether access logging is enabled
  enableAccessLogging bool
  // Service attachment for the deployment's private endpoint
  privateServiceAttachment string
  // Private HTTPS URI for prediction requests
  predictHttpUri string
  // Private HTTPS URI for explanation requests
  explainHttpUri string
  // Private HTTPS URI for health checks
  healthHttpUri string
  // Time the model was deployed
  createdAt time
}

// Google Cloud (GCP) Vertex AI pipeline job
//
// Vertex AI Pipelines run that executes an ML pipeline as a directed graph
// of containerized steps. Reports the current state (PIPELINE_STATE_QUEUED,
// RUNNING, SUCCEEDED, FAILED, CANCELLING, CANCELLED, PAUSED), the pipeline
// and runtime configuration, run-as service account, VPC network,
// encryption, template URI, and execution timestamps. Audit these to review
// pipeline security posture and job lifecycle.
private gcp.project.vertexaiService.pipelineJob @defaults("name displayName state") {
  // Full resource name
  name string
  // Display name
  displayName string
  // Current state (PIPELINE_STATE_QUEUED, RUNNING, SUCCEEDED, FAILED, CANCELLING, CANCELLED, PAUSED)
  state string
  // Pipeline spec
  pipelineSpec dict
  // Runtime config
  runtimeConfig dict
  // Service account email used by the resource
  //
  // Deprecated in favor of `serviceAccountRef`, which resolves the identity
  // to the service account resource (the email is available as its `email`).
  // Note that `serviceAccountRef` is null when the service account has been
  // deleted or lives in another project, whereas this field still holds the
  // raw email.
  serviceAccount @maturity("deprecated") string
  // Service account identity the pipeline job runs as
  serviceAccountRef() gcp.project.iamService.serviceAccount
  // VPC network the resource is attached to
  //
  // Deprecated in favor of `networkRef`, which resolves the VPC network resource.
  network @maturity("deprecated") string
  // VPC network the resource is attached to (resolved from network)
  networkRef() gcp.project.computeService.network
  // Encryption spec
  encryptionSpec dict
  // Customer-managed Cloud KMS key used to encrypt this resource at rest
  kmsKey() gcp.project.kmsService.keyring.cryptokey
  // Template URI
  templateUri string
  // Template metadata
  templateMetadata dict
  // Schedule that created this pipeline job
  scheduleRef() gcp.project.vertexaiService.schedule
  // Error status if the pipeline job failed
  error dict
  // Reserved IP ranges the pipeline job's network draws from
  reservedIpRanges []string
  // User-defined key/value labels for organizing the resource
  labels map[string]string
  // Creation time
  createdAt time
  // Last update time
  updatedAt time
  // Start time
  startTime time
  // End time
  endTime time
  // Infrastructure-management system that provisioned the resource
  //
  // Value derived from the provenance labels and annotations Google and IaC
  // tools apply: "terraform", "config-connector", or "cloud-composer". Empty
  // when the resource carries no management signal.
  managedBy() string
}

// Google Cloud (GCP) Vertex AI dataset
//
// Managed dataset that holds training data for AutoML and custom model

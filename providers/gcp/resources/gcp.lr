// Google Cloud (GCP) Artifact Registry repository
//
// Examine a single Artifact Registry repository — its package format
// (DOCKER, MAVEN, NPM, PYTHON, APT, YUM, GO, GENERIC), repository mode
// (STANDARD, VIRTUAL, REMOTE), encryption key, cleanup policies, format-
// and mode-specific configuration, and IAM policy bindings. Use
// `vulnerabilityScanningConfig` to audit whether container-image scanning
// is active or inherited.
private gcp.project.artifactRegistryService.repository @defaults("name format location") {
  // Project ID
  projectId string
  // Full resource path
  resourcePath string
  // Repository name
  name string
  // Repository location
  location string
  // Repository description
  description string
  // Package format (DOCKER, MAVEN, NPM, PYTHON, APT, YUM, GO, GENERIC, etc.)
  format string
  // Repository mode (STANDARD_REPOSITORY, VIRTUAL_REPOSITORY, REMOTE_REPOSITORY)
  mode string
  // User-assigned labels
  labels map[string]string
  // Cloud KMS encryption key name (empty means Google-managed encryption)
  kmsKeyName string
  // Creation time
  createTime time
  // Last update time
  updateTime time
  // Total storage size in bytes
  sizeBytes int
  // Registry endpoint URI (e.g., us-docker.pkg.dev/project/repo)
  registryUri string
  // Whether the repository satisfies Physical Zone Separation
  satisfiesPzs bool
  // Whether the repository satisfies Physical Zone Isolation
  satisfiesPzi bool
  // Whether cleanup policy dry-run mode is enabled
  cleanupPolicyDryRun bool
  // Vulnerability scanning configuration
  vulnerabilityScanningConfig gcp.project.artifactRegistryService.repository.vulnScanConfig
  // Cleanup policies for artifact retention

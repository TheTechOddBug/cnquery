  // Human-readable description of the resource
  description string
  // Whether the rule is disabled
  disabled bool
  // Whether this is a logging-enabled rule
  enableLogging bool
  // Match conditions for the rule
  match dict
  // Target resources for the rule
  targetResources []string
  // Target service accounts for the rule
  targetServiceAccounts []string
  // Rule name (optional)
  ruleName string
  // Security profile group URL
  securityProfileGroup string
  // Source IPv4/IPv6 CIDR ranges the rule matches
  srcIpRanges []string
  // Destination IPv4/IPv6 CIDR ranges the rule matches

// back the chain reaches. `freeableSizeBytes` and `exclusiveSizeBytes`
// indicate the storage reclaimed or attributed to this backup within its
// chain.
private gcp.project.spannerService.instance.backup @defaults("name") {
  // Project ID
  projectId string
  // Instance name
  instanceName string
  // Resource name of the backup
  name string
  // Source database of the backup
  database string
  // Current state of the backup
  state string
  // Expiration time
  expireTime time
  // Version time of the backup
  versionTime time
  // Creation time
  createdAt time
  // Size of the backup in bytes
  sizeBytes int
  // Encryption information
  encryptionInfo dict
  // Database dialect
  databaseDialect string
  // Maximum expiration time
  maxExpireTime time
  // Bytes freed by deleting this backup (zero if part of an incremental chain with newer dependents)
  freeableSizeBytes int
  // Storage space attributable to this backup within its incremental chain
  exclusiveSizeBytes int
  // Resource names of restored databases that reference this backup
  referencingDatabases []string
  // Resource names of destination backups that reference this backup (copy chain)
  referencingBackups []string
  // Backup schedule URIs associated with creating this backup
  backupSchedules []string
  // Identifier linking backups in the same incremental chain
  incrementalBackupChainId string
  // Earliest version time retained in this backup
  oldestVersionTime time
}


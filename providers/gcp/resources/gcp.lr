  // Creation timestamp
  created time
  // Region URL (empty for global policies)
  regionUrl string
  // Rules associated with this firewall policy
  rules() []gcp.project.computeService.firewallPolicy.rule
  // Associations of this policy with networks
  associations []dict
}

// Google Cloud (GCP) Compute network firewall policy rule
private gcp.project.computeService.firewallPolicy.rule @defaults("priority action direction") {
  // Internal ID
  id string
  // Priority of the rule (lower is higher priority)
  priority int
  // Action to take (allow, deny, goto_next, apply_security_profile_group)

  // Daily maintenance window start time (HH:MM format, GMT)
  dailyMaintenanceWindowStartTime string
  // Daily maintenance window duration (PTnHnMnS format)
  dailyMaintenanceWindowDuration string
  // Recurring maintenance window recurrence (RRULE format)
  recurringWindowRecurrence string
  // Recurring maintenance window start time

  googleReferenceId string
  // NOC contact email
  nocContactEmail string
  // Location URL
  location string
  // Remote location (for Cross-Cloud Interconnect)
  remoteLocation string
  // User-defined key/value labels for organizing the resource
  labels map[string]string
  // Available features (e.g., IF_MACSEC)
  availableFeatures []string
  // Requested features
  requestedFeatures []string
  // Interconnect attachment URLs
  interconnectAttachmentUrls []string
  // Circuit information
  circuitInfos []dict
  // Expected outages
  expectedOutages []dict
  // Whether this resource satisfies zone separation
  satisfiesPzs bool
  // Self-link URL
  selfLink string
  // Creation timestamp
  created time
}


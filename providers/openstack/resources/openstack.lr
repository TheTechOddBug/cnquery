option provider = "go.mondoo.com/mql/providers/openstack"
option go_package = "go.mondoo.com/mql/v13/providers/openstack/resources"

// OpenStack connection
//
// Root entry point to a single scoped OpenStack project, gathering its
// identity, compute, networking, storage, load-balancing, key-management, DNS,
// shared-file, container-infrastructure, database, bare-metal, and
// orchestration resources under one connection. Keystone principals and the
// service catalog support identity and access-control audits (who exists, what
// roles they hold, and where credentials and trusts delegate authority); Nova,
// Placement, and Cinder collections surface the compute, capacity, and
// block-storage posture of the project; and the Neutron, FWaaS v2, VPNaaS v2,
// Octavia, and Barbican collections cover the networking, perimeter
// firewalling, site-to-site VPN, load-balancing, and secret-management surface
// most relevant to security review. The `authUrl`, `projectId`, and `region`
// fields identify the connection scope every other resource is read against.
openstack {
  // Keystone auth URL the connection is bound to
  authUrl string
  // Scoped project ID
  projectId string
  // Region the connection is targeting
  region() openstack.identity.region

  // Keystone projects visible to the authenticated user (admin scope returns all)
  projects() []openstack.project
  // Keystone users (typically admin-only)
  users() []openstack.user
  // Keystone roles (typically admin-only)
  roles() []openstack.role
  // Keystone domains (typically admin-only)
  domains() []openstack.domain
  // Keystone groups (typically admin-only)
  groups() []openstack.group
  // Keystone credentials such as EC2 access keys and X.509 certs (typically admin-only)
  credentials() []openstack.credential
  // Keystone trusts delegating authorization between users (typically admin-only)
  trusts() []openstack.trust
  // Keystone service-catalog services (typically admin-only)
  identityServices() []openstack.identity.service
  // Keystone service-catalog endpoints (typically admin-only)
  identityEndpoints() []openstack.identity.endpoint
  // Keystone regions
  regions() []openstack.identity.region
  // Keystone role assignments showing which principals hold which roles at which scope (typically admin-only)
  roleAssignments() []openstack.identity.roleAssignment
  // Keystone role inference rules mapping a prior role to an implied role (typically admin-only)
  roleInferences() []openstack.identity.roleInference

  // Nova compute servers (instances) in the scoped project
  servers() []openstack.compute.server
  // Nova flavors (VM sizes)
  flavors() []openstack.compute.flavor
  // Nova SSH keypairs
  keypairs() []openstack.compute.keypair
  // Nova server groups (affinity / anti-affinity)
  serverGroups() []openstack.compute.serverGroup
  // Nova hypervisors (admin-only)
  hypervisors() []openstack.compute.hypervisor
  // Nova compute services (admin-only)
  computeServices() []openstack.compute.service
  // Nova host aggregates (admin-only)
  aggregates() []openstack.compute.aggregate
  // Per-project Nova resource limits and current usage
  computeLimits() openstack.compute.limits
  // Placement resource providers (compute nodes, storage pools, and accelerator/GPU devices) with their inventory and traits
  resourceProviders() []openstack.placement.resourceProvider
  // Per-project Cinder quota
  blockStorageQuotaSet() openstack.blockstorage.quotaSet
  // Per-project Neutron quota
  networkQuotaSet() openstack.network.quotaSet
  // Per-project Nova compute quota
  computeQuotaSet() openstack.compute.quotaSet

  // Neutron networks
  networks() []openstack.network
  // Neutron subnets
  subnets() []openstack.subnet
  // Neutron routers
  routers() []openstack.router
  // Neutron ports
  ports() []openstack.port
  // Neutron floating IPs
  floatingIps() []openstack.floatingIp
  // Neutron security groups (with embedded rules)
  securityGroups() []openstack.securityGroup

  // Cinder block-storage volumes in the scoped project
  volumes() []openstack.blockstorage.volume
  // Cinder volume snapshots in the scoped project
  snapshots() []openstack.blockstorage.snapshot
  // Cinder volume backups in the scoped project
  backups() []openstack.blockstorage.backup
  // Cinder volume types (storage classes) visible to the scoped project
  volumeTypes() []openstack.blockstorage.volumeType
  // Cinder QoS specifications (IOPS/bandwidth throttling policies); admin-only
  blockStorageQosSpecs() []openstack.blockstorage.qosSpec
  // Glance images visible to the scoped project
  images() []openstack.image
  // Barbican secrets in the scoped project
  secrets() []openstack.keymanager.secret
  // Barbican secret containers (e.g. TLS bundles referenced by Octavia listeners) in the scoped project
  secretContainers() []openstack.keymanager.container
  // Barbican secret-generation orders in the scoped project
  secretOrders() []openstack.keymanager.order
  // Octavia load balancers in the scoped project
  loadBalancers() []openstack.octavia.loadBalancer
  // Octavia listeners in the scoped project
  listeners() []openstack.octavia.listener
  // Octavia pools in the scoped project
  pools() []openstack.octavia.pool
  // Octavia health monitors in the scoped project
  healthMonitors() []openstack.octavia.healthMonitor
  // Octavia L7 policies in the scoped project
  l7Policies() []openstack.octavia.l7Policy
  // Neutron subnet pools (admin-allocated CIDR ranges) visible to the scoped project
  subnetPools() []openstack.subnetPool
  // Neutron QoS policies in the scoped project
  qosPolicies() []openstack.qosPolicy
  // Neutron RBAC policies controlling which projects a network or QoS policy is shared with
  rbacPolicies() []openstack.network.rbacPolicy
  // Neutron trunks (parent/subport multi-VLAN containers) in the scoped project
  trunks() []openstack.trunk
  // Neutron FWaaS v2 firewall groups in the scoped project
  firewallGroups() []openstack.firewall.group
  // Neutron FWaaS v2 firewall policies in the scoped project
  firewallPolicies() []openstack.firewall.policy
  // Neutron FWaaS v2 firewall rules in the scoped project
  firewallRules() []openstack.firewall.rule
  // Neutron VPNaaS v2 IPsec VPN services in the scoped project
  vpnServices() []openstack.vpn.service
  // Neutron VPNaaS v2 IKE policies in the scoped project
  vpnIkePolicies() []openstack.vpn.ikePolicy
  // Neutron VPNaaS v2 IPsec policies in the scoped project
  vpnIpsecPolicies() []openstack.vpn.ipsecPolicy
  // Neutron VPNaaS v2 endpoint groups in the scoped project
  vpnEndpointGroups() []openstack.vpn.endpointGroup
  // Neutron VPNaaS v2 IPsec site-to-site connections in the scoped project
  vpnSiteConnections() []openstack.vpn.siteConnection

  // Swift object-storage account for the scoped project
  objectStorageAccount() openstack.objectstorage.account
  // Swift object-storage containers in the scoped project
  objectStorageContainers() []openstack.objectstorage.container

  // Designate DNS zones visible to the scoped project
  dnsZones() []openstack.dns.zone

  // Manila shared file systems (NFS/CIFS shares) in the scoped project
  shares() []openstack.sharedfilesystem.share
  // Manila security services (Active Directory, LDAP, or Kerberos) backing share networks
  securityServices() []openstack.sharedfilesystem.securityService
  // Manila share networks tying shares to Neutron networks and subnets
  shareNetworks() []openstack.sharedfilesystem.shareNetwork

  // Magnum container-orchestration clusters (Kubernetes, Docker Swarm) in the scoped project
  clusters() []openstack.containerinfra.cluster
  // Magnum cluster templates (blueprints for new clusters)
  clusterTemplates() []openstack.containerinfra.clusterTemplate

  // Trove managed database instances in the scoped project
  databaseInstances() []openstack.db.instance

  // Ironic bare-metal nodes in the scoped project
  baremetalNodes() []openstack.baremetal.node

  // Heat orchestration stacks in the scoped project
  stacks() []openstack.orchestration.stack
}

// OpenStack Keystone project (formerly "tenant")
//
// Keystone project that owns and scopes cloud resources such as compute
// instances, networks, and volumes. Projects are the primary unit of
// ownership, quota, and access control in OpenStack, so auditing them
// reveals which tenancies exist, whether they are still enabled, and how
// they nest beneath domains and parent projects. Select a project by its
// UUID, for example `openstack.project(id: "a1b2c3d4-...")`. The isDomain
// field distinguishes an ordinary project from one that acts as a domain,
// and parent is null for top-level projects.
private openstack.project @defaults("id name enabled") {
  init(id? string)
  // Project ID (UUID)
  id string
  // Project name
  name string
  // Description
  description string
  // Whether the project is enabled
  enabled bool
  // Whether this project acts as a domain
  isDomain bool
  // Tags
  tags []string
  // Domain this project belongs to
  domain() openstack.domain
  // Parent project; null for top-level projects
  parent() openstack.project
}

// OpenStack Keystone user
//
// Identity account in the Keystone identity service, selected by its
// UUID with `openstack.user(id: "...")`. Exposes the account's enabled
// state, password expiry, and per-user security options such as
// multi-factor authentication enforcement and lockout exemption, along
// with the domain it belongs to, its effective role assignments, group
// memberships, and the application and EC2-compatible credentials it
// owns. Audit these to find over-privileged, stale, or MFA-exempt
// accounts.
private openstack.user @defaults("id name enabled") {
  init(id? string)
  // User ID (UUID)
  id string
  // Username
  name string
  // Whether the user account is enabled
  enabled bool
  // Description
  description string
  // When the user's password expires (null when no expiry is set, e.g. federated users)
  passwordExpiresAt time
  // Whether the user is exempt from account lockout after repeated failed authentication attempts (Keystone option `ignore_lockout_failure_attempts`)
  ignoreLockoutFailureAttempts bool
  // Whether multi-factor authentication is required for this user (Keystone option `multi_factor_auth_enabled`)
  multiFactorAuthEnabled bool
  // Multi-factor authentication rule sets (Keystone option `multi_factor_auth_rules`)
  //
  // Each entry is a list of auth-method names that together satisfy MFA, for example `["password", "totp"]`. Empty when no rules are configured.
  multiFactorAuthRules []dict
  // Domain this user belongs to
  domain() openstack.domain
  // Default project the user is scoped to when authenticating without an explicit scope; null when unset
  defaultProject() openstack.project
  // Roles assigned to this user across all scopes (effective; deduplicated, includes group-derived roles)
  roles() []openstack.role
  // Groups this user belongs to
  groups() []openstack.group
  // Application credentials owned by this user
  applicationCredentials() []openstack.applicationCredential
  // EC2-compatible access credentials owned by this user
  ec2Credentials() []openstack.ec2Credential
}

// OpenStack Keystone role
//
// Named permission set that Keystone grants to users or groups on a
// project or domain, driving what actions an identity may perform.
// Auditing roles surfaces the privilege vocabulary of the cloud (for
// example admin, member, and reader) so you can reason about who holds
// elevated access. A role is selected by its UUID, for example
// openstack.role(id: "9fe2ff9ee4384b1894a90878d3e92bab"). The domain
// field is null for global roles and set for roles scoped to a single
// domain.
private openstack.role @defaults("id name") {
  init(id? string)
  // Role ID (UUID)
  id string
  // Role name (e.g., admin, member, reader)
  name string
  // Description
  description string
  // Domain this role belongs to; null for global roles
  domain() openstack.domain
}

// OpenStack Keystone domain
//
// Top-level identity boundary in Keystone that contains projects, users, and
// groups, providing administrative separation between tenants. Auditing a
// domain reveals whether it is enabled and which groups it holds, which
// together govern the scope of authentication and authorization within it. A
// domain is selected by its `id`, for example `openstack.domain(id: "default")`
// for the bootstrap domain.
private openstack.domain @defaults("id name enabled") {
  init(id? string)
  // Domain ID (UUID, or "default" for the bootstrap domain)
  id string
  // Domain name
  name string
  // Description
  description string
  // Whether the domain is enabled
  enabled bool
  // Groups in this domain
  groups() []openstack.group
}

// OpenStack Keystone group
//
// Keystone group that aggregates users so roles can be granted collectively
// rather than to each user individually. Auditing groups reveals who inherits
// privileged access through membership: the users field lists the members and
// the roles field reports the effective roles the group confers across project,
// domain, and system scopes. Select a group by its UUID, for example
// openstack.group(id: "a1b2c3d4...").
private openstack.group @defaults("id name") {
  init(id? string)
  // Group ID (UUID)
  id string
  // Group name
  name string
  // Description
  description string
  // Domain this group belongs to
  domain() openstack.domain
  // Users that are members of this group
  users() []openstack.user
  // Effective roles assigned to this group (deduplicated across project/domain/system scopes)
  roles() []openstack.role
}

// OpenStack Keystone role assignment
//
// Flattened record of a single role granted to a single principal (a user or a
// group) at a single scope (a project or a domain). Enumerating these is how a
// policy audits who holds privileged roles such as `admin` across the whole
// cloud, instead of walking each user or group. System-scoped grants and the
// inherited flag are not reported, because the underlying client does not
// return them.
private openstack.identity.roleAssignment @defaults("roleName actorType scopeType") {
  // Whether the role is granted to a user or a group ("user" or "group")
  actorType string
  // Whether the grant applies to a project or a domain ("project" or "domain")
  scopeType string
  // Name of the granted role; empty when the role catalog is not readable
  roleName string
  // Role granted by this assignment
  role() openstack.role
  // User the role is granted to; null when the grant is to a group
  user() openstack.user
  // Group the role is granted to; null when the grant is to a user
  group() openstack.group
  // Project the grant applies to; null when the grant is domain-scoped
  scopeProject() openstack.project
  // Domain the grant applies to; null when the grant is project-scoped
  scopeDomain() openstack.domain
}

// OpenStack Keystone role inference rule
//
// Mapping from a prior role to an implied role: any principal holding the prior
// role automatically gains the implied role. Chains of these rules are a
// privilege-escalation path to audit, since a low-privilege role can imply a
// more powerful one.
private openstack.identity.roleInference @defaults("priorRoleName impliedRoleName") {
  // Name of the prior role that is held directly; empty when the role catalog is not readable
  priorRoleName string
  // Name of the implied role conferred by holding the prior role; empty when the role catalog is not readable
  impliedRoleName string
  // Prior role held directly
  priorRole() openstack.role
  // Implied role conferred by the prior role
  impliedRole() openstack.role
}

// OpenStack Nova compute server (instance)
//
// Nova virtual machine instance, the primary compute workload in an
// OpenStack cloud. Query lifecycle and power state through status,
// vmState, powerState, and taskState; the image and flavor it booted
// from; and attached securityGroups, ports, floatingIps, and volumes.
// Boot-time inputs such as keyName, metadata, and userData reveal how the
// instance was provisioned, and userData is a common place to audit for
// hardcoded credentials. Use exposure to check public reachability.
// Select a server by its id with `openstack.compute.server(id: "...")`.
private openstack.compute.server @defaults("id name status") {
  init(id? string)
  // Server ID (UUID)
  id string
  // Server name
  name string
  // Status (ACTIVE, SHUTOFF, ERROR, BUILD, ...)
  status string
  // Power state (Nova `OS-EXT-STS:power_state`)
  powerState int
  // VM state (Nova `OS-EXT-STS:vm_state`)
  vmState string
  // Task state (Nova `OS-EXT-STS:task_state`)
  taskState string
  // Whether the server is locked
  locked bool
  // Hypervisor host ID (opaque hash)
  hostId string
  // Public IPv4 address (Nova `accessIPv4`)
  accessIPv4 string
  // Public IPv6 address (Nova `accessIPv6`)
  accessIPv6 string
  // SSH keypair name used at boot
  keyName string
  // Availability zone
  availabilityZone string
  // Disk config (AUTO or MANUAL)
  diskConfig string
  // Whether the server was booted with a config drive carrying instance metadata and cloud-init data (Nova `config_drive`)
  configDrive bool
  // Hypervisor host the server runs on (Nova `OS-EXT-SRV-ATTR:host`); admin-only, empty for non-admin tokens
  host string
  // Hypervisor hostname the server runs on (Nova `OS-EXT-SRV-ATTR:hypervisor_hostname`); admin-only, empty for non-admin tokens
  hypervisorHostname string
  // Hypervisor-level instance name (Nova `OS-EXT-SRV-ATTR:instance_name`, e.g. "instance-0000004f"); admin-only, empty for non-admin tokens
  instanceName string
  // Cloud-init user data the server was booted with (Nova `OS-EXT-SRV-ATTR:user_data`)
  //
  // Admin-only and empty for non-admin tokens. The raw value may embed bootstrap secrets, so auditing it for hardcoded credentials is a common use.
  userData string
  // Per-network address allocations
  //
  // Keyed by network name; each value is a list of address entries with `addr`, `version` (4 or 6), `OS-EXT-IPS:type` (fixed or floating), and `OS-EXT-IPS-MAC:mac_addr`.
  addresses dict
  // Free-form server metadata
  metadata map[string]string
  // Tags
  tags []string
  // Creation timestamp
  created time
  // Last update timestamp
  updated time
  // Launch timestamp (Nova `OS-SRV-USG:launched_at`)
  launchedAt time
  // Termination timestamp (Nova `OS-SRV-USG:terminated_at`; null while running)
  terminatedAt time
  // Image the server was booted from; null when booted from a volume
  image() openstack.image
  // Flavor (VM size) the server was booted with
  flavor() openstack.compute.flavor
  // SSH keypair injected at boot; null when no key was used
  keypair() openstack.compute.keypair
  // Security groups attached at boot
  securityGroups() []openstack.securityGroup
  // Cinder volumes attached to this server
  volumes() []openstack.blockstorage.volume
  // Project that owns this server
  project() openstack.project
  // User that created this server
  user() openstack.user
  // Neutron ports attached to this server
  ports() []openstack.port
  // Floating (public) IPs mapped to this server through its ports; empty when the server has none
  floatingIps() []openstack.floatingIp
  // Internet-exposure summary for this server (public reachability plus the security-group rules that open it up)
  exposure() openstack.compute.server.exposure
}

// OpenStack Nova compute server internet exposure
//
// Summarizes whether a server is reachable from the public internet and, when
// it is, the security-group rules that open it up. A server is publicly
// accessible when it has a floating IP or a port on an external network;
// internetReachable additionally requires a security-group rule permitting
// ingress from a public source. Inspect openIngressRules for the rules and
// their port ranges.
private openstack.compute.server.exposure @defaults("internetReachable publiclyAccessible securityGroupAllowsIngress") {
  // Whether the server is reachable from the internet (publicly accessible and a security group permits ingress from a public source)
  internetReachable bool
  // Whether the server has a public edge: a floating IP, or a port on an external network
  publiclyAccessible bool
  // Whether a security group attached to the server permits ingress from a public source
  securityGroupAllowsIngress bool
  // Security-group ingress rules that open the server to the internet, including their port ranges
  openIngressRules []openstack.securityGroup.rule
  // Floating (public) IPs mapped to the server
  floatingIps []openstack.floatingIp
}

// OpenStack Nova flavor (VM size)
//
// Nova flavor defining the CPU, memory, and disk a server is allocated at
// boot. vcpus, ram, disk, swap, and ephemeral set the sizing, while
// extraSpecs carries scheduler hints and hardware policies (CPU pinning,
// NUMA placement, hardware acceleration) and isPublic controls whether
// every project can boot it. Select a flavor by its id with
// `openstack.compute.flavor(id: "...")`.
private openstack.compute.flavor @defaults("id name vcpus ram disk") {
  init(id? string)
  // Flavor ID (UUID for v2.55+, integer string for older clouds)
  id string
  // Flavor name
  name string
  // vCPU count
  vcpus int
  // RAM in MB
  ram int
  // Root disk size in GB
  disk int
  // Swap size in MB (0 when no swap)
  swap int
  // Ephemeral disk size in GB
  ephemeral int
  // RX/TX bandwidth factor
  rxtxFactor float
  // Whether the flavor is publicly visible
  isPublic bool
  // Flavor description (added in microversion 2.55)
  description string
  // Extra specs (e.g., hw:cpu_policy, aggregate_instance_extra_specs:*)
  extraSpecs() map[string]string
}

// OpenStack Nova SSH keypair
//
// SSH keypair registered with Nova and injectable into a server at boot.
// fingerprint and publicKey identify the key material and type
// distinguishes an ssh key from an x509 certificate. Keypairs are scoped
// per user, so a stale or widely shared key is worth auditing as a
// persistent access path into instances that booted with it.
private openstack.compute.keypair @defaults("name type fingerprint") {
  // Keypair name (unique per user)
  name string
  // Type (ssh, x509)
  type string
  // Public key fingerprint
  fingerprint string
  // Public key material
  publicKey string
  // User that owns this keypair
  user() openstack.user
}

// OpenStack Nova server group (affinity / anti-affinity)
//
// Nova server group that constrains how its member instances are placed
// across compute hosts. policies records the scheduling rule (affinity,
// anti-affinity, soft-affinity, soft-anti-affinity) and members lists the
// instances bound by it, which matters for availability and blast-radius
// analysis. Select a server group by its id with
// `openstack.compute.serverGroup(id: "...")`.
private openstack.compute.serverGroup @defaults("id name policies") {
  init(id? string)
  // Server group ID
  id string
  // Server group name
  name string
  // Scheduling policies (e.g., affinity, anti-affinity, soft-affinity, soft-anti-affinity)
  policies []string
  // Member server IDs
  members []string
  // User-defined metadata
  metadata map[string]string
  // Servers in this group
  memberServers() []openstack.compute.server
  // Project that owns this server group
  project() openstack.project
  // User that created this server group
  user() openstack.user
}

// OpenStack Neutron network
//
// Layer-2 virtual network in the Neutron networking service, the
// broadcast domain that ports and subnets attach to. Query it to audit
// tenant isolation and exposure: `shared` reveals a network usable by
// other projects, `external` marks a provider network that bridges to
// the outside world, and `portSecurityEnabled` sets whether ports
// created on the network get anti-spoofing and security-group
// enforcement by default. The provider attributes
// (providerNetworkType, providerPhysicalNetwork,
// providerSegmentationId) expose the underlying segmentation, and
// subnets returns the address ranges carved from the network. Select a
// network by id with `openstack.network(id: "...")`.
private openstack.network @defaults("id name status") {
  init(id? string)
  // Network ID (UUID)
  id string
  // Network name
  name string
  // Status (ACTIVE, DOWN, BUILD, ERROR)
  status string
  // Whether the network is administratively up
  adminStateUp bool
  // Whether the network is shared with other projects
  shared bool
  // Whether this is an external (public) network
  external bool
  // MTU
  mtu int
  // Description
  description string
  // Tags
  tags []string
  // Provider network type (vxlan, vlan, flat, gre, ...)
  providerNetworkType string
  // Provider physical network mapping
  providerPhysicalNetwork string
  // Provider segmentation ID (VLAN tag, VXLAN VNI, ...)
  providerSegmentationId int
  // Default port-security setting applied to ports created on this network; false disables anti-spoofing and security groups for those ports by default
  portSecurityEnabled bool
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Subnets attached to this network
  subnets() []openstack.subnet
  // Project that owns this network
  project() openstack.project
  // QoS policy attached to this network; null when none is attached
  qosPolicy() openstack.qosPolicy
}

// OpenStack Neutron subnet
//
// IP address range carved out of a Neutron network, defined by its `cidr`,
// IP version, default gateway, and DHCP behavior. A subnet governs how
// addresses are handed to ports and which DNS nameservers and host routes
// instances receive. Selected by ID, for example
// `openstack.subnet(id: "a1b2c3d4-...")`. Query subnets to confirm CIDR
// sizing, gateway placement, whether DHCP is enabled, and the IPv6 address
// and router-advertisement modes.
private openstack.subnet @defaults("id name cidr") {
  init(id? string)
  // Subnet ID (UUID)
  id string
  // Subnet name
  name string
  // CIDR
  cidr string
  // IP version (4 or 6)
  ipVersion int
  // Default gateway IP
  gatewayIp string
  // Whether DHCP is enabled
  enableDhcp bool
  // Whether fixed IPs assigned from this subnet are published to DNS
  dnsPublishFixedIp bool
  // IPv6 address assignment mode (slaac, dhcpv6-stateful, dhcpv6-stateless; empty for IPv4 or unset)
  ipv6AddressMode string
  // IPv6 router-advertisement mode (slaac, dhcpv6-stateful, dhcpv6-stateless; empty for IPv4 or unset)
  ipv6RaMode string
  // DNS nameservers advertised by DHCP
  dnsNameservers []string
  // Allocation pools
  //
  // IP ranges from which addresses are assigned to ports on this subnet.
  // Each entry is a dict with `start` and `end` keys holding the first and
  // last IP of the pool.
  allocationPools []dict
  // Host routes
  //
  // Additional routes advertised to instances through DHCP. Each entry is a
  // dict with `destination` (the target CIDR) and `nexthop` (the gateway IP
  // used to reach it).
  hostRoutes []dict
  // Network this subnet belongs to
  network() openstack.network
  // Subnet pool this subnet's CIDR was allocated from; null when the CIDR was assigned manually
  subnetPool() openstack.subnetPool
  // Description
  description string
  // Tags
  tags []string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Project that owns this subnet
  project() openstack.project
}

// OpenStack Neutron router
//
// A Neutron router that connects tenant networks to each other and to
// external networks, providing routing, source NAT, and floating-IP
// gateway services. Query a single router by its UUID, for example
// openstack.router(id: "a1b2c3d4-..."). Security-relevant surface
// includes externalGatewayInfo and enableSnat (whether tenant traffic
// egresses through source NAT), the static routes it advertises, and
// whether admin state is up. The externalNetwork field resolves the
// external network used for the gateway.
private openstack.router @defaults("id name status") {
  init(id? string)
  // Router ID (UUID)
  id string
  // Router name
  name string
  // Operational status
  //
  // One of ACTIVE, DOWN, BUILD, or ERROR.
  status string
  // Whether the router is administratively up
  adminStateUp bool
  // Whether the router is distributed (DVR)
  distributed bool
  // Description
  description string
  // Tags
  tags []string
  // External gateway info ({network_id, enable_snat, external_fixed_ips})
  externalGatewayInfo dict
  // Whether source NAT is enabled on the external gateway; false when no external gateway is set
  enableSnat bool
  // Static routes ([{destination, nexthop}])
  routes []dict
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // External network the router uses for its gateway; null when no external gateway is set
  externalNetwork() openstack.network
  // Project that owns this router
  project() openstack.project
}

// OpenStack Neutron port
//
// Virtual network interface attached to a server, router, or other network
// device, carrying the security posture of that attachment. Select a port by
// its UUID, for example `openstack.port(id: "a1b2c3d4-...")`. The
// `portSecurityEnabled` flag governs whether MAC/IP anti-spoofing and security
// group filtering apply at all, `allowedAddressPairs` widens which source
// addresses bypass that filtering, and `deviceOwner` records what the port is
// bound to (compute instance, router interface, DHCP agent). Fixed and
// floating IP bindings, attached security groups, and the owning network,
// server, router, and project are all reachable from the port.
private openstack.port @defaults("id name status macAddress") {
  init(id? string)
  // Port ID (UUID)
  id string
  // Port name
  name string
  // Status (ACTIVE, DOWN, BUILD)
  status string
  // Whether the port is administratively up
  adminStateUp bool
  // MAC address
  macAddress string
  // Device owner (compute:nova, network:router_interface, ...)
  deviceOwner string
  // Fixed IPs ([{subnet_id, ip_address}])
  fixedIps []dict
  // Allowed address pairs ([{ip_address, mac_address}])
  //
  // Additional IP/MAC pairs the port may send and receive traffic for beyond its fixed IPs. Anti-spoofing does not apply to these, so a wide entry (for example a large CIDR) can bypass it.
  allowedAddressPairs []dict
  // Whether port security is enabled
  portSecurityEnabled bool
  // Whether port uplink status propagation is enabled
  propagateUplinkStatus bool
  // Description
  description string
  // Tags
  tags []string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Network this port belongs to
  network() openstack.network
  // Security groups attached to the port
  securityGroups() []openstack.securityGroup
  // Subnets this port has fixed IPs on
  subnets() []openstack.subnet
  // Project that owns this port
  project() openstack.project
  // Server this port is attached to; null when the port is not bound to a compute instance
  server() openstack.compute.server
  // Router this port is attached to; null when the port is not a router interface or gateway
  router() openstack.router
  // Floating (public) IPs bound to this port; empty when none are bound
  floatingIps() []openstack.floatingIp
}

// OpenStack Neutron floating IP
//
// Public IPv4 address allocated from an external network and mapped
// through NAT to a private fixed IP on a Neutron port, giving an
// instance inbound reachability from outside the tenant network.
// Select a floating IP by its UUID, for example
// `openstack.floatingIp(id: "a1b2c3d4-...")`. Auditing floating IPs
// reveals which internal workloads are exposed to the internet, the
// external network they draw from, the port and router carrying their
// NAT, and any DNAT port-forwarding rules that publish additional
// private services.
private openstack.floatingIp @defaults("id floatingIpAddress status") {
  init(id? string)
  // Floating IP ID (UUID)
  id string
  // Status
  //
  // One of ACTIVE, DOWN, or ERROR.
  status string
  // The floating (public) IP address
  floatingIpAddress string
  // The fixed (private) IP address it maps to (empty when unattached)
  fixedIpAddress string
  // Description
  description string
  // Tags
  tags []string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // External network this floating IP is allocated from
  floatingNetwork() openstack.network
  // Port this floating IP is bound to; null when unattached
  port() openstack.port
  // Router handling NAT for this floating IP; null when unattached
  router() openstack.router
  // Project that owns this floating IP
  project() openstack.project
  // DNAT port-forwarding rules on this floating IP; empty when none are configured
  portForwardings() []openstack.floatingIp.portForwarding
}

// OpenStack Neutron floating IP port forwarding rule
//
// A public-to-private DNAT mapping on a floating IP. The rule forwards
// traffic arriving on the floating IP's external port (or external port
// range) to a private port (or port range) on a backing Neutron port,
// publishing a specific private service to the internet even when the
// backing instance has no floating IP of its own. A floating IP with port
// forwarding cannot also be associated one-to-one to a port.
private openstack.floatingIp.portForwarding @defaults("protocol externalPort internalIpAddress internalPort") {
  // Port forwarding rule ID (UUID)
  id string
  // IP protocol forwarded (tcp, udp, ...)
  protocol string
  // Public port on the floating IP; 0 when a port range is used instead
  externalPort int
  // Public port range on the floating IP (for example "80:90"); empty when a single port is used
  externalPortRange string
  // Private port on the backing Neutron port; 0 when a port range is used instead
  internalPort int
  // Private port range on the backing Neutron port (for example "80:90"); empty when a single port is used
  internalPortRange string
  // Private IPv4 address traffic is forwarded to
  internalIpAddress string
  // Description
  description string
  // Backing Neutron port that receives the forwarded traffic
  port() openstack.port
}

// OpenStack Neutron security group
//
// Set of firewall rules that govern ingress and egress traffic for the
// ports and instances the group is attached to. Audit security groups to
// find overly permissive access, such as rules that expose services to the
// public internet. The stateful field distinguishes connection-tracking
// groups from stateless ones that require explicit return-traffic rules,
// and allowsPublicIngress flags any group whose ingress rules reach a
// public source. Select a group by its UUID, for example
// openstack.securityGroup(id: "9d6f...").
private openstack.securityGroup @defaults("id name") {
  init(id? string)
  // Security group ID (UUID)
  id string
  // Security group name
  name string
  // Description
  description string
  // Whether the security group is stateful (tracks connection state); stateless groups require explicit return-traffic rules
  stateful bool
  // Tags
  tags []string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Project that owns this security group
  project() openstack.project
  // Embedded rules
  rules []openstack.securityGroup.rule
  // Whether any ingress rule permits traffic from a public source (a public CIDR or an unscoped any-source rule)
  allowsPublicIngress() bool
}

// OpenStack Neutron security group rule
//
// Single ingress or egress rule within a security group, defining the
// protocol, port range, and remote source or destination that traffic is
// matched against. Audit rules to find open ports and public exposure:
// includesPublicSource flags a rule whose source or destination reaches
// the public internet. A rule scopes its remote endpoint by exactly one of
// remoteIpPrefix (a CIDR), remoteGroup (another security group), or
// remoteAddressGroupId (an address group), which determines where the rule
// applies.
private openstack.securityGroup.rule @defaults("id direction protocol portRangeMin portRangeMax") {
  // Rule ID (UUID)
  id string
  // Direction (ingress, egress)
  direction string
  // Ethertype (IPv4, IPv6)
  ethertype string
  // Protocol (tcp, udp, icmp, ...; empty matches any)
  protocol string
  // Lower bound of the matched port range (0 when not set)
  portRangeMin int
  // Upper bound of the matched port range (0 when not set)
  portRangeMax int
  // Remote IP prefix (CIDR; empty when matched by remote group instead)
  remoteIpPrefix string
  // Remote address group ID the rule matches; empty when matched by IP prefix or remote security group instead
  remoteAddressGroupId string
  // Description
  description string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Security group this rule belongs to
  securityGroup() openstack.securityGroup
  // Remote security group the rule matches; null when matched by IP prefix instead
  remoteGroup() openstack.securityGroup
  // Whether the rule's source reaches the public internet
  //
  // True when remoteIpPrefix is a public CIDR (a broad block such as 0.0.0.0/0 or ::/0, excluding private and reserved ranges) or when the rule is unscoped (no remote IP prefix, no remote group, and no remote address group), which Neutron treats as any source. A rule scoped to a remote security group or remote address group is not public. Direction-agnostic, so it also classifies egress destinations.
  includesPublicSource() bool
  // Project that owns this security group rule
  project() openstack.project
}

// OpenStack Cinder block-storage volume
//
// Cinder block-storage volume backing compute servers or held as
// standalone storage. Records its encryption-at-rest posture, whether
// it can attach to multiple servers concurrently, its attachment
// records, and the project and user that own it. Select a volume by id
// with `openstack.blockstorage.volume(id: "...")`.
private openstack.blockstorage.volume @defaults("id name status size") {
  init(id? string)
  // Volume ID (UUID)
  id string
  // Volume name
  name string
  // Description
  description string
  // Status (available, in-use, error, creating, attaching, detaching, ...)
  status string
  // Size in GB
  size int
  // Whether the volume is bootable
  bootable bool
  // Whether the volume is encrypted at rest
  encrypted bool
  // Whether the volume can be attached to multiple servers concurrently
  multiAttach bool
  // Volume type name (storage class name as reported by the API)
  volumeTypeName string
  // Availability zone
  availabilityZone string
  // Replication status
  replicationStatus string
  // User-defined metadata
  metadata map[string]string
  // Image metadata for volumes booted from a Glance image (empty for non-image volumes)
  imageMetadata map[string]string
  // Attachment records ([{server_id, attached_at, device, attachment_id, host_name}])
  attachments []dict
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Project that owns this volume
  project() openstack.project
  // User that created this volume; null when the volume API does not return a user
  user() openstack.user
  // Source volume this volume was cloned from; null when not cloned
  sourceVolume() openstack.blockstorage.volume
  // Snapshot this volume was created from; null when not created from a snapshot
  sourceSnapshot() openstack.blockstorage.snapshot
  // Backup this volume was restored from; null when not restored from a backup
  restoredFromBackup() openstack.blockstorage.backup
  // Servers this volume is attached to; empty when detached
  servers() []openstack.compute.server
  // Volume type (storage class) for this volume; null when the API does not report one
  volumeType() openstack.blockstorage.volumeType
  // Backups of this volume
  backups() []openstack.blockstorage.backup
}

// OpenStack Cinder volume snapshot
//
// Point-in-time snapshot of a Cinder volume, used for backup and clone
// workflows. Records the source volume, whether the snapshot counts
// against project quota, and its status through the creation lifecycle.
// Select a snapshot by id with
// `openstack.blockstorage.snapshot(id: "...")`.
private openstack.blockstorage.snapshot @defaults("id name status size") {
  init(id? string)
  // Snapshot ID (UUID)
  id string
  // Snapshot name
  name string
  // Description
  description string
  // Status (available, creating, error, deleting, ...)
  status string
  // Size in GB (matches the source volume's size at snapshot time)
  size int
  // Progress of the snapshot creation (e.g. "100%")
  progress string
  // Group snapshot ID; empty when not part of a consistency group snapshot
  groupSnapshotId string
  // Whether the snapshot consumes project quota
  consumesQuota bool
  // User-defined metadata
  metadata map[string]string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Volume this snapshot was taken from
  volume() openstack.blockstorage.volume
  // Project that owns this snapshot
  project() openstack.project
  // User that created this snapshot; null when the snapshot API does not return a user
  user() openstack.user
}

// OpenStack Glance image
//
// Virtual machine image registered in Glance, the source template instances
// boot from. Select one by its UUID, for example
// `openstack.image(id: "7c9d9e5f-...")`. Audit `visibility` to find images
// exposed publicly or to the whole community, `protected` and `hidden` to
// understand lifecycle and listing controls, and the integrity fields
// (`checksum`, `osHashAlgo`, `osHashValue`) alongside `imageSignature` to
// confirm images are signed and untampered. The `members` field enumerates
// the projects a shared image is visible to, and `kernel` and `ramdisk`
// resolve the AMI-style boot components.
private openstack.image @defaults("id name status visibility") {
  init(id? string)
  // Image ID (UUID)
  id string
  // Image name
  name string
  // Status (queued, saving, active, killed, deleted, pending_delete, deactivated, uploading, importing)
  status string
  // Visibility (public, private, community, shared)
  visibility string
  // Whether the image is delete-protected
  protected bool
  // Whether the image is hidden from the default image list (`os_hidden`)
  hidden bool
  // Container format (ami, ari, aki, bare, ovf)
  containerFormat string
  // Disk format (ami, ari, aki, vhd, vmdk, raw, qcow2, vdi, iso)
  diskFormat string
  // Minimum root disk in GB required to boot the image
  minDiskGigabytes int
  // Minimum RAM in MB required to boot the image
  minRamMegabytes int
  // Image data checksum (MD5; deprecated by Glance but still populated on most clouds)
  checksum string
  // Secure-hash algorithm used for the image integrity digest (for example `sha512`); empty when the cloud does not report one
  osHashAlgo string
  // Image integrity digest in the algorithm named by osHashAlgo; empty when the cloud does not report one
  osHashValue string
  // Image data size in bytes
  sizeBytes int
  // Virtual disk size in bytes
  virtualSize int
  // Tags
  tags []string
  // User-defined metadata
  metadata map[string]string
  // Free-form image properties
  //
  // Carries Glance signing fields (`img_signature`, `img_signature_hash_method`, `img_signature_key_type`, `img_signature_certificate_uuid`), kernel/ramdisk references, and OS distro hints.
  properties dict
  // Glance image signature (`img_signature` property); empty string when the image is unsigned
  imageSignature() string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Project that owns the image
  owner() openstack.project
  // Sharing members for this image (projects the image has been shared with). Returns empty for community/public images and for non-shared private images.
  members() []openstack.image.member
  // Kernel image this image boots with (AMI-style `kernel_id` property); null when not set
  kernel() openstack.image
  // Ramdisk image this image boots with (AMI-style `ramdisk_id` property); null when not set
  ramdisk() openstack.image
}

// OpenStack Barbican secret
//
// Cryptographic secret material held by the Barbican key manager: symmetric
// keys, public and private keys, passphrases, certificates, and opaque blobs.
// Select a secret by its `id`, for example `openstack.keymanager.secret(id:
// "...")`. Query `secretType`, `algorithm`, and `bitLength` to audit what kind
// of key material is stored, `status` and `expiresAt` to find inactive or
// expired secrets, and `acl` to see who is allowed to read it. The raw
// `payload` (the secret material itself) is intentionally not exposed.
private openstack.keymanager.secret @defaults("id name secretType status") {
  init(id? string)
  // Secret ID (UUID extracted from secretRef)
  id string
  // Secret name
  name string
  // Secret type (symmetric, public, private, passphrase, certificate, opaque)
  secretType string
  // Algorithm (e.g. AES, RSA)
  algorithm string
  // Bit length of the secret material
  bitLength int
  // Mode (e.g. CBC, GCM); empty when not applicable
  mode string
  // Status (ACTIVE, PENDING, ERROR)
  status string
  // Available payload content types (e.g. {"default": "application/octet-stream"})
  contentTypes map[string]string
  // Full Barbican secret URL
  //
  // Matches the `default_tls_container_ref` / `sni_container_refs` strings used by Octavia listeners (when those point at a secret rather than a container).
  secretRef string
  // Expiration timestamp; null when the secret has no expiry
  expiresAt time
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // User that created this secret; null when the API does not return a creator
  creator() openstack.user
  // Access control list for this secret; null when no ACL is set
  acl() openstack.keymanager.acl
}

// OpenStack Barbican secret container
//
// Bundle of related Barbican secrets grouped under a single reference. Select
// a container by its `id`, for example `openstack.keymanager.container(id:
// "...")`. Certificate-typed containers hold a certificate together with its
// private key and any intermediate CA bundle, and are what Octavia listeners
// point at for TLS termination. Query `type` to tell generic, rsa, and
// certificate containers apart, `secrets` for the referenced secret material,
// and `consumers` to see which services depend on the container.
private openstack.keymanager.container @defaults("id name type status") {
  init(id? string)
  // Container ID (UUID extracted from containerRef)
  id string
  // Container name
  name string
  // Type (generic, rsa, certificate)
  type string
  // Status (ACTIVE, PENDING, ERROR)
  status string
  // Full Barbican container URL; matches the `default_tls_container_ref` / `sni_container_refs` strings used by Octavia listeners
  containerRef string
  // Raw secret references on this container
  //
  // One entry per referenced secret as `{name, secret_ref}`, where `name` is
  // the role within the container (for example certificate, private_key, or
  // intermediates) and `secret_ref` is the full Barbican secret URL. See
  // `secrets` for the resolved secret material.
  secretRefs []dict
  // Consumers registered on this container ([{name, url}])
  consumers []dict
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // User that created this container; null when the API does not return a creator
  creator() openstack.user
  // All secrets referenced by this container
  secrets() []openstack.keymanager.secret
  // Certificate body; only set on certificate-typed containers
  certificate() openstack.keymanager.secret
  // Private key paired with the certificate; only set on certificate-typed containers
  privateKey() openstack.keymanager.secret
  // Intermediate CA bundle; only set on certificate-typed containers that include intermediates
  intermediates() openstack.keymanager.secret
  // Access control list for this container; null when no ACL is set
  acl() openstack.keymanager.acl
}

// OpenStack Barbican secret-generation order
//
// Asynchronous request that has Barbican generate secret material server-side:
// a key, an asymmetric key pair, or a certificate. Select an order by its
// `id`, for example `openstack.keymanager.order(id: "...")`. Query `type` for
// what is being produced, `status` and `subStatus` to track progress,
// `errorReason` when generation fails, and `secret` or `container` for the
// material produced once the order completes.
private openstack.keymanager.order @defaults("id type status subStatus") {
  init(id? string)
  // Order ID (UUID extracted from orderRef)
  id string
  // Order type (key, asymmetric, certificate)
  type string
  // Status (PENDING, ACTIVE, ERROR)
  status string
  // Sub-status; finer-grained progress when status is PENDING
  subStatus string
  // Sub-status human-readable message
  subStatusMessage string
  // Error reason; populated when status is ERROR
  errorReason string
  // Error status code; populated when status is ERROR
  errorStatusCode string
  // Full Barbican order URL
  orderRef string
  // Order metadata (algorithm, bit_length, expiration, mode, name, payload_content_type)
  meta dict
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // User that created this order; null when the API does not return a creator
  creator() openstack.user
  // Secret produced by this order; null until the order completes (or for container-producing orders)
  secret() openstack.keymanager.secret
  // Container produced by this order; null for secret-producing orders
  container() openstack.keymanager.container
}

// OpenStack Octavia load balancer
//
// Load balancer fronting backend pools through Octavia, the OpenStack
// load-balancing service. Query it to audit public reachability, TLS
// enforcement across its listeners, the VIP's network and subnet
// placement, and the provider serving traffic (amphora, ovn). Select one
// by its UUID, for example `openstack.octavia.loadBalancer(id: "8f8a...")`.
// The exposure field reports whether the VIP is reachable from the
// internet and which listeners are open to the world, and enforcesTls is
// true only when every listener uses an encrypted protocol.
private openstack.octavia.loadBalancer @defaults("id name provisioningStatus operatingStatus vipAddress") {
  init(id? string)
  // Load balancer ID (UUID)
  id string
  // Load balancer name
  name string
  // Description
  description string
  // Whether the load balancer is administratively up
  adminStateUp bool
  // Provisioning status (ACTIVE, PENDING_CREATE, PENDING_UPDATE, PENDING_DELETE, ERROR)
  provisioningStatus string
  // Operating status (ONLINE, OFFLINE, DEGRADED, ERROR, NO_MONITOR, DRAINING)
  operatingStatus string
  // Virtual IP address
  vipAddress string
  // Octavia provider (amphora, ovn, ...)
  provider string
  // Octavia flavor ID; empty when no flavor is set
  flavorId string
  // Octavia availability zone; empty when not specified
  availabilityZone string
  // Additional VIPs ([{subnet_id, ip_address}]); microversion 2.26+
  additionalVips []dict
  // Tags
  tags []string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Project that owns this load balancer
  project() openstack.project
  // Neutron port hosting the VIP; null when no port is associated yet
  vipPort() openstack.port
  // Neutron network the VIP is allocated on
  vipNetwork() openstack.network
  // Neutron subnet the VIP is allocated from
  vipSubnet() openstack.subnet
  // Listeners attached to this load balancer
  listeners() []openstack.octavia.listener
  // Pools attached to this load balancer
  pools() []openstack.octavia.pool
  // Whether every listener uses an encrypted protocol
  //
  // True when no listener uses a plaintext protocol (HTTP, TCP, UDP, SCTP, or PROMETHEUS). A load balancer with no listeners has no plaintext exposure and is reported as enforcing; pair with `exposure.internetReachable` to scope an audit to internet-facing load balancers.
  enforcesTls() bool
  // Internet-exposure summary for this load balancer (public reachability plus the listeners open to the world)
  exposure() openstack.octavia.loadBalancer.exposure
}

// OpenStack Octavia load balancer internet exposure
//
// Summarizes whether a load balancer is reachable from the public internet and,
// when it is, the listeners that accept traffic from any source. A load balancer
// is publicly accessible when its VIP sits on an external network or has a
// floating IP; internetReachable additionally requires at least one listener
// open to the world (an empty or public allowedCidrs list).
private openstack.octavia.loadBalancer.exposure @defaults("internetReachable publiclyAccessible") {
  // Whether the load balancer is reachable from the internet (publicly accessible and at least one listener is open to the world)
  internetReachable bool
  // Whether the VIP has a public edge: it sits on an external network, or a floating IP is mapped to it
  publiclyAccessible bool
  // Listeners that accept connections from any source (allowedCidrs is empty or contains a public CIDR)
  listenersOpenToWorld []openstack.octavia.listener
  // Floating (public) IPs mapped to the VIP port
  floatingIps []openstack.floatingIp
}

// OpenStack Octavia listener
//
// Frontend that binds a protocol and port on a load balancer's virtual IP
// and forwards matching traffic to a default pool or through L7 policies.
// Query it to audit which ports accept connections, whether traffic is
// TLS-terminated and with which ciphers, versions, and client
// authentication mode, and how far the source is restricted through
// allowedCidrs. The openToWorld field is true when the listener accepts
// connections from any source. Select one by its UUID, for example
// `openstack.octavia.listener(id: "...")`.
private openstack.octavia.listener @defaults("id name protocol protocolPort provisioningStatus") {
  init(id? string)
  // Listener ID (UUID)
  id string
  // Listener name
  name string
  // Description
  description string
  // Whether the listener is administratively up
  adminStateUp bool
  // Protocol (TCP, SCTP, UDP, HTTP, HTTPS, TERMINATED_HTTPS, PROMETHEUS)
  protocol string
  // Listening port (1-65535)
  protocolPort int
  // Maximum simultaneous connections allowed; -1 means unlimited
  connectionLimit int
  // Provisioning status (ACTIVE, PENDING_*, ERROR)
  provisioningStatus string
  // OpenSSL-format colon-separated cipher list applied to TLS-terminated listeners
  tlsCiphers string
  // Allowed TLS protocol versions (e.g. TLSv1.2, TLSv1.3); microversion 2.17+
  tlsVersions []string
  // Allowed ALPN protocols (http/1.0, http/1.1, h2); microversion 2.20+
  alpnProtocols []string
  // TLS client authentication mode (NONE, OPTIONAL, MANDATORY); microversion 2.8+
  clientAuthentication string
  // CIDRs allowed to connect to the listener; empty list allows all
  allowedCidrs []string
  // Headers Octavia inserts before forwarding to the backend (e.g. X-Forwarded-For)
  insertHeaders map[string]string
  // Frontend client inactivity timeout in milliseconds
  timeoutClientData int
  // Backend member inactivity timeout in milliseconds
  timeoutMemberData int
  // Backend member connection timeout in milliseconds
  timeoutMemberConnect int
  // Wait time, in milliseconds, for additional TCP packets for content inspection
  timeoutTcpInspect int
  // Whether HSTS includeSubDomains is enabled (microversion 2.27+)
  hstsIncludeSubdomains bool
  // Tags
  tags []string
  // Project that owns this listener
  project() openstack.project
  // Load balancer this listener is attached to
  loadBalancer() openstack.octavia.loadBalancer
  // Default backend pool for traffic on this listener; null when no default pool is set
  defaultPool() openstack.octavia.pool
  // Barbican container holding the listener's default TLS material; null when not set or when the ref points at a bare Barbican secret
  defaultTlsContainer() openstack.keymanager.container
  // Barbican containers used for SNI; empty when SNI is not configured
  sniContainers() []openstack.keymanager.container
  // Barbican container holding the client CA bundle for mTLS; null when not configured
  clientCATlsContainer() openstack.keymanager.container
  // Barbican container holding the client CRL list; null when not configured
  clientCRLContainer() openstack.keymanager.container
  // L7 policies attached to this listener
  l7Policies() []openstack.octavia.l7Policy
  // Whether the listener accepts connections from any source (allowedCidrs is empty or contains a public CIDR)
  openToWorld() bool
}

// OpenStack Octavia backend pool
//
// Group of backend members that a listener load-balances across using a
// selection algorithm. Query it to audit the algorithm in use, whether
// backend connections are encrypted (tlsEnabled with its ciphers and
// versions), the session persistence policy, and the health monitor
// guarding the members. Select one by its UUID, for example
// `openstack.octavia.pool(id: "...")`.
private openstack.octavia.pool @defaults("id name lbAlgorithm protocol provisioningStatus") {
  init(id? string)
  // Pool ID (UUID)
  id string
  // Pool name
  name string
  // Description
  description string
  // Whether the pool is administratively up
  adminStateUp bool
  // Load-balancing algorithm (ROUND_ROBIN, LEAST_CONNECTIONS, SOURCE_IP, SOURCE_IP_PORT)
  lbAlgorithm string
  // Pool protocol (TCP, UDP, HTTP, HTTPS, PROXY, PROXYV2, SCTP)
  protocol string
  // Provisioning status (ACTIVE, PENDING_*, ERROR)
  provisioningStatus string
  // Operating status (ONLINE, OFFLINE, DEGRADED, ERROR, NO_MONITOR, DRAINING)
  operatingStatus string
  // Octavia provider serving this pool
  provider string
  // Session persistence config ({type, cookie_name, persistence_timeout, persistence_granularity}); empty when persistence is disabled
  persistence dict
  // Whether backend connections use TLS; microversion 2.8+
  tlsEnabled bool
  // OpenSSL-format colon-separated cipher list for backend TLS; microversion 2.15+
  tlsCiphers string
  // Allowed TLS protocol versions for backend TLS; microversion 2.17+
  tlsVersions []string
  // ALPN protocols for backend TLS (microversion 2.24+)
  alpnProtocols []string
  // Tags
  tags []string
  // Project that owns this pool
  project() openstack.project
  // Load balancer this pool is attached to; null when standalone
  loadBalancer() openstack.octavia.loadBalancer
  // Listeners that use this pool as their default; usually 0 or 1
  listeners() []openstack.octavia.listener
  // Health monitor watching this pool; null when no monitor is attached
  healthMonitor() openstack.octavia.healthMonitor
  // Subnet the pool's members live on
  subnet() openstack.subnet
  // Barbican container holding the CA bundle used to verify backend TLS; null when not set
  caTlsContainer() openstack.keymanager.container
  // Barbican container holding the CRL list for backend TLS; null when not set
  crlContainer() openstack.keymanager.container
  // Barbican container holding the client cert/key bundle for backend mTLS; null when not set
  clientTlsContainer() openstack.keymanager.container
  // Members in this pool
  members() []openstack.octavia.member
}

// OpenStack Octavia pool member
private openstack.octavia.member @defaults("id name address protocolPort weight") {
  // Member ID (UUID)
  id string
  // Member name
  name string
  // Whether the member is administratively up
  adminStateUp bool
  // Backend IP address
  address string
  // Backend protocol port (1-65535)
  protocolPort int
  // Member weight (relative weight in the load-balancing algorithm); 0 means standby
  weight int
  // Whether this is a backup member (only receives traffic when all non-backup members are down)
  backup bool
  // Alternate IP address used for health monitoring; empty falls back to address
  monitorAddress string
  // Alternate port used for health monitoring; 0 falls back to protocolPort
  monitorPort int
  // Provisioning status (ACTIVE, PENDING_*, ERROR)
  provisioningStatus string
  // Operating status (ONLINE, OFFLINE, DEGRADED, ERROR, NO_MONITOR)
  operatingStatus string
  // Tags (microversion 2.5+)
  tags []string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Project that owns this member
  project() openstack.project
  // Pool this member belongs to
  pool() openstack.octavia.pool
  // Subnet the member's address lives on; null when no subnet is associated
  subnet() openstack.subnet
}

// OpenStack Octavia health monitor
//
// Probe configuration Octavia uses to test the health of a pool's backend
// members and remove failing ones from rotation. Query it to audit the
// probe type, interval and timeout, retry thresholds, and the HTTP method,
// path, and expected response codes used by HTTP and HTTPS probes. Select
// one by its UUID, for example `openstack.octavia.healthMonitor(id: "...")`.
private openstack.octavia.healthMonitor @defaults("id name type delay timeout") {
  init(id? string)
  // Health monitor ID (UUID)
  id string
  // Health monitor name
  name string
  // Whether the health monitor is administratively up
  adminStateUp bool
  // Probe type (PING, TCP, HTTP, HTTPS, TLS-HELLO, UDP-CONNECT, SCTP)
  type string
  // Seconds between probes
  delay int
  // Probe connection timeout in seconds (must be < delay)
  timeout int
  // Allowed connection failures before a member is marked unhealthy (1-10)
  maxRetries int
  // Allowed connection failures before a member is marked DOWN (1-10)
  maxRetriesDown int
  // HTTP method used by HTTP/HTTPS probes (GET, HEAD, POST, ...)
  httpMethod string
  // HTTP version used by HTTP/HTTPS probes (1.0, 1.1)
  httpVersion string
  // HTTP path probed (must start with /)
  urlPath string
  // Expected HTTP response codes (e.g. "200", "200,201,202", "200-299")
  expectedCodes string
  // HTTP Host header used by HTTP/HTTPS probes
  domainName string
  // Status of the health monitor itself
  status string
  // Provisioning status (ACTIVE, PENDING_*, ERROR)
  provisioningStatus string
  // Operating status (ONLINE, OFFLINE, ERROR)
  operatingStatus string
  // Tags
  tags []string
  // Project that owns this health monitor
  project() openstack.project
  // Pools watched by this health monitor; usually 1
  pools() []openstack.octavia.pool
}

// OpenStack Octavia L7 policy
//
// Layer-7 policy on a listener that inspects HTTP requests and, when all of
// its rules match, redirects them to a pool or URL or rejects them. Query
// it to audit the action taken, its evaluation position among sibling
// policies, any redirect target, and the match rules that trigger it.
// Select one by its UUID, for example `openstack.octavia.l7Policy(id: "...")`.
private openstack.octavia.l7Policy @defaults("id name action position provisioningStatus") {
  init(id? string)
  // L7 policy ID (UUID)
  id string
  // L7 policy name
  name string
  // Description
  description string
  // Whether the policy is administratively up
  adminStateUp bool
  // Action to take when all rules match (REDIRECT_PREFIX, REDIRECT_TO_POOL, REDIRECT_TO_URL, REJECT)
  action string
  // Evaluation position relative to other policies on the same listener
  position int
  // URL prefix when action is REDIRECT_PREFIX
  redirectPrefix string
  // URL when action is REDIRECT_TO_URL
  redirectUrl string
  // HTTP response code used with REDIRECT_TO_URL or REDIRECT_PREFIX
  redirectHttpCode int
  // Provisioning status (ACTIVE, PENDING_*, ERROR)
  provisioningStatus string
  // Operating status (ONLINE, OFFLINE, ERROR)
  operatingStatus string
  // Tags
  tags []string
  // Project that owns this policy
  project() openstack.project
  // Listener this policy is attached to
  listener() openstack.octavia.listener
  // Pool requests are redirected to when action is REDIRECT_TO_POOL; null otherwise
  redirectPool() openstack.octavia.pool
  // Match rules; the policy fires when ALL rules match
  rules() []openstack.octavia.l7Rule
}

// OpenStack Octavia L7 match rule
private openstack.octavia.l7Rule @defaults("id ruleType compareType value") {
  // L7 rule ID (UUID)
  id string
  // Rule type (COOKIE, FILE_TYPE, HEADER, HOST_NAME, PATH, SSL_CONN_HAS_CERT, SSL_VERIFY_RESULT, SSL_DN_FIELD)
  ruleType string
  // Comparison type (CONTAINS, ENDS_WITH, EQUAL_TO, REGEX, STARTS_WITH)
  compareType string
  // Comparison value (e.g. "/api/v1", ".example.com")
  value string
  // Comparison key (e.g. cookie name when ruleType is COOKIE); empty when not applicable
  key string
  // Whether the comparison is inverted (e.g. "not equal to")
  invert bool
  // Whether the rule is administratively up
  adminStateUp bool
  // Provisioning status (ACTIVE, PENDING_*, ERROR)
  provisioningStatus string
  // Operating status (ONLINE, OFFLINE, ERROR)
  operatingStatus string
  // Tags
  tags []string
  // Project that owns this rule
  project() openstack.project
  // L7 policy this rule belongs to
  l7Policy() openstack.octavia.l7Policy
}

// OpenStack Neutron subnet pool
//
// Pool of CIDR prefixes that Neutron carves tenant subnets from, so
// address space is managed centrally instead of assigned ad hoc. The
// `id` field selects a specific pool, for example
// `openstack.subnetPool(id: "a1b2c3d4-...")`. Auditing a pool shows the
// prefixes it can allocate, the allowed prefix-length bounds
// (minPrefixLen, maxPrefixLen), the per-project address quota, whether
// the pool is shared across projects, and the address scope it is bound
// to, all of which govern how much address space each tenant can claim.
private openstack.subnetPool @defaults("id name ipVersion shared isDefault") {
  init(id? string)
  // Subnet pool ID (UUID)
  id string
  // Subnet pool name
  name string
  // Description
  description string
  // CIDR prefixes the pool can allocate from
  prefixes []string
  // Default prefix length used when carving a subnet without an explicit length
  defaultPrefixLen int
  // Smallest prefix the pool can allocate (default 8 for IPv4, 64 for IPv6)
  minPrefixLen int
  // Largest prefix the pool can allocate (default 32 for IPv4, 128 for IPv6)
  maxPrefixLen int
  // Per-project quota in addresses
  defaultQuota int
  // Address scope ID this pool is bound to; empty when not in any address scope
  addressScopeId string
  // IP version (4 or 6)
  ipVersion int
  // Whether the pool is shared across projects
  shared bool
  // Whether the pool is the default for its IP version
  isDefault bool
  // Tags
  tags []string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Project that owns this subnet pool
  project() openstack.project
}

// OpenStack Neutron QoS policy
//
// Quality-of-Service policy that attaches traffic-shaping rules to Neutron
// ports, networks, and floating IPs. Each policy holds a set of rules
// (bandwidth limits, DSCP marking, minimum guaranteed bandwidth, and
// packet-rate limits) exposed through `rules`. The `shared` flag governs
// whether other projects can attach the policy, and `isDefault` marks the
// policy that new ports inherit, so both are worth auditing when reviewing
// tenant traffic controls. Select a policy by its UUID, for example
// `openstack.qosPolicy(id: "d1e2f3a4-...")`.
private openstack.qosPolicy @defaults("id name shared isDefault") {
  init(id? string)
  // QoS policy ID (UUID)
  id string
  // QoS policy name
  name string
  // Description
  description string
  // Whether the policy is shared across projects
  shared bool
  // Whether the policy is the project's default
  isDefault bool
  // Rules attached to this policy
  //
  // Rules are heterogeneous; each entry has a `type` key (`bandwidth_limit`, `dscp_marking`, `minimum_bandwidth`, `packet_rate_limit`) plus the type-specific fields (e.g. `max_kbps`, `dscp_mark`, `min_kbps`).
  rules []dict
  // Tags
  tags []string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Project that owns this QoS policy
  project() openstack.project
}

// OpenStack Neutron trunk
//
// Neutron trunk port that multiplexes traffic from several networks onto a
// single parent port. Traffic for each attached network arrives on a subport
// tagged with its own VLAN ID, letting one instance reach many networks over
// one virtual NIC. Select a trunk by its UUID, for example
// `openstack.trunk(id: "...")`. Audit trunks to see which ports an instance is
// bridged onto, whether the trunk is administratively up (adminStateUp), and
// its operational status. The parentPort and subportPorts accessors resolve the
// underlying Neutron ports for reachability and security-group analysis.
private openstack.trunk @defaults("id name status") {
  init(id? string)
  // Trunk ID (UUID)
  id string
  // Trunk name
  name string
  // Description
  description string
  // Whether the trunk is administratively up
  adminStateUp bool
  // Status (ACTIVE, DOWN, BUILD, DEGRADED, ERROR)
  status string
  // Subport entries
  //
  // Each entry is a dict with keys `port_id` (the Neutron port carried on the
  // trunk), `segmentation_type` (the tagging scheme, typically `vlan`), and
  // `segmentation_id` (the VLAN tag that isolates the subport's traffic on the
  // parent port). See subportPorts for these ports resolved as Neutron port
  // resources.
  subports []dict
  // Tags
  tags []string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Project that owns this trunk
  project() openstack.project
  // Parent port that carries the trunk
  parentPort() openstack.port
  // Subports as resolved Neutron ports
  subportPorts() []openstack.port
}

// OpenStack FWaaS v2 firewall group
//
// Firewall-as-a-Service v2 group that binds an ingress and an egress
// policy to a set of Neutron ports, applying stateful packet filtering
// at the port level. The status field reports the provisioning state
// (ACTIVE, INACTIVE, PENDING_*, ERROR), adminStateUp reports whether the
// group is administratively enabled, and shared reports whether other
// projects can use it. Selected by group ID.
private openstack.firewall.group @defaults("id name status adminStateUp") {
  init(id? string)
  // Firewall group ID (UUID)
  id string
  // Firewall group name
  name string
  // Description
  description string
  // Whether the firewall group is administratively up
  adminStateUp bool
  // Status (ACTIVE, INACTIVE, PENDING_*, ERROR)
  status string
  // Whether the group is shared across projects
  shared bool
  // Project that owns this firewall group
  project() openstack.project
  // Ports protected by this firewall group
  ports() []openstack.port
  // Policy applied to ingress traffic; null when no ingress policy is bound
  ingressPolicy() openstack.firewall.policy
  // Policy applied to egress traffic; null when no egress policy is bound
  egressPolicy() openstack.firewall.policy
}

// OpenStack FWaaS v2 firewall policy
//
// Firewall-as-a-Service v2 policy holding an ordered list of rules that a
// firewall group evaluates in sequence. The audited flag records whether
// an administrator has reviewed the current rule set, and shared reports
// whether other projects can reference the policy. Selected by policy ID.
private openstack.firewall.policy @defaults("id name audited shared") {
  init(id? string)
  // Firewall policy ID (UUID)
  id string
  // Firewall policy name
  name string
  // Description
  description string
  // Whether the policy has been audited (an admin has reviewed it)
  audited bool
  // Whether the policy is shared across projects
  shared bool
  // Project that owns this firewall policy
  project() openstack.project
  // Rules in this policy in evaluation order
  rules() []openstack.firewall.rule
}

// OpenStack FWaaS v2 firewall rule
//
// Firewall-as-a-Service v2 rule, a single match-action entry that one or
// more policies reference. Matches on protocol, source and destination
// IP/CIDR, and source and destination port ranges, then applies the
// action (allow, deny, reject). The enabled flag controls whether the
// rule is evaluated, and ipVersion selects IPv4 or IPv6. Selected by
// rule ID.
private openstack.firewall.rule @defaults("id name action protocol enabled") {
  init(id? string)
  // Firewall rule ID (UUID)
  id string
  // Firewall rule name
  name string
  // Description
  description string
  // Match protocol (tcp, udp, icmp, any; empty matches any)
  protocol string
  // Action (allow, deny, reject)
  action string
  // IP version the rule applies to (4 or 6); 0 when unspecified
  ipVersion int
  // Source IP/CIDR; empty matches any
  sourceIpAddress string
  // Destination IP/CIDR; empty matches any
  destinationIpAddress string
  // Source port or range (e.g. "443" or "1024:65535"); empty matches any
  sourcePort string
  // Destination port or range; empty matches any
  destinationPort string
  // Whether the rule is shared across projects
  shared bool
  // Whether the rule is currently evaluated (disabled rules are skipped)
  enabled bool
  // Project that owns this firewall rule
  project() openstack.project
  // Policies that reference this rule
  policies() []openstack.firewall.policy
}

// OpenStack VPNaaS v2 IPsec VPN service
//
// An IPsec VPN service bound to a router, the anchor that site-to-site
// connections attach to. Fields cover the administrative state, the
// operational status, and the external IPv4 and IPv6 addresses the
// service terminates tunnels on. Selected by service ID.
private openstack.vpn.service @defaults("id name status adminStateUp") {
  init(id? string)
  // VPN service ID (UUID)
  id string
  // VPN service name
  name string
  // Description
  description string
  // Operational status (ACTIVE, DOWN, PENDING_CREATE, ERROR, ...)
  status string
  // Whether the service is administratively enabled
  adminStateUp bool
  // External IPv4 address the service terminates tunnels on; empty when none
  externalV4Ip string
  // External IPv6 address the service terminates tunnels on; empty when none
  externalV6Ip string
  // Flavor ID applied to the service; empty when none
  flavorId string
  // Subnet the service is bound to; null when the service uses endpoint groups instead
  subnet() openstack.subnet
  // Router the service runs on
  router() openstack.router
  // Project that owns this VPN service
  project() openstack.project
}

// OpenStack VPNaaS v2 IKE policy
//
// IKE key-exchange negotiation parameters referenced by site-to-site
// connections. The authentication and encryption algorithms, the
// perfect-forward-secrecy group, the IKE version, the negotiation mode,
// and the security-association lifetime are the values to audit for weak
// cryptography (for example a sha1 auth algorithm, 3des encryption, or a
// disabled PFS group). Selected by policy ID.
private openstack.vpn.ikePolicy @defaults("id name authAlgorithm encryptionAlgorithm pfs ikeVersion") {
  init(id? string)
  // IKE policy ID (UUID)
  id string
  // IKE policy name
  name string
  // Description
  description string
  // Authentication hash algorithm (for example "sha1", "sha256", "sha384", "sha512")
  authAlgorithm string
  // Encryption algorithm (for example "3des", "aes-128", "aes-256")
  encryptionAlgorithm string
  // Perfect forward secrecy group (for example "group2", "group5", "group14")
  pfs string
  // IKE key-exchange negotiation mode (for example "main")
  phase1NegotiationMode string
  // IKE protocol version ("v1" or "v2")
  ikeVersion string
  // Security-association lifetime units ("seconds" or "kilobytes")
  lifetimeUnits string
  // Security-association lifetime value in the lifetime units
  lifetimeValue int
  // Project that owns this IKE policy
  project() openstack.project
}

// OpenStack VPNaaS v2 IPsec policy
//
// IPsec data-channel negotiation parameters referenced by site-to-site
// connections. The authentication and encryption algorithms, the
// perfect-forward-secrecy group, the encapsulation mode, the transform
// protocol, and the security-association lifetime are the values to audit
// for weak cryptography. Selected by policy ID.
private openstack.vpn.ipsecPolicy @defaults("id name authAlgorithm encryptionAlgorithm pfs transformProtocol") {
  init(id? string)
  // IPsec policy ID (UUID)
  id string
  // IPsec policy name
  name string
  // Description
  description string
  // Authentication hash algorithm (for example "sha1", "sha256", "sha384", "sha512")
  authAlgorithm string
  // Encryption algorithm (for example "3des", "aes-128", "aes-256")
  encryptionAlgorithm string
  // Perfect forward secrecy group (for example "group2", "group5", "group14")
  pfs string
  // Encapsulation mode ("tunnel" or "transport")
  encapsulationMode string
  // Transform protocol ("esp", "ah", or "ah-esp")
  transformProtocol string
  // Security-association lifetime units ("seconds" or "kilobytes")
  lifetimeUnits string
  // Security-association lifetime value in the lifetime units
  lifetimeValue int
  // Project that owns this IPsec policy
  project() openstack.project
}

// OpenStack VPNaaS v2 endpoint group
//
// A named set of local subnets or peer CIDRs that a site-to-site
// connection references in place of a single bound subnet. The type
// distinguishes subnet groups (local) from CIDR groups (peer), and
// endpoints lists the members. Selected by endpoint-group ID.
private openstack.vpn.endpointGroup @defaults("id name type") {
  init(id? string)
  // Endpoint group ID (UUID)
  id string
  // Endpoint group name
  name string
  // Description
  description string
  // Endpoint type ("subnet" for local subnet IDs or "cidr" for peer CIDRs)
  type string
  // Member subnet IDs or CIDRs, depending on the type
  endpoints []string
  // Project that owns this endpoint group
  project() openstack.project
}

// OpenStack VPNaaS v2 IPsec site-to-site connection
//
// An IPsec tunnel from a local VPN service to a remote peer. Fields cover
// the peer address and identity, the local and peer CIDRs reachable
// through the tunnel, the dead-peer-detection settings, the negotiation
// initiator, and the referenced IKE and IPsec policies, so the
// cryptographic strength and exposure of a tunnel can be audited end to
// end. The pre-shared key is intentionally not exposed. Selected by
// connection ID.
private openstack.vpn.siteConnection @defaults("id name status peerAddress adminStateUp") {
  init(id? string)
  // Site connection ID (UUID)
  id string
  // Site connection name
  name string
  // Description
  description string
  // Operational status (ACTIVE, DOWN, PENDING_CREATE, ERROR, ...)
  status string
  // Whether the connection is administratively enabled
  adminStateUp bool
  // Public address of the remote peer
  peerAddress string
  // Identity of the remote peer (IP, FQDN, or DN)
  peerId string
  // Local identity presented to the peer; empty when defaulted
  localId string
  // Remote CIDRs reachable through the tunnel
  peerCidrs []string
  // Route advertisement mode (for example "static")
  routeMode string
  // Who initiates the tunnel ("bi-directional" or "response-only")
  initiator string
  // IKE authentication mode (for example "psk")
  authMode string
  // Tunnel MTU
  mtu int
  // Dead peer detection action ("hold", "clear", "restart", "disabled", "restart-by-peer")
  dpdAction string
  // Dead peer detection timeout in seconds
  dpdTimeout int
  // Dead peer detection interval in seconds
  dpdInterval int
  // VPN service this connection runs on
  service() openstack.vpn.service
  // IKE policy used for key-exchange negotiation
  ikePolicy() openstack.vpn.ikePolicy
  // IPsec policy used for data-channel negotiation
  ipsecPolicy() openstack.vpn.ipsecPolicy
  // Local endpoint group (local subnets); null when the connection binds a subnet directly
  localEndpointGroup() openstack.vpn.endpointGroup
  // Peer endpoint group (peer CIDRs); null when peer CIDRs are set directly
  peerEndpointGroup() openstack.vpn.endpointGroup
  // Project that owns this site connection
  project() openstack.project
}

// OpenStack Swift object-storage account
//
// Account-level totals for a scoped project's Swift object storage,
// aggregating byte usage, container count, and object count across
// every container. There is one account per scoped project. Compare
// quotaBytes against bytesUsed for capacity planning, and check
// tempUrlKeySet to confirm whether a temporary-URL signing key is
// configured on the account.
private openstack.objectstorage.account @defaults("bytesUsed containerCount objectCount") {
  // Account identifier (Swift account URL path, e.g. AUTH_<project_id>)
  id string
  // Total bytes stored in this account
  bytesUsed int
  // Number of containers
  containerCount int
  // Total number of objects across all containers
  objectCount int
  // Account-level byte quota (-1 when unset)
  quotaBytes int
  // Whether an X-Account-Meta-Temp-URL-Key is configured (presence only; value not exposed)
  tempUrlKeySet bool
  // Free-form account metadata (X-Account-Meta-* headers, without the prefix)
  metadata map[string]string
}

// OpenStack Swift object-storage container
//
// Storage container within a Swift account, holding objects along
// with its own read/write ACLs, storage policy, and versioning
// settings. The name field selects the container, for example
// openstack.objectstorage.container(name: "backups"). The public
// predicate reports whether the read ACL grants unauthenticated read
// access (the ACL contains ".r:*"), the key check for unintended data
// exposure.
private openstack.objectstorage.container @defaults("name objectCount bytes public") {
  init(name? string)
  // Container name (also acts as identifier within the account)
  name string
  // Number of objects in the container
  objectCount int
  // Total bytes stored in the container
  bytes int
  // Creation timestamp (derived from the container's X-Timestamp header)
  created() time
  // Read ACL entries (X-Container-Read; e.g. ".r:*" means publicly readable)
  readACL() []string
  // Write ACL entries (X-Container-Write)
  writeACL() []string
  // Storage policy assigned to the container
  storagePolicy() string
  // Container that stores prior versions of objects (X-Versions-Location); empty when versioning is disabled
  versionsLocation() string
  // Container that records overwritten/deleted object versions (X-History-Location); empty when history is disabled
  historyLocation() string
  // Free-form container metadata (X-Container-Meta-* headers, without the prefix)
  metadata() map[string]string
  // Whether the container's read ACL grants unauthenticated read access (i.e. contains ".r:*")
  public() bool
  // Objects in this container (lazy; full listing can be expensive)
  objects() []openstack.objectstorage.object
}

// OpenStack Swift object stored in a container
//
// Individual object within a Swift container, exposing its size,
// content type, MD5/ETag hash, and last-modification time. Selected
// by container and object name, for example
// openstack.objectstorage.object(containerName: "backups", name: "db.sql").
private openstack.objectstorage.object @defaults("name contentType bytes") {
  init(containerName? string, name? string)
  // Object name (path within the container)
  name string
  // Name of the container that holds this object
  containerName string
  // MIME content type
  contentType string
  // Object size in bytes
  bytes int
  // ETag / MD5 hash of the object body
  hash string
  // Last modification timestamp
  lastModified time
  // Container that holds this object
  container() openstack.objectstorage.container
}

// OpenStack Designate DNS zone
//
// A domain namespace managed by the Designate DNS service, holding the
// records that resolve names under it. Query a single zone by its id, for
// example `openstack.dns.zone(id: "a86dba58-0043-4cc6-a1bb-69d5e86f3ca3")`.
// Audit zones to review which domains a project serves, check the SOA email
// and default ttl, and spot SECONDARY zones that transfer records from
// external masters. The type field distinguishes PRIMARY zones from
// SECONDARY ones, and recordsets returns the individual record collections
// defined within the zone.
private openstack.dns.zone @defaults("id name type ttl status") {
  init(id? string)
  // Zone ID (UUID)
  id string
  // Zone name (FQDN, e.g. "example.com.")
  name string
  // Email address recorded in the zone SOA
  email string
  // Description
  description string
  // Default TTL in seconds for records that do not override it
  ttl int
  // SOA serial number
  serial int
  // Zone status (ACTIVE, PENDING, ERROR, ...)
  status string
  // Last action performed on the zone (CREATE, UPDATE, DELETE, NONE)
  action string
  // Zone type (PRIMARY or SECONDARY)
  type string
  // Master nameservers for SECONDARY zones (empty for PRIMARY zones)
  masters []string
  // Owning project ID
  //
  // Deprecated in favor of project.
  projectId @maturity("deprecated") string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Last successful transfer timestamp (SECONDARY zones); null when never transferred
  transferredAt time
  // Project that owns this zone
  project() openstack.project
  // Recordsets in this zone
  recordsets() []openstack.dns.recordset
}

// OpenStack Designate DNS recordset (one or more records sharing a name and type)
//
// A collection of DNS records that share the same name and record type
// within a Designate zone, along with the values they resolve to. Query a
// single recordset by its id, for example
// `openstack.dns.recordset(id: "f7b10e9b-0cae-4a91-b162-562bc6096648")`.
// Audit recordsets to review what a zone resolves, catch entries pointing at
// unexpected or externally controlled targets, and check the type and ttl.
// The records field holds the raw values (one per record, formatted per type)
// and zone links back to the owning zone.
private openstack.dns.recordset @defaults("id name type ttl") {
  init(id? string)
  // Recordset ID (UUID)
  id string
  // Recordset name (FQDN, e.g. "www.example.com.")
  name string
  // Owning zone ID
  //
  // Deprecated in favor of zone.
  zoneId @maturity("deprecated") string
  // Record type (A, AAAA, MX, CNAME, TXT, SRV, NS, PTR, SPF, SSHFP, CAA, ...)
  type string
  // TTL in seconds; null when the zone default applies
  ttl int
  // Record values (one entry per record; format depends on type)
  records []string
  // Description
  description string
  // Recordset status (ACTIVE, PENDING, ERROR, ...)
  status string
  // Last action performed (CREATE, UPDATE, DELETE, NONE)
  action string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Owning zone
  zone() openstack.dns.zone
}

// OpenStack Nova hypervisor (compute host)
//
// Compute host as reported by Nova, exposing its capacity and current
// load: total and used vcpus, memoryMb, and localGb, runningVms,
// currentWorkload, and cpuInfo. state and status show whether the host is
// reachable and administratively enabled. Reading it requires an admin
// token. Select a hypervisor by its id with
// `openstack.compute.hypervisor(id: "...")`.
private openstack.compute.hypervisor @defaults("id hostname type state status") {
  init(id? string)
  // Hypervisor ID (Nova-assigned UUID or integer string)
  id string
  // Hypervisor hostname as reported by the compute service
  hostname string
  // Hypervisor type (e.g. QEMU, KVM, VMware, Xen, ironic)
  type string
  // Hypervisor driver version (Nova `hypervisor_version`)
  version int
  // IP address of the hypervisor host
  hostIp string
  // Connection state (up, down)
  state string
  // Administrative status (enabled, disabled)
  status string
  // Total vCPUs on the host
  vcpus int
  // vCPUs allocated to running instances
  vcpusUsed int
  // Total RAM in megabytes
  memoryMb int
  // RAM allocated to running instances in megabytes
  memoryMbUsed int
  // Free RAM in megabytes
  freeRamMb int
  // Total local disk in gigabytes
  localGb int
  // Local disk allocated in gigabytes
  localGbUsed int
  // Free local disk in gigabytes
  freeDiskGb int
  // Number of instances currently running on the host
  runningVms int
  // Current scheduler workload metric
  currentWorkload int
  // Hypervisor CPU information
  //
  // Keys: `vendor`, `arch`, `model`, `features` (list of CPU feature flags), and `topology` (with `sockets`, `cores`, and `threads`).
  cpuInfo dict
  // The compute service backing this hypervisor (typically the nova-compute on the same host)
  service() openstack.compute.service
}

// OpenStack Nova compute service
//
// Nova control-plane or compute daemon (nova-compute, nova-scheduler,
// nova-conductor, and similar) and its health. state reports whether the
// daemon is up or down, status reports whether it is administratively
// enabled or disabled, and disabledReason records why a service was taken
// out of rotation. Reading it requires an admin token. Select a service
// by its id with `openstack.compute.service(id: "...")`.
private openstack.compute.service @defaults("id binary host zone status state") {
  init(id? string)
  // Service ID (Nova-assigned UUID or integer string)
  id string
  // Service binary name (nova-compute, nova-scheduler, nova-conductor, ...)
  binary string
  // Host the service runs on
  host string
  // Availability zone
  zone string
  // Administrative status (enabled, disabled)
  status string
  // Connection state (up, down)
  state string
  // Reason given when the service was administratively disabled; empty when enabled
  disabledReason string
  // Whether the service is forced down (Nova `forced_down`)
  forcedDown bool
  // Last update timestamp reported by the service
  updatedAt time
}

// OpenStack Cinder volume type
//
// Storage class that governs which backend a volume lands on and its
// encryption posture. When the type is encrypted, the encryption*
// fields report the provider class, cipher, key size, and where
// encryption is performed; they are empty on unencrypted types.
// `extraSpecs` holds the backend-specific configuration. Select a type
// by id with `openstack.blockstorage.volumeType(id: "...")`.
private openstack.blockstorage.volumeType @defaults("id name isPublic encryptionProvider") {
  init(id? string)
  // Volume type ID (UUID)
  id string
  // Volume type name
  name string
  // Description
  description string
  // Whether the volume type is publicly available to all projects
  isPublic bool
  // Backend-specific configuration (e.g. volume_backend_name, RESKEY:availability_zones, encryption keys)
  extraSpecs map[string]string
  // Encryption provider class name (e.g. "luks", "nova.volume.encryptors.luks.LuksEncryptor"); empty when the type is unencrypted
  encryptionProvider() string
  // Encryption cipher (e.g. "aes-xts-plain64"); empty when the type is unencrypted
  encryptionCipher() string
  // Encryption key size in bits; 0 when the type is unencrypted
  encryptionKeySize() int
  // Where encryption is performed ("front-end" on the Nova compute host, or "back-end" on the storage system); empty when the type is unencrypted
  encryptionControlLocation() string
  // Encryption configuration ID (UUID); empty when the type is unencrypted
  encryptionId() string
  // QoS specification (IOPS/bandwidth throttling) associated with this volume type; null when none
  qosSpec() openstack.blockstorage.qosSpec
  // Volumes that use this volume type (filtered from the scoped project's volumes)
  volumes() []openstack.blockstorage.volume
}

// OpenStack Cinder volume backup
//
// Backup of a Cinder volume stored in object storage (for example
// Swift). Unlike snapshots, backups can be incremental and live
// independently of the source volume. Records the backup status, the
// source volume or snapshot, and whether other incrementals depend on
// it. Select a backup by id with
// `openstack.blockstorage.backup(id: "...")`.
private openstack.blockstorage.backup @defaults("id name status size createdAt") {
  init(id? string)
  // Backup ID (UUID)
  id string
  // Backup name
  name string
  // Description
  description string
  // Status (available, creating, deleting, error, error_deleting, restoring, ...)
  status string
  // Size in GB
  size int
  // Number of objects in the backup (Swift container objects when Swift is the backup driver)
  objectCount int
  // Container that stores the backup (Swift container name when Swift is the backup driver)
  container string
  // Whether other backups depend on this backup (true for full backups with dependent incrementals)
  hasDependentBackups bool
  // Whether this is an incremental backup
  isIncremental bool
  // Reason for the most recent backup failure; empty when no failure
  failReason string
  // Availability zone of the backup; empty when the backup driver does not report one
  availabilityZone string
  // Free-form backup metadata (requires Cinder microversion >= 3.43)
  metadata map[string]string
  // Owning project ID (admin-only attribute; empty for non-admin tokens)
  //
  // Deprecated in favor of project.
  projectId @maturity("deprecated") string
  // Timestamp when the data on the source volume was first saved (matches the source's data, not the backup's creation)
  dataTimestamp time
  // Backup creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Volume this backup was taken from
  volume() openstack.blockstorage.volume
  // Snapshot this backup was taken from; null when the backup was taken directly from a volume
  sourceSnapshot() openstack.blockstorage.snapshot
  // Project that owns this backup
  project() openstack.project
}

// OpenStack Glance image-sharing member. One entry per project the image has been shared with.
private openstack.image.member @defaults("memberId imageId status") {
  init(imageId? string, memberId? string)
  // Member ID (project UUID the image is shared with)
  memberId string
  // Image ID (image being shared)
  imageId string
  // Member status (pending, accepted, rejected)
  status string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Image being shared
  image() openstack.image
  // Project the image has been shared with
  project() openstack.project
}

// OpenStack Keystone application credential
//
// Long-lived authentication credential for service principals (often used by automation), scoped to a single project with a subset of the owning user's roles.
private openstack.applicationCredential @defaults("id name unrestricted expiresAt") {
  init(id? string)
  // Application credential ID (UUID)
  id string
  // Credential name (human-readable label, unique per owning user)
  name string
  // Description
  description string
  // Whether the credential can use restricted operations
  //
  // True when the credential is allowed to create other credentials or trusts. Unrestricted credentials are equivalent to long-lived tokens for the scoped roles and should be reviewed closely.
  unrestricted bool
  // Role names this credential is allowed to assume (subset of the owning user's roles)
  roleNames []string
  // API endpoint access rules
  //
  // Restrictions limiting which API calls the credential may make. Each entry
  // is a dict with `id` (the rule UUID), `service` (the service type, for
  // example `compute` or `image`), `method` (the HTTP method, for example
  // `GET` or `POST`), and `path` (the request path the rule permits). An empty
  // list means the credential can call every endpoint its granted roles allow.
  accessRules []dict
  // Expiration timestamp; null when the credential never expires
  expiresAt time
  // Owning user
  user() openstack.user
  // Project the credential is scoped to
  project() openstack.project
}

// OpenStack Keystone credential
//
// Stored authentication credential owned by a user and scoped to a project,
// most commonly an EC2-style access/secret key pair (`type` ec2) or an X.509
// certificate (`type` cert). Select a credential by its `id`. The secret
// material (the credential blob) is intentionally not exposed; query `type`,
// `user`, and `project` to audit who holds long-lived credentials.
private openstack.credential @defaults("id type") {
  init(id? string)
  // Credential ID (UUID)
  id string
  // Credential type
  //
  // Common values are `ec2` (an access/secret key pair) and `cert` (an X.509
  // certificate).
  type string
  // Owning user
  user() openstack.user
  // Project the credential is scoped to
  project() openstack.project
}

// OpenStack Keystone EC2-compatible credential
//
// EC2-style access credential owned by a user, used by EC2/S3-compatible API
// clients. Select a credential by its `access` key, for example
// `openstack.ec2Credential(access: "abc123...")`. The secret key is
// intentionally not exposed; query `access`, `user`, `project`, and `trust` to
// audit long-lived programmatic access.
private openstack.ec2Credential @defaults("access") {
  init(access? string)
  // Access key (UUID) identifying the credential
  access string
  // Owning user
  user() openstack.user
  // Project the credential is scoped to
  project() openstack.project
  // Trust scoping the credential; null when not trust-scoped
  trust() openstack.trust
}

// OpenStack Keystone trust
//
// Delegation of authorization from a trustor user to a trustee user,
// optionally limited to a subset of roles on a project, with optional
// impersonation and re-delegation. Select a trust by its `id`, for example
// `openstack.trust(id: "3d2c...")`. Trusts that allow impersonation or
// unlimited uses grant standing access on the trustor's behalf and should be
// reviewed closely.
private openstack.trust @defaults("id impersonation") {
  init(id? string)
  // Trust ID (UUID)
  id string
  // Whether the trustee may impersonate the trustor
  impersonation bool
  // Role names delegated by this trust
  roleNames []string
  // Whether the trustee may re-delegate the trust to another user
  allowRedelegation bool
  // Remaining number of times the trust can be used; 0 when unlimited
  remainingUses int
  // Expiration timestamp; null when the trust never expires
  expiresAt time
  // Trustee user (the principal granted authorization)
  trustee() openstack.user
  // Trustor user (the principal delegating authorization)
  trustor() openstack.user
  // Project the delegated roles apply to; null for an unscoped trust
  project() openstack.project
  // Trust this one was re-delegated from; null when not re-delegated
  redelegated() openstack.trust
}

// OpenStack Keystone service-catalog service
//
// Registered service in the Keystone catalog: the abstract service
// (such as `compute`, `identity`, or `network`) that endpoints attach to.
// Select a service by its `id`. Query `type` and `enabled` to inventory which
// services the deployment advertises.
private openstack.identity.service @defaults("id name type enabled") {
  init(id? string)
  // Service ID (UUID)
  id string
  // Service name
  name string
  // Service type
  //
  // The catalog type such as `identity`, `compute`, `network`, `image`, or
  // `object-store`.
  type string
  // Description
  description string
  // Whether the service is enabled
  enabled bool
}

// OpenStack Keystone service-catalog endpoint
//
// Single URL at which a service is reachable, for one interface type
// (public, internal, or admin) in one region. Select an endpoint by its `id`.
// Auditing which services expose `public` endpoints, and on which URLs, is the
// primary use.
private openstack.identity.endpoint @defaults("id interface url") {
  init(id? string)
  // Endpoint ID (UUID)
  id string
  // Interface type
  //
  // One of `public`, `internal`, or `admin`.
  interface string
  // Endpoint name
  name string
  // Endpoint URL
  url string
  // Whether the endpoint is enabled
  enabled bool
  // Description
  description string
  // Service this endpoint exposes
  service() openstack.identity.service
  // Region the endpoint is located in; null when the endpoint has no region or the region is not listed
  region() openstack.identity.region
}

// OpenStack Keystone region
//
// Logical grouping of service endpoints, optionally nested
// under a parent region. Select a region by its `id`. Query `parentRegion` to
// walk the region hierarchy.
private openstack.identity.region @defaults("id parentRegionId") {
  init(id? string)
  // Region ID
  id string
  // Description
  description string
  // ID of the parent region; empty for a top-level region
  parentRegionId string
  // Parent region; null for a top-level region
  parentRegion() openstack.identity.region
}

// OpenStack Nova host aggregate
//
// Admin-defined grouping of compute hosts, commonly used as a building block for availability zones or to expose pinned scheduling capabilities.
private openstack.compute.aggregate @defaults("id name availabilityZone hostCount") {
  init(id? int)
  // Aggregate ID (Nova-assigned integer)
  id int
  // Aggregate name
  name string
  // Availability zone this aggregate defines; empty when the aggregate is not zone-defining
  availabilityZone string
  // Hostnames of compute hosts in this aggregate
  hosts []string
  // Free-form aggregate metadata (e.g. `pinned=true`, `filter_tenant_id=...`)
  metadata map[string]string
  // Number of hosts in the aggregate (matches hosts.length)
  hostCount int
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Whether the aggregate has been soft-deleted
  deleted bool
}

// OpenStack Nova compute limits and usage for the scoped project
//
// Reports both the configured maximum (`max*`) and the current usage (`*Used`) for each tracked resource. Limits without a usage counter are admin-set caps only.
private openstack.compute.limits @defaults("maxTotalInstances totalInstancesUsed maxTotalCores totalCoresUsed maxTotalRAMSize totalRAMUsed") {
  // Project ID the limits report applies to
  //
  // Deprecated in favor of project.
  projectId @maturity("deprecated") string
  // Project the limits report applies to
  project() openstack.project
  // Maximum number of vCPU cores
  maxTotalCores int
  // vCPU cores currently in use
  totalCoresUsed int
  // Maximum number of running instances
  maxTotalInstances int
  // Running instances currently in use
  totalInstancesUsed int
  // Maximum total RAM in megabytes
  maxTotalRAMSize int
  // RAM currently allocated in megabytes
  totalRAMUsed int
  // Maximum number of SSH keypairs
  maxTotalKeypairs int
  // Maximum number of security groups
  maxSecurityGroups int
  // Security groups currently in use
  totalSecurityGroupsUsed int
  // Maximum number of security group rules per security group
  maxSecurityGroupRules int
  // Maximum number of floating IPs
  maxTotalFloatingIps int
  // Floating IPs currently in use
  totalFloatingIpsUsed int
  // Maximum number of server groups
  maxServerGroups int
  // Server groups currently in use
  totalServerGroupsUsed int
  // Maximum number of members per server group
  maxServerGroupMembers int
  // Maximum image metadata items per image
  maxImageMeta int
  // Maximum server metadata items per instance
  maxServerMeta int
  // Maximum number of personality files per instance (legacy)
  maxPersonality int
  // Maximum personality file content size in bytes (legacy)
  maxPersonalitySize int
}

// OpenStack Placement resource provider
//
// Source of consumable inventory in the Placement service, such as a compute
// node, a shared storage pool, or an accelerator device (GPU/FPGA). Select a
// provider by its `id` (UUID). The `inventories` and `traits` fields audit
// accelerator capacity, for example the `VGPU` and `PGPU` resource classes and
// `HW_GPU_*` traits, and how much of each class is already allocated. The
// `parent` and `root` fields traverse nested provider trees, such as a compute
// node with child GPU providers.
private openstack.placement.resourceProvider @defaults("id name generation") {
  init(id? string)
  // Resource provider ID (UUID)
  id string
  // Resource provider name (often the compute host name, or a device name for child providers)
  name string
  // Consistency-view generation marker (increments as the provider's inventory/allocations change)
  generation int
  // Capability traits advertised by this provider
  //
  // Standardized (`HW_GPU_*`, `HW_CPU_*`, `STORAGE_DISK_SSD`, ...) and operator-defined (`CUSTOM_*`) qualitative markers used by the scheduler to place workloads.
  traits() []string
  // Inventory lines, one per resource class
  //
  // Each entry has `resource_class` (for example `VCPU`, `MEMORY_MB`, `DISK_GB`, `VGPU`, `PGPU`, or a `CUSTOM_*` device class) plus `total`, `reserved`, `allocation_ratio`, `min_unit`, `max_unit`, `step_size`, and `used` (the amount of that class currently allocated against this provider).
  inventories() []dict
  // Placement aggregate UUIDs this provider belongs to
  aggregates() []string
  // Immediate parent provider in a nested tree; null for a top-level provider
  parent() openstack.placement.resourceProvider
  // Top-most provider in this provider's tree (itself for a top-level provider)
  root() openstack.placement.resourceProvider
}

// OpenStack Cinder block-storage quota for the scoped project (configured maximums; usage values are not exposed by the default API path).
private openstack.blockstorage.quotaSet @defaults("volumes snapshots gigabytes backups") {
  // Project ID the quota applies to
  //
  // Deprecated in favor of project.
  projectId @maturity("deprecated") string
  // Project the quota applies to
  project() openstack.project
  // Maximum number of volumes
  volumes int
  // Maximum number of snapshots
  snapshots int
  // Maximum total volume storage in gigabytes
  gigabytes int
  // Maximum size of a single volume in gigabytes (-1 when unlimited)
  perVolumeGigabytes int
  // Maximum number of backups
  backups int
  // Maximum total backup storage in gigabytes
  backupGigabytes int
  // Maximum number of volume groups (modern replacement for consistency groups); 0 when groups are unsupported on this cloud
  groups int
}

// OpenStack Neutron network-service quota
//
// Per-project ceilings the networking service enforces on Neutron
// objects: networks, subnets, ports, routers, floating IPs, security
// groups and their rules, subnet pools, RBAC policies, and trunks.
// These are the configured maximums; current usage is not exposed by
// the default API path. The quota applies to the scoped project,
// reachable through project.
private openstack.network.quotaSet @defaults("network subnet port floatingIp router") {
  // Project ID the quota applies to
  //
  // Deprecated in favor of project.
  projectId @maturity("deprecated") string
  // Project the quota applies to
  project() openstack.project
  // Maximum number of networks
  network int
  // Maximum number of subnets
  subnet int
  // Maximum number of ports
  port int
  // Maximum number of routers
  router int
  // Maximum number of floating IPs
  floatingIp int
  // Maximum number of security groups
  securityGroup int
  // Maximum number of security group rules
  securityGroupRule int
  // Maximum number of subnet pools
  subnetPool int
  // Maximum number of RBAC policies
  rbacPolicy int
  // Maximum number of trunks
  trunk int
}

// OpenStack Barbican access control list for a secret or container
//
// Per-operation grants that override the default project-scoped access to a
// Barbican secret or container. The `entries` dict is keyed by operation
// (typically "read") and lists the users allowed to perform it, so you can
// audit whether secret material has been shared beyond its owning project.
private openstack.keymanager.acl @defaults("entries") {
  // ACL entries keyed by operation (e.g. "read"); each entry contains `{users: [string], project_access: bool, created, updated}`
  entries dict
}

// OpenStack Manila shared file system
//
// Shared file system (an NFS or CIFS/SMB export) provisioned by Manila.
// Select a share by its `id`. Query `isPublic`, `shareProto`, and
// `accessRules` to audit who can reach the share, and `shareNetwork` to see
// which Neutron network it is attached to.
private openstack.sharedfilesystem.share @defaults("id name shareProto status size isPublic") {
  init(id? string)
  // Share ID (UUID)
  id string
  // Share name
  name string
  // Description
  description string
  // Build/availability status (for example `available`, `creating`, or `error`)
  status string
  // Share protocol
  //
  // One of `NFS`, `CIFS`, `CEPHFS`, `GLUSTERFS`, `HDFS`, or `MAPRFS`.
  shareProto string
  // Size of the share in gibibytes
  size int
  // Whether the share is visible to all projects
  isPublic bool
  // Share type ID
  shareType string
  // Share type name
  shareTypeName string
  // Availability zone the share lives in
  availabilityZone string
  // Backend host serving the share
  host string
  // Whether the share has replicas
  hasReplicas bool
  // Replication type; empty when replication is not configured
  replicationType string
  // Whether the backend supports creating snapshots of the share
  snapshotSupport bool
  // Snapshot ID the share was created from; empty when not created from a snapshot
  snapshotId string
  // Owning project ID
  //
  // Deprecated in favor of project.
  projectId @maturity("deprecated") string
  // User-defined metadata
  metadata map[string]string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Network the share is exported on
  shareNetwork() openstack.sharedfilesystem.shareNetwork
  // Project that owns the share
  project() openstack.project
  // Access rules granting clients access to the share
  accessRules() []openstack.sharedfilesystem.share.accessRule
}

// OpenStack Manila share access rule
//
// Single rule granting a client access to a share: the access type (IP,
// user, or certificate), the value it matches, and the level (read-only or
// read-write). The access key/secret is intentionally not exposed.
private openstack.sharedfilesystem.share.accessRule @defaults("id accessType accessTo accessLevel state") {
  // Access rule ID (UUID)
  id string
  // Access type
  //
  // One of `ip`, `user`, `cert`, or `cephx`.
  accessType string
  // Value the rule grants access to (for example a CIDR, user name, or common name)
  accessTo string
  // Access level
  //
  // Either `rw` (read-write) or `ro` (read-only).
  accessLevel string
  // Rule state (for example `active`, `new`, or `error`)
  state string
  // ID of the share this rule applies to
  shareId string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Share this rule applies to
  share() openstack.sharedfilesystem.share
}

// OpenStack Manila security service
//
// Active Directory, LDAP, or Kerberos configuration that share networks
// authenticate against. Select a service by its `id`. Stored credentials
// (the bind password) are intentionally not exposed; query `type`, `server`,
// `domain`, and `user` to audit directory integration.
private openstack.sharedfilesystem.securityService @defaults("id name type status") {
  init(id? string)
  // Security service ID (UUID)
  id string
  // Service name
  name string
  // Description
  description string
  // Security service type
  //
  // One of `active_directory`, `ldap`, or `kerberos`.
  type string
  // Status
  status string
  // Domain the service authenticates against
  domain string
  // DNS IP address used to resolve the directory server
  dnsIp string
  // Organizational unit (OU) within the directory
  ou string
  // Bind/service account user name
  user string
  // Directory server hostname or IP address
  server string
  // Owning project ID
  //
  // Deprecated in favor of project.
  projectId @maturity("deprecated") string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Project that owns the security service
  project() openstack.project
}

// OpenStack Manila share network
//
// Binding of Manila shares to a Neutron network and subnet, with the CIDR
// and segmentation used to reach the share servers. Select a share network
// by its `id`. Query `network` and `subnet` to trace shares back to their
// L2/L3 placement.
private openstack.sharedfilesystem.shareNetwork @defaults("id name networkType cidr") {
  init(id? string)
  // Share network ID (UUID)
  id string
  // Share network name
  name string
  // Description
  description string
  // Neutron network ID the share servers attach to
  neutronNetId string
  // Neutron subnet ID the share servers attach to
  neutronSubnetId string
  // Network type (for example `vlan`, `vxlan`, or `flat`)
  networkType string
  // Segmentation ID (VLAN/VXLAN tag); 0 when not segmented
  segmentationId int
  // CIDR of the share network
  cidr string
  // IP version (4 or 6)
  ipVersion int
  // Owning project ID
  //
  // Deprecated in favor of project.
  projectId @maturity("deprecated") string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Neutron network the share servers attach to
  network() openstack.network
  // Neutron subnet the share servers attach to
  subnet() openstack.subnet
  // Project that owns the share network
  project() openstack.project
}

// OpenStack Magnum cluster
//
// Container-orchestration cluster (typically Kubernetes) provisioned by Magnum
// from a cluster template. Select a cluster by its `id`, for example
// `openstack.containerinfra.cluster(id: "...")`. The `apiAddress` and
// `floatingIpEnabled` fields reveal whether the control plane is reachable
// externally, and `clusterTemplate` carries the security posture it was built
// from (TLS, registry, network).
private openstack.containerinfra.cluster @defaults("id name status nodeCount masterCount") {
  init(id? string)
  // Cluster ID (UUID)
  id string
  // Cluster name
  name string
  // Lifecycle status (for example `CREATE_COMPLETE` or `CREATE_FAILED`)
  status string
  // Human-readable reason for the current status
  statusReason string
  // Health status (for example `HEALTHY` or `UNHEALTHY`)
  healthStatus string
  // Container-orchestration engine version (for example the Kubernetes version)
  coeVersion string
  // API endpoint address of the cluster control plane
  apiAddress string
  // Number of master (control-plane) nodes
  masterCount int
  // Number of worker nodes
  nodeCount int
  // IP addresses of the master nodes
  masterAddresses []string
  // IP addresses of the worker nodes
  nodeAddresses []string
  // Per-node Docker volume size in gibibytes
  dockerVolumeSize int
  // Whether nodes are assigned floating (public) IPs
  floatingIpEnabled bool
  // Whether the master nodes sit behind a load balancer
  masterLbEnabled bool
  // etcd discovery URL used during cluster bootstrap
  discoveryUrl string
  // Labels (key/value tuning and feature flags) applied to the cluster
  labels map[string]string
  // Owning project ID
  //
  // Deprecated in favor of project.
  projectId @maturity("deprecated") string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Template the cluster was created from
  clusterTemplate() openstack.containerinfra.clusterTemplate
  // SSH key pair injected into the nodes
  keypair() openstack.compute.keypair
  // Flavor used for the worker nodes
  flavor() openstack.compute.flavor
  // Flavor used for the master nodes
  masterFlavor() openstack.compute.flavor
  // Fixed (private) network the cluster runs on; null when unset or when the API returned a name that does not resolve to a known network
  fixedNetwork() openstack.network
  // Fixed (private) subnet the cluster runs on; null when unset or when the API returned a name that does not resolve to a known subnet
  fixedSubnet() openstack.subnet
  // Project that owns the cluster
  project() openstack.project
  // User that created the cluster
  user() openstack.user
  // Heat stack backing the cluster; null when the API did not report a stack
  stack() openstack.orchestration.stack
}

// OpenStack Magnum cluster template
//
// Reusable blueprint that defines how Magnum builds clusters (orchestration
// engine, image, network, TLS, and registry settings). Select a template by
// its `id`, for example `openstack.containerinfra.clusterTemplate(id: "...")`.
// The `tlsDisabled`, `public`, and `floatingIpEnabled` fields are the key
// security toggles to audit.
private openstack.containerinfra.clusterTemplate @defaults("id name coe tlsDisabled public") {
  init(id? string)
  // Cluster template ID (UUID)
  id string
  // Template name
  name string
  // Container-orchestration engine
  //
  // One of `kubernetes`, `swarm`, `swarm-mode`, or `mesos`.
  coe string
  // Base OS distribution for cluster nodes (for example `fedora-coreos`)
  clusterDistro string
  // Node server type (`vm` or `bm` for bare metal)
  serverType string
  // Whether TLS is disabled for the cluster API
  //
  // True disables TLS on the control-plane API — clusters built from this
  // template expose an unauthenticated/unencrypted endpoint and should be
  // flagged.
  tlsDisabled bool
  // Whether the template is visible to all projects
  public bool
  // Whether the template is hidden from the default template list
  hidden bool
  // Whether a private container registry is enabled in the cluster
  registryEnabled bool
  // Insecure (non-TLS) registry the cluster is allowed to pull from; empty when unset
  insecureRegistry string
  // Whether nodes are assigned floating (public) IPs
  floatingIpEnabled bool
  // Whether the master nodes sit behind a load balancer
  masterLbEnabled bool
  // Container network driver (for example `flannel` or `calico`)
  networkDriver string
  // Container volume driver (for example `cinder`)
  volumeDriver string
  // Docker storage driver (for example `overlay2`)
  dockerStorageDriver string
  // Per-node Docker volume size in gibibytes
  dockerVolumeSize int
  // DNS nameserver configured for cluster nodes
  dnsNameserver string
  // API server port
  apiServerPort int
  // HTTP proxy configured for cluster nodes; empty when unset
  httpProxy string
  // HTTPS proxy configured for cluster nodes; empty when unset
  httpsProxy string
  // Hosts excluded from proxying; empty when unset
  noProxy string
  // Labels (key/value tuning and feature flags) applied to clusters
  labels map[string]string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Glance image used for cluster nodes
  image() openstack.image
  // External (public) network clusters attach to
  externalNetwork() openstack.network
  // Flavor used for worker nodes
  flavor() openstack.compute.flavor
  // Flavor used for master nodes
  masterFlavor() openstack.compute.flavor
  // SSH key pair injected into cluster nodes
  keypair() openstack.compute.keypair
  // Project that owns the template
  project() openstack.project
  // User that created the template
  user() openstack.user
}

// OpenStack Trove database instance
//
// Managed database instance provisioned by the Trove database service. Select
// an instance by its `id`, for example `openstack.db.instance(id: "...")`. The
// `addresses` and `hostname` fields show how the database is reachable, and
// `datastoreType`/`datastoreVersion` identify the engine and version so you can
// flag outdated database software. The `databases` and `users` fields enumerate
// the logical databases and accounts on the instance; user passwords are
// intentionally not exposed.
private openstack.db.instance @defaults("id name status datastoreType datastoreVersion") {
  init(id? string)
  // Instance ID (UUID)
  id string
  // Instance name
  name string
  // Build/lifecycle status (for example `ACTIVE`, `BUILD`, or `ERROR`)
  status string
  // DNS-resolvable hostname of the instance; empty when only IP addresses are assigned
  hostname string
  // Datastore type (the database engine, for example `mysql`, `postgresql`, or `mariadb`)
  datastoreType string
  // Datastore version (the engine version, for example `5.7`)
  datastoreVersion string
  // Size of the attached data volume in gibibytes
  volumeSize int
  // Creation timestamp
  created time
  // Network addresses assigned to the instance ([{type, address}]); `type` is for example `public` or `private`
  addresses []dict
  // Flavor (compute size) the instance runs on
  flavor() openstack.compute.flavor
  // Logical databases hosted on the instance ([{name, charset, collate}])
  databases() []dict
  // Database user accounts on the instance ([{name, databases: [string]}]); passwords are not included
  users() []dict
}

// OpenStack Ironic bare-metal node
//
// Physical machine managed by Ironic, the OpenStack bare-metal provisioning
// service. Select a node by its `id` (UUID). The `provisionState`,
// `maintenance`, `powerState`, and `fault` fields report whether the node is
// in service or has a hardware problem, `instance` links to the Nova instance
// (if any) that the node backs, and `owner` and `lessee` capture multi-tenant
// ownership.
private openstack.baremetal.node @defaults("id name provisionState powerState maintenance") {
  init(id? string)
  // Node ID (UUID)
  id string
  // Node name; empty when the node has no name
  name string
  // Current power state (for example `power on`, `power off`, or null when unknown)
  powerState string
  // Requested power state during a transition; empty when stable
  targetPowerState string
  // Current provisioning state (for example `active`, `available`, `manageable`, or `enroll`)
  provisionState string
  // Requested provisioning state during a transition; empty when stable
  targetProvisionState string
  // Whether the node is in maintenance mode (excluded from scheduling)
  maintenance bool
  // Reason the node was put into maintenance; empty when not in maintenance
  maintenanceReason string
  // Fault detected on the node (for example `power failure`); empty when healthy
  fault string
  // Last error recorded for the node; empty when none
  lastError string
  // Driver managing the node (for example `ipmi` or `redfish`)
  driver string
  // Scheduling resource class advertised to Nova
  resourceClass string
  // Conductor group the node belongs to
  conductorGroup string
  // Conductor currently responsible for the node
  conductor string
  // Whether the node is protected from undeploy/deletion
  protected bool
  // Reason the node is protected; empty when not protected
  protectedReason string
  // Free-form description of the node
  description string
  // Whether serial console access is enabled
  consoleEnabled bool
  // Boot interface driver (for example `pxe` or `ipxe`)
  bootInterface string
  // Deploy interface driver (for example `direct` or `iscsi`)
  deployInterface string
  // Network interface driver (for example `flat` or `neutron`)
  networkInterface string
  // Traits advertised by the node for scheduling
  traits []string
  // UUID of the Nova instance deployed on this node; empty when the node is not in use
  instanceUuid string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Nova instance deployed on this node; null when the node is not in use
  instance() openstack.compute.server
  // Network ports attached to the node
  ports() []openstack.baremetal.port
  // Project that owns the node; null when the node has no owner
  owner() openstack.project
  // Project the node is leased to; null when not leased
  lessee() openstack.project
}

// OpenStack Ironic bare-metal port
//
// Network port (NIC) on an Ironic bare-metal node, covering its MAC address,
// PXE setting, and physical-network binding. Select a port by its `id` (UUID).
// The `pxeEnabled` and `localLinkConnection` fields describe how the port boots
// and which switch port it connects to.
private openstack.baremetal.port @defaults("id address nodeUuid pxeEnabled") {
  // Port ID (UUID)
  id string
  // MAC address of the port
  address string
  // UUID of the node this port belongs to
  nodeUuid string
  // Whether PXE is enabled on this port
  pxeEnabled bool
  // Physical network the port is mapped to; empty when unset
  physicalNetwork string
  // Port group UUID this port is a member of; empty when standalone
  portgroupUuid string
  // Whether the port is on a smart NIC
  isSmartNic bool
  // Local link connection details (switch ID/port, e.g. `{switch_id, port_id, switch_info}`)
  localLinkConnection dict
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Node this port belongs to
  node() openstack.baremetal.node
}

// OpenStack Heat orchestration stack
//
// Set of OpenStack resources deployed and managed together from a Heat
// template (OpenStack's infrastructure-as-code). Select a stack by its `id`.
// The `status` field tracks deployment and drift state (for example
// `CREATE_COMPLETE`, `UPDATE_FAILED`, or `ROLLBACK_COMPLETE`), and
// `disableRollback` flags stacks that will not roll back on failure, leaving
// partially created resources behind.
private openstack.orchestration.stack @defaults("id name status") {
  init(id? string)
  // Stack ID (UUID)
  id string
  // Stack name
  name string
  // Description
  description string
  // Stack status (for example `CREATE_COMPLETE`, `UPDATE_FAILED`, or `ROLLBACK_COMPLETE`)
  status string
  // Human-readable reason for the current status
  statusReason string
  // Tags applied to the stack
  tags []string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Whether rollback on failure is disabled
  //
  // True leaves a failed stack in place instead of rolling back; failed
  // deployments then linger with partially created resources.
  disableRollback() bool
  // Stack timeout in minutes; 0 when no timeout is set
  timeoutMinutes() int
  // Input parameters the stack was deployed with
  parameters() map[string]string
}

// OpenStack Nova compute quota for the scoped project
//
// Configured per-project ceilings Nova enforces on compute consumption:
// instances, cores, ram, keyPairs, serverGroups, and the legacy
// nova-network limits. Comparing these caps against actual usage (see
// openstack.compute.limits) surfaces projects near capacity or with
// overly permissive quotas.
private openstack.compute.quotaSet @defaults("instances cores ram") {
  // Project ID the quota applies to
  //
  // Deprecated in favor of project.
  projectId @maturity("deprecated") string
  // Project the quota applies to
  project() openstack.project
  // Maximum number of instances
  instances int
  // Maximum number of instance cores (vCPUs)
  cores int
  // Maximum instance RAM in megabytes
  ram int
  // Maximum number of SSH keypairs
  keyPairs int
  // Maximum number of metadata items per instance
  metadataItems int
  // Maximum number of server groups
  serverGroups int
  // Maximum number of members per server group
  serverGroupMembers int
  // Maximum number of security groups (legacy nova-network)
  securityGroups int
  // Maximum number of security group rules (legacy nova-network)
  securityGroupRules int
  // Maximum number of fixed IPs (legacy nova-network)
  fixedIps int
  // Maximum number of floating IPs (legacy nova-network)
  floatingIps int
  // Maximum number of injected files
  injectedFiles int
  // Maximum bytes per injected file
  injectedFileContentBytes int
  // Maximum bytes for each injected file path
  injectedFilePathBytes int
}

// Neutron RBAC policy
//
// Role-based access control policy that governs cross-project sharing
// of a network or QoS policy. The `action` distinguishes
// `access_as_shared` (other projects may use the object) from
// `access_as_external` (the network may be used as an external
// gateway), `objectType` together with the `network` and `qosPolicy`
// accessors identifies the shared object, and `targetProjectId` names
// the project the share is granted to. The literal `*` means every
// project, a cloud-wide share worth flagging. Select a policy by id
// with `openstack.network.rbacPolicy(id: "...")`.
private openstack.network.rbacPolicy @defaults("id action objectType targetProjectId") {
  init(id? string)
  // RBAC policy ID (UUID)
  id string
  // Action (access_as_shared, access_as_external)
  action string
  // Type of the shared object (network, qos-policy)
  objectType string
  // ID of the shared object (a network ID or QoS policy ID, per objectType)
  objectId string
  // Project the share is granted to; the literal "*" means all projects (cloud-wide share)
  targetProjectId string
  // Shared network; null unless objectType is "network"
  network() openstack.network
  // Shared QoS policy; null unless objectType is "qos-policy"
  qosPolicy() openstack.qosPolicy
  // Project that owns the RBAC policy
  project() openstack.project
}

// Cinder QoS specification
//
// Quality-of-service specification for Cinder: the IOPS and
// bandwidth throttling limits a deployment can attach to volume types.
// `consumer` records where the limits are enforced (`front-end` on the
// Nova host, `back-end` on the storage system, or `both`), and `specs`
// holds the rate-limit key/value pairs. Volume types reference a QoS
// spec through the volumeType `qosSpec` field. Listing
// QoS specs is admin-only. Select a spec by id with
// `openstack.blockstorage.qosSpec(id: "...")`.
private openstack.blockstorage.qosSpec @defaults("id name consumer") {
  init(id? string)
  // QoS spec ID (UUID)
  id string
  // QoS spec name
  name string
  // Where the QoS limits are enforced (front-end, back-end, both)
  consumer string
  // Rate-limit key/value pairs (e.g. total_iops_sec, read_bytes_sec)
  specs map[string]string
}

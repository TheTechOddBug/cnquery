}

// OpenStack Cinder volume backup. Backups live in object storage (e.g. Swift) and can be incremental, unlike snapshots.
private openstack.blockstorage.backup @defaults("id name status size createdAt") {
  init(id? string)
  // Backup ID (UUID)
  id string
  // Backup name
  name string
  // Description
  description string
  // Status (available, creating, deleting, error, error_deleting, restoring, ...)
  status string
  // Size in GB
  size int
  // Number of objects in the backup (Swift container objects when Swift is the backup driver)
  objectCount int
  // Container that stores the backup (Swift container name when Swift is the backup driver)
  container string
  // Whether other backups depend on this backup (true for full backups with dependent incrementals)
  hasDependentBackups bool
  // Whether this is an incremental backup
  isIncremental bool
  // Reason for the most recent backup failure; empty when no failure
  failReason string
  // Availability zone of the backup; empty when the backup driver does not report one
  availabilityZone string
  // Free-form backup metadata (requires Cinder microversion >= 3.43)
  metadata map[string]string
  // Project that owns this backup (admin-only attribute; empty for non-admin tokens)
  projectId string
  // Timestamp when the data on the source volume was first saved (matches the source's data, not the backup's creation)
  dataTimestamp time
  // Backup creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Volume this backup was taken from
  volume() openstack.blockstorage.volume
  // Snapshot this backup was taken from; null when the backup was taken directly from a volume
  sourceSnapshot() openstack.blockstorage.snapshot
  // Project that owns this backup
  project() openstack.project
}

// OpenStack Glance image-sharing member. One entry per project the image has been shared with.
private openstack.image.member @defaults("memberId imageId status") {
  init(imageId? string, memberId? string)
  // Member ID (project UUID the image is shared with)
  memberId string
  // Image ID (image being shared)
  imageId string
  // Member status (pending, accepted, rejected)
  status string
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Image being shared
  image() openstack.image
  // Project the image has been shared with
  project() openstack.project
}

// OpenStack Keystone application credential
//
// Long-lived authentication credential for service principals (often used by automation), scoped to a single project with a subset of the owning user's roles.
private openstack.applicationCredential @defaults("id name unrestricted expiresAt") {
  init(id? string)
  // Application credential ID (UUID)
  id string
  // Credential name (human-readable label, unique per owning user)
  name string
  // Description
  description string
  // Whether the credential can use restricted operations
  //
  // True when the credential is allowed to create other credentials or trusts. Unrestricted credentials are equivalent to long-lived tokens for the scoped roles and should be reviewed closely.
  unrestricted bool
  // Owning user ID
  userId string
  // Project the credential is scoped to
  projectId string
  // Role names this credential is allowed to assume (subset of the owning user's roles)
  roleNames []string
  // Access rules ([{id, service, method, path}]) limiting which API endpoints this credential can call; empty means all endpoints the granted roles allow
  accessRules []dict
  // Expiration timestamp; null when the credential never expires
  expiresAt time
  // Owning user
  user() openstack.user
  // Project the credential is scoped to
  project() openstack.project
}

// OpenStack Nova host aggregate
//
// Admin-defined grouping of compute hosts, commonly used as a building block for availability zones or to expose pinned scheduling capabilities.
private openstack.compute.aggregate @defaults("id name availabilityZone hostCount") {
  init(id? int)
  // Aggregate ID (Nova-assigned integer)
  id int
  // Aggregate name
  name string
  // Availability zone this aggregate defines; empty when the aggregate is not zone-defining
  availabilityZone string
  // Hostnames of compute hosts in this aggregate
  hosts []string
  // Free-form aggregate metadata (e.g. `pinned=true`, `filter_tenant_id=...`)
  metadata map[string]string
  // Number of hosts in the aggregate (matches hosts.length)
  hostCount int
  // Creation timestamp
  createdAt time
  // Last update timestamp
  updatedAt time
  // Whether the aggregate has been soft-deleted
  deleted bool
}

// OpenStack Nova compute limits and usage for the scoped project
//
// Reports both the configured maximum (`max*`) and the current usage (`*Used`) for each tracked resource. Limits without a usage counter are admin-set caps only.
private openstack.compute.limits @defaults("maxTotalInstances totalInstancesUsed maxTotalCores totalCoresUsed maxTotalRAMSize totalRAMUsed") {
  // Project the limits report applies to
  projectId string
  // Maximum number of vCPU cores
  maxTotalCores int
  // vCPU cores currently in use
  totalCoresUsed int
  // Maximum number of running instances
  maxTotalInstances int
  // Running instances currently in use
  totalInstancesUsed int
  // Maximum total RAM in megabytes
  maxTotalRAMSize int
  // RAM currently allocated in megabytes
  totalRAMUsed int
  // Maximum number of SSH keypairs
  maxTotalKeypairs int
  // Maximum number of security groups
  maxSecurityGroups int
  // Security groups currently in use
  totalSecurityGroupsUsed int
  // Maximum number of security group rules per security group
  maxSecurityGroupRules int
  // Maximum number of floating IPs
  maxTotalFloatingIps int
  // Floating IPs currently in use
  totalFloatingIpsUsed int
  // Maximum number of server groups
  maxServerGroups int
  // Server groups currently in use
  totalServerGroupsUsed int
  // Maximum number of members per server group
  maxServerGroupMembers int
  // Maximum image metadata items per image
  maxImageMeta int
  // Maximum server metadata items per instance
  maxServerMeta int
  // Maximum number of personality files per instance (legacy)
  maxPersonality int
  // Maximum personality file content size in bytes (legacy)
  maxPersonalitySize int
}

// OpenStack Cinder block-storage quota for the scoped project (configured maximums; usage values are not exposed by the default API path).
private openstack.blockstorage.quotaSet @defaults("volumes snapshots gigabytes backups") {
  // Project the quota applies to
  projectId string
  // Maximum number of volumes
  volumes int
  // Maximum number of snapshots
  snapshots int
  // Maximum total volume storage in gigabytes
  gigabytes int
  // Maximum size of a single volume in gigabytes (-1 when unlimited)
  perVolumeGigabytes int
  // Maximum number of backups
  backups int
  // Maximum total backup storage in gigabytes
  backupGigabytes int
  // Maximum number of volume groups (modern replacement for consistency groups); 0 when groups are unsupported on this cloud
  groups int
}

// OpenStack Neutron network-service quota for the scoped project (configured maximums; usage values are not exposed by the default API path).
private openstack.network.quotaSet @defaults("network subnet port floatingIp router") {
  // Project the quota applies to
  projectId string
  // Maximum number of networks
  network int
  // Maximum number of subnets
  subnet int

option provider = "go.mondoo.com/mql/v13/providers/cloudflare"
option go_package = "go.mondoo.com/mql/v13/providers/cloudflare/resources"

// Cloudflare
//
// Use this resource to access Cloudflare zones, accounts, API tokens, and
// account-level services. Query `zones` to enumerate DNS zones, `accounts`
// for account-level configuration, and `apiTokens` for token inventory and
// policy audits.
cloudflare {
	// List all zones
	zones() []cloudflare.zone

	// List available accounts
	accounts() []cloudflare.account

	// API tokens visible to the calling user (user-scoped tokens)
	apiTokens() []cloudflare.apiToken
}

// Cloudflare DNS Zone
//
// Examine the configuration and security posture of a single Cloudflare DNS
// zone. A zone corresponds to a registered domain managed through Cloudflare.
// Query `settings` for TLS, WAF, and HSTS enforcement; `dns` for DNS records;
// `rulesets` and `wafRules` for firewall policy; `certificatePacks` and
// `customCertificates` for TLS certificates; `dnssec` for DNSSEC configuration;
// `botManagement` for bot-mitigation settings; `emailRouting` for SPF/DKIM/DMARC
// status; and `logpushJobs` for data-export configuration.
private cloudflare.zone @defaults("name account.name") {
	// Zone identifier
	id string
	// Zone name
	name string
	// Nameservers for this zone
	nameServers []string
	// Original name servers
	originalNameServers []string

	// The current status of the zone (initializing, pending, active, or moved)
  status string
  // Whether the zone is paused
  paused bool
  // DNS zone type (full or partial)
  type string

	// Time the zone was created
	createdOn time
	// Time the zone was last modified
	modifiedOn time

	// Zone owner account
  account cloudflare.zone.account
	// Zone owner
	owner cloudflare.zone.owner
	// Zone plan. Deprecated and will be removed in the next major release.
	plan @maturity("deprecated") cloudflare.zone.plan

	// Zone security settings
	settings() cloudflare.zone.settings
	// Custom SSL certificates (user-uploaded)
	customCertificates() []cloudflare.zone.customCertificate
	// Managed certificate packs (Cloudflare-issued)
	certificatePacks() []cloudflare.zone.certificatePack

	// DNS records associated with the zone
	dns() cloudflare.dns

	// Live inputs
	liveInputs() []cloudflare.streams.liveInput

	// Stream video assets uploaded or streamed through Cloudflare
	videos() []cloudflare.streams.video

	// Cloudflare R2 storage (account-scoped, exposed on zone for consistency)
	r2() cloudflare.r2

  // Cloudflare Workers configuration and deployments
	workers() cloudflare.workers

	// Cloudflare One (Zero Trust)
	one() cloudflare.one

	// Cloudflare tunnels (account-scoped, exposed on zone for consistency with workers/r2)
	tunnels() []cloudflare.tunnel
	// Tunnel routes (account-scoped)
	tunnelRoutes() []cloudflare.tunnel.route
	// Tunnel virtual networks (account-scoped)
	tunnelVirtualNetworks() []cloudflare.tunnel.virtualNetwork

	// Firewall rules (legacy)
	firewallRules() []cloudflare.zone.firewallRule
	// Managed and custom rulesets evaluated for this zone
	rulesets() []cloudflare.zone.ruleset
	// Page rules
	pageRules() []cloudflare.zone.pageRule
	// Load balancers
	loadBalancers() []cloudflare.zone.loadBalancer

	// Origin CA certificates
	originCACertificates() []cloudflare.zone.originCACertificate
	// mTLS certificates
	mtlsCertificates() []cloudflare.mtlsCertificate
	// Custom hostnames
	customHostnames() []cloudflare.zone.customHostname

	// Logpush jobs
	logpushJobs() []cloudflare.zone.logpushJob
	// Bot management settings
	botManagement() cloudflare.zone.botManagement

	// DNSSEC configuration for the zone
	dnssec() cloudflare.zone.dnssec
	// Rate-limit rules (legacy rate-limiting product)
	rateLimitRules() []cloudflare.zone.rateLimitRule
	// WAF rules (managed and custom rulesets, expanded into individual rules)
	wafRules() []cloudflare.zone.wafRule
	// Email routing configuration (SPF/DKIM/DMARC awareness)
	emailRouting() cloudflare.zone.emailRouting
}

// Cloudflare account
private cloudflare.zone.account @defaults("name") {
	// Account identifier
	id string
	// Account name
	name string
	// Account type. Deprecated and will be removed in the next major release.
	type @maturity("deprecated") string
	// Account email. Deprecated and will be removed in the next major release.
	email @maturity("deprecated") string
}

// Cloudflare zone owner
private cloudflare.zone.owner @defaults("name") {
	// Owner identifier
	id string
	// Owner email. Deprecated and will be removed in the next major release.
	email @maturity("deprecated") string
	// Owner name
	name string
	// Owner type
	ownerType string
}

// Cloudflare zone plan
//
// Examine the Cloudflare service plan attached to a zone. Will be
// removed in the next major release.
private cloudflare.zone.plan @defaults("name") @maturity("deprecated") {
	// Plan identifier
	id string
	// Plan name
	name string
	// Plan price
	price int
	// Plan currency
	currency string
	// Plan frequency
	frequency string
	// Whether the zone is subscribed to this plan
	isSubscribed bool
}

// Cloudflare zone security settings
private cloudflare.zone.settings {
	// SSL/TLS encryption mode (off, flexible, full, strict)
	ssl string
	// Whether HTTPS is always used (on, off)
	alwaysUseHttps string
	// Minimum TLS version (1.0, 1.1, 1.2, 1.3)
	minTlsVersion string
	// TLS 1.3 support (on, off, zrt)
	tls13 string
	// Automatic HTTPS rewrites (on, off)
	automaticHttpsRewrites string
	// Security level (essentially_off, low, medium, high, under_attack)
	securityLevel string
	// Web Application Firewall (on, off)
	waf string
	// Browser integrity check (on, off)
	browserCheck string
	// Opportunistic encryption (on, off)
	opportunisticEncryption string
	// Email obfuscation (on, off)
	emailObfuscation string
	// Hotlink protection (on, off)
	hotlinkProtection string
	// Server-side excludes (on, off)
	serverSideExcludes string
	// HTTP/3 (QUIC) support (on, off)
	http3 string
	// 0-RTT connection resumption (on, off)
	zeroRtt string
	// WebSocket connections support (on, off)
	websockets string
	// IP geolocation header — adds CF-IPCountry to origin requests (on, off)
	ipGeolocation string
	// True-Client-IP header sent to the origin (on, off; Enterprise only)
	trueClientIpHeader string
	// Challenge page TTL — how long a visitor's challenge clearance lasts, in seconds
	challengeTtl int

	// Whether HSTS (Strict-Transport-Security) is enabled for the zone
	hstsEnabled bool
	// HSTS max-age (in seconds)
	hstsMaxAge int
	// Whether HSTS applies to subdomains
	hstsIncludeSubdomains bool
	// Whether the domain is signaled as eligible for HSTS preload list inclusion
	hstsPreload bool
	// Whether the X-Content-Type-Options: nosniff header is sent alongside HSTS
	hstsNoSniff bool
}

// Cloudflare custom SSL certificate (user-uploaded)
private cloudflare.zone.customCertificate @defaults("id status") {
	// Certificate identifier
	id string
	// Hostnames covered by the certificate
	hosts []string
	// Certificate issuer
	issuer string
	// Signature type
	signature string
	// Certificate status
	status string
	// Certificate bundle method
	bundleMethod string
	// Time the certificate expires
	expiresAt time
	// Time the certificate was uploaded
	uploadedAt time
	// Time the certificate was last modified
	modifiedAt time
	// Certificate priority
	priority int
}

// Cloudflare managed certificate pack (Cloudflare-issued)
private cloudflare.zone.certificatePack @defaults("id status") {
	// Certificate pack identifier
	id string
	// Certificate pack type
	type string
	// Hostnames covered by the certificate pack
	hosts []string
	// Certificate pack status
	status string
	// Domain control validation method
	validationMethod string
	// Certificate validity in days
	validityDays int
	// Certificate authority used
	certificateAuthority string
}

// Cloudflare DNS namespace
//
// Use this resource to iterate over DNS records for a zone. Access it via
// `cloudflare.zone.dns` and query `records` to enumerate all DNS record types
// (A, AAAA, CNAME, MX, TXT, and others) with their content, TTL, and proxy status.
private cloudflare.dns {
	// List all DNS records
	records() []cloudflare.dns.record
}

// DNS record
private cloudflare.dns.record @defaults("type content name") {
	// Cloudflare internal ID
	id string

  // Record name
	name string
	// Free-form comment or description for the DNS record
	comment string
	// Tags for organizing and filtering DNS records
	tags []string
	// Whether the record is proxied (false indicated DNS only)
	proxied bool
	// Whether the record can be proxied
	proxiable bool

	// Type of record (e.g., A, AAAA, or CNAME)
	type string
	// Content of the record (e.g., hostname or IP Address)
	content string
	// Time to live (in seconds)
	ttl int

	// Record priority (used by MX, SRV, and URI records)
	priority int

	// Time the record was created
	createdOn time
	// Time the record was last modified
	modifiedOn time
}

// Cloudflare Account
//
// Examine a Cloudflare account and its sub-resources. Query `settings` for
// account-level preferences such as two-factor enforcement; `roles` for the
// set of named roles defined in the account; `liveInputs` and `videos` for
// Stream assets scoped to the account.
private cloudflare.account @defaults("name") {
	// Cloudflare account identifier
	id string

	// Account name
	name string

	// Account type
	type string

	// Account-level configuration and preferences
	settings cloudflare.account.settings

	// Time the account was created
	createdOn time

	// Live inputs
	liveInputs() []cloudflare.streams.liveInput

	// Stream video assets uploaded or streamed through Cloudflare
	videos() []cloudflare.streams.video

	// Account roles
	roles() []cloudflare.account.role

	// Members (users) of the account, with their assigned roles and 2FA status
	members() []cloudflare.account.member

	// Recent audit log entries for the account (most recent first; first page only)
	//
	// Returns the first page of account audit log entries. The Cloudflare API caps a page at 100 entries; for older history, narrow with a `.where(when > ...)` filter or paginate at the API level outside MQL. Use this to verify a change actor, spot unauthorized configuration changes, or feed an access review.
	auditLogs() []cloudflare.account.auditLog

	// Notification policies (alert subscriptions) configured for the account
	notificationPolicies() []cloudflare.notificationPolicy
}

// Cloudflare API Token
//
// Examine a user-scoped Cloudflare API token. Query `status` to verify the
// token is active (not disabled or expired), `expiresOn` and `notBefore` for
// validity windows, `ipIn` and `ipNotIn` for IP-allowlist/blocklist enforcement,
// and `policies` for the effect, resources, and permission groups the token grants.
private cloudflare.apiToken @defaults("name status expiresOn") {
	// Token identifier
	id string
	// Token name
	name string
	// Token status (active, disabled, expired)
	status string
	// Time the token was issued
	issuedOn time
	// Time the token was last modified
	modifiedOn time
	// Earliest time the token is valid
	notBefore time
	// Time the token expires
	expiresOn time
	// IP addresses allowed to use the token (CIDR list)
	ipIn []string
	// IP addresses blocked from using the token (CIDR list)
	ipNotIn []string
	// Token policies (each dict has effect, resources, and permission groups defining what the token can do)
	policies []dict
}

// Account settings
private cloudflare.account.settings {
	// Whether membership in this account requires that two-factor authentication is enabled
	enforceTwoFactor bool
}

// Cloudflare Stream namespace
//
// Use this resource to access Cloudflare Stream assets. Query `liveInputs`
// to enumerate live-streaming inputs and `videos` to enumerate uploaded or
// recorded video assets.
private cloudflare.streams {}

// Cloudflare live input (stream)
private cloudflare.streams.liveInput @defaults("uid name") {
	// mql resource ID
	id string

	// Unique identifier
	uid string

	// Input name
	name string

	// Number of days after which to delete the recording
	deleteRecordingAfterDays int
}

// Cloudflare videos and recordings
private cloudflare.streams.video @defaults("name id") {
	// mql resource ID
	id string

	// Unique identifier
	uid string

	// Display name of the video
	name string

	// Creator ID
	creator string

	// Video duration in seconds
	duration float

	// Height (px)
	height int

	// Width (px)
	width int

	// Live input ID
	liveInput string

	// Dash URL
	dash string

	// HLS URL
	hls string

	// Preview URL
	preview string

	// Whether the video is ready to stream
	ready bool

	// Whether the video can be a accessed using the UID
	requireSignedUrls bool

	// Date and time at which the video will be deleted (No value or a null value means that the video won't be deleted.)
	scheduledDeletion time

	// Size in Bytes
	size int

	// Thumbnail URL
	thumbnail string

	// Timestamp for a thumbnail image, as a percentage of the video's duration
	//
	// To convert from a second-wise timestamp to a percentage, divide the desired timestamp by the total duration of the video. If this value is not set, the default thumbnail image is taken from 0s of the video.
	thumbnailTimestampPct float

	// Time the video was uploaded
	uploaded time
}

// Cloudflare R2 namespace
//
// Use this resource to access Cloudflare R2 object-storage resources for an
// account. Query `buckets` to enumerate R2 buckets and inspect each bucket's
// `name`, `location`, `createdOn`, `publicAccessEnabled`, and `publicAccessDomain`.
private cloudflare.r2 @defaults("name location") {
	// R2 buckets in the account
	buckets() []cloudflare.r2.bucket
}

// Cloudflare R2 bucket
private cloudflare.r2.bucket {
 	// Bucket name
  name string
  // Bucket location
  location string
  // Time the bucket was created
  createdOn time
  // Whether public access via the managed r2.dev subdomain is enabled
  publicAccessEnabled() bool
  // Managed r2.dev domain assigned to the bucket (empty when public access is disabled)
  publicAccessDomain() string
}

// Cloudflare Workers namespace
//
// Use this resource to access Cloudflare Workers deployments and Pages projects.
// Query `workers` for script metadata (size, placement mode, LogPush status),
// `pages` for Pages deployment details (environment, URL, aliases), `secrets`
// for the inventory of secrets bound to worker scripts (metadata only — values
// are never exposed), and `pageEnvVars` for the inventory of environment variables
// across Pages project environments.
private cloudflare.workers {
	// List all workers
	workers() []cloudflare.workers.worker

	// List all pages
	pages() []cloudflare.workers.page

	// Inventory of secrets bound to all worker scripts (metadata only — values are not exposed)
	secrets() []cloudflare.workers.secret

	// Inventory of environment variables bound to Pages projects across preview and production environments (metadata only — values are not exposed)
	pageEnvVars() []cloudflare.pages.envVar
}

// Cloudflare worker
private cloudflare.workers.worker @defaults("id") {
	// Worker ID
  id string
  // Worker etag
  etag string
  // Worker size
  size int
  // Deployment for the worker
  deploymentId string
  // CI/CD pipeline for the worker
  pipelineHash string
  // Placement mode for the worker (e.g., smart)
  placementMode string

  // Worker was last deployed from
  lastDeployedFrom string
  // Whether LogPush is enabled for the worker
  logPush bool
  // Time the worker was created
  createdOn time
  // Time the worker was last modified
  modifiedOn time
}

// Cloudflare Pages page
private cloudflare.workers.page @defaults("shortId") {
	// Worker ID
	id string
	// Worker short ID
	shortId string
	// Pages project identifier
	projectId string
	// Pages project name
	projectName string
	// Deployment environment (preview or production)
	environment string
	// Public URL of the deployment
	url string

	// Custom domain aliases pointing at this deployment
	aliases []string

	// Branch from which production deployments are built
	productionBranch string

  // Time the worker was created
	createdOn time
  // Time the worker was last modified
	modifiedOn time
}

// Cloudflare One (Zero Trust) namespace
//
// Use this resource to audit Cloudflare Zero Trust configuration for an account.
// Query `apps` for Access application settings (allowed IdPs, session duration,
// cookie security); `identityProviders` for configured IdPs and SAML/SCIM settings;
// `accessPolicies` and `accessGroups` for reusable policy components; `serviceTokens`
// for machine-to-machine token inventory; `organization` for org-wide settings such
// as auth domain and WARP session duration; `gatewayRules` for DNS/HTTP/L4 traffic
// policies; `lists`, `locations`, and `dlpProfiles` for Gateway data sources;
// `devices` for enrolled device inventory; and `devicePostureRules` and
// `devicePostureIntegrations` for posture-check configuration.
private cloudflare.one {
	// Cloudflare Zero Trust applications
	apps() []cloudflare.one.app
	// Identity providers
	identityProviders() []cloudflare.one.idp
	// Access policies (reusable)
	accessPolicies() []cloudflare.one.accessPolicy
	// Access groups
	accessGroups() []cloudflare.one.accessGroup
	// Access service tokens
	serviceTokens() []cloudflare.one.serviceToken
	// Access organization configuration
	organization() cloudflare.one.organization
	// Gateway rules
	gatewayRules() []cloudflare.one.gatewayRule
	// Gateway lists
	lists() []cloudflare.one.list
	// Gateway locations
	locations() []cloudflare.one.location
	// DLP profiles
	dlpProfiles() []cloudflare.one.dlpProfile
	// Registered devices
	devices() []cloudflare.one.device
	// Device posture rules
	devicePostureRules() []cloudflare.one.devicePostureRule
	// Device posture integrations
	devicePostureIntegrations() []cloudflare.one.devicePostureIntegration
}

// Cloudflare One application
//
// Examine a single Cloudflare One (Access) application — the identity
// providers it accepts, its CORS and cookie hardening, its session and
// authentication policies, and the deny / launcher UX it presents to users.
private cloudflare.one.app @defaults("name id") {
	// UUID
	id string
	// Audience tag
	aud string

	// Name of the application
	name string
	// Domain of the application
	domain string

	// Allowed identity providers
	allowedIdentityProviders []string
	// Whether the application displays in the App Launcher
	appLauncherVisible bool
	// Whether users skip the identity provider selection step during login
	autoRedirectToIdentity bool

	// CORS headers
	corsHeaders cloudflare.corsHeaders
	// Whether preflight requests bypass Access authentication
	//
	// When true, preflight requests are allowed to go directly to the origin. Can't be true if corsHeaders is set.
	optionsPreflightBypass bool

	// Custom error message shown to a user when they are denied access to the application
	customDenyMessage string
	// Custom URL to redirect a user to when they are denied access to the application
	customDenyUrl string
	// Whether to return a 401 status code when the request is blocked by a Service Auth policy
	serviceAuth401Redirect bool

	// Whether to allow the binding cookie
	//
	// Increases security against compromised authorization tokens and CSRF attacks.
	enableBindingCookie bool
	// Whether the HttpOnly cookie attribute is enabled
	//
	// Increases security against XSS attacks.
	httpOnlyCookieAttribute bool
	// SameSite cookie setting
	//
	// Provides increased security against CSRF attacks.
	sameSiteCookieAttribute string

	// URL of the application's logo
	logoUrl string

	// Amount of time that tokens issued for this application will be valid
	//
	// Format is 300ms or 2h45m. Valid time units are: ns, us (or µs), ms, s, m, and h.
	sessionDuration string

	// Whether automatic authentication through cloudflared is enabled
	skipInterstitial bool

	// Application type
	type string

	// Time the application was created
	createdAt time
	// Time the application was last updated
	updatedAt time

	// Access policies governing the application
	policies() []cloudflare.one.accessPolicy
}

// CORS headers
private cloudflare.corsHeaders {
	allowAllHeaders bool
	allowAllMethods bool
	allowAllOrigins bool
	allowCredentials bool

	allowedHeaders []string
	allowedMethods []string
	allowedOrigins []string

	maxAge int // The maximum number of seconds the results of a preflight request can be cached.
}

// Cloudflare One identity provider
private cloudflare.one.idp @defaults("name") {
	id string // UUID
	name string // The name of the identity provider, shown to users on the login page.
	type string // The type of the identity provider.

	// Whether this IdP is SAML-based (SAML, Centrify, OneLogin, Ping, or Okta-via-the-generic-saml-type; OIDC and social IdPs are excluded)
	saml bool
	// SAML SSO target URL (only set for SAML IdPs)
	ssoTargetUrl string
	// SAML/OIDC issuer URL
	issuerUrl string
	// Whether SAML AuthnRequests are signed
	signRequest bool
	// PEM-encoded IdP signing certificate (SAML)
	idpPublicCert string
	// SAML attribute used as the user's email
	emailAttributeName string
	// Additional SAML attributes mapped from the IdP
	attributes []string
	// Whether SCIM provisioning is enabled for this IdP
	scimEnabled bool
}

// Cloudflare One access policy
private cloudflare.one.accessPolicy @defaults("name decision") {
	// Policy identifier
	id string
	// Policy name
	name string
	// The action Access will take if the policy matches (allow, deny, non_identity, bypass)
	decision string
	// The order in which the policy is executed
	precedence int
	// Time the policy was created
	createdAt time
	// Time the policy was last updated
	updatedAt time
	// Rules that grant access — the user must satisfy at least one (OR)
	//
	// Each dict is one condition keyed by its rule type (e.g. email, email_domain, ip, ip_list, group, everyone, certificate, gsuite, okta, saml, azureAD, github-organization, service_token, device_posture).
	include []dict
	// Rules that must all be satisfied (AND); same dict shape as include
	require []dict
	// Rules that deny access when satisfied (NOT); same dict shape as include
	exclude []dict
}

// Cloudflare One access group
private cloudflare.one.accessGroup @defaults("name") {
	// Group identifier
	id string
	// Group name
	name string
	// Time the group was created
	createdAt time
	// Time the group was last updated
	updatedAt time
}

// Cloudflare One access service token
private cloudflare.one.serviceToken @defaults("name id") {
	// Token identifier
	id string
	// Token name
	name string
	// OAuth 2.0 client ID
	clientId string
	// Token duration before expiration
	duration string
	// Time the token expires
	expiresAt time
	// Time the token was last seen
	lastSeenAt time
	// Time the token was created
	createdAt time
	// Time the token was last updated
	updatedAt time
}

// Cloudflare One organization configuration
private cloudflare.one.organization @defaults("name authDomain") {
	// Organization name
	name string
	// Auth domain for the organization (e.g., example.cloudflareaccess.com)
	authDomain string
	// Whether the UI is read-only
	isUiReadOnly bool
	// Inactivity time before user seat expires
	userSeatExpirationInactiveTime string
	// Whether users auto-redirect to identity provider
	autoRedirectToIdentity bool
	// Default session duration
	sessionDuration string
	// WARP auth session duration
	warpAuthSessionDuration string
	// Whether authentication via WARP is allowed
	allowAuthenticateViaWarp bool
	// Time the organization was created
	createdAt time
	// Time the organization was last updated
	updatedAt time
}

// Cloudflare One Gateway rule
private cloudflare.one.gatewayRule @defaults("name action") {
	// Rule identifier
	id string
	// Rule name
	name string
	// Rule description
	description string
	// Rule action (allow, block, isolate, log, etc.)
	action string
	// Whether the rule is enabled
	enabled bool
	// Rule precedence (lower numbers execute first)
	precedence int
	// Filter expression for network traffic
	traffic string
	// Filter expression for user identity
	identity string
	// Filter expression for device posture
	devicePosture string
	// Which filter types apply (dns, http, l4, egress, resolve)
	filters []string
	// Rule version
	version int
	// Time the rule was created
	createdAt time
	// Time the rule was last updated
	updatedAt time
}

// Cloudflare One Gateway list
private cloudflare.one.list @defaults("name type") {
	// List identifier
	id string
	// List name
	name string
	// List type (SERIAL, URL, DOMAIN, EMAIL, IP)
	type string
	// List description
	description string
	// Number of items in the list
	count int
	// Time the list was created
	createdAt time
	// Time the list was last updated
	updatedAt time
}

// Cloudflare One Gateway location
private cloudflare.one.location @defaults("name") {
	// Location identifier
	id string
	// Location name
	name string
	// DoH subdomain for this location
	dohSubdomain string
	// Assigned IPv4 address
	ip string
	// Whether anonymized logs are enabled
	anonymizedLogsEnabled bool
	// Whether this is the default client location
	clientDefault bool
	// Whether ECS (EDNS Client Subnet) is supported
	ecsSupport bool
	// Time the location was created
	createdAt time
	// Time the location was last updated
	updatedAt time
}

// Cloudflare One DLP profile
private cloudflare.one.dlpProfile @defaults("name type") {
	// Profile identifier
	id string
	// Profile name
	name string
	// Profile type (predefined, custom, integration)
	type string
	// Profile description
	description string
	// Number of matches allowed before triggering
	allowedMatchCount int
	// Whether OCR is enabled
	ocrEnabled bool
	// Time the profile was created
	createdAt time
	// Time the profile was last updated
	updatedAt time
}

// Cloudflare One device
private cloudflare.one.device @defaults("name id") {
	// Device identifier
	id string
	// Device name
	name string
	// Device type (desktop, mobile, etc.)
	deviceType string
	// Device model
	model string
	// Device manufacturer
	manufacturer string
	// Device serial number
	serialNumber string
	// Device MAC address
	macAddress string
	// Device IP address
	ip string
	// OS version
	osVersion string
	// OS distribution name
	osDistroName string
	// OS distribution revision
	osDistroRevision string
	// WARP client version
	version string
	// Whether the device has been deleted
	deleted bool
	// Time the device was created
	created time
	// Time the device was last updated
	updated time
	// Time the device was last seen
	lastSeen time
	// Time the device was revoked
	revokedAt time
}

// Cloudflare One device posture rule
private cloudflare.one.devicePostureRule @defaults("name type") {
	// Rule identifier
	id string
	// Rule name
	name string

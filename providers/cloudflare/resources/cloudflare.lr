	// Ruleset phase (e.g., http_request_firewall_managed, http_request_firewall_custom)
	rulesetPhase string
	// Action (block, challenge, managed_challenge, log, skip, etc.)
	action string
	// Filter expression
	expression string
	// Rule description
	description string
	// Rule reference tag
	ref string
	// Whether the rule is enabled
	enabled bool
	// Score threshold for the rule (managed rulesets)
	scoreThreshold int
	// Rule version
	version string
	// Time the rule was last updated

	// DNSKEY key type
	keyType string
	// DS digest type
	digestType string
	// DS digest algorithm
	digestAlgorithm string
	// DS digest hex value
	digest string
	// DS resource record (parent-zone-ready string)
	ds string
	// DNSKEY key tag
	keyTag int
	// DNSKEY public key
	publicKey string
	// Time the configuration was last modified
	modifiedOn time
}

// Cloudflare zone rate-limit rule (legacy rate-limiting product)
private cloudflare.zone.rateLimitRule @defaults("id action.mode threshold") {
	// Rule identifier
	id string
	// Rule description
	description string
	// Whether the rule is disabled
	disabled bool
	// Number of requests allowed within `period` before the action triggers
	threshold int
	// Window over which `threshold` is measured (seconds)
	period int
	// Action taken when the threshold is exceeded ({mode, timeout, response})
	action dict
	// Request URL pattern matched by this rule

// AWS Private Certificate Authority (ACM PCA)
aws.privateca {
  // List of private certificate authorities
  certificateAuthorities() []aws.privateca.certificateAuthority
}

// AWS Private Certificate Authority
private aws.privateca.certificateAuthority @defaults("arn status type") {
  // ARN of the certificate authority
  arn string
  // Region where the CA exists
  region string
  // Status: CREATING, PENDING_CERTIFICATE, ACTIVE, DELETED, DISABLED, EXPIRED, or FAILED
  status string
  // Type: ROOT or SUBORDINATE
  type string
  // Usage mode: GENERAL_PURPOSE or SHORT_LIVED_CERTIFICATE
  usageMode string
  // Serial number of the CA certificate
  serial string
  // Key algorithm used by the CA (e.g., RSA_2048, EC_prime256v1)
  keyAlgorithm string
  // Signing algorithm used by the CA
  signingAlgorithm string
  // Subject information for the CA
  subject dict
  // Revocation configuration for the CA (CRL and OCSP settings)
  revocationConfiguration dict
  // Key storage security standard (e.g., FIPS_140_2_LEVEL_3_OR_HIGHER)
  keyStorageSecurityStandard string
  // Owner account ID
  ownerAccount string
  // Date before which the CA certificate is not valid
  notBefore time
  // Date after which the CA certificate is not valid
  notAfter time
  // Date the CA was created
  createdAt time
  // Date of the last state change
  lastStateChangeAt time
  // Failure reason if the CA is in a failed state
  failureReason string
  // Tags for the certificate authority
  tags() map[string]string
  // PEM-encoded CA certificate
  certificate() string
  // PEM-encoded CA certificate chain
  certificateChain() string
  // Resource-based policy for the CA (JSON string, empty if none)
  policy() string
}


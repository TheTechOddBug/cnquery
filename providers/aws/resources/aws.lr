  // Deprecated in favor of `fargateSubnets()`.
  subnets() @maturity("deprecated") []string
  // Subnets associated with the Fargate profile
  fargateSubnets() []aws.vpc.subnet
  // Status of the Fargate profile: CREATING, ACTIVE, DELETING, CREATE_FAILED, DELETE_FAILED
  status() string
  // Region where the cluster exists
  region string
  // Tags associated with the Fargate profile
  tags() map[string]string
  // When the Fargate profile was created
  createdAt() time
}

// AWS EKS pod identity association
private aws.eks.podIdentityAssociation @defaults("associationId namespace serviceAccount") {
  // ARN of the association
  associationArn string
  // Unique ID of the association
  associationId string
  // Name of the EKS cluster

  // Date the application version was last updated
  updatedAt time
  // ARN of the AWS CodeBuild build artifact reference, if the version was built by CodeBuild
  buildArn string
  // Amazon S3 bucket holding the source bundle for the application version
  sourceBundleS3Bucket string
  // Amazon S3 key for the source bundle of the application version
  sourceBundleS3Key string
  // Location of the source code, formatted per the source repository
  sourceLocation string
  // Source repository where the application version's source code is stored: CodeCommit or S3
  sourceRepository string
  // Type of source repository: Git or Zip

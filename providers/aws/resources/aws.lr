  startTime time
}

// AWS SageMaker endpoint data capture configuration
private aws.sagemaker.endpoint.dataCaptureConfig @defaults("enableCapture captureStatus") {
  // Whether data capture is enabled
  enableCapture bool
  // Status of data capture: Started or Stopped
  captureStatus string
  // Current sampling percentage
  currentSamplingPercentage int
  // S3 destination URI for captured data
  destinationS3Uri string
  // Capture modes: Input, Output
  captureOptions []string
  // KMS key used to encrypt captured data
  kmsKey() aws.kms.key
}

// AWS SageMaker model
private aws.sagemaker.model @defaults("arn name") {
  // ARN for the model
  arn string
  // Name of the model
  name string
  // Region where the model exists
  region string
  // Time when the model was created
  createdAt time
  // Tags for the model
  tags() map[string]string
  // Whether network isolation is enabled for the model

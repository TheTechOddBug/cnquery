  clusterCreatedAt time
  // Region where the snapshot exists
  region string
}

// Amazon Cognito
//
// Use the Cognito namespace to enumerate user-facing identity stores in
// the account. Iterate `userPools()` for user-pool directories (with their
// password policy, MFA configuration, app clients, identity providers,
// hosted UI domain, and Lambda triggers), and `identityPools()` for
// federated identity pools (with their authentication providers, role
// mappings, and unauthenticated-identity policy).
aws.cognito @defaults("userPools") {
  // List of Cognito user pools
  userPools() []aws.cognito.userPool
  // List of Cognito identity pools (federated identities)
  identityPools() []aws.cognito.identityPool
}

// Amazon Cognito user pool
private aws.cognito.userPool @defaults("arn name") {
  // ARN of the user pool
  arn string
  // User pool ID
  id string
  // Name of the user pool
  name string
  // Region of the user pool
  region string
  // Status: Enabled or Disabled
  status string
  // Whether deletion protection is enabled
  deletionProtection() bool
  // MFA configuration: OFF, ON, OPTIONAL
  mfaConfiguration() string
  // Password policy
  passwordPolicy() dict
  // Advanced security mode: OFF, AUDIT, ENFORCED
  advancedSecurityMode() string
  // User pool tags
  tags() map[string]string
  // App clients registered with the user pool
  clients() []aws.cognito.userPoolClient
  // Hosted UI domain for the user pool, or null if no domain is configured
  domain() aws.cognito.userPoolDomain
  // Federated identity providers configured on the user pool
  identityProviders() []aws.cognito.userPoolIdentityProvider
  // User pool feature plan: LITE, ESSENTIALS, or PLUS
  //
  // Determines eligibility for managed login, access-token customization,
  // and threat protection. Defaults to ESSENTIALS on new user pools.
  userPoolTier() string
  // Account-recovery configuration
  //
  // Lists the password-recovery delivery mechanisms (email, phone) and the
  // priority order Cognito applies when a user calls ForgotPassword. Keys
  // include RecoveryMechanisms (a list of {Name, Priority} entries).
  accountRecoverySetting() dict
  // Device-remembering configuration
  //
  // A null value means device remembering is deactivated. When set, exposes
  // ChallengeRequiredOnNewDevice and DeviceOnlyRememberedOnUserPrompt.
  deviceConfiguration() dict
  // Username case-sensitivity configuration
  //
  // Exposes CaseSensitive: when false, users can sign in with any
  // capitalization variation of their username or email alias.
  usernameConfiguration() dict
  // Attribute schema of the user pool
  //
  // Each entry describes a standard or custom attribute (custom: prefix).
  // Common keys: Name, AttributeDataType (String, Number, DateTime, Boolean),
  // Mutable, Required, StringAttributeConstraints, NumberAttributeConstraints.
  schema() []dict
  // Verification message template
  //
  // Templates Cognito uses when sending an account-confirmation code or link
  // to a user's email or phone. Keys include DefaultEmailOption
  // (CONFIRM_WITH_LINK or CONFIRM_WITH_CODE), EmailMessage, EmailSubject,
  // EmailMessageByLink, EmailSubjectByLink, SmsMessage.
  verificationMessageTemplate() dict
  // Email-delivery configuration
  //
  // Exposes EmailSendingAccount (COGNITO_DEFAULT or DEVELOPER), From,
  // ReplyToEmailAddress, SourceArn (an SES-verified address or domain),
  // and ConfigurationSet.
  emailConfiguration() dict
  // SMS-delivery configuration
  //
  // Exposes SnsCallerArn (the IAM role Cognito assumes to publish to SNS),
  // ExternalId, and SnsRegion. Null when the user pool isn't configured
  // to send SMS messages.
  smsConfiguration() dict
  // Lambda triggers configured on the user pool
  //
  // Map of trigger point to Lambda function ARN. Possible keys include
  // PreSignUp, PostConfirmation, PreAuthentication, PostAuthentication,
  // CustomMessage, DefineAuthChallenge, CreateAuthChallenge,
  // VerifyAuthChallengeResponse, PreTokenGeneration, UserMigration,
  // CustomEmailSender, CustomSMSSender, KMSKeyID.
  lambdaConfig() dict
  // Threat-protection risk configuration at the user-pool level
  //
  // Returned by DescribeRiskConfiguration. Keys include
  // CompromisedCredentialsRiskConfiguration (EventFilter, Actions with
  // EventAction of BLOCK or NO_ACTION), AccountTakeoverRiskConfiguration
  // (LowAction, MediumAction, HighAction, each with Notify and EventAction
  // of BLOCK, MFA_IF_CONFIGURED, MFA_REQUIRED, or NO_ACTION), and
  // RiskExceptionConfiguration (BlockedIPRangeList, SkippedIPRangeList).
  riskConfiguration() dict
  // Date the user pool was created
  createdAt time
  // Date the user pool was last modified
  updatedAt time
}

// Cognito user pool app client
private aws.cognito.userPoolClient @defaults("clientId clientName userPoolId") {
  // Client ID
  clientId string
  // Friendly name of the app client
  clientName string
  // User pool ID this client belongs to
  userPoolId string
  // Region of the user pool
  region string
  // User pool that owns the client
  userPool() aws.cognito.userPool
  // Whether the app client has a generated client secret
  generateSecret bool
  // Refresh token validity (numeric value, see tokenValidityUnits for the unit)
  refreshTokenValidity int
  // Access token validity (numeric value, see tokenValidityUnits for the unit)
  accessTokenValidity int
  // ID token validity (numeric value, see tokenValidityUnits for the unit)
  idTokenValidity int
  // Time units applied to the *Validity numeric fields, keyed by token type
  //
  // Keys: accessToken, idToken, refreshToken. Values are seconds, minutes, hours, or days.
  tokenValidityUnits dict
  // Permitted sign-in flows, e.g. ALLOW_USER_PASSWORD_AUTH, ALLOW_USER_SRP_AUTH
  explicitAuthFlows []string
  // Identity providers the client can use, e.g. COGNITO, Google, SAML provider names
  supportedIdentityProviders []string
  // Allowed callback URLs after the hosted UI sign-in
  callbackURLs []string
  // Allowed sign-out URLs after hosted UI sign-out
  logoutURLs []string
  // Default redirect URI used when more than one is configured
  defaultRedirectURI string
  // Permitted OAuth grant flows: code, implicit, client_credentials
  allowedOAuthFlows []string
  // Permitted OAuth scopes: phone, email, openid, profile, aws.cognito.signin.user.admin
  allowedOAuthScopes []string
  // Whether OAuth via the hosted UI is enabled for the client
  allowedOAuthFlowsUserPoolClient bool
  // Behavior on unknown user errors during sign-in: LEGACY or ENABLED
  preventUserExistenceErrors string
  // Whether refresh-token revocation is enabled
  enableTokenRevocation bool
  // Authentication session validity in minutes
  authSessionValidity int
  // Date the client was created
  createdAt time
  // Date the client was last modified
  updatedAt time
}

// Hosted UI domain for a Cognito user pool
private aws.cognito.userPoolDomain @defaults("domain userPoolId status") {
  // Domain name (the prefix-style or custom hostname users sign in at)
  domain string
  // User pool ID the domain serves
  userPoolId string
  // Region of the user pool
  region string
  // User pool that owns the domain
  userPool() aws.cognito.userPool
  // Status of the domain provisioning: CREATING, DELETING, UPDATING, ACTIVE, FAILED
  status string
  // CloudFront distribution backing the domain
  cloudFrontDistribution string
  // S3 bucket holding the hosted UI assets
  s3Bucket string
  // Configuration for a custom domain (ACM cert ARN), or null for prefix-style domains
  customDomainConfig dict

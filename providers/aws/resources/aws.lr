  // List of Step Functions activities
  activities() []aws.sfn.activity
}

// AWS Step Functions state machine
private aws.sfn.stateMachine @defaults("arn name type status") {
  // ARN of the state machine
  arn string
  // Name of the state machine
  name string
  // Region where the state machine exists
  region string
  // Type of the state machine: STANDARD or EXPRESS
  type string
  // Status of the state machine: ACTIVE or DELETING
  status() string
  // Description of the state machine
  description() string
  // Revision identifier for the latest published version of the state machine configuration
  revisionId() string
  // Label that identifies a Map state when the ARN is a qualified state machine ARN
  label() string
  // Amazon States Language definition of the state machine
  definition() string
  // IAM role used by the state machine
  iamRole() aws.iam.role
  // CloudWatch Logs log level: ALL, ERROR, FATAL, or OFF
  loggingLevel() string
  // Whether execution data is included in CloudWatch Logs entries
  loggingIncludeExecutionData() bool
  // CloudWatch Logs log groups that receive execution history events
  loggingDestinations() []aws.cloudwatch.loggroup
  // Raw logging configuration dict
  //
  // Deprecated in favor of `loggingLevel`, `loggingIncludeExecutionData`,
  // and `loggingDestinations`.
  loggingConfiguration() @maturity("deprecated") dict
  // Whether X-Ray tracing is enabled
  tracingEnabled() bool
  // Encryption type: AWS_OWNED_KEY or CUSTOMER_MANAGED_KMS_KEY
  encryptionType() string
  // Customer-managed KMS key identifier (alias, alias ARN, key ID, or key ARN) used to encrypt the state machine, empty when AWS-owned
  encryptionKmsKeyId() string
  // Customer-managed KMS key used to encrypt the state machine, null when AWS-owned
  kmsKey() aws.kms.key
  // Maximum duration in seconds that Step Functions reuses data keys before calling GenerateDataKey
  encryptionKmsDataKeyReusePeriodSeconds() int
  // Raw encryption configuration dict
  //
  // Deprecated in favor of `encryptionType`, `encryptionKmsKeyId`,
  // `kmsKey`, and `encryptionKmsDataKeyReusePeriodSeconds`.
  encryptionConfiguration() @maturity("deprecated") dict
  // Date the state machine was created

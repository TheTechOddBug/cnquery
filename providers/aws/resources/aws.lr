  // Name of the scheduling policy
  name string
  // Region of the scheduling policy
  region string
  // Whether a fair-share policy is configured
  hasFairSharePolicy bool
  // Seconds over which fair-share usage decays
  shareDecaySeconds int
  // Percentage of resources reserved for new share identifiers
  computeReservation int
  // Per-identifier share distribution (shareIdentifier, weightFactor)
  shareDistribution []dict
  // Tags for the scheduling policy
  tags map[string]string
}


  // Deprecated in favor of `foundationModel()`.
  foundationModelArn @maturity("deprecated") string
  // Number of model units provisioned
  modelUnits int
  // Status: Creating, InService, Updating, or Failed
  status string
  // Commitment duration: ONE_MONTH, SIX_MONTHS, or NO_COMMITMENT
  commitmentDuration string
}

// Amazon Bedrock Agent
//
// A Bedrock Agent is a generative-AI assistant configured with a
// foundation model, a natural-language instruction prompt, an IAM
// service role, and optional collaborators. Agents can call action
// groups (Lambda-backed tools) and consult knowledge bases for
// retrieval-augmented generation. Each row exposes the orchestration
// foundation model, the long-form instruction prompt, the session
// idle-timeout, the customer-managed encryption key, and lazy-loaded
// `actionGroups()` and `knowledgeBases()` lists.
private aws.bedrock.agent @defaults("name status foundationModel") {
  // Unique identifier of the agent
  id string
  // ARN of the agent
  arn() string
  // Name of the agent
  name string
  // Region where the agent exists
  region string
  // Status of the agent
  //
  // One of CREATING, PREPARING, PREPARED, NOT_PREPARED, FAILED, UPDATING, DELETING, or VERSIONING.
  status string
  // Description of the agent
  description() string
  // Foundation model used for agent orchestration
  foundationModel() string
  // Instruction prompt that tells the agent what to do and how to interact
  instruction() string
  // Idle session time-to-live in seconds
  idleSessionTtl() int
  // IAM service role granting the agent permission to invoke API operations
  iamRole() aws.iam.role
  // ARN of the IAM service role associated with the agent
  agentResourceRoleArn() string
  // Customer-managed KMS key used to encrypt the agent
  customerEncryptionKey() aws.kms.key
  // Time the agent was created
  createdAt() time
  // Time the agent was last updated
  updatedAt() time
  // Action groups attached to the agent's DRAFT version
  actionGroups() []dict
  // Knowledge bases associated with the agent's DRAFT version
  knowledgeBases() []dict
  // Aliases pointing at prepared versions of the agent
  aliases() []aws.bedrock.agent.alias
}

// Amazon Bedrock Agent alias
//
// An agent alias points at one or more prepared versions of a Bedrock
// Agent and is the stable target that applications invoke. Examine the
// alias status and its routing configuration to see which agent versions
// receive traffic. The `name` field selects an alias within its agent.
private aws.bedrock.agent.alias @defaults("name status") {
  // Unique identifier of the alias
  id string
  // Identifier of the agent that owns the alias
  agentId string
  // Name of the alias
  name string
  // Region where the alias exists
  region string
  // Status of the alias
  //
  // One of CREATING, PREPARED, FAILED, UPDATING, DELETING, or DISSOCIATED.
  status string
  // Description of the alias
  description string
  // Invocation state of the alias (whether it accepts invocations)
  invocationState string
  // Routing configuration mapping the alias to agent versions
  routingConfiguration []dict
  // Time the alias was created
  createdAt time
  // Time the alias was last updated
  updatedAt time
}

// Amazon Bedrock knowledge base
//
// A Bedrock knowledge base ingests source documents from configured
// data sources into a vector store and serves them to agents and
// retrieve-and-generate flows. Each row exposes the IAM role used for
// ingestion and retrieval, the vector-store backing configuration
// (OpenSearch Serverless, Pinecone, RDS, Redis Enterprise Cloud, or
// MongoDB Atlas), the embedding-model configuration, and lazy-loaded
// `dataSources()`.
private aws.bedrock.knowledgeBase @defaults("name status") {
  // Unique identifier of the knowledge base
  id string
  // ARN of the knowledge base
  arn() string
  // Name of the knowledge base
  name string
  // Region where the knowledge base exists
  region string
  // Status of the knowledge base
  //
  // One of CREATING, ACTIVE, DELETING, UPDATING, FAILED, DELETE_UNSUCCESSFUL, or DELETE_INACCESSIBLE_SOURCE.
  status string
  // Description of the knowledge base
  description() string
  // IAM service role granting permission to invoke API operations on the knowledge base
  iamRole() aws.iam.role
  // ARN of the IAM service role associated with the knowledge base
  roleArn() string
  // Storage configuration for the knowledge base's vector store
  //
  // Carries a `type` discriminator (OPENSEARCH_SERVERLESS, OPENSEARCH_MANAGED_CLUSTER, PINECONE, RDS, REDIS_ENTERPRISE_CLOUD, MONGO_DB_ATLAS, NEPTUNE_ANALYTICS, or S3_VECTORS) and the backend-specific configuration block.
  storageConfiguration() dict
  // Knowledge-base configuration including the type and embedding-model settings
  //
  // Carries a `type` discriminator (VECTOR, KENDRA, or SQL) and the backend-specific configuration including the embedding-model ARN for vector knowledge bases.
  knowledgeBaseConfiguration() dict
  // Time the knowledge base was created
  createdAt() time
  // Time the knowledge base was last updated
  updatedAt() time
  // Data sources connected to the knowledge base
  dataSources() []dict
}

// Amazon Bedrock flow
//
// A Bedrock flow is an authored generative-AI workflow that connects
// prompts, agents, knowledge bases, Lambda functions, conditions, and
// other nodes into a directed graph. Each row exposes the execution
// IAM role, the customer-managed encryption key, the flow version, and
// flow status.
private aws.bedrock.flow @defaults("name status version") {
  // Unique identifier of the flow
  id string
  // ARN of the flow
  arn string
  // Name of the flow
  name string
  // Region where the flow exists
  region string
  // Status of the flow
  //
  // One of Failed, Prepared, Preparing, or NotPrepared.
  status string
  // Version of the flow for which information was retrieved
  version() string
  // Description of the flow
  description() string
  // IAM service role granting the flow permission to invoke other Bedrock and AWS services
  iamRole() aws.iam.role
  // ARN of the IAM service role associated with the flow
  executionRoleArn() string
  // Customer-managed KMS key used to encrypt the flow
  customerEncryptionKey() aws.kms.key
  // Time the flow was created
  createdAt time
  // Time the flow was last updated
  updatedAt time
}

// Amazon Bedrock model-evaluation job
//
// A model-evaluation job benchmarks one or more foundation models or
// knowledge-base configurations against a dataset, either automatically
// or with human reviewers. Each row exposes the job type, model
// identifiers under evaluation, the IAM service role, and the
// customer-managed encryption key.
private aws.bedrock.evaluationJob @defaults("jobName status jobType") {
  // ARN of the evaluation job
  jobArn string
  // Name of the evaluation job
  jobName string
  // Region where the evaluation job exists
  region string
  // Status of the evaluation job
  //
  // One of InProgress, Completed, Failed, Stopping, Stopped, or Deleting.
  status string
  // Job type
  //
  // One of Automated or Human.
  jobType string
  // ARNs of the models or knowledge bases under evaluation
  modelIdentifiers []string
  // Application type
  //
  // One of ModelEvaluation or RagEvaluation.
  applicationType string
  // IAM service role used by the evaluation job
  iamRole() aws.iam.role
  // ARN of the IAM service role used by the evaluation job
  roleArn() string
  // Customer-managed KMS key used to encrypt the evaluation job
  customerEncryptionKey() aws.kms.key
  // Time the evaluation job was created
  createdAt time
  // Description of the evaluation job
  jobDescription() string
}

// Amazon Bedrock model-import job
//
// A model-import job imports a custom foundation model from an Amazon
// S3 bucket or other supported source so it can be used in Bedrock.
// Each row exposes the resulting imported-model ARN, the input data
// source, the IAM service role, and the customer-managed encryption
// key applied to the imported model.
private aws.bedrock.modelImportJob @defaults("jobName status") {
  // ARN of the model-import job
  jobArn string
  // Name of the model-import job
  jobName string
  // Region where the model-import job exists
  region string
  // Status of the import job
  //
  // One of InProgress, Completed, or Failed.
  status string
  // ARN of the imported model produced by the job
  importedModelArn string
  // Data source for the imported model (S3 location and other source-specific details)
  modelDataSource() dict
  // IAM service role used by the model-import job
  iamRole() aws.iam.role
  // ARN of the IAM service role used by the model-import job
  roleArn() string
  // Customer-managed KMS key used to encrypt the imported model
  customerEncryptionKey() aws.kms.key
  // Time the import job was created
  createdAt time
  // Time the import job was last modified
  lastModifiedTime time
  // Time the import job ended
  endTime time
}

// Amazon Bedrock batch inference job
//
// A batch inference job runs model invocations against records staged
// in Amazon S3 and writes outputs back to S3. Each row exposes the
// foundation model used, the IAM service role, the S3 input and output
// configurations, and the job timeout.
private aws.bedrock.batchInferenceJob @defaults("jobName modelId status") {
  // ARN of the batch inference job
  jobArn string
  // Name of the batch inference job
  jobName string
  // Region where the batch inference job exists
  region string
  // Identifier of the foundation model used for inference
  modelId string
  // Status of the batch inference job
  //
  // One of Submitted, InProgress, Completed, Failed, Stopping, Stopped, PartiallyCompleted, Expired, Validating, or Scheduled.
  status string
  // Input data configuration (S3 location and input format)
  inputDataConfig dict
  // Output data configuration (S3 location and optional encryption key)
  outputDataConfig dict
  // IAM service role used by the batch inference job
  iamRole() aws.iam.role
  // ARN of the IAM service role used by the batch inference job
  //
  // Deprecated in favor of `iamRole`.
  roleArn @maturity("deprecated") string
  // Time the batch inference job was submitted
  submitTime time
  // Time the batch inference job was last modified
  lastModifiedTime time
  // Time the batch inference job ended
  endTime time
  // Failure message when the job failed
  message string
  // Number of hours after which the batch inference job times out
  timeoutDurationInHours int
}

// Amazon Q Business
//
// Use the Q Business namespace to enumerate the generative-AI assistant
// applications in the account. Iterate `applications()` for every Q
// Business application across enabled regions; from each application
// reach its indices, data sources, retrievers, plugins, and web
// experiences to audit what corporate content is ingested and which
// external systems the assistant can reach.
aws.qBusiness {
  // Q Business applications in the account
  applications() []aws.qBusiness.application
}

// Amazon Q Business application
//
// A Q Business application is a generative-AI assistant configured with
// an identity provider, an IAM service role, and an optional
// customer-managed encryption key. Examine the identity type and service
// role that govern access, then iterate `indices()`, `dataSources()`,
// `retrievers()`, `plugins()`, and `webExperiences()` to audit what the
// assistant ingests and which external systems it can reach. The `id`
// field selects an application.
private aws.qBusiness.application @defaults("name status identityType") {
  // Unique identifier of the application
  id string
  // ARN of the application
  arn() string
  // Display name of the application
  name string
  // Region where the application exists
  region string
  // Current status of the application
  status string
  // Identity provider type controlling end-user access
  //
  // One of AWS_IAM_IDP_SAML, AWS_IAM_IDP_OIDC, AWS_IAM_IDC, AWS_QUICKSIGHT_IDP, or ANONYMOUS.
  identityType string
  // Time the application was created
  createdAt time
  // Time the application was last updated
  updatedAt time
  // Description of the application
  description() string
  // IAM service role the application assumes
  iamRole() aws.iam.role
  // ARN of the IAM service role associated with the application
  roleArn() string
  // Customer-managed KMS key used to encrypt application data
  kmsKey() aws.kms.key
  // Indices that store the application's ingested content
  indices() []aws.qBusiness.index
  // Data sources that feed content into the application's indices
  dataSources() []aws.qBusiness.dataSource
  // Retrievers that fetch content for the application at query time
  retrievers() []aws.qBusiness.retriever
  // Plugins that let the application act against external systems
  plugins() []aws.qBusiness.plugin
  // Web experiences that serve the application to end users
  webExperiences() []aws.qBusiness.webExperience
}

// Amazon Q Business index
//
// An index stores the content ingested from an application's data sources
// so the assistant can retrieve it. Examine the index status to see
// whether it is active and ready to serve queries. The `id` field selects
// an index.
private aws.qBusiness.index @defaults("name status") {
  // Unique identifier of the index
  id string
  // Identifier of the application that owns the index
  applicationId string
  // Display name of the index
  name string
  // Region where the index exists
  region string
  // Current status of the index
  status string
  // Time the index was created
  createdAt time
  // Time the index was last updated
  updatedAt time
}

// Amazon Q Business data source
//
// A data source connects an application's index to an external content
// repository (Amazon S3, SharePoint, Confluence, and others) and ingests
// its documents. Examine the source type, the IAM role used to read the
// source, and the sync schedule to audit what content is being ingested
// and how. The `id` field selects a data source.
private aws.qBusiness.dataSource @defaults("name type status") {
  // Unique identifier of the data source
  id string
  // Identifier of the application that owns the data source
  applicationId string
  // Identifier of the index the data source feeds
  indexId string
  // Display name of the data source
  name string
  // Type of the data source repository (for example S3, SHAREPOINT, or CONFLUENCE)
  type string
  // Region where the data source exists
  region string
  // Current status of the data source
  status string
  // Time the data source was created
  createdAt time
  // Time the data source was last updated
  updatedAt time
  // IAM role the data source assumes to read the external repository
  iamRole() aws.iam.role
  // ARN of the IAM role associated with the data source
  roleArn() string
  // Sync schedule for the data source as a cron expression (empty when on-demand)
  syncSchedule() string
}

// Amazon Q Business retriever
//
// A retriever fetches relevant content for an application at query time,
// backed either by a native Q Business index or an Amazon Kendra index.
// Examine the retriever type and the IAM role it assumes. The `id` field
// selects a retriever.
private aws.qBusiness.retriever @defaults("name type status") {
  // Unique identifier of the retriever
  id string
  // Identifier of the application that owns the retriever
  applicationId string
  // Display name of the retriever
  name string
  // Region where the retriever exists
  region string
  // Type of the retriever
  //
  // One of NATIVE_INDEX or KENDRA_INDEX.
  type string
  // Current status of the retriever
  status string
  // IAM role the retriever assumes
  iamRole() aws.iam.role
  // ARN of the IAM role associated with the retriever
  roleArn() string
}

// Amazon Q Business plugin
//
// A plugin lets the assistant take actions against an external system
// (ServiceNow, Salesforce, Jira, a custom endpoint, and others). Examine
// the plugin type and the server URL it targets to audit the external
// reach the assistant has been granted. The `id` field selects a plugin.
private aws.qBusiness.plugin @defaults("name type state") {
  // Unique identifier of the plugin
  id string
  // Identifier of the application that owns the plugin
  applicationId string
  // Display name of the plugin
  name string
  // Region where the plugin exists
  region string
  // Type of the plugin
  //
  // For example SERVICE_NOW, SALESFORCE, JIRA, ZENDESK, QUICKSIGHT, or CUSTOM.
  type string
  // URL of the external server the plugin targets
  serverUrl string
  // Activation state of the plugin
  //
  // One of ENABLED or DISABLED.
  state string
  // Build status of the plugin
  buildStatus string
  // Time the plugin was created
  createdAt time
  // Time the plugin was last updated
  updatedAt time
}

// Amazon Q Business web experience
//
// A web experience is the end-user-facing chat interface for an
// application. Examine the default endpoint that serves the experience
// and its current status. The `id` field selects a web experience.
private aws.qBusiness.webExperience @defaults("id status") {
  // Unique identifier of the web experience
  id string
  // Identifier of the application that owns the web experience
  applicationId string
  // Region where the web experience exists
  region string
  // Default endpoint URL serving the web experience
  defaultEndpoint string
  // Current status of the web experience
  status string
  // Time the web experience was created
  createdAt time
  // Time the web experience was last updated
  updatedAt time
}

// Amazon Bedrock inference profile
//
// An inference profile routes model-invocation requests across one or
// more regions for a foundation model, enabling cross-region inference
// and serving as a governance and cost-tracking boundary. Examine the
// profile type and the model ARNs it routes to. The `id` field selects an
// inference profile.
private aws.bedrock.inferenceProfile @defaults("name status type") {
  // ARN of the inference profile
  arn string
  // Identifier of the inference profile
  id string
  // Name of the inference profile
  name string
  // Region where the inference profile exists
  region string
  // Status of the inference profile
  status string
  // Type of the inference profile
  //
  // One of SYSTEM_DEFINED or APPLICATION.
  type string
  // Description of the inference profile
  description string
  // ARNs of the foundation models the profile routes requests to
  modelArns []string
  // Foundation models the profile routes requests to
  models() []aws.bedrock.foundationModel
  // Time the inference profile was created
  createdAt time
  // Time the inference profile was last updated
  updatedAt time
}

// Amazon Bedrock imported model
//
// A custom model imported into Bedrock from external weights. Examine the
// model architecture, whether it supports instruction following, and the
// customer-managed key used to encrypt it. The `arn` field selects an
// imported model.
private aws.bedrock.importedModel @defaults("name modelArchitecture") {
  // ARN of the imported model
  arn string
  // Name of the imported model
  name string
  // Region where the imported model exists
  region string
  // Architecture of the imported model
  modelArchitecture string
  // Whether the model supports instruction following
  instructSupported bool
  // Time the model was imported
  createdAt time
  // Customer-managed KMS key used to encrypt the model
  kmsKey() aws.kms.key
}

// Amazon Bedrock prompt
//
// A managed prompt stored in Bedrock prompt management, versioned and
// reusable across agents and flows. Examine the prompt version and
// description. The `id` field selects a prompt.
private aws.bedrock.prompt @defaults("name version") {
  // ARN of the prompt
  arn string
  // Identifier of the prompt
  id string
  // Name of the prompt
  name string
  // Region where the prompt exists
  region string
  // Version of the prompt
  version string
  // Description of the prompt
  description string
  // Time the prompt was created
  createdAt time
  // Time the prompt was last updated
  updatedAt time
}

// AWS Step Functions
//
// Use the Step Functions namespace to enumerate state machines in the
// account. Iterate `stateMachines()` for every state machine across
// enabled regions — each row surfaces the type (STANDARD or EXPRESS),
// the Amazon States Language definition, the IAM execution role,
// logging and X-Ray tracing configuration, and creation time. The
// related `aws.sfn` namespace exposes the same service with an extra
// `activities()` accessor.
aws.stepfunctions @defaults("stateMachines") {
  // List of state machines across all regions
  stateMachines() []aws.stepfunctions.stateMachine
}

// AWS Step Functions state machine
private aws.stepfunctions.stateMachine @defaults("arn name") {
  // ARN of the state machine
  arn string
  // Name of the state machine
  name string
  // Region where the state machine exists
  region string
  // Type: STANDARD or EXPRESS
  type string
  // Status: ACTIVE or DELETING
  status() string
  // State machine definition in Amazon States Language (JSON)
  definition() string
  // IAM role used by the state machine
  iamRole() aws.iam.role
  // When the state machine was created
  createdAt() time
  // Logging configuration
  loggingConfiguration() aws.stepfunctions.stateMachine.loggingConfiguration
  // Whether X-Ray tracing is enabled
  tracingEnabled() bool
  // Tags for the state machine
  tags() map[string]string
}

// AWS Step Functions state machine logging configuration
private aws.stepfunctions.stateMachine.loggingConfiguration @defaults("level") {
  // Log level: ALL, ERROR, FATAL, or OFF
  level string
  // Whether execution data is included in log events
  includeExecutionData bool
  // CloudWatch Logs log group destinations
  destinations []dict
}

// AWS Firewall Manager
//
// Examine the organization-wide Firewall Manager configuration that
// centrally enforces WAF, Shield Advanced, security group, Network
// Firewall, DNS Firewall, and third-party firewall policies across member
// accounts. Read `defaultAdminAccount` and `adminAccounts()` to see who
// administers Firewall Manager, `policies()` for the policies in effect
// (including per-account compliance status), `notificationChannel` for the
// SNS topic that receives activity events, and `appsLists()`,
// `protocolsLists()`, and `resourceSets()` for the reusable building
// blocks referenced by policies. Firewall Manager administration runs
// against `us-east-1`; this namespace surfaces data only when the scanned
// account is the organization's Firewall Manager administrator.
aws.fms @defaults("defaultAdminAccount") {
  // ID of the account configured as the Firewall Manager default administrator
  defaultAdminAccount() string
  // Onboarding/role status of the default administrator (READY, CREATING, PENDING_DELETION, DELETING, or UNKNOWN if access is denied)
  defaultAdminRoleStatus() string
  // List of Firewall Manager administrator accounts in the organization
  adminAccounts() []aws.fms.adminAccount
  // List of Firewall Manager policies
  policies() []aws.fms.policy
  // SNS notification channel that receives Firewall Manager activity events
  notificationChannel() aws.fms.notificationChannel
  // List of applications lists used by content audit security group policies
  appsLists() []aws.fms.appsList
  // List of protocols lists used by network ACL or content audit security group policies
  protocolsLists() []aws.fms.protocolsList
  // List of resource sets that group resources for policy application
  resourceSets() []aws.fms.resourceSet
}

// AWS Firewall Manager administrator account
private aws.fms.adminAccount @defaults("accountId defaultAdmin status") {
  // ID of the administrator account
  accountId string
  // Whether this is the default Firewall Manager administrator
  //
  // The default administrator can manage third-party firewalls and has full administrative scope; there is only one per organization.
  defaultAdmin bool
  // Onboarding status: ONBOARDING, ONBOARDING_COMPLETE, OFFBOARDING, or OFFBOARDING_COMPLETE
  status string
}

// AWS Firewall Manager policy
private aws.fms.policy @defaults("name resourceType securityServiceType") {
  // ARN of the policy
  arn string
  // ID of the policy
  id string
  // Name of the policy
  name string
  // Description of the policy
  description string
  // Status of the policy in the administrator's scope: ACTIVE or OUT_OF_ADMIN_SCOPE
  status string
  // Whether Firewall Manager applies the policy to new resources automatically
  remediationEnabled bool
  // Whether Firewall Manager removes managed protections from resources that leave policy scope and cleans up managed resources when accounts leave scope
  deleteUnusedFMManagedResources bool
  // Type of resource the policy protects
  //
  // For example: AWS::EC2::SecurityGroup, AWS::ElasticLoadBalancingV2::LoadBalancer, AWS::EC2::VPC. Set to ResourceTypeList when the policy applies to multiple types.
  resourceType string
  // List of resource types when the policy applies to more than one
  resourceTypeList []string
  // Tags that define the policy's resource scope, keyed by tag name with the tag value as the value
  resourceTags map[string]string
  // Whether resources with the specified `resourceTags` are excluded from the policy scope (true) or are the only resources in scope (false)
  excludeResourceTags bool
  // Logical operator (AND or OR) used to combine `resourceTags`
  resourceTagLogicalOperator string
  // Security service backing the policy
  //
  // One of: WAF, WAFV2, SHIELD_ADVANCED, SECURITY_GROUPS_COMMON, SECURITY_GROUPS_CONTENT_AUDIT, SECURITY_GROUPS_USAGE_AUDIT, NETWORK_FIREWALL, DNS_FIREWALL, IMPORT_NETWORK_FIREWALL, NETWORK_ACL_COMMON, or THIRD_PARTY_FIREWALL.
  securityServiceType string
  // Service-specific managed configuration (parsed from the SDK's ManagedServiceData JSON string)
  securityServiceManagedServiceData dict
  // Accounts and organizational units the policy applies to, keyed by ACCOUNT or ORG_UNIT
  includeMap map[string][]string
  // Accounts and organizational units the policy excludes, keyed by ACCOUNT or ORG_UNIT
  excludeMap map[string][]string
  // IDs of resource sets referenced by the policy
  resourceSetIds []string
  // Resource sets referenced by the policy
  resourceSets() []aws.fms.resourceSet
  // Per-member-account compliance evaluations
  //
  // Each entry has `memberAccount`, `status`, `violatorCount`, `evaluationLimitExceeded`, `issueInfoMap`, and `lastUpdated`.
  complianceStatuses() []dict
}

// AWS Firewall Manager notification channel
private aws.fms.notificationChannel @defaults("snsTopicArn snsRoleName") {
  // ARN of the SNS topic that records Firewall Manager activity
  snsTopicArn string
  // Name of the IAM role that grants Firewall Manager permission to publish to the SNS topic
  snsRoleName string
  // SNS topic that records Firewall Manager activity
  snsTopic() aws.sns.topic
}

// AWS Firewall Manager applications list
private aws.fms.appsList @defaults("name id") {
  // ARN of the applications list
  arn string
  // ID of the applications list
  id string
  // Name of the applications list
  name string
  // Applications in the list, each with `appName`, `protocol`, and `port`
  apps []dict
}

// AWS Firewall Manager protocols list
private aws.fms.protocolsList @defaults("name id") {
  // ARN of the protocols list
  arn string
  // ID of the protocols list
  id string
  // Name of the protocols list
  name string
  // Protocol names included in the list (tcp, udp, icmp, or numeric IP protocol numbers)
  protocols []string
}

// AWS Firewall Manager resource set
private aws.fms.resourceSet @defaults("name id status") {
  init(id? string)
  // ARN of the resource set
  arn string
  // ID of the resource set
  id string
  // Name of the resource set
  name string
  // Description of the resource set
  description string
  // Resource types contained in the set
  resourceTypeList []string
  // Status in the administrator's scope: ACTIVE or OUT_OF_ADMIN_SCOPE
  status string
  // Time the resource set was last modified
  lastUpdateTime time
}

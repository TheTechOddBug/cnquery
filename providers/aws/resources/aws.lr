  // Content filtering policy configuration
  contentPolicy() dict
  // Sensitive information policy (PII detection)
  sensitiveInformationPolicy() dict
  // Topic policy configuration (denied topics)
  topicPolicy() dict
  // Word policy configuration (blocked words)
  wordPolicy() dict
}

// Amazon Bedrock model invocation logging configuration
private aws.bedrock.modelInvocationLoggingConfiguration @defaults("region textDataDeliveryEnabled imageDataDeliveryEnabled") {

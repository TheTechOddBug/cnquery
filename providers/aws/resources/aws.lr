  // Name of the Glue security configuration applied to the job
  securityConfiguration string
  // Glue security configuration applied to the job
  glueSecurityConfiguration() aws.glue.securityConfiguration
  // Execution class of the job: FLEX or STANDARD
  executionClass string
  // Date and time the job was created
  createdAt time
  // Date and time the job was last modified
  updatedAt time
  // Region where the job exists
  region string
  // Tags for the job
  tags() map[string]string
}


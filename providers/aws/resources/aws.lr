  // Output modalities supported
  outputModalities []string
  // Customizations supported (e.g., FINE_TUNING, CONTINUED_PRE_TRAINING)
  customizationsSupported []string
  // Inference types supported (e.g., ON_DEMAND, PROVISIONED)

  // Description of the environment
  description string
  // Environment ID
  environmentId string
  // Platform ARN
  platformArn string
  // Solution stack name
  solutionStackName string
  // Status: Launching, Updating, Ready, Terminating, Terminated, Aborting, LinkingFrom, LinkingTo
  status string
  // Health: Green, Yellow, Red, Grey
  health string
  // Health status: Ok, Info, Warning, Degraded, Severe, Suspended, Pending, Unknown, NoData
  healthStatus string
  // CNAME of the environment
  cname string
  // Endpoint URL
  endpointUrl string
  // Environment tier (Worker or WebServer)
  tier dict
  // Name of the environment tier: WebServer or Worker
  tierName string
  // Type of the environment tier: Standard (web server) or SQS/HTTP (worker)
  tierType string
  // Name of the configuration template originally used to launch the environment
  templateName string
  // ARN of the environment's operations role
  operationsRoleArn string
  // IAM operations role assumed by Elastic Beanstalk when managing the environment

  issuerUrl() string
  // Client ID for the OIDC provider
  clientId() string
  // Prefix prepended to username claims
  usernamePrefix() string
  // Username claim in the OIDC token
  usernameClaim() string
  // Prefix prepended to group claims
  groupsPrefix() string
  // Groups claim in the OIDC token
  groupsClaim() string
  // Required claims that must be present in the OIDC token
  requiredClaims() map[string]string
  // Tags for the identity provider configuration
  tags() map[string]string
}

// Amazon EKS cluster insight (upgrade readiness, best practices)

  mode string
  // Maximum jitter window in minutes (1-15 when mode is FLEXIBLE; 0 when OFF)
  maximumWindowInMinutes int
}

// Schedule target invocation configuration
private aws.eventbridge.schedule.target @defaults("targetType arn") {
  // Raw target ARN
  arn string
  // IAM role assumed when invoking the target
  //
  // Deprecated in favor of `iamRole`.
  roleArn @maturity("deprecated") string
  // IAM role assumed when invoking the target
  iamRole() aws.iam.role
  // Target.Input payload sent to the target. WARNING: may contain sensitive data — audit carefully for credentials, tokens, or PII.
  input string
  // Target type discriminator: lambda, sqs, sns, stepFunction, kinesis, firehose, ecs, eventBridge, sagemakerPipeline, codebuild, universal, unknown
  targetType string
  // ECS task invocation parameters (null unless targetType == ecs)
  ecsParameters() aws.eventbridge.schedule.target.ecsParameters
  // EventBridge event-bus invocation parameters (null unless targetType == eventBridge)
  eventBridgeParameters() aws.eventbridge.schedule.target.eventBridgeParameters
  // Kinesis stream invocation parameters (null unless targetType == kinesis)
  kinesisParameters() aws.eventbridge.schedule.target.kinesisParameters
  // SageMaker pipeline invocation parameters (null unless targetType == sagemakerPipeline)
  sagemakerParameters() aws.eventbridge.schedule.target.sagemakerParameters
  // SQS queue invocation parameters (null unless targetType == sqs and a message-group is configured)
  sqsParameters() aws.eventbridge.schedule.target.sqsParameters
  // Universal target — populated only when arn matches arn:aws:scheduler:::aws-sdk:<service>:<action>
  universalTarget() aws.eventbridge.schedule.target.universalTarget
}

// ECS RunTask invocation parameters
private aws.eventbridge.schedule.target.ecsParameters @defaults("launchType taskCount") {
  // ARN of the task definition referenced
  taskDefinitionArn string
  // Task definition resource
  taskDefinition() aws.ecs.taskDefinition
  // Number of tasks to start
  taskCount int
  // Launch type: EC2, FARGATE, EXTERNAL
  launchType string
  // Whether ECS Exec is enabled. Audit signal: allows shell access into running tasks.
  enableExecuteCommand bool
  // Whether ECS-managed tags are enabled
  enableEcsManagedTags bool
  // Task group identifier
  group string
  // Fargate platform version (e.g. LATEST or 1.4.0)
  platformVersion string
  // Tag propagation: TASK_DEFINITION
  propagateTags string
  // Reference ID for tracking
  referenceId string
  // Subnet IDs the task ENI is placed in
  //
  // Deprecated in favor of `subnets`.
  subnetIds @maturity("deprecated") []string
  // Subnets the task ENI is placed in
  subnets() []aws.vpc.subnet
  // Security group IDs attached to the task ENI
  //
  // Deprecated in favor of `securityGroups`.
  securityGroupIds @maturity("deprecated") []string
  // Security groups attached to the task ENI
  securityGroups() []aws.ec2.securitygroup
  // Whether the task ENI is assigned a public IP: ENABLED or DISABLED. Audit signal.
  assignPublicIp string
  // Capacity provider strategy entries
  capacityProviderStrategy []dict
  // Placement constraint expressions
  placementConstraints []dict
  // Placement strategy entries
  placementStrategy []dict
  // Tags applied to launched tasks

  kinesisStream() aws.eventbridge.pipe.sourceParameters.kinesisStream
  // DynamoDB stream source parameters (null unless type == dynamodbStream)
  dynamodbStream() aws.eventbridge.pipe.sourceParameters.dynamodbStream
  // Amazon MQ ActiveMQ source parameters (null unless type == activeMQ)
  activeMQ() aws.eventbridge.pipe.sourceParameters.activeMQ
  // Amazon MQ RabbitMQ source parameters (null unless type == rabbitMQ)
  rabbitMQ() aws.eventbridge.pipe.sourceParameters.rabbitMQ
  // Amazon MSK source parameters (null unless type == msk)
  msk() aws.eventbridge.pipe.sourceParameters.msk
  // Self-managed Apache Kafka source parameters (null unless type == selfManagedKafka)

// Amazon Bedrock
//
// Use the Bedrock namespace to enumerate the foundation-model service
// configuration in the account. Iterate `foundationModels()` for the
// catalog of foundation models offered by Bedrock providers (with their
// modalities, customization support, and inference types),
// `customModels()` for fine-tuned or continued-pretraining models the
// account owns, `guardrails()` for the content-policy guardrails (with
// their topic, content, sensitive-information, and word-policy
// filters), `provisionedModelThroughputs()` for committed
// model-throughput allocations, and
// `modelInvocationLoggingConfigurations()` for the per-region delivery
// of model invocation logs to S3 and CloudWatch. For generative-AI
// applications built on Bedrock, iterate `agents()` for Bedrock Agents
// (with their foundation model, instructions, IAM service role, and
// linked action groups and knowledge bases), `knowledgeBases()` for
// retrieval-augmented-generation data stores (with their vector-store
// backend, embedding model, and data sources), and `flows()` for
// authored generative-AI workflows. Iterate `evaluationJobs()` for
// model-evaluation jobs, `modelImportJobs()` for custom-model imports,
// and `batchInferenceJobs()` for batch model-invocation jobs.
aws.bedrock {
  // Foundation models available in Bedrock
  foundationModels() []aws.bedrock.foundationModel
  // Custom models in the account
  customModels() []aws.bedrock.customModel
  // Guardrails configured in the account
  guardrails() []aws.bedrock.guardrail
  // Model invocation logging configurations (one per region)
  modelInvocationLoggingConfigurations() []aws.bedrock.modelInvocationLoggingConfiguration
  // Provisioned model throughputs
  provisionedModelThroughputs() []aws.bedrock.provisionedModelThroughput
  // Advanced prompt optimization jobs in the account
  advancedPromptOptimizationJobs() []aws.bedrock.advancedPromptOptimizationJob
  // Bedrock Agents in the account
  agents() []aws.bedrock.agent
  // Bedrock knowledge bases in the account
  knowledgeBases() []aws.bedrock.knowledgeBase
  // Bedrock flows in the account
  flows() []aws.bedrock.flow
  // Model-evaluation jobs in the account
  evaluationJobs() []aws.bedrock.evaluationJob
  // Custom-model import jobs in the account
  modelImportJobs() []aws.bedrock.modelImportJob
  // Batch inference (model-invocation) jobs in the account
  batchInferenceJobs() []aws.bedrock.batchInferenceJob
  // Cross-region inference profiles in the account
  inferenceProfiles() []aws.bedrock.inferenceProfile
  // Custom models imported into the account
  importedModels() []aws.bedrock.importedModel
  // Managed prompts in the account
  prompts() []aws.bedrock.prompt
  // AgentCore namespace for agentic-AI infrastructure (gateways, runtimes, memory, tools, and identity)
  agentCore() aws.bedrock.agentCore
}

// Amazon Bedrock AgentCore
//
// Use the AgentCore namespace to enumerate the agentic-AI infrastructure
// in the account: gateways that expose tools to agents over the Model
// Context Protocol (MCP), hosted agent runtimes, short- and long-term
// memory stores, the browser and code-interpreter sandboxes agents use
// as built-in tools, and the Identity credential providers and workload
// identities that govern how agents authenticate to external services.
// Iterate `gateways()` for MCP servers, `runtimes()` for deployed agents,
// and `memories()`, `browsers()`, `codeInterpreters()`,
// `oauth2CredentialProviders()`, `apiKeyCredentialProviders()`, and
// `workloadIdentities()` for the supporting infrastructure.
private aws.bedrock.agentCore {
  // MCP gateways in the account
  gateways() []aws.bedrock.agentCore.gateway
  // Hosted agent runtimes in the account
  runtimes() []aws.bedrock.agentCore.runtime
  // Memory stores in the account
  memories() []aws.bedrock.agentCore.memory
  // Browser tool sandboxes in the account
  browsers() []aws.bedrock.agentCore.browser
  // Code-interpreter tool sandboxes in the account
  codeInterpreters() []aws.bedrock.agentCore.codeInterpreter
  // OAuth2 credential providers configured in AgentCore Identity
  oauth2CredentialProviders() []aws.bedrock.agentCore.oauth2CredentialProvider
  // API-key credential providers configured in AgentCore Identity
  apiKeyCredentialProviders() []aws.bedrock.agentCore.apiKeyCredentialProvider
  // Workload identities configured in AgentCore Identity
  workloadIdentities() []aws.bedrock.agentCore.workloadIdentity
}

// Amazon Bedrock AgentCore gateway
//
// A gateway exposes a set of tools to agents over the Model Context
// Protocol (MCP). Examine the endpoint URL agents connect to, the
// protocol type, the inbound authorizer that controls which callers may
// invoke the gateway, the IAM role the gateway assumes, and the
// customer-managed encryption key. Iterate `targets()` for the individual
// tool targets (Lambda functions, OpenAPI or Smithy APIs) federated
// through the gateway.
private aws.bedrock.agentCore.gateway @defaults("name status protocolType") {
  // ARN of the gateway
  arn() string
  // Name of the gateway
  name string
  // Region where the gateway exists
  region string
  // Current status of the gateway
  status string
  // Description of the gateway
  description string
  // Protocol exposed by the gateway (e.g., MCP)
  protocolType string
  // Inbound authorizer type controlling access
  //
  // One of CUSTOM_JWT, AWS_IAM, NONE, or AUTHENTICATE_ONLY.
  authorizerType string
  // Time the gateway was created
  createdAt time
  // Time the gateway was last updated
  updatedAt time
  // Endpoint URL agents use to invoke the gateway over its protocol
  gatewayUrl() string
  // IAM role the gateway assumes to invoke its targets
  iamRole() aws.iam.role
  // ARN of the IAM role associated with the gateway
  roleArn() string
  // Customer-managed KMS key used to encrypt the gateway
  kmsKey() aws.kms.key
  // Workload identity that anchors the gateway's AgentCore Identity credentials
  workloadIdentity() aws.bedrock.agentCore.workloadIdentity
  // ARN of the workload identity associated with the gateway
  workloadIdentityArn() string
  // Tool targets federated through the gateway
  targets() []aws.bedrock.agentCore.gatewayTarget
}

// Amazon Bedrock AgentCore gateway target
//
// A gateway target is a single tool source federated through an MCP
// gateway — a Lambda function, an OpenAPI or Smithy API, or another
// backend. Examine the target's backing configuration and the credential
// provider configurations that determine how the gateway authenticates
// outbound to the target. The `name` field selects a target within its
// gateway.
private aws.bedrock.agentCore.gatewayTarget @defaults("name status") {
  // Unique identifier of the target
  targetId string
  // Identifier of the gateway that owns this target
  gatewayId string
  // Name of the target
  name string
  // Region where the target exists
  region string
  // Current status of the target
  status string
  // Description of the target
  description string
  // Time the target was created
  createdAt time
  // Time the target was last updated
  updatedAt time
  // Backing configuration for the target
  //
  // Carries the target type (Lambda, OpenAPI schema, Smithy model, or
  // other backend) and the backend-specific configuration block.
  targetConfiguration() dict
  // Credential provider configurations governing outbound authentication to the target
  credentialProviderConfigurations() []dict
}

// Amazon Bedrock AgentCore runtime
//
// An agent runtime is a deployed agent hosted by AgentCore. Examine the

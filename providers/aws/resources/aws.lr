  // List of IP access settings across all enabled regions
  ipAccessSettings() []aws.workspacesweb.ipAccessSetting
  // List of trust stores across all enabled regions
  trustStores() []aws.workspacesweb.trustStore
  // List of user settings across all enabled regions
  userSettings() []aws.workspacesweb.userSetting
}

// Amazon WorkSpaces Web portal

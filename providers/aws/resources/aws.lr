  // Region where the web app exists
  region string
  // Endpoint type: PUBLIC or VPC
  endpointType string
  // The URL provided to users to interact with the web app
  accessEndpoint string
  // The unique URL for the web app (used as a CloudFront origin)
  webAppEndpoint string
  // Tags for the web app
  tags() map[string]string
}

// AWS Transfer Family workflow
private aws.transfer.workflow @defaults("arn workflowId description") {
  // ARN of the workflow
  arn string
  // Workflow identifier
  workflowId string
  // Region where the workflow exists
  region string
  // Description for the workflow

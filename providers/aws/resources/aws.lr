  publiclyAccessible bool
  // Whether the cluster is reachable from the internet
  //
  // True when the cluster is configured for public access, which assigns it a
  // publicly resolvable endpoint reachable from outside its VPC.
  internetReachable() bool
  // Connection endpoint address for the cluster (empty when the cluster has no endpoint)
  endpointAddress string
  // Connection endpoint port for the cluster (0 when the cluster has no endpoint)
  endpointPort int
  // VPC endpoints associated with the cluster (used when publiclyAccessible is false)
  endpointVpcEndpoints []dict
  // Region where the cluster exists
  region string
  // Tags for the cluster
  tags map[string]string
  // ID of the VPC where the cluster is running
  //
  // Deprecated in favor of `vpc()`.
  vpcId @maturity("deprecated") string
  // VPC where the cluster is running
  vpc() aws.vpc
  // Availability status (Available, Unavailable, Maintenance, Modifying)
  clusterAvailabilityStatus string
  // Total storage capacity in megabytes
  totalStorageCapacityInMegaBytes int
  // Name of the maintenance track for the cluster
  maintenanceTrackName string
  // HSM status for the cluster
  hsmStatus dict
  // Status of modifications to the cluster (e.g., resizing)
  modifyStatus string
  // Whether the cluster is a Multi-AZ deployment
  multiAZ bool
  // Number of days manual snapshots are retained (-1 means indefinite)
  manualSnapshotRetentionPeriod int
  // IP address type for the cluster (ipv4 or dualstack)
  ipAddressType string
  // KMS key used to encrypt the master password secret in Secrets Manager
  masterPasswordSecretKmsKey() aws.kms.key
  // Identifier of the snapshot schedule associated with the cluster, if any
  snapshotScheduleIdentifier string
  // Snapshots for this cluster
  snapshots() []aws.redshift.snapshot
  // Whether the cluster was created by restoring from a snapshot
  restoredFromSnapshot bool
  // Status of the restore-from-snapshot operation: starting, restoring, completed, or failed
  restoreStatus string
  // Percentage of the restore completed, when a restore is in progress
  restoreProgressPercent float
  // IAM roles the cluster can assume to access other AWS services, such as S3 and Glue
  iamRoles() []aws.iam.role
  // Default IAM role used for operations that don't name a role
  defaultIamRole() aws.iam.role
  // Master user password secret managed by Secrets Manager
  masterPasswordSecret() aws.secretsmanager.secret
  // Infrastructure-management system that owns the cluster, inferred from provenance tags
  managedBy() string
  // CloudFormation stack that provisioned the cluster, when tagged
  cloudformationStack() aws.cloudformation.stack
  // Namespace ARN, a stable identity that persists across cluster rename and restore
  clusterNamespaceArn string
  // Whether cross-region snapshot copy is enabled for the cluster
  crossRegionSnapshotCopyEnabled bool
  // Destination region automated snapshots are copied to
  snapshotCopyDestinationRegion string
  // Retention period, in days, for automated snapshots copied to the destination region
  snapshotCopyRetentionPeriod int
  // Retention period, in days, for manual snapshots copied to the destination region
  snapshotCopyManualRetentionPeriod int
  // Snapshot copy grant used to encrypt copied snapshots in the destination region
  snapshotCopyGrantName string
  // Time the next automatic snapshot is expected to be taken
  expectedNextSnapshotScheduleAt time
  // State of the next expected scheduled snapshot: OnTrack or Pending
  expectedNextSnapshotScheduleStatus string
  // State of the snapshot schedule attached to the cluster: ACTIVE, MODIFYING, or FAILED
  snapshotScheduleState string
  // VPC security groups attached to the cluster
  securityGroups() []aws.ec2.securitygroup
  // Custom domain name configured for the cluster endpoint
  customDomainName string
  // ACM certificate backing the custom domain
  customDomainCertificate() aws.acm.certificate
  // Expiration date of the custom domain certificate
  customDomainCertificateExpiresAt time
  // Status of Availability Zone relocation for the cluster
  availabilityZoneRelocationStatus string
  // Elastic IP address of the cluster, when one is configured
  elasticIp string
}


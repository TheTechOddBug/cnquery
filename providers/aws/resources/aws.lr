}

// Amazon Bedrock provisioned model throughput
private aws.bedrock.provisionedModelThroughput @defaults("provisionedModelName modelArn status") {
  // ARN of the provisioned model throughput
  provisionedModelArn string
  // Name of the provisioned model throughput
  provisionedModelName string
  // Region where the provisioned throughput exists
  region string
  // ARN of the model
  modelArn string
  // Foundation model for the provisioned throughput
  foundationModel() aws.bedrock.foundationModel
  // ARN of the foundation model

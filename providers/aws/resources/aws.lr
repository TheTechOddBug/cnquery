  productionVariants() []aws.sagemaker.endpoint.productionVariant
  // Shadow production variants deployed on this endpoint
  shadowProductionVariants() []aws.sagemaker.endpoint.productionVariant
  // Data capture configuration
  dataCaptureConfig() aws.sagemaker.endpoint.dataCaptureConfig
}

// AWS SageMaker endpoint production variant
private aws.sagemaker.endpoint.productionVariant @defaults("variantName") {

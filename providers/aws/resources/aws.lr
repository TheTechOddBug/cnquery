  // ARN of the model
  modelArn string
  // ID of the model (e.g., anthropic.claude-3-sonnet)
  modelId string
  // Name of the model
  modelName string
  // Provider name (e.g., Anthropic, Amazon, Meta)
  providerName string
  // Input modalities supported (e.g., TEXT, IMAGE)
  inputModalities []string
  // Output modalities supported
  outputModalities []string
  // Customizations supported (e.g., FINE_TUNING, CONTINUED_PRE_TRAINING)
  customizationsSupported []string
  // Inference types supported (e.g., ON_DEMAND, PROVISIONED)
  inferenceTypesSupported []string
  // Whether response streaming is supported
  responseStreamingSupported bool
  // Model lifecycle status (e.g., ACTIVE, LEGACY)
  modelLifecycleStatus string
}

// Amazon Bedrock custom model
private aws.bedrock.customModel @defaults("modelArn modelName") {
  // ARN of the custom model
  modelArn string
  // Name of the custom model
  modelName string
  // Region where the custom model exists
  region string
  // Base model used for customization

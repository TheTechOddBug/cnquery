  // Date and time the watermark was attached to the AMI
  createdAt time
  // ID of the source AMI the watermark was originally attached to
  sourceImageId string
  // Region where the source AMI was located
  sourceImageRegion string
  // Creation date of the source AMI
  sourceImageCreatedAt time
}


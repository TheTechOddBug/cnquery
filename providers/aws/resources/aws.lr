  // Availability zone where the file system exists if a specific AZ is defined
  availabilityZone string
  // ID of the availability zone where the file system exists if a specific AZ is defined
  availabilityZoneId string
  // Opaque idempotency token supplied when the file system was created
  //
  // Infrastructure-as-code tools often set this to a meaningful value. When left unset, the Terraform AWS provider auto-generates a token with a "terraform-" prefix, which managedBy uses as a fallback signal.
  creationToken string
  // Provisioned throughput in MiBps, set only when throughputMode is provisioned

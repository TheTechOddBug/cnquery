  // Deprecated in favor of `vpc()`.
  vpcConfig() @maturity("deprecated") dict
  // VPC associated with this model
  vpc() aws.vpc
  // Additional containers in the inference pipeline
  containers() []aws.sagemaker.model.container
  // Inference execution configuration
  inferenceExecutionConfig() dict
}


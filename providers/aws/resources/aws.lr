  // Account ID that owns the bucket
  bucketAccountId string
  // Network origin of the access point: Internet or VPC
  networkOrigin string
  // VPC the access point is restricted to (null for Internet-origin access points)
  vpc() aws.vpc
  // Alias of the access point
  alias string
  // Public access block configuration for the access point
  publicAccessBlock() dict
  // Resource policy attached to the access point
  policy() string
}

// Amazon S3 bucket grant
private aws.s3.bucket.grant @defaults("name permission") {
  // ID of the bucket grant
  id string
  // Name for the bucket grant
  name string
  // Permission associated with the grant

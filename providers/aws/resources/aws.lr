  modelName() string
  // ML instance type (from the endpoint configuration)
  instanceType() string
  // Current number of instances
  currentInstanceCount int
  // Desired number of instances
  desiredInstanceCount int
  // Current traffic weight
  currentWeight float
  // Desired traffic weight
  desiredWeight float
  // Current serverless configuration
  currentServerlessConfig() dict
  // Desired serverless configuration
  desiredServerlessConfig() dict
  // Variant status details
  variantStatuses() []aws.sagemaker.endpoint.productionVariant.status
  // Managed instance scaling configuration

  connectors() []aws.transfer.connector
  // List of Transfer Family web apps
  webApps() []aws.transfer.webApp
  // List of Transfer Family workflows
  workflows() []aws.transfer.workflow
}

// AWS Transfer Family connector (sends files via AS2 or SFTP to an external endpoint)
private aws.transfer.connector @defaults("arn connectorId status") {
  // ARN of the connector
  arn string
  // Connector identifier
  connectorId string
  // Region where the connector exists
  region string
  // URL of the partner's AS2 or SFTP endpoint
  url string
  // Connector status: PENDING, ACTIVE, ERRORED
  status() string
  // Egress configuration type: SERVICE_MANAGED or VPC_LATTICE

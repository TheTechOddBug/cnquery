  // Customization type: FINE_TUNING or CONTINUED_PRE_TRAINING
  customizationType string
  // KMS key used for model encryption
  kmsKey() aws.kms.key
  // Training data configuration
  trainingDataConfig() dict
  // Output data configuration
  outputDataConfig() dict
}

// Amazon Bedrock guardrail
private aws.bedrock.guardrail @defaults("id name status") {
  // ARN of the guardrail

}

// Amazon GuardDuty detector member account
private aws.guardduty.detector.member @defaults("accountId relationshipStatus") {
  // AWS account ID of the member
  accountId string
  // Region of the detector
  region string
  // Email address of the member account
  email string
  // Relationship status: INVITED, ENABLED, DISABLED, CREATED, REMOVED, RESIGNED, EMAIL_VERIFICATION_IN_PROGRESS, EMAIL_VERIFICATION_FAILED
  relationshipStatus string

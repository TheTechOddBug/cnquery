  abuseContactEmail() string
}

// Route 53 traffic policy
//
// Examine the JSON-encoded routing logic of a single traffic policy — the
// rules, endpoints, and decision tree that Route 53 uses when this policy
// is applied to a hosted zone through a `trafficPolicyInstance`. The
// `document` field carries the raw policy JSON in the format documented at
// https://docs.aws.amazon.com/Route53/latest/APIReference/api-policies-traffic-policy-document-format.html.
// Listing returns the latest version of each policy; use `version` to
// distinguish versions when the same `id` has multiple revisions.
private aws.route53.trafficPolicy @defaults("id name version type") {
  // Unique identifier for the traffic policy
  id string
  // Traffic policy version
  version int
  // Name of the traffic policy
  name string
  // DNS record type the policy produces (A, AAAA, CNAME, etc.)
  type string
  // Traffic policy document in JSON form
  document string
  // Comment associated with this policy version
  comment string
  // Whether this is the latest version of the policy
  latestVersion bool
}

// Route 53 traffic policy instance
//
// Examine a single traffic policy applied to a hosted zone. A traffic
// policy instance is the materialized record set that Route 53 creates
// when a `trafficPolicy` is bound to a DNS name in a hosted zone. Use
// `trafficPolicy()` to traverse to the policy version that produced it,
// `hostedZone()` to reach the zone, `state` to confirm the records are
// `Applied` (vs. `Creating`, `Failed`, or `Deleting`), and `message` for
// the failure reason when state is `Failed`.
private aws.route53.trafficPolicyInstance @defaults("id name state") {
  // Unique identifier for the traffic policy instance
  id string
  // DNS name the instance manages
  name string
  // Hosted zone ID the instance belongs to
  hostedZoneId string
  // Associated hosted zone
  hostedZone() aws.route53.hostedZone
  // Traffic policy ID used to create this instance
  trafficPolicyId string
  // Traffic policy version used to create this instance
  trafficPolicyVersion int
  // DNS record type the traffic policy produced (A, AAAA, CNAME, etc.)
  trafficPolicyType string
  // Traffic policy version backing this instance
  trafficPolicy() aws.route53.trafficPolicy
  // TTL applied to the resource record sets created from the policy
  ttl int
  // Current state of the instance: Applied, Creating, Deleting, or Failed
  state string
  // Explanation of the state when state is Failed; empty otherwise
  message string
}

// Route 53 CIDR collection
//
// Examine a single CIDR collection — a named bag of IP ranges grouped
// into locations that backs CIDR-based DNS routing on resource record
// sets. Use `locations` to enumerate the locations defined for the
// collection along with the CIDR blocks they cover; the collection is
// referenced from `aws.route53.record.cidrRoutingConfig` by `id` and
// `locationName`.
private aws.route53.cidrCollection @defaults("name id version") {
  // ARN of the CIDR collection
  arn string
  // Unique identifier for the CIDR collection
  id string
  // Name of the CIDR collection
  name string
  // Monotonically increasing version counter
  version int
  // Locations defined for the collection
  //
  // Each entry has `locationName` (string) and `cidrBlocks` ([]string).
  locations() []dict
}

// Route 53 Resolver endpoint
//
// Examine a single resolver endpoint — the ENI-backed bridge that
// connects a VPC to DNS resolvers either inside or outside AWS. Inbound
// endpoints (`direction == "INBOUND"`) accept DNS queries from
// on-premises networks into Route 53 Resolver; outbound endpoints
// (`direction == "OUTBOUND"`) forward VPC queries out through the
// `targetIps` of resolver `rule`s. Each endpoint pins two or more IP
// addresses (`ipAddresses`) in subnets of the host VPC (`hostVpc()`) and
// is protected by security groups (`securityGroups()`). Use `status` and
// `statusMessage` to verify the endpoint is healthy.
private aws.route53.resolver.endpoint @defaults("id name direction status") {
  // Unique identifier for the resolver endpoint
  id string
  // ARN of the resolver endpoint
  arn string
  // Name of the resolver endpoint
  name string
  // Region the endpoint resides in
  region string
  // Direction of DNS traffic
  //
  // One of `INBOUND`, `OUTBOUND`, or `INBOUND_DELEGATION`.
  direction string
  // Current status of the endpoint
  //
  // One of `CREATING`, `OPERATIONAL`, `UPDATING`, `AUTO_RECOVERING`,
  // `ACTION_NEEDED`, or `DELETING`.
  status string
  // Status message returned by the Route 53 Resolver API
  statusMessage string
  // VPC ID hosting the endpoint
  hostVpcId string
  // VPC hosting the endpoint
  hostVpc() aws.vpc
  // Security groups attached to the endpoint
  securityGroups() []aws.ec2.securitygroup
  // IP addresses the endpoint uses for DNS queries
  //
  // Each entry has `ipId`, `subnetId`, `ip`, `ipv6`, and `status`.
  ipAddresses() []dict
  // Endpoint IP address type
  //
  // One of `IPV4`, `IPV6`, or `DUALSTACK`.
  resolverEndpointType string
  // Number of IP addresses associated with the endpoint
  ipAddressCount int
  // Creation timestamp
  creationTime string
  // Last modification timestamp
  modificationTime string
}

// Route 53 Resolver rule
//
// Examine a single resolver rule — the DNS forwarding decision applied
// to outbound queries from a VPC. The `domainName` field selects which
// queries the rule matches and `ruleType` (`FORWARD`, `SYSTEM`, or
// `RECURSIVE`) determines how the rule behaves: `FORWARD` rules ship
// matching queries to `targetIps` through the outbound `resolverEndpoint()`,
// `SYSTEM` rules intentionally override a broader forwarding rule for a
// subdomain, and `RECURSIVE` rules are managed by Resolver itself. Use
// `shareStatus` and `ownerId` to identify rules shared via Resource Access
// Manager.
private aws.route53.resolver.rule @defaults("id name domainName ruleType status") {
  // Unique identifier for the resolver rule
  id string
  // ARN of the resolver rule
  arn string
  // Name of the resolver rule
  name string
  // Region the rule resides in
  region string
  // Current status of the rule
  status string
  // Status message returned by the Route 53 Resolver API
  statusMessage string
  // Domain name the rule applies to
  domainName string
  // Rule type: FORWARD, SYSTEM, or RECURSIVE
  ruleType string
  // Resolver endpoint ID used by FORWARD rules; empty otherwise
  resolverEndpointId string
  // Outbound resolver endpoint used by the rule
  resolverEndpoint() aws.route53.resolver.endpoint
  // Target DNS resolvers for FORWARD rules
  //
  // Each entry has `ip`, `ipv6`, `port`, and `protocol`.
  targetIps []dict
  // Sharing status: NOT_SHARED, SHARED_BY_ME, or SHARED_WITH_ME
  shareStatus string
  // Account ID that owns the rule
  ownerId string
  // Creation timestamp
  creationTime string
  // Last modification timestamp
  modificationTime string
}

// Route 53 Resolver rule association
//
// Examine a single VPC↔resolver-rule association. Use `vpc()` to reach
// the VPC the rule applies to and `resolverRule()` to traverse back to
// the rule definition. The `status` field reflects whether the binding
// is `CREATING`, `COMPLETE`, `DELETING`, `FAILED`, or `OVERRIDDEN`.
private aws.route53.resolver.ruleAssociation @defaults("id name status") {
  // Unique identifier for the association
  id string
  // Name of the association
  name string
  // Region the association resides in
  region string
  // Resolver rule ID
  resolverRuleId string
  // Associated resolver rule
  resolverRule() aws.route53.resolver.rule
  // VPC ID the rule is associated with
  //
  // Deprecated in favor of `vpc`.
  vpcId @maturity("deprecated") string
  // Associated VPC
  vpc() aws.vpc
  // Status of the association
  status string
  // Status message returned by the Route 53 Resolver API
  statusMessage string
}

// Route 53 Resolver query log configuration
//
// Examine a single query log configuration — the destination Route 53
// Resolver uses to log DNS queries originating in associated VPCs. The
// `destinationArn` field carries the raw ARN of the target (S3 bucket,
// CloudWatch Logs log group, or Kinesis Data Firehose delivery stream)
// and the typed `s3Bucket()`, `cloudwatchLogGroup()`, and
// `firehoseDeliveryStream()` accessors resolve to whichever destination
// is in use. Use `associationCount` for a quick check that the
// configuration is in active use and pair with
// `aws.route53.resolver.queryLogConfigAssociations` to enumerate the VPCs.
private aws.route53.resolver.queryLogConfig @defaults("id name status destinationArn") {
  // Unique identifier for the query log configuration
  id string
  // ARN of the query log configuration
  arn string
  // Name of the query log configuration
  name string
  // Region the configuration resides in
  region string
  // Account ID that owns the configuration
  ownerId string
  // Configuration status: CREATING, CREATED, DELETING, or FAILED
  status string
  // Sharing status: NOT_SHARED, SHARED_BY_ME, or SHARED_WITH_ME
  shareStatus string
  // Number of VPCs currently associated with this configuration
  associationCount int
  // Destination ARN that receives query logs
  //
  // Points at an S3 bucket, CloudWatch Logs log group, or Kinesis Data
  // Firehose delivery stream.
  destinationArn string
  // S3 bucket destination when destinationArn points at S3
  s3Bucket() aws.s3.bucket
  // CloudWatch Logs log group destination when destinationArn points at CloudWatch Logs
  cloudwatchLogGroup() aws.cloudwatch.loggroup
  // Kinesis Data Firehose destination when destinationArn points at Firehose
  firehoseDeliveryStream() aws.kinesis.firehoseDeliveryStream
  // Creation timestamp
  creationTime string
  // Caller-supplied request id used to create the configuration
  creatorRequestId string
}

// Route 53 Resolver query log configuration association
//
// Examine a single VPC↔query-log-configuration binding. Use `vpc()` to
// reach the VPC whose DNS queries are being logged and
// `resolverQueryLogConfig()` for the configuration. When `status` is
// `FAILED`, `error` and `errorMessage` indicate the cause (such as
// `DESTINATION_NOT_FOUND` or `ACCESS_DENIED`).
private aws.route53.resolver.queryLogConfigAssociation @defaults("id status") {
  // Unique identifier for the association
  id string
  // Region the association resides in
  region string
  // Query log configuration ID
  resolverQueryLogConfigId string
  // Associated query log configuration
  resolverQueryLogConfig() aws.route53.resolver.queryLogConfig
  // ID of the associated resource (typically a VPC ID)
  resourceId string
  // Associated VPC
  vpc() aws.vpc
  // Association status: CREATING, ACTIVE, ACTION_NEEDED, DELETING, or FAILED
  status string
  // Error code when status is FAILED
  //
  // One of `NONE`, `DESTINATION_NOT_FOUND`, `ACCESS_DENIED`, or `INTERNAL_SERVICE_ERROR`.
  error string
  // Error message when status is FAILED
  errorMessage string
  // Creation timestamp
  creationTime string
}

// Route 53 Resolver DNS Firewall rule group
//
// Examine a single DNS Firewall rule group — the ordered set of rules
// that DNS Firewall applies to queries originating in VPCs the group is
// associated with. Iterate `rules` to inspect every rule in priority
// order, including the `action` (`ALLOW`, `ALERT`, `BLOCK`), the
// `firewallDomainListId` that supplies the match list, the optional
// `blockResponse` and `blockOverride*` fields for `BLOCK` rules, and
// `qtype` to scope a rule to a specific DNS record type. Pair with
// `aws.route53.resolver.firewallRuleGroupAssociation` to find the VPCs
// the group filters.
private aws.route53.resolver.firewallRuleGroup @defaults("id name ruleCount status") {
  // Unique identifier for the rule group
  id string
  // ARN of the rule group
  arn string
  // Name of the rule group
  name string
  // Region the rule group resides in
  region string
  // Number of rules in the group
  ruleCount int
  // Rule group status
  status string
  // Status message returned by the Route 53 Resolver API
  statusMessage string
  // Account ID that owns the rule group
  ownerId string
  // Sharing status: NOT_SHARED, SHARED_BY_ME, or SHARED_WITH_ME
  shareStatus string
  // Creation timestamp
  creationTime string
  // Last modification timestamp
  modificationTime string
  // Caller-supplied request id used to create the rule group
  creatorRequestId string
  // Ordered list of rules in the group as raw dicts
  //
  // Deprecated in favor of `firewallRules`, which returns typed
  // `aws.route53.resolver.firewallRule` resources that also expose the
  // rule classification (`firewallRuleType`), DNS threat protection
  // settings, and a `firewallDomainList()` reference. Each dict entry has
  // `name`, `priority`, `action` (`ALLOW`/`BLOCK`/`ALERT`),
  // `blockResponse`, `blockOverrideDomain`, `blockOverrideDnsType`,
  // `blockOverrideTtl`, `firewallDomainListId`, `qtype`, `creationTime`,
  // and `modificationTime`.
  rules() @maturity("deprecated") []dict
  // Ordered list of rules in the group
  firewallRules() []aws.route53.resolver.firewallRule
}

// Route 53 Resolver DNS Firewall rule
//
// Examine a single rule within a DNS Firewall rule group. `action`
// decides what happens to a matching DNS query — `ALLOW` lets it through,
// `BLOCK` stops resolution, and `ALERT` permits it while recording a
// finding. `priority` sets evaluation order within the group (lower runs
// first). A rule matches either a domain list — reachable through
// `firewallDomainList()` — or, for managed threat rules, AWS DNS threat
// protection (`dnsThreatProtection`, `confidenceThreshold`). `BLOCK`
// rules carry `blockResponse` and the `blockOverride*` fields.
private aws.route53.resolver.firewallRule @defaults("name priority action") {
  // Name of the rule
  name string
  // ID of the rule group this rule belongs to
  firewallRuleGroupId string
  // Evaluation priority within the rule group (lower values run first)
  priority int
  // Action taken on a matching query: ALLOW, BLOCK, or ALERT
  action string
  // Response for BLOCK rules
  //
  // One of `NODATA`, `NXDOMAIN`, or `OVERRIDE`.
  blockResponse string
  // Custom domain returned when blockResponse is OVERRIDE
  blockOverrideDomain string
  // DNS record type for the override response (CNAME)
  blockOverrideDnsType string
  // TTL for the override response, in seconds
  blockOverrideTtl int
  // ID of the domain list this rule matches against
  firewallDomainListId string
  // Domain list this rule matches against
  firewallDomainList() aws.route53.resolver.firewallDomainList
  // How matched domains are redirected during resolution
  //
  // One of `INSPECT_REDIRECTION_DOMAIN` or `TRUST_REDIRECTION_DOMAIN`.
  firewallDomainRedirectionAction string
  // DNS query type the rule applies to (e.g., A, AAAA, or empty for all)
  qtype string
  // Advanced DNS Firewall rule type for threat detection
  //
  // One of `DGA` (domain generation algorithm detection), `DNS_TUNNELING`,
  // or empty for non-advanced rules.
  dnsThreatProtection string
  // Confidence threshold for advanced threat detection
  //
  // One of `LOW`, `MEDIUM`, or `HIGH`; empty for non-advanced rules.
  confidenceThreshold string
  // Advanced rule-type configuration
  //
  // Present for advanced and threat-protection rules; exactly one of the
  // following keys is populated. `dnsThreatProtection`:
  // `{confidenceThreshold, value}` where value is `DGA` or `DNS_TUNNELING`.
  // `firewallAdvancedContentCategory`: `{category}`.
  // `firewallAdvancedThreatCategory`: `{category}`.
  firewallRuleType dict
  // ID of the threat protection configuration backing a threat-protection rule
  firewallThreatProtectionId string
  // Creation timestamp
  creationTime string
  // Last modification timestamp
  modificationTime string
  // Caller-supplied request id used to create the rule
  creatorRequestId string
}

// Route 53 Resolver DNS Firewall rule group association
//
// Examine a single binding between a DNS Firewall rule group and a VPC.
// Use `vpc()` to reach the VPC and `firewallRuleGroup()` for the rules
// applied. The `priority` field controls evaluation order when multiple
// rule groups are bound to the same VPC; `mutationProtection`
// (`ENABLED`/`DISABLED`) controls whether the association can be removed
// without first turning off protection.
private aws.route53.resolver.firewallRuleGroupAssociation @defaults("id name status priority") {
  // Unique identifier for the association
  id string
  // ARN of the association
  arn string
  // Name of the association
  name string
  // Region the association resides in
  region string
  // ID of the firewall rule group
  firewallRuleGroupId string
  // Associated rule group
  firewallRuleGroup() aws.route53.resolver.firewallRuleGroup
  // VPC ID the rule group is associated with
  //
  // Deprecated in favor of `vpc`.
  vpcId @maturity("deprecated") string
  // Associated VPC
  vpc() aws.vpc
  // Evaluation priority among rule groups bound to the same VPC
  priority int
  // Whether the association is protected against accidental modification
  //
  // One of `ENABLED` or `DISABLED`.
  mutationProtection string
  // Owner of the association when managed externally (e.g., Firewall Manager)
  managedOwnerName string
  // Association status
  status string
  // Status message returned by the Route 53 Resolver API
  statusMessage string
  // Creation timestamp
  creationTime string
  // Last modification timestamp
  modificationTime string
  // Caller-supplied request id used to create the association
  creatorRequestId string
}

// Route 53 Resolver DNS Firewall domain list
//
// Examine a single DNS Firewall domain list — the named bag of domain
// names that `firewallRuleGroup` rules match against. `managedOwnerName`
// is populated for AWS-managed lists (such as
// `AWSManagedDomainsMalwareDomainList`) and empty for user-managed
// lists; in either case `domainCount` reflects the total entries
// regardless of how many `domains()` are materialized.
private aws.route53.resolver.firewallDomainList @defaults("id name domainCount status") {
  // Unique identifier for the domain list
  id string
  // ARN of the domain list
  arn string
  // Name of the domain list
  name string
  // Region the domain list resides in
  region string
  // Number of domains in the list
  domainCount int
  // Domain names in the list
  domains() []string
  // Category of the domain list (e.g., AWS_MANAGED or empty for customer-managed lists)
  category string
  // Managed-list type for AWS-managed lists
  //
  // One of `AWS_MANAGED_DOMAIN_LIST`, `ACCOUNT_MANAGED_DOMAIN_LIST`, or
  // empty for customer-managed lists.
  managedListType string
  // Domain list status
  status string
  // Status message returned by the Route 53 Resolver API
  statusMessage string
  // Owner of the list when managed by AWS (e.g., AWSManagedDomainsMalwareDomainList); empty for customer-managed lists
  managedOwnerName string
  // Creation timestamp
  creationTime string
  // Last modification timestamp
  modificationTime string
  // Caller-supplied request id used to create the domain list
  creatorRequestId string
}

// Route 53 Resolver DNS Firewall per-VPC configuration
//
// Examine the DNS Firewall per-VPC configuration that controls how the
// firewall fails when it cannot evaluate a query. With
// `firewallFailOpen == "ENABLED"`, queries are allowed through when the
// firewall cannot reach a decision (availability over security); with
// `firewallFailOpen == "DISABLED"` (the default), queries are dropped
// (security over availability). Use `vpc()` to reach the VPC the
// configuration applies to.
private aws.route53.resolver.firewallConfig @defaults("resourceId firewallFailOpen") {
  // Unique identifier for the firewall configuration
  id string
  // Region the configuration resides in
  region string
  // VPC ID the configuration applies to
  resourceId string
  // Associated VPC
  vpc() aws.vpc
  // Account ID that owns the VPC
  ownerId string
  // Fail-open behavior
  //
  // One of `ENABLED` (allow queries on failure) or `DISABLED` (block on
  // failure, the default).
  firewallFailOpen string
}

// Amazon Elastic Container Registry (ECR)
//
// Use the ECR namespace to enumerate container image registries and the
// images they hold. Iterate `privateRepositories()` and
// `publicRepositories()` for private (per-account) and public ECR
// repositories (with their image-tag immutability, scan-on-push setting,
// repository policy, and lifecycle policy), and `images()` for images
// across those repos with their tags, digests, and image-scan findings.
// Read `replicationConfiguration` for cross-region/account replication and
// `scanningConfiguration` for the registry-level scanning posture.
aws.ecr {
  // List of private repositories
  privateRepositories() []aws.ecr.repository
  // List of public repositories associated with the AWS account
  publicRepositories() []aws.ecr.repository
  // List of images
  images() []aws.ecr.image
  // Registry replication configuration
  replicationConfiguration() dict
  // Registry-level scanning configuration
  scanningConfiguration() aws.ecr.scanningConfiguration
}

// AWS Elastic Container Registry repository
private aws.ecr.repository @defaults("uri region") {
  // ARN of the repository
  arn string
  // Name of the repository
  name string
  // URI of the repository, used for push/pull operations
  uri string
  // AWS Account ID associated with public registry for this repository
  registryId string
  // Whether the repository is public
  public bool
  // List of images in the repository
  images() []aws.ecr.image
  // Region where the image is stored
  region string
  // Whether the repository option to scan on image push is enabled
  imageScanOnPush bool
  // Whether image tags are immutable (MUTABLE or IMMUTABLE); immutable tags prevent image overwrites
  imageTagMutability string
  // Encryption type for images at rest (AES256, KMS, or KMS_DSSE)
  encryptionType string
  // KMS key protecting images at rest, when encryptionType is KMS or KMS_DSSE
  kmsKey() aws.kms.key
  // When the repository was created
  createdAt time
  // Scanning frequency for the repository: SCAN_ON_PUSH, CONTINUOUS_SCAN, or MANUAL
  scanningFrequency() string
  // Access policy for the repository (parsed JSON; private repositories only)
  policy() dict
  // Parsed statements from the repository access policy
  policyStatements() []aws.iam.policyStatement
  // Whether the resource policy grants public access (a wildcard principal with no scoping conditions)
  isPublic() bool
  // Lifecycle policy for the repository
  lifecyclePolicy() aws.ecr.lifecyclePolicy
  // About text from catalog data (public repositories only)
  aboutText() string
  // Usage text from catalog data (public repositories only)
  usageText() string
  // Short description from catalog data (public repositories only)
  catalogDescription() string
  // Operating systems from catalog data (public repositories only)
  operatingSystems() []string
  // Architectures from catalog data (public repositories only)
  architectures() []string
  // AWS resource tags for the repository (private repositories only)
  tags() map[string]string
  // CloudFormation stack that manages this repository, if any
  cloudformationStack() aws.cloudformation.stack
  // Infrastructure-management system that owns this repository
  //
  // Inferred from the provenance tags AWS injects on managed resources (for example cloudformation, elasticbeanstalk, eks). Empty when the repository is unmanaged or managed by a tool that leaves no recognizable tag.
  managedBy() string
}

// AWS ECR repository lifecycle policy
private aws.ecr.lifecyclePolicy @defaults("rules") {
  // Unique identifier for this lifecycle policy
  id string
  // Time the lifecycle policy was last evaluated
  lastEvaluatedAt time
  // Rules in the lifecycle policy
  rules []aws.ecr.lifecyclePolicy.rule
}

// AWS ECR lifecycle policy rule
private aws.ecr.lifecyclePolicy.rule @defaults("rulePriority description") {
  // Unique identifier for this rule
  id string
  // Priority of the rule (lower numbers are evaluated first)
  rulePriority int
  // Description of the rule
  description string
  // Tag status filter: tagged, untagged, or any
  tagStatus string
  // Tag pattern list for filtering images (glob patterns)
  tagPatternList []string
  // Tag prefix list for filtering images
  tagPrefixList []string
  // Count type: imageCountMoreThan, sinceImagePushed, sinceImagePulled, or sinceImageTransitioned
  countType string
  // Count unit for time-based rules (days)
  countUnit string
  // Count number threshold
  countNumber int
  // Action type: expire or transition
  actionType string
}

// AWS Elastic Container Registry image
private aws.ecr.image @defaults("uri region") {
  // SHA256 of the image manifest
  digest string
  // Type of image manifest
  mediaType string
  // Media type of the artifact, when the image is an attached artifact rather than a container image (for example an SBOM or signature)
  artifactMediaType string
  // List of tags associated with image
  tags []string
  // AWS account ID associated with public registry for this image
  registryId string
  // Name of the repository for the image
  repoName string
  // ECR repository that contains the image
  repository() aws.ecr.repository
  // Region where the ECR image is located
  region string
  // ARN for the image
  arn string
  // URI for the image repository
  uri string
  // Time the image was pushed
  pushedAt time
  // Size of the image in bytes
  sizeInBytes int
  // Time of the most recent image pull (Amazon only refreshes this data once every 24 hours.)
  lastRecordedPullTime time
  // Status of the most recent image scan
  //
  // One of: COMPLETE, FAILED, IN_PROGRESS, UNSUPPORTED_IMAGE, ACTIVE, SCAN_ELIGIBILITY_EXPIRED, FINDINGS_UNAVAILABLE, or NOT_SCANNED.
  scanStatus() string
  // Findings from the most recent image scan (basic scan findings; private repositories only)
  scanFindings() []aws.ecr.image.scanFinding
  // Severity counts from the most recent image scan
  scanFindingSeverityCounts() dict
}

// AWS ECR image scan finding
private aws.ecr.image.scanFinding @defaults("severity name") {
  // Name of the vulnerability (e.g., CVE ID)
  name string
  // Description of the vulnerability
  description string
  // URI with more information about the vulnerability
  uri string
  // Severity: INFORMATIONAL, LOW, MEDIUM, HIGH, CRITICAL, or UNDEFINED
  severity string
  // Attributes associated with the finding (e.g., CVSS score)
  attributes dict
}

// AWS ECR registry scanning configuration
private aws.ecr.scanningConfiguration @defaults("scanType") {
  // Scan type for the registry: BASIC or ENHANCED
  scanType string
  // Scanning rules applied to repositories
  rules []aws.ecr.scanningConfiguration.rule
}

// AWS ECR registry scanning configuration rule
private aws.ecr.scanningConfiguration.rule @defaults("scanFrequency") {
  // Scan frequency: SCAN_ON_PUSH, CONTINUOUS_SCAN, or MANUAL
  scanFrequency string
  // Repository filters applied by this rule
  repositoryFilters []dict
}

// AWS Database Migration Service (DMS)
//
// Use the DMS namespace to enumerate the replication infrastructure
// configured for database migration in the account. Iterate
// `replicationInstances()` for the replication instances DMS uses to copy
// data between source and target endpoints, `endpoints()` for the source
// and target connection definitions, `replicationTasks()` for the
// migration tasks bound to instances, and `replicationSubnetGroups()` for
// the subnet groups that scope replication instances to a VPC.
aws.dms @defaults("replicationInstances") {
  // List of DMS replication instances
  replicationInstances() []aws.dms.replicationInstance
  // List of DMS endpoints (source and target databases)
  endpoints() []aws.dms.endpoint
  // List of DMS replication tasks
  replicationTasks() []aws.dms.replicationTask
  // List of DMS replication subnet groups
  replicationSubnetGroups() []aws.dms.replicationSubnetGroup
}

// AWS DMS replication instance
private aws.dms.replicationInstance @defaults("arn replicationInstanceIdentifier replicationInstanceClass replicationInstanceStatus") {
  // ARN of the replication instance
  arn string
  // User-supplied replication instance identifier
  replicationInstanceIdentifier string
  // Compute and memory capacity class (for example, `dms.t3.medium`)
  replicationInstanceClass string
  // Status of the replication instance (for example, `available`, `creating`, `modifying`)
  replicationInstanceStatus string
  // Engine version number of the replication instance
  engineVersion string
  // Whether minor engine upgrades are applied automatically during the maintenance window
  autoMinorVersionUpgrade bool
  // Whether the replication instance is a Multi-AZ deployment
  multiAZ bool
  // Whether the replication instance has a public IP address
  publiclyAccessible bool
  // Storage allocated for the replication instance, in gigabytes
  allocatedStorage int
  // Availability Zone for a single-AZ replication instance
  availabilityZone string
  // Availability Zone of the standby replica in a Multi-AZ deployment
  secondaryAvailabilityZone string
  // Time the replication instance was created
  instanceCreateTime time
  // Weekly maintenance window for the replication instance
  preferredMaintenanceWindow string
  // IP addressing protocol (`IPV4` or `DUAL`)
  networkType string
  // Private IP addresses of the replication instance
  replicationInstancePrivateIpAddresses []string
  // Public IP addresses of the replication instance
  replicationInstancePublicIpAddresses []string
  // IPv6 addresses of the replication instance
  replicationInstanceIpv6Addresses []string
  // DNS name servers configured for the replication instance
  dnsNameServers string
  // Region the replication instance is deployed in
  region string
  // KMS key used to encrypt data on the replication instance
  kmsKey() aws.kms.key
  // VPC security groups attached to the replication instance
  securityGroups() []aws.ec2.securitygroup
  // Subnet group that scopes the replication instance to a VPC
  subnetGroup() aws.dms.replicationSubnetGroup
  // Pending modifications scheduled for the next maintenance window
  pendingModifiedValues dict
}

// AWS DMS endpoint
private aws.dms.endpoint @defaults("arn endpointIdentifier endpointType engineName status") {
  // ARN of the endpoint
  arn string
  // User-supplied endpoint identifier
  endpointIdentifier string
  // Endpoint role (`source` or `target`)
  endpointType string
  // Database engine name (for example, `mysql`, `postgres`, `s3`, `kinesis`)
  engineName string
  // Display name for the engine (for example, `Amazon Aurora MySQL`)
  engineDisplayName string
  // Username used to connect to the endpoint
  username string
  // Server name (hostname) for the endpoint
  serverName string
  // Port the endpoint listens on
  port int
  // Database name on the endpoint
  databaseName string
  // Status of the endpoint
  status string
  // SSL mode used to connect to the endpoint (one of `none`, `require`, `verify-ca`, `verify-full`)
  sslMode string
  // Whether the endpoint is read-only (managed by DMS as part of a zero-ETL integration)
  isReadOnly bool
  // Extra connection attribute string passed to the engine driver
  extraConnectionAttributes string
  // Region the endpoint was created in
  region string
  // KMS key used to encrypt the connection parameters for the endpoint
  kmsKey() aws.kms.key
  // ACM certificate used for SSL connections to the endpoint
  certificate() aws.acm.certificate
  // IAM role DMS assumes to access the endpoint (used by S3, Kinesis, OpenSearch, and other AWS-service endpoints)
  serviceAccessIamRole() aws.iam.role
}

// AWS DMS replication task
private aws.dms.replicationTask @defaults("arn replicationTaskIdentifier migrationType status") {
  // ARN of the replication task
  arn string
  // User-supplied replication task identifier
  replicationTaskIdentifier string
  // Migration type (one of `full-load`, `cdc`, `full-load-and-cdc`)
  migrationType string
  // Status of the replication task (for example, `creating`, `ready`, `running`, `stopped`, `failed`)
  status string
  // Last failure message recorded for the task
  lastFailureMessage string
  // Reason the task was stopped (for example, `Stop Reason NORMAL`, `Stop Reason FATAL_ERROR`)
  stopReason string
  // Time the replication task was created
  replicationTaskCreationDate time
  // Time the replication task was scheduled to start
  replicationTaskStartDate time
  // CDC start position (date, checkpoint, LSN, or SCN) the task resumes from
  cdcStartPosition string
  // CDC stop position (server time or commit time) the task halts at
  cdcStopPosition string
  // Last CDC checkpoint reached by the task; can be supplied as `cdcStartPosition` to resume
  recoveryCheckpoint string
  // Region the task was created in
  region string
  // Percent complete for the full-load phase of the task
  fullLoadProgressPercent int
  // Elapsed time of the task, in milliseconds
  elapsedTimeMillis int
  // Number of tables loaded by the task
  tablesLoaded int
  // Number of tables currently loading
  tablesLoading int
  // Number of tables queued for loading
  tablesQueued int
  // Number of tables that errored during loading
  tablesErrored int
  // Source endpoint the task reads from
  sourceEndpoint() aws.dms.endpoint
  // Target endpoint the task writes to
  targetEndpoint() aws.dms.endpoint
  // Replication instance the task runs on
  replicationInstance() aws.dms.replicationInstance
}

// AWS DMS replication subnet group
private aws.dms.replicationSubnetGroup @defaults("replicationSubnetGroupIdentifier subnetGroupStatus") {
  // User-supplied identifier of the subnet group
  replicationSubnetGroupIdentifier string
  // Description of the subnet group
  replicationSubnetGroupDescription string
  // Status of the subnet group (for example, `Complete`, `Incomplete`)
  subnetGroupStatus string
  // IP addressing protocols supported by the subnet group (for example, `IPV4`, `DUAL`)
  supportedNetworkTypes []string
  // Whether the subnet group is read-only (managed by DMS as part of a zero-ETL integration)
  isReadOnly bool
  // Region the subnet group is in
  region string
  // VPC the subnet group is in
  vpc() aws.vpc
  // Subnets that make up the subnet group
  subnets() []aws.vpc.subnet
}

// Amazon API Gateway (REST APIs)
//
// Use the API Gateway namespace to enumerate REST APIs (the v1 product) and
// the configuration around them. Iterate `restApis()` for every REST API
// across enabled regions (with its stages, methods, authorizers, and
// resource policies), `apiKeys()` for the API keys callers can use,
// `usagePlans()` for throttling and quota plans bound to API stages, and
// `vpcLinks()` for private integration links into VPCs. HTTP and WebSocket
// APIs (the v2 product) live under `aws.apigatewayv2`.
aws.apigateway @defaults("restApis") {
  // List of REST APIs across all enabled regions in the account
  restApis() []aws.apigateway.restapi
  // List of API keys across all enabled regions in the account
  apiKeys() []aws.apigateway.apiKey
  // List of usage plans across all enabled regions in the account
  usagePlans() []aws.apigateway.usagePlan
  // List of VPC links across all enabled regions in the account
  vpcLinks() []aws.apigateway.vpcLink
}

// Amazon API Gateway REST API
private aws.apigateway.restapi @defaults("name id") {
  // ARN for the REST API
  arn string
  // Unique ID for the REST API
  id string
  // Name for the REST API
  name string
  // Time when the REST API was created
  createdDate time
  // Description for the REST API
  description string
  // Stages for the REST API
  stages() []aws.apigateway.stage
  // Authorizers for the REST API
  authorizers() []aws.apigateway.authorizer
  // Request validators for the REST API
  requestValidators() []aws.apigateway.requestValidator
  // Deployments of the REST API
  deployments() []aws.apigateway.deployment
  // Region where the REST API exists
  region string
  // Tags for the REST API
  tags map[string]string
  // CloudFormation stack that manages this API, if any
  cloudformationStack() aws.cloudformation.stack
  // Infrastructure-management system that owns this API
  //
  // Inferred from the provenance tags AWS injects on managed resources (for example cloudformation, elasticbeanstalk, eks). Empty when the API is unmanaged or managed by a tool that leaves no recognizable tag.
  managedBy() string
  // Source of the API key for metering requests (HEADER or AUTHORIZER)
  apiKeySource string
  // Whether the default execute-api endpoint is disabled
  disableExecuteApiEndpoint bool
  // Endpoint types for the REST API (EDGE, REGIONAL, PRIVATE)
  endpointTypes []string
  // VPC endpoint IDs associated with a PRIVATE REST API
  endpointVpcEndpointIds []string
  // Minimum payload size in bytes for compression (0 to enable for all, -1 if disabled)
  minimumCompressionSize int
  // Supported binary media types
  binaryMediaTypes []string
  // Version identifier for the API
  version string
  // TLS version and cipher suite for the API
  //
  // One of: TLS_1_0, TLS_1_2, SecurityPolicy_TLS13_1_3_2025_09, SecurityPolicy_TLS13_1_3_FIPS_2025_09, SecurityPolicy_TLS13_1_2_PFS_PQ_2025_09, SecurityPolicy_TLS13_1_2_FIPS_PQ_2025_09, SecurityPolicy_TLS13_1_2_FIPS_PFS_PQ_2025_09, SecurityPolicy_TLS13_1_2_PQ_2025_09, SecurityPolicy_TLS13_1_2_2021_06, SecurityPolicy_TLS13_2025_EDGE, SecurityPolicy_TLS12_PFS_2025_EDGE, SecurityPolicy_TLS12_2018_EDGE.
  securityPolicy string
  // Resource policy for the API (JSON string)
  policy string
}

// Amazon API Gateway REST API stages
private aws.apigateway.stage @defaults("arn") {
  // ARN for the REST API stage
  arn string
  // Name for the stage
  name string
  // Whether tracing is enabled for the stage
  tracingEnabled bool
  // Description for the stage
  description string
  // ID of the deployment the stage is attached to
  deploymentId string
  // Method settings for the stage
  methodSettings dict
  // Whether a cache cluster is enabled for the stage
  cacheClusterEnabled bool
  // Size of the cache cluster (0.5, 1.6, 6.1, 13.5, 28.4, 58.2, 118, 237)
  cacheClusterSize string
  // Status of the cache cluster
  cacheClusterStatus string
  // Client certificate ID for mutual TLS with backend
  clientCertificateId string
  // WAF web ACL associated with the stage
  webAcl() aws.waf.acl
  // ARN of the WAF web ACL associated with the stage
  //
  // Deprecated in favor of `webAcl()`.
  webAclArn @maturity("deprecated") string
  // Time when the stage was created
  createdAt time
  // Time when the stage was last updated
  lastUpdatedAt time
  // Documentation version associated with the stage
  documentationVersion string
  // Stage variables
  variables map[string]string
  // Tags for the stage
  tags map[string]string
}

// Amazon API Gateway authorizer
private aws.apigateway.authorizer @defaults("name type restApiId") {
  // ARN for the authorizer (synthetic — API Gateway authorizers do not have a native ARN)
  arn string
  // Identifier of the authorizer
  id string
  // Name of the authorizer
  name string
  // Type of authorizer (TOKEN, REQUEST, COGNITO_USER_POOLS)
  type string
  // Optional customer-defined auth type used in OpenAPI imports/exports
  authType string
  // Identifier of the REST API the authorizer belongs to
  restApiId string
  // ARN of the IAM role API Gateway assumes to invoke the authorizer; null for resource-based Lambda permissions
  authorizerCredentials string
  // IAM role API Gateway assumes to invoke the authorizer
  iamRole() aws.iam.role
  // URI of the authorizer (Lambda invocation URI for TOKEN/REQUEST authorizers)
  authorizerUri string
  // Lambda function backing the authorizer (parsed from authorizerUri; null for COGNITO_USER_POOLS)
  lambdaFunction() aws.lambda.function
  // TTL in seconds of cached authorizer results; 0 disables caching
  authorizerResultTtlInSeconds int
  // Identity source mapping expression(s) used to look up the authorizer cache key
  identitySource string
  // Validation expression for the incoming identity token (TOKEN authorizers); regex matched against aud claim for COGNITO_USER_POOLS
  identityValidationExpression string
  // Cognito user pool ARNs for COGNITO_USER_POOLS authorizers
  providerArns []string
  // Cognito user pools backing the authorizer (COGNITO_USER_POOLS only)
  userPools() []aws.cognito.userPool
  // Region where the authorizer exists
  region string
}

// Amazon API Gateway request validator
private aws.apigateway.requestValidator @defaults("name restApiId") {
  // ARN for the request validator (synthetic — API Gateway request validators do not have a native ARN)
  arn string
  // Identifier of the request validator
  id string
  // Name of the request validator
  name string
  // Identifier of the REST API the validator belongs to
  restApiId string
  // Whether the request body is validated against the configured Model schema
  validateRequestBody bool
  // Whether request parameters are validated
  validateRequestParameters bool
  // Region where the request validator exists
  region string
}

// Deployment of an API Gateway REST API
//
// Examine a single deployment of a REST API: when it was created, its
// description, and a snapshot of the API methods it captured. The deployment
// history records when each version of the API was pushed live, which is the
// change provenance for the API. Select by the deployment `id` within a REST
// API.
private aws.apigateway.deployment @defaults("id createdDate") {
  // Identifier of the deployment
  id string
  // Identifier of the REST API the deployment belongs to
  restApiId string
  // Time when the deployment was created
  createdDate time
  // Description of the deployment
  description string
  // Snapshot of the API methods captured at deployment time, keyed by resource path then HTTP method
  apiSummary dict
  // Region where the deployment exists
  region string
}

// Amazon API Gateway API key
private aws.apigateway.apiKey @defaults("name id enabled") {
  // ARN for the API key
  arn string
  // Identifier of the API key
  id string
  // Name of the API key
  name string
  // Description of the API key
  description string
  // Whether the API key can be used by callers
  enabled bool
  // Marketplace customer identifier when integrating with the AWS SaaS Marketplace
  customerId string
  // Stages associated with the API key (formatted as `{restApiId}/{stageName}`)
  stageKeys []string
  // Time when the API key was created
  createdDate time
  // Time when the API key was last updated
  lastUpdatedDate time
  // Tags for the API key
  tags map[string]string
  // Region where the API key exists
  region string
}

// Amazon API Gateway usage plan
private aws.apigateway.usagePlan @defaults("name id") {
  // ARN for the usage plan
  arn string
  // Identifier of the usage plan
  id string
  // Name of the usage plan
  name string
  // Description of the usage plan
  description string
  // AWS Marketplace product code associated with the plan
  productCode string
  // Associated API stages (each entry has apiId, stage, and per-method throttle settings)
  apiStages []dict
  // Quota limit — the target maximum number of permitted requests per period; -1 if unset
  quotaLimit int
  // Quota offset — requests subtracted from the limit in the initial period; -1 if unset
  quotaOffset int
  // Quota period (DAY, WEEK, MONTH); empty if unset
  quotaPeriod string
  // Throttle burst limit — request burst rate; -1 if unset
  throttleBurstLimit int
  // Throttle rate limit — steady-state request rate per second; -1 if unset
  throttleRateLimit float
  // Tags for the usage plan
  tags map[string]string
  // Region where the usage plan exists
  region string
}

// Amazon API Gateway VPC link
private aws.apigateway.vpcLink @defaults("name id status") {
  // ARN for the VPC link
  arn string
  // Identifier of the VPC link
  id string
  // Name of the VPC link
  name string
  // Description of the VPC link
  description string
  // Status of the VPC link (AVAILABLE, PENDING, DELETING, FAILED)
  status string
  // Description of the VPC link status
  statusMessage string
  // ARNs of the network load balancers targeted by the VPC link
  targetArns []string
  // Network load balancers targeted by the VPC link
  targets() []aws.elb.loadbalancer
  // Tags for the VPC link
  tags map[string]string
  // Region where the VPC link exists
  region string
}

// Amazon API Gateway v2 (HTTP and WebSocket APIs)
//
// Use the v2 namespace to enumerate HTTP and WebSocket APIs separately
// from the REST APIs surfaced under aws.apigateway. Iterate `apis()` to
// get every v2 API in the account across configured regions; on each
// api, traverse its `stages()`, `routes()`, and `authorizers()` for the
// security configuration that determines which callers can reach which
// route. Use `domainNames()` for per-region custom-domain entries — the
// best place to audit ACM cert mappings, mTLS authentication, and
// domain routing modes.
aws.apigatewayv2 @defaults("apis") {
  // HTTP and WebSocket APIs across all configured regions
  apis() []aws.apigatewayv2.api
  // Custom domain names registered with the v2 service
  domainNames() []aws.apigatewayv2.domainName
}

// HTTP or WebSocket API in API Gateway v2
//
// Examine an HTTP or WebSocket API along with its stages, routes, and
// authorizers. Use the apiId field as the selection key — for example
// `aws.apigatewayv2.api(apiId: "abc123xyz")`. The `protocolType` field
// disambiguates HTTP versus WebSocket; for WebSocket APIs the
// `routeSelectionExpression` is meaningful (it picks a route from the
// incoming frame), while HTTP APIs use route keys directly.
private aws.apigatewayv2.api @defaults("apiId name protocolType") {
  // API ID
  apiId string
  // ARN of the API
  arn string
  // Friendly name of the API
  name string
  // Protocol of the API: HTTP or WEBSOCKET
  protocolType string
  // Region where the API exists
  region string
  // Description of the API
  description string
  // Default endpoint URL the service publishes for the API
  apiEndpoint string
  // Whether the default execute-api endpoint is disabled
  disableExecuteApiEndpoint bool
  // Whether request schema validation is disabled
  disableSchemaValidation bool
  // API key selection expression (e.g. `$request.header.x-api-key`)
  apiKeySelectionExpression string
  // Route selection expression (WebSocket APIs)
  routeSelectionExpression string
  // CORS configuration for HTTP APIs
  //
  // Keys: allowMethods, allowHeaders, allowOrigins, allowCredentials, exposeHeaders, maxAge.
  // Null when CORS is not configured.
  corsConfiguration dict
  // IP address type configured on the API (ipv4 or dualstack)
  ipAddressType string
  // Whether the API is owned and managed by another AWS service
  apiGatewayManaged bool
  // OpenAPI version reported by the import that created the API
  version string
  // Stages deployed for the API
  stages() []aws.apigatewayv2.stage
  // Routes configured on the API
  routes() []aws.apigatewayv2.route
  // Authorizers configured on the API
  authorizers() []aws.apigatewayv2.authorizer
  // Tags on the API
  tags map[string]string
  // Date the API was created
  createdAt time
}

// Stage of an API Gateway v2 API
//
// Examine a deployed stage — the named environment that exposes a
// particular deployment of the parent API. Selection key is the
// composite of api id and stage name. The `accessLogSettings` and
// `defaultRouteSettings` fields drive logging and throttling audits;
// the `routeSettings` map holds per-route overrides.
private aws.apigatewayv2.stage @defaults("stageName apiId") {
  // Stage name
  stageName string
  // API ID the stage belongs to
  apiId string
  // Region where the stage exists
  region string
  // API the stage belongs to
  api() aws.apigatewayv2.api
  // Description of the stage
  description string
  // Whether changes to routes auto-deploy
  autoDeploy bool
  // Deployment ID currently associated with the stage
  deploymentId string
  // Client certificate ID used for mutual TLS
  clientCertificateId string
  // Stage variables passed to integrations as `$stageVariables`
  stageVariables map[string]string
  // Default per-route settings
  //
  // Keys: throttlingBurstLimit, throttlingRateLimit, detailedMetricsEnabled, dataTraceEnabled, loggingLevel.
  defaultRouteSettings dict
  // Per-route setting overrides keyed by route key
  routeSettings dict
  // Access-log destination and format, or null when access logging is off
  accessLogSettings dict
  // Whether the stage is owned and managed by another AWS service
  apiGatewayManaged bool
  // Status message of the most recent deployment
  lastDeploymentStatusMessage string
  // Tags on the stage
  tags map[string]string
  // Date the stage was created
  createdAt time
  // Date the stage was last updated
  updatedAt time
}

// Route in an API Gateway v2 API
//
// Examine the mapping from an incoming request (HTTP method+path, or
// WebSocket route-selection value) to its integration target. Selection
// key is the composite of api id and route id. The `authorizationType`
// and `authorizerId` fields are the audit-relevant entry points for who
// is allowed to reach the route.
private aws.apigatewayv2.route @defaults("routeKey apiId authorizationType") {
  // Route ID
  routeId string
  // API ID the route belongs to
  apiId string
  // Region where the route exists
  region string
  // API the route belongs to
  api() aws.apigatewayv2.api
  // Route key
  //
  // For HTTP APIs: `METHOD /path`. For WebSocket APIs: the route value matched against the parent api's routeSelectionExpression.
  routeKey string
  // Integration target reference (typically `integrations/{integrationId}`)
  target string
  // Authorization type: NONE, AWS_IAM, CUSTOM, JWT
  authorizationType string
  // Authorizer ID resolved on the parent api when authorizationType is JWT or CUSTOM
  authorizerId string
  // Authorization scopes required (JWT routes)
  authorizationScopes []string
  // Whether an API key is required to invoke the route
  apiKeyRequired bool
  // Operation name used in OpenAPI imports
  operationName string
  // Request models keyed by content type (HTTP) or selection (WebSocket)
  requestModels map[string]string
  // Whether the route is owned and managed by another AWS service
  apiGatewayManaged bool
  // Whether the route is publicly invocable (no authorizer — authorization type NONE)
  isPublic() bool
}

// Authorizer in an API Gateway v2 API
//
// Examine an authorizer that validates requests before they reach a
// route. Selection key is the composite of api id and authorizer id.
// The `authorizerType` field determines how the rest of the
// configuration is interpreted — JWT uses `jwtConfiguration`, REQUEST
// uses `authorizerUri` and `identitySource`.
private aws.apigatewayv2.authorizer @defaults("name authorizerType apiId") {
  // Authorizer ID
  authorizerId string
  // API ID the authorizer belongs to
  apiId string
  // Region where the authorizer exists
  region string
  // API the authorizer belongs to
  api() aws.apigatewayv2.api
  // Friendly name of the authorizer
  name string
  // Authorizer type: REQUEST or JWT
  authorizerType string
  // ARN of the IAM role API Gateway assumes to invoke a Lambda authorizer
  authorizerCredentialsArn string
  // Lambda function ARN invoked to authorize requests (REQUEST type)
  authorizerUri string
  // Lambda authorizer payload-format version (1.0 or 2.0)
  authorizerPayloadFormatVersion string
  // TTL for cached authorizer results, in seconds
  authorizerResultTtlInSeconds int
  // Whether the Lambda authorizer can return a simple iam-policy-free response
  enableSimpleResponses bool
  // Identity sources used to look up the caller (e.g. `$request.header.Authorization`)
  identitySource []string
  // Regex used to validate the identity source value (REQUEST type)
  identityValidationExpression string
  // JWT configuration: audience (list of allowed `aud` values) and issuer URL
  jwtConfiguration dict
}

// Custom domain registered with API Gateway v2
//
// Examine a custom domain mapped to one or more v2 APIs. Selection key
// is the domain name. Inspect `domainNameConfigurations` for the ACM
// certificate ARN, security policy, and endpoint type per
// configuration; `mutualTlsAuthentication` for client-cert-required
// audits; and `routingMode` to see whether traffic is routed by api
// mappings or routing rules.
private aws.apigatewayv2.domainName @defaults("domainName routingMode") {
  // Domain name
  domainName string
  // ARN of the domain
  arn string
  // Region where the domain is registered
  region string
  // Routing mode: API_MAPPING_ONLY or ROUTING_RULE_THEN_API_MAPPING
  routingMode string
  // API mapping selection expression
  apiMappingSelectionExpression string
  // Per-endpoint configurations
  //
  // Each entry contains apiGatewayDomainName, certificateArn, certificateName,
  // certificateUploadDate, domainNameStatus, domainNameStatusMessage,
  // endpointType (REGIONAL or EDGE), hostedZoneId, ipAddressType,
  // ownershipVerificationCertificateArn, and securityPolicy (TLS_1_0 or TLS_1_2).
  domainNameConfigurations []dict
  // Mutual TLS configuration
  //
  // Keys: truststoreUri, truststoreVersion, truststoreWarnings. Null when mTLS is not configured.
  mutualTlsAuthentication dict
  // Tags on the domain
  tags map[string]string
}

// AWS Lake Formation
//
// Use the Lake Formation namespace to audit how data-lake access is governed
// across all enabled regions. Iterate `settings()` for the
// per-region governance configuration — the data lake administrators, the
// default database and table permissions granted to new resources (the
// signal for whether the lake falls back to open IAM access or enforces Lake
// Formation grants), the trusted resource owners, and the external
// data-filtering settings. Iterate `permissions()` for every Lake Formation
// grant (principal, resource, and the actions allowed, with or without grant
// option). Iterate `resources()` for every S3 location registered with Lake
// Formation, along with the IAM role used to access it.
aws.lakeformation {
  // Per-region Lake Formation data lake settings
  settings() []aws.lakeformation.dataLakeSettings
  // Lake Formation permission grants
  permissions() []aws.lakeformation.permission
  // S3 locations registered with Lake Formation
  resources() []aws.lakeformation.resource
}

// AWS Lake Formation data lake settings
//
// Examine the Lake Formation governance configuration for one region. Each
// settings record is selected by its region — for example
// `aws.lakeformation.dataLakeSettings(region: "us-east-1")` — and exposes the
// data lake administrators, the default permissions handed to newly created
// databases and tables, the trusted resource owners, and the external
// data-filtering controls. A `createDatabaseDefaultPermissions` or
// `createTableDefaultPermissions` entry granting `ALL` to the
// `IAM_ALLOWED_PRINCIPALS` group means new resources fall back to IAM-based
// access rather than Lake Formation grants.
private aws.lakeformation.dataLakeSettings @defaults("region") {
  // Region these settings apply to
  region string
  // IAM principals designated as Lake Formation data lake administrators
  admins []string
  // IAM principals designated as read-only data lake administrators
  readOnlyAdmins []string
  // AWS account IDs whose resources can be shared into this account without IAM permissions
  trustedResourceOwners []string
  // Whether third-party engines are allowed to access data managed by Lake Formation
  allowExternalDataFiltering bool
  // Whether third-party engines are allowed full-table access to data managed by Lake Formation
  allowFullTableExternalDataAccess bool
  // Default permissions granted on databases created in the catalog
  //
  // Each entry shape: `{principal: "<identifier>", permissions: ["<permission>", ...]}`. An entry granting ALL to IAM_ALLOWED_PRINCIPALS means new databases use IAM access rather than Lake Formation grants.
  createDatabaseDefaultPermissions []dict
  // Default permissions granted on tables created in the catalog
  //
  // Each entry shape: `{principal: "<identifier>", permissions: ["<permission>", ...]}`. An entry granting ALL to IAM_ALLOWED_PRINCIPALS means new tables use IAM access rather than Lake Formation grants.
  createTableDefaultPermissions []dict
  // Session tag values authorized for use in external data filtering
  authorizedSessionTagValueList []string
  // Key-value parameters configured for the data lake
  parameters map[string]string
}

// AWS Lake Formation permission grant
//
// Examine a single Lake Formation grant — the binding of a principal to a set
// of actions on a catalog resource. Each grant exposes the principal it is
// granted to, the resource it applies to, and the permissions allowed, along
// with the subset that the principal may further grant to others.
private aws.lakeformation.permission @defaults("principal region") {
  // Region the grant applies to
  region string
  // Principal the permissions are granted to (an IAM ARN, account ID, or the IAM_ALLOWED_PRINCIPALS group)
  principal string
  // Catalog resource the grant applies to
  //
  // Shape mirrors the Lake Formation resource selector and varies by resource kind: one of `catalog`, `database`, `table`, `tableWithColumns`, `dataLocation`, `dataCellsFilter`, `lfTag`, `lfTagPolicy`, or `lfTagExpression`.
  resource dict
  // Actions the principal is allowed on the resource
  //
  // For example ALL, SELECT, ALTER, DROP, INSERT, DELETE, DESCRIBE, CREATE_DATABASE, CREATE_TABLE, or DATA_LOCATION_ACCESS.
  permissions []string
  // Subset of the actions that the principal may grant to other principals
  permissionsWithGrantOption []string
  // When the grant was last updated
  lastUpdated time
  // Principal that last updated the grant
  lastUpdatedBy string
}

// AWS Lake Formation registered resource
//
// Examine an S3 location registered with Lake Formation. Each resource is
// keyed by its ARN — for example
// `aws.lakeformation.resource(arn: "arn:aws:s3:::my-data-lake-bucket")` — and
// exposes the IAM role Lake Formation assumes to access the location and the
// access modes enabled for it.
private aws.lakeformation.resource @defaults("arn region") {
  // ARN of the registered resource (an S3 location)
  arn string
  // Region the resource is registered in
  region string
  // IAM role Lake Formation assumes to access the registered location
  iamRole() aws.iam.role
  // Whether the registered location uses a federated, hybrid access mode
  withFederation bool
  // Whether both Lake Formation permissions and IAM permissions are honored for the location
  hybridAccessEnabled bool
  // Whether privileged access is enabled for the registered location
  withPrivilegedAccess bool
  // When the resource registration was last modified
  lastModified time
}

// AWS Lambda
//
// Use the Lambda namespace to enumerate serverless functions and the
// building blocks around them. Iterate `functions()` for every Lambda
// function across enabled regions (with its runtime, handler, package type,
// IAM execution role, environment variables, KMS key, VPC configuration,
// concurrency settings, code signing config, and resource policy),
// `layers()` for shared Lambda layers, and `eventSourceMappings()` for the
// event source mappings that connect functions to Kinesis, DynamoDB
// Streams, SQS, MSK, MQ, and self-managed Kafka.
aws.lambda {
  // List of Lambda functions across all regions in the account
  functions() []aws.lambda.function
  // List of Lambda layers across all regions in the account
  layers() []aws.lambda.layer
  // List of event source mappings across all regions in the account
  eventSourceMappings() []aws.lambda.eventSourceMapping
}

// AWS Lambda function
private aws.lambda.function @defaults("arn") {
  // ARN of the function
  arn string
  // Name of the function
  name string
  // Runtime environment for the function
  runtime string
  // Concurrency limit for the function
  concurrency() int
  // Target ARN of the dead-letter queue config
  dlqTargetArn string
  // Recursive loop detection mode, either "Allow" or "Terminate"
  recursiveLoop() string
  // Policy for the function
  policy() dict
  // Parsed statements from the function resource policy
  policyStatements() []aws.iam.policyStatement
  // Whether the resource policy grants public access (a wildcard principal with no scoping conditions)
  isPublic() bool
  // Whether the resource policy grants access to any principal
  //
  // True when an Allow statement grants a wildcard principal (`*`) without a
  // scoping condition on `aws:SourceArn`, `aws:SourceAccount`, or
  // `aws:PrincipalOrgID`. False when the function has no resource policy.
  allowsPublicAccess() bool
  // Raw VPC configuration for the Lambda function
  //
  // Deprecated in favor of `vpc()`, `subnets()`, and `securityGroups()`.
  vpcConfig @maturity("deprecated") dict
  // VPC the Lambda function is connected to
  vpc() aws.vpc
  // Subnets the Lambda function is connected to
  subnets() []aws.vpc.subnet
  // Security groups associated with the Lambda function
  securityGroups() []aws.ec2.securitygroup
  // Region where the function exists
  region string
  // Tags for the function
  tags() map[string]string
  // CloudFormation stack that manages this function, if any
  cloudformationStack() aws.cloudformation.stack
  // Infrastructure-management system that owns this function
  //
  // Inferred from the provenance tags AWS injects on managed resources (for example cloudformation, elasticbeanstalk, eks). Empty when the function is unmanaged or managed by a tool that leaves no recognizable tag.
  managedBy() string
  // Instruction set architectures supported by the function (x86_64, arm64)
  architectures []string
  // Size of the /tmp directory in MB (512-10240)
  ephemeralStorageSize int
  // Amount of memory available to the function at runtime in MB
  memorySize int
  // IAM execution role for the function
  role() aws.iam.role
  // Maximum execution time in seconds before the function is stopped (1-900)
  timeout int
  // Function entry point handler (e.g., index.handler)
  handler string
  // AWS X-Ray tracing mode for the function (Active or PassThrough)
  tracingMode string
  // Deployment package type (Zip or Image)
  packageType string
  // SHA-256 hash of the function deployment package
  codeSha256 string
  // Latest revision of the function's configuration and code, updated on every change
  revisionId string
  // ARN of the resolved managed runtime version the function runs on
  //
  // Identifies the exact patched build of the managed runtime, distinct from runtimeManagementConfig, which only reports the update mode. Empty for OS-only runtimes and container-image functions.
  runtimeVersionArn string
  // Human-readable description of the function
  description string
  // When the function was last updated
  lastModifiedAt time
  // Function URL configuration (null if no URL is configured)
  urlConfig() aws.lambda.function.urlConfig
  // Authentication type of the function URL, empty if no URL is configured
  //
  // One of AWS_IAM or NONE, or an empty string when the function has no URL
  // configured. NONE means the function URL is publicly invocable without
  // authentication.
  urlConfigAuthType() string
  // Current state of the function (Active, Inactive, Pending, Failed, Deactivating, Deactivated, ActiveNonInvocable, Deleting)
  state string
  // Size of the function deployment package in bytes
  codeSize int

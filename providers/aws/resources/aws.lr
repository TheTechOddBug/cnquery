  // Volume name
  name string
  // Associated file system ID
  fileSystemId string
  // Volume type (ONTAP or OPENZFS)
  volumeType string
  // Lifecycle status (AVAILABLE, CREATING, DELETING, FAILED, MISCONFIGURED, PENDING)
  lifecycle string

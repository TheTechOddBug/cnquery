  // Maximum number of application versions to retain (0 if the max-count rule is not configured)
  versionLifecycleMaxCount int
  // Maximum number of days to retain application versions (0 if the max-age rule is not configured)
  versionLifecycleMaxAgeDays int
  // Whether deleted application versions matched by the max-count rule have their source bundle removed from Amazon S3
  versionLifecycleMaxCountDeleteSourceFromS3 bool
  // Whether deleted application versions matched by the max-age rule have their source bundle removed from Amazon S3
  versionLifecycleMaxAgeDeleteSourceFromS3 bool
  // ARN of the IAM service role Elastic Beanstalk assumes to apply lifecycle settings
  versionLifecycleServiceRoleArn string
  // IAM service role Elastic Beanstalk assumes to apply lifecycle settings
  versionLifecycleServiceIamRole() aws.iam.role
  // Application versions for this application
  applicationVersions() []aws.elasticbeanstalk.applicationVersion
  // Tags for the application
  tags() map[string]string
}

// AWS Elastic Beanstalk application version

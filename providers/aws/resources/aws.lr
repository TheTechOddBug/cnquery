// Amazon EventBridge Scheduler schedule
private aws.eventbridge.schedule @defaults("arn name state") {
  // ARN of the schedule
  arn string
  // Name of the schedule
  name string
  // Region of the schedule
  region string
  // Schedule group name
  groupName string
  // State: ENABLED or DISABLED
  state string
  // Schedule expression (cron, rate, or at)
  scheduleExpression() string
  // IANA timezone the schedule expression is evaluated in (e.g. "America/Los_Angeles")
  scheduleExpressionTimezone() string
  // Date and time the schedule starts being evaluated (null when not bounded)
  startDate() time
  // Date and time the schedule stops being evaluated (null when not bounded)
  endDate() time
  // Behavior after the last invocation: NONE or DELETE — DELETE makes the schedule self-destructing
  actionAfterCompletion() string
  // Description of the schedule
  description() string
  // Target ARN
  targetArn() string
  // IAM role used for the target. Audit signal: an over-broad role makes the schedule a privilege-escalation primitive.
  iamRole() aws.iam.role
  // KMS key wrapping Target.Input at rest in scheduler-managed storage. Not the key used by the target service.
  kmsKey() aws.kms.key
  // Schedule group this schedule belongs to
  group() aws.eventbridge.scheduleGroup
  // Dead-letter queue receiving failed invocation events (always SQS per AWS Scheduler SDK; null when not configured)
  deadLetterQueue() aws.sqs.queue
  // Retry policy applied to invocation failures
  retryPolicy() aws.eventbridge.schedule.retryPolicy
  // Flexible time window (jitter) configuration
  flexibleTimeWindow() aws.eventbridge.schedule.flexibleTimeWindow
  // Target invoked by this schedule (Lambda, SQS, SNS, ECS task, etc.) and its input
  target() aws.eventbridge.schedule.target
  // Tags for the schedule
  tags() map[string]string
  // Date the schedule was created
  createdAt time
  // Date the schedule was last modified
  updatedAt time
}

// Retry policy for failed schedule invocations
private aws.eventbridge.schedule.retryPolicy @defaults("maximumRetryAttempts maximumEventAgeInSeconds") {
  // Maximum age of an event before it is dropped (seconds; default 86400)
  maximumEventAgeInSeconds int
  // Maximum number of retry attempts before sending to the dead-letter queue (default 185)
  maximumRetryAttempts int
}

// Flexible time window (jitter) configuration
private aws.eventbridge.schedule.flexibleTimeWindow @defaults("mode maximumWindowInMinutes") {
  // OFF (exact-time invocation) or FLEXIBLE (jittered window)
  mode string
  // Maximum jitter window in minutes (1-15 when mode is FLEXIBLE; 0 when OFF)
  maximumWindowInMinutes int
}

// Schedule target invocation configuration
private aws.eventbridge.schedule.target @defaults("targetType arn") {
  // Raw target ARN
  arn string
  // IAM role assumed when invoking the target (raw ARN; parent schedule also exposes typed iamRole())
  roleArn string
  // Target.Input payload sent to the target. WARNING: may contain sensitive data — audit carefully for credentials, tokens, or PII.
  input string
  // Target type discriminator: lambda, sqs, sns, stepFunction, kinesis, firehose, ecs, eventBridge, sagemakerPipeline, codebuild, universal, unknown
  targetType string

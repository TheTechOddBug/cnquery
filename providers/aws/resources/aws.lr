// AWS Batch job
//
// Examine a single Batch job's runtime state. Use the `arn` field as the
// selection key — for example
// `aws.batch.job(arn: "arn:aws:batch:us-east-1:111122223333:job/abc123")`.
// Each row surfaces the job's lifecycle (status, status reason, created /
// started / stopped timestamps), typed references to the parent
// `jobQueue()` and `jobDefinition()`, the `computeEnvironment()` the job
// landed on, container/array/multi-node attempts, dependencies, and
// retry/timeout settings. The parent collection only enumerates
// non-terminal statuses by default (SUBMITTED, PENDING, RUNNABLE,
// STARTING, RUNNING).
aws.batch.job @defaults("id name status jobQueueArn") {
  // Job ID
  id string
  // Job ARN
  arn string
  // Job name
  name string
  // Region of the job
  region string
  // Status: SUBMITTED, PENDING, RUNNABLE, STARTING, RUNNING, SUCCEEDED, FAILED
  status string
  // Reason the job entered its current status
  statusReason string
  // Job creation time
  createdAt time
  // Time the job moved to STARTING
  startedAt time
  // Time the job reached a terminal state
  stoppedAt time
  // Job definition ARN (revision-scoped)
  jobDefinitionArn string
  // Typed job definition reference
  jobDefinition() aws.batch.jobDefinition
  // Job queue ARN
  jobQueueArn string
  // Typed job queue reference
  jobQueue() aws.batch.jobQueue
  // Scheduling priority override (higher wins in fair-share queues)
  schedulingPriority int
  // Fair-share identifier selecting which share weight applies
  shareIdentifier string
  // Whether definition tags were propagated to the ECS task
  propagateTags bool
  // Parameter substitution values at submission time
  parameters map[string]string
  // Effective runtime container state (command, env, resourceRequirements, logStreamName). Includes any overrides applied at submission.
  container dict
  // Stream name in CloudWatch Logs where the job wrote logs
  logStreamName string
  // Job dependencies with typed job references
  dependsOn() []aws.batch.job.dependency
  // Attempt history (exit code, reason, timestamps per attempt)
  attempts []dict
  // Array job properties (size, index, status summary). Null for non-array jobs.
  arrayProperties dict
  // Multi-node-parallel child-node details. Null for non-MNP jobs.
  nodeDetails dict
  // Whether the job has been cancelled
  isCancelled bool
  // Whether the job has been terminated
  isTerminated bool
  // Tags for the job
  tags map[string]string
}

// AWS Batch job dependency (jobId is natural key, resolved via typed job() ref)
private aws.batch.job.dependency @defaults("jobId type") {
  // Dependent job ID
  jobId string
  // Dependency type: N_TO_N or SEQUENTIAL
  type string

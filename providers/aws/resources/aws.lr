  // List of Glue Data Catalog resource policies (account-level and resource-scoped)
  resourcePolicies() []aws.glue.resourcePolicy
}

// AWS Glue crawler
//
// Examine a single crawler that populates the Data Catalog with table
// definitions from one or more data stores. Surfaces the crawl `targets`
// (S3, JDBC, MongoDB, DynamoDB, Catalog, Delta, Iceberg, Hudi), the
// `schedule`, the `state` (READY/RUNNING/STOPPING), the IAM `role` it
// assumes (resolvable via `iamRole()`), the optional Glue security
// configuration encrypting its logs and bookmarks (resolvable via
// `glueSecurityConfiguration()`), the `schemaChangePolicy`,
// `recrawlPolicy`, `lineageConfiguration`, `lakeFormationConfiguration`,
// `tablePrefix`, and the `lastCrawl` summary.
private aws.glue.crawler @defaults("name state databaseName region") {
  // Name of the crawler
  name string
  // ARN of the crawler
  arn string
  // ARN or name of the IAM role used by the crawler
  role string
  // IAM role assumed by the crawler when accessing data stores and writing to the Data Catalog
  iamRole() aws.iam.role
  // Name of the database where results are stored
  databaseName string
  // Description of the crawler
  description string
  // Targets for the crawler
  //
  // Holds the data stores the crawler scans, keyed by target type: `S3Targets`, `JdbcTargets`, `MongoDBTargets`, `DynamoDBTargets`, `CatalogTargets`, `DeltaTargets`, `IcebergTargets`, and `HudiTargets`. Each entry contains the connection name, paths/tables, exclusions, and target-specific options.
  targets dict
  // Schedule for the crawler (cron expression)
  schedule string
  // Classifiers used by the crawler
  classifiers []string
  // Schema change policy ({UpdateBehavior: LOG|UPDATE_IN_DATABASE, DeleteBehavior: LOG|DELETE_FROM_DATABASE|DEPRECATE_IN_DATABASE})
  schemaChangePolicy dict
  // Recrawl policy
  //
  // Controls whether the crawler scans the entire dataset or only newly added folders. Shape: {RecrawlBehavior: CRAWL_EVERYTHING|CRAWL_NEW_FOLDERS_ONLY|CRAWL_EVENT_MODE}.
  recrawlPolicy dict
  // Lineage configuration that controls whether data lineage is captured for the crawler ({CrawlerLineageSettings: ENABLE|DISABLE})
  lineageConfiguration dict
  // Lake Formation configuration
  //
  // Controls whether the crawler uses Lake Formation credentials instead of the IAM role. Shape: {UseLakeFormationCredentials: bool, AccountId: string}.
  lakeFormationConfiguration dict
  // Current state of the crawler: READY, RUNNING, or STOPPING
  state string
  // Crawler-versioned JSON configuration string (Version, CrawlerOutput, Grouping, etc.)
  configuration string
  // Prefix added to the names of tables that are created
  tablePrefix string
  // Name of the Glue security configuration applied to the crawler
  securityConfiguration string
  // Glue security configuration applied to the crawler
  glueSecurityConfiguration() aws.glue.securityConfiguration
  // Total time elapsed since the last crawl began, in seconds (0 when the crawler is idle)
  crawlElapsedTime int
  // Status of the last crawl
  //
  // Includes the last crawl status (SUCCEEDED, CANCELLED, FAILED), error message, log group, log stream, message prefix, and start time.
  lastCrawl dict
  // Monotonically incrementing crawler version, bumped each time the crawler definition is updated
  version int
  // Date and time the crawler was created
  createdAt time
  // Date and time the crawler was last updated
  updatedAt time
  // Region where the crawler exists
  region string
  // Tags for the crawler
  tags() map[string]string
}

// AWS Glue ETL job
//
// Examine an ETL job definition. Surfaces the `command` that drives the
// job (script location, Python/Ray runtime), the IAM `role` assumed at
// runtime (resolvable via `iamRole()`), the worker fleet (`workerType`,
// `numberOfWorkers`, or DPU-based `maxCapacity`), the `glueVersion` and
// `executionClass`, the `executionProperty.MaxConcurrentRuns`, the
// `notificationProperty.NotifyDelayAfter`, the optional Glue security
// configuration encrypting logs and bookmarks (resolvable via
// `glueSecurityConfiguration()`), and the `defaultArguments` passed to
// every run.
private aws.glue.job @defaults("name region") {
  // Name of the job
  name string
  // ARN of the job
  arn string
  // Description of the job
  description string
  // ARN of the IAM role associated with this job
  role string
  // IAM role assumed by the job at runtime
  iamRole() aws.iam.role
  // Command that the job runs ({Name: glueetl|gluestreaming|pythonshell, ScriptLocation: s3://..., PythonVersion: 2|3, Runtime: Ray runtime version})
  command dict
  // Maximum number of times to retry this job if it fails
  maxRetries int
  // Job timeout in minutes
  timeout int
  // Glue version used by this job (2.0, 3.0, 4.0, 5.0, ...)
  glueVersion string
  // Number of workers allocated to this job
  numberOfWorkers int
  // Type of predefined worker allocated: Standard, G.1X, G.2X, G.4X, G.8X, G.025X, or Z.2X
  workerType string
  // Maximum number of Glue data processing units (DPUs) allocated when MaxCapacity is set instead of WorkerType/NumberOfWorkers
  maxCapacity float

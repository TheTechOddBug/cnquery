  // Desired size of the group
  desiredCapacity int
  // List of availability zones associated with the group
  availabilityZones []string
  // List of availability zone IDs associated with the group
  availabilityZoneIds []string
  // Capacity distribution across Availability Zones (CapacityDistributionStrategy, CapacityReservationTarget)
  availabilityZoneDistribution dict
  // Availability Zone impairment policy (ImpairedZoneHealthCheckBehavior, ZonalShiftEnabled)
  availabilityZoneImpairmentPolicy dict
  // Whether Capacity Rebalancing is enabled
  capacityRebalance bool
  // Capacity reservation specification (CapacityReservationPreference, CapacityReservationTarget)
  capacityReservationSpecification dict
  // Reserved user context string
  context string
  // Duration of the default instance warmup, in seconds
  defaultInstanceWarmup int
  // Deletion protection setting: "none" or "prevent-force-deletion"
  deletionProtection string
  // Metrics enabled for the group (each entry has Metric and Granularity fields)
  enabledMetrics []dict

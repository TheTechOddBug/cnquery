//
// Examine a single Secrets Manager instance. The instance is keyed
// by its UUID `id` and exposes the `name`, status, API URL, secrets
// engine, configured ACL list, and the number of secrets stored.
private stackit.secretsManager.instance @defaults("id name state") {
  init(id? string)
  // Instance UUID
  id string
  // Instance name
  name string
  // Lifecycle state (CREATING, CREATED, UPDATING, FAILED, DELETING, …)
  state string
  // API URL
  apiUrl string
  // Engine type (e.g., kv)
  secretsEngine string
  // Number of secrets stored in the instance
  secretCount int
  // When instance creation started
  creationStartedAt time
  // When instance creation finished
  creationFinishedAt time
  // ACL CIDRs allowed to connect
  acls() []string
}


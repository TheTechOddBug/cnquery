  cfSpaceGuid string
  // Dashboard URL for the DBaaS UI (empty if not provisioned)
  dashboardUrl string
  // Image / engine version
  imageUrl string
  // Connection parameters returned by the API
  parameters dict
  // Whether the instance accepts connections from any address

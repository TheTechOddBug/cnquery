  // Users and groups the method applies to
  //
  // Each entry has an `id` (the user or group object ID) and a `targetType`
  // of `user` or `group`.
  includeTargets []dict
  // Users and groups excluded from the method
  //
  // Each entry has an `id` (the user or group object ID) and a `targetType`
  // of `user` or `group`.
  excludeTargets []dict
  // Whether attestation is enforced for FIDO2 security keys
  isAttestationEnforced bool
  // Whether users can self-service register FIDO2 security keys
  isSelfServiceRegistrationAllowed bool
  // Whether AAGUID key restrictions are enforced
  keyRestrictionsEnforced bool
  // How the AAGUID list is applied (allow, block)
  keyRestrictionsEnforcementType string
  // The AAGUIDs that the key restriction allows or blocks
  keyRestrictionsAaGuids []string
}

// Microsoft Authenticator authentication method configuration
//
// Tenant policy for Microsoft Authenticator authentication. Reports whether

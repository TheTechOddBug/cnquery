// Retention Policy
private ms365.exchangeonline.retentionPolicy @defaults("name retentionPolicyTagLinks retentionId") {
  // Policy name
  name string
  // Retention policy tag links
  retentionPolicyTagLinks []string
  // Retention ID
  retentionId string
}

// Exchange Online mail flow transport rule
//
// Examine a single mail flow rule returned by Get-TransportRule, selected by
// `name`. Each rule reports its evaluation `priority` (lower numbers run
// first), enablement `state`, operating `mode`, and administrator `comments`.
// The full condition and action set of a rule remains available through the
// deprecated `transportRule` dictionary.
private ms365.exchangeonline.transportRule @defaults("name state priority") {
  // The rule identity
  identity string
  // The rule name
  name string
  // Rule evaluation priority (lower runs first)
  priority int
  // Whether the rule is enabled or disabled
  state string
  // Rule operating mode (Enforce, Audit, or AuditAndNotify)
  mode string
  // Administrator comments on the rule
  comments string
}

// Exchange Online anti-phishing policy
//
// Examine a single anti-phishing policy returned by Get-AntiPhishPolicy,
// selected by `name`. Each policy reports whether it is `enabled`, the
// `phishThresholdLevel` (1-4, where higher is more aggressive), the
// mailbox-intelligence, spoof-intelligence, and impersonation-protection
// toggles, and the actions taken when impersonation is detected or sender
// authentication fails.
private ms365.exchangeonline.antiPhishPolicy @defaults("name enabled phishThresholdLevel") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether the policy is enabled
  enabled bool
  // Phishing detection aggressiveness (1-4, higher is more aggressive)
  phishThresholdLevel int
  // Whether mailbox intelligence is enabled
  enableMailboxIntelligence bool
  // Whether mailbox intelligence impersonation protection is enabled
  enableMailboxIntelligenceProtection bool
  // Whether spoof intelligence is enabled
  enableSpoofIntelligence bool
  // Whether first-contact safety tips are shown
  enableFirstContactSafetyTips bool
  // Whether protected-user impersonation protection is enabled
  enableTargetedUserProtection bool
  // Whether protected-domain impersonation protection is enabled
  enableTargetedDomainsProtection bool
  // Whether impersonation protection covers all organization domains
  enableOrganizationDomainsProtection bool
  // Action for detected user impersonation (for example Quarantine or MoveToJmf)
  targetedUserProtectionAction string
  // Action for detected domain impersonation (for example Quarantine or MoveToJmf)
  targetedDomainProtectionAction string
  // Action when sender authentication (SPF/DKIM/DMARC) fails
  authenticationFailAction string
}

// Exchange Online Safe Links policy
//
// Examine a single Defender for Office 365 Safe Links policy returned by
// Get-SafeLinksPolicy, selected by `name`. Each policy reports which
// workloads URL scanning covers (email, Teams, and Office apps), whether
// clicks are tracked, whether users may click through to the original URL,
// and whether URL rewriting is disabled.
private ms365.exchangeonline.safeLinksPolicy @defaults("name enableSafeLinksForEmail") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether Safe Links scanning applies to email
  enableSafeLinksForEmail bool
  // Whether Safe Links scanning applies to Microsoft Teams
  enableSafeLinksForTeams bool
  // Whether Safe Links scanning applies to Office apps
  enableSafeLinksForOffice bool
  // Whether user clicks are tracked
  trackClicks bool
  // Whether users can click through to the original URL
  allowClickThrough bool
  // Whether URLs are scanned in real time
  scanUrls bool
  // Whether scanning applies to internal senders
  enableForInternalSenders bool
  // Whether messages are held until scanning completes
  deliverMessageAfterScan bool
  // Whether URL rewriting is disabled
  disableUrlRewrite bool
}

// Exchange Online Safe Attachments policy
//
// Examine a single Defender for Office 365 Safe Attachments policy returned
// by Get-SafeAttachmentPolicy, selected by `name`. Each policy reports
// whether it is enabled, the `action` taken on detected malware (Allow,
// Block, Replace, or DynamicDelivery), and whether and where detected
// messages are redirected.
private ms365.exchangeonline.safeAttachmentPolicy @defaults("name enable action") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether the policy is enabled
  enable bool
  // Action for detected malware (Allow, Block, Replace, or DynamicDelivery)
  action string
  // Whether detected messages are redirected
  redirect bool
  // Address detected messages are redirected to
  redirectAddress string
}

// Exchange Online malware filter policy
//
// Examine a single malware filter policy returned by Get-MalwareFilterPolicy,
// selected by `name`. Each policy reports whether the common-attachment file
// filter is enabled and the `fileTypes` it blocks, whether zero-hour auto
// purge is on, and whether internal- and external-sender admin notifications
// are sent.
private ms365.exchangeonline.malwareFilterPolicy @defaults("name enableFileFilter zapEnabled") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether the common attachment file filter is enabled
  enableFileFilter bool
  // Whether zero-hour auto purge (ZAP) is enabled
  zapEnabled bool
  // Whether internal-sender admin notifications are enabled
  enableInternalSenderAdminNotifications bool
  // Whether external-sender admin notifications are enabled
  enableExternalSenderAdminNotifications bool
  // File extensions blocked by the common attachment filter
  fileTypes []string
}

// Exchange Online hosted content (anti-spam) filter policy
//
// Examine a single inbound anti-spam policy returned by
// Get-HostedContentFilterPolicy, selected by `name`. Each policy reports the
// actions taken on spam, high-confidence spam, phishing, high-confidence
// phishing, and bulk mail, the `bulkThreshold` (1-9), whether end-user spam
// notifications are sent, and the always-allowed and always-blocked sender
// domains.
private ms365.exchangeonline.hostedContentFilterPolicy @defaults("name spamAction highConfidenceSpamAction") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Action applied to spam
  spamAction string
  // Action applied to high-confidence spam
  highConfidenceSpamAction string
  // Action applied to phishing
  phishSpamAction string
  // Action applied to high-confidence phishing
  highConfidencePhishAction string
  // Action applied to bulk mail
  bulkSpamAction string
  // Bulk complaint level threshold (1-9)
  bulkThreshold int
  // Whether end-user spam notifications are enabled
  enableEndUserSpamNotifications bool
  // Sender domains always treated as allowed
  allowedSenderDomains []string
  // Sender domains always treated as blocked
  blockedSenderDomains []string
}

// Exchange Online hosted outbound spam filter policy
//
// Examine a single outbound spam policy returned by
// Get-HostedOutboundSpamFilterPolicy, selected by `name`. Each policy reports
// the external, internal, and daily recipient limits, the action taken when a
// limit is reached, the automatic email-forwarding mode (Automatic, On, or
// Off), and whether suspicious outbound mail is bcc'd and notified.
private ms365.exchangeonline.hostedOutboundSpamFilterPolicy @defaults("name autoForwardingMode") {
  // The policy identity
  identity string
  // The policy name
  name string
  // External recipient limit per hour
  recipientLimitExternalPerHour int
  // Internal recipient limit per hour
  recipientLimitInternalPerHour int
  // Recipient limit per day
  recipientLimitPerDay int
  // Action taken when a sending limit is reached
  actionWhenThresholdReached string
  // Automatic external email forwarding mode (Automatic, On, or Off)
  autoForwardingMode string
  // Whether suspicious outbound mail is blind-copied to a designated address
  bccSuspiciousOutboundMail bool
  // Whether notifications are sent for outbound spam
  notifyOutboundSpam bool
}

// Exchange Online DKIM signing configuration
//
// Examine the DKIM signing configuration for one accepted domain, returned by
// Get-DkimSigningConfig and selected by `domain`. The `enabled` field reports
// whether outbound DKIM signing is on for the domain, and `status` reports its
// current state.
private ms365.exchangeonline.dkimSigningConfig @defaults("domain enabled status") {
  // The configuration identity
  identity string
  // The domain the configuration applies to
  domain string
  // Whether DKIM signing is enabled for the domain
  enabled bool
  // The configuration status
  status string
}

// Exchange Online authentication policy
//
// Examine a single authentication policy returned by Get-AuthenticationPolicy,
// selected by `name`. Each policy exposes one boolean per connection protocol
// (ActiveSync, Autodiscover, IMAP, MAPI, offline address book, the Outlook
// service, POP, remote PowerShell, reporting web services, Outlook RPC,
// authenticated SMTP, and Exchange Web Services) indicating whether legacy
// basic authentication is still allowed for it.
private ms365.exchangeonline.authenticationPolicy @defaults("name allowBasicAuthSmtp") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether basic authentication is allowed for Exchange ActiveSync
  allowBasicAuthActiveSync bool
  // Whether basic authentication is allowed for Autodiscover
  allowBasicAuthAutodiscover bool
  // Whether basic authentication is allowed for IMAP
  allowBasicAuthImap bool
  // Whether basic authentication is allowed for MAPI
  allowBasicAuthMapi bool
  // Whether basic authentication is allowed for the offline address book
  allowBasicAuthOfflineAddressBook bool
  // Whether basic authentication is allowed for the Outlook service
  allowBasicAuthOutlookService bool
  // Whether basic authentication is allowed for POP3
  allowBasicAuthPop bool
  // Whether basic authentication is allowed for remote PowerShell
  allowBasicAuthPowershell bool
  // Whether basic authentication is allowed for reporting web services
  allowBasicAuthReportingWebServices bool
  // Whether basic authentication is allowed for Outlook RPC
  allowBasicAuthRpc bool
  // Whether basic authentication is allowed for authenticated SMTP
  allowBasicAuthSmtp bool
  // Whether basic authentication is allowed for Exchange Web Services
  allowBasicAuthWebServices bool
}

// Exchange Online Outlook on the web mailbox policy
//
// Examine a single Outlook on the web mailbox policy returned by
// Get-OwaMailboxPolicy, selected by `name`. Each policy reports whether
// third-party storage providers are available, whether direct file access is
// enabled on public and private computers, whether forced save applies to
// filtered attachments, and the allowed and blocked attachment file types.
private ms365.exchangeonline.owaMailboxPolicy @defaults("name additionalStorageProvidersAvailable") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether third-party storage providers are available in Outlook on the web
  additionalStorageProvidersAvailable bool
  // Whether direct file access is enabled on public computers
  directFileAccessOnPublicComputersEnabled bool
  // Whether direct file access is enabled on private computers
  directFileAccessOnPrivateComputersEnabled bool
  // Whether forced save is applied to filtered attachments
  forceSaveAttachmentFilteringEnabled bool
  // File types users are allowed to open or save
  allowedFileTypes []string
  // File types users are blocked from opening or saving
  blockedFileTypes []string
}

// Exchange Online remote domain configuration
//
// Examine the mail-handling configuration for one remote domain returned by
// Get-RemoteDomain, selected by `name`. The `domainName` field reports the
// domain it applies to, and further fields report the out-of-office reply type
// allowed and whether automatic replies, automatic forwarding, delivery
// reports, and non-delivery reports are permitted to that domain.
private ms365.exchangeonline.remoteDomain @defaults("name domainName autoForwardEnabled") {
  // The remote domain identity
  identity string
  // The remote domain name
  name string
  // The domain the configuration applies to
  domainName string
  // Out-of-office reply type allowed to the domain (External, ExternalLegacy, or InternalLegacy)
  allowedOOFType string
  // Whether automatic replies are allowed to the domain
  autoReplyEnabled bool
  // Whether automatic forwarding is allowed to the domain
  autoForwardEnabled bool
  // Whether delivery reports are allowed to the domain
  deliveryReportEnabled bool
  // Whether non-delivery reports are allowed to the domain
  ndrEnabled bool
  // Whether the domain is treated as internal
  isInternal bool
}

// Exchange Online quarantine policy
//
// Examine a single quarantine policy returned by Get-QuarantinePolicy,
// selected by `name`. Each policy reports the
// `endUserQuarantinePermissionsValue` bitmask that controls what recipients
// may do with their quarantined messages, and whether end-user spam
// (quarantine) notifications are enabled.
private ms365.exchangeonline.quarantinePolicy @defaults("name esnEnabled") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Bitmask of end-user permissions granted for quarantined messages
  endUserQuarantinePermissionsValue int
  // Whether end-user spam notifications (quarantine notifications) are enabled
  esnEnabled bool
}

// Exchange Online Defender for Office 365 ATP policy
//
// Examine the Defender for Office 365 advanced threat protection policy
// returned by Get-AtpPolicyForO365, selected by `name`. It reports whether
// Safe Documents is enabled, whether users may bypass it to open a file, and
// whether ATP protection is enabled for SharePoint, OneDrive, and Teams.
private ms365.exchangeonline.atpPolicyForO365 @defaults("name enableSafeDocs") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether Safe Documents is enabled
  enableSafeDocs bool
  // Whether users can bypass Safe Documents and open the file
  allowSafeDocsOpen bool
  // Whether ATP is enabled for SharePoint, OneDrive, and Teams
  enableATPForSPOTeamsODB bool
}

// Exchange Online sharing policy
//
// Examine a single calendar and contact sharing policy returned by
// Get-SharingPolicy, selected by `name`. The `enabled` field reports whether
// the policy is active, `isDefault` reports whether it is the tenant default,
// and the `domains` field lists which external domains may be shared with and
// at what level.
private ms365.exchangeonline.sharingPolicy @defaults("name enabled isDefault") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether the policy is enabled
  enabled bool
  // Whether this is the default sharing policy
  isDefault bool
  // Domains and sharing actions defined by the policy
  domains []string
}

// Exchange Online role assignment policy
//
// Examine a single role assignment policy returned by
// Get-RoleAssignmentPolicy, selected by `name`. Each policy reports whether
// it is the tenant default, its `description`, and the management roles it
// assigns to mailboxes (for example MyProfileInformation or MyBaseOptions),
// which govern the self-service capabilities users have over their own
// mailbox.
private ms365.exchangeonline.roleAssignmentPolicy @defaults("name isDefault") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether this is the default role assignment policy
  isDefault bool
  // The policy description
  description string
  // Management roles assigned by the policy
  assignedRoles []string
}

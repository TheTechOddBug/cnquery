  // Profile description
  description string
  // Windows feature update version the profile deploys
  featureUpdateVersion string
  // Display name of the deployable content
  deployableContentDisplayName string
  // Whether the feature update is offered as an optional install
  installFeatureUpdatesOptional bool
  // Date the deployed version reaches end of support
  endOfSupportDate time
  // Role scope tag IDs assigned to the profile
  roleScopeTagIds []string
  // Date and time the profile was created
  createdDateTime time
  // Date and time the profile was last modified
  lastModifiedDateTime time
}

// Microsoft Intune Windows quality update profile
//
// Windows quality update deployment profile, selected by its `id`. These
// profiles drive expedited quality (security) update rollout;
// `expeditedQualityUpdateRelease` identifies the release to expedite and
// `expeditedDaysUntilForcedReboot` how long users may defer the reboot.
private microsoft.devicemanagement.windowsQualityUpdateProfile @defaults("displayName") {
  // Profile ID
  id string
  // Profile display name
  displayName string
  // Profile description
  description string
  // Display name of the deployable content
  deployableContentDisplayName string
  // Display name of the release date
  releaseDateDisplayName string
  // Quality update release to expedite
  expeditedQualityUpdateRelease string
  // Days before a reboot is forced after an expedited update
  expeditedDaysUntilForcedReboot int
  // Role scope tag IDs assigned to the profile
  roleScopeTagIds []string
  // Date and time the profile was created
  createdDateTime time
  // Date and time the profile was last modified
  lastModifiedDateTime time
}

// Microsoft Intune managed app configuration policy
//
// App configuration policy that delivers settings to managed apps (MAM),

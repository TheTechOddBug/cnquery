  riskDetail string
  // The risk state (none, confirmedSafe, remediated, dismissed, atRisk, confirmedCompromised, unknownFutureValue)
  riskState string
  // The aggregated risk level (none, low, medium, high, hidden, unknownFutureValue)
  riskLevelAggregated string
  // The risk level during sign-in (none, low, medium, high, hidden, unknownFutureValue)
  riskLevelDuringSignIn string
  // The risk event types associated with the sign-in
  riskEventTypes []string
  // The sign-in error code; 0 indicates the sign-in succeeded
  statusErrorCode int
  // The reason behind a failed sign-in
  statusFailureReason string
  // The city the sign-in originated from
  city string
  // The state or province the sign-in originated from
  state string
  // The country or region the sign-in originated from
  countryOrRegion string

// Microsoft Intune settings catalog policy
//
// Settings catalog (unified configuration) policy, selected by its `id`.
// Metadata covers the `name`, `description`, the `platforms` and
// `technologies` the policy targets, the number of configured settings
// (`settingCount`), `roleScopeTagIds`, and whether it `isAssigned`. When the
// policy was created from a template, `templateId`, `templateDisplayName`, and
// `templateFamily` identify it. Use `settings` to read the individual
// configured settings; each entry reports its `settingDefinitionId`,
// `settingType`, and `value`.
private microsoft.devicemanagement.configurationPolicy @defaults("name platforms technologies settingCount") {
  // Policy ID
  id string
  // Policy name
  name string
  // Policy description
  description string
  // Platforms the policy targets (for example windows10, iOS, macOS, android, linux)
  platforms string
  // Technologies that enforce the policy (for example mdm, configManager, microsoftSense)
  technologies string
  // Whether the policy is assigned to any group
  isAssigned bool
  // Number of settings configured by the policy
  settingCount int
  // Role scope tag IDs assigned to the policy
  roleScopeTagIds []string
  // Template ID when the policy was created from a template, empty otherwise
  templateId string
  // Template display name when the policy was created from a template
  templateDisplayName string
  // Template family when the policy was created from a template (for example endpointSecurityAntivirus, baseline)
  templateFamily string
  // Date and time the policy was created
  createdDateTime time
  // Date and time the policy was last modified
  lastModifiedDateTime time
  // Configured settings, each a dictionary of settingDefinitionId, settingType, and value
  settings() []dict
}

// Microsoft Intune Mobile Threat Defense connector
//
// Integration between Intune and a Mobile Threat Defense (MTD) partner,
// selected by its `id`. `partnerState` and `lastHeartbeatDateTime`
// report whether the partner is connected and responsive, and the per-platform
// flags show where the connection is active: `androidEnabled`, `iosEnabled`,
// and `windowsEnabled` gate device-compliance evaluation, the
// `*MobileApplicationManagementEnabled` flags gate app protection, and the
// `*DeviceBlockedOnMissingPartnerData` flags decide whether devices are blocked
// when the partner has not reported. `microsoftDefenderForEndpointAttachEnabled`
// indicates the Defender for Endpoint connector is attached.
private microsoft.devicemanagement.mobileThreatDefenseConnector @defaults("id partnerState lastHeartbeatDateTime") {
  // Connector ID
  id string
  // Partner connection state (available, enabled, unavailable, unresponsive, unknown, notSetUp)
  partnerState string
  // Date and time the partner last reported a heartbeat
  lastHeartbeatDateTime time
  // Days without a heartbeat before the partner is treated as unresponsive
  partnerUnresponsivenessThresholdInDays int
  // Whether devices on an unsupported OS version are blocked
  partnerUnsupportedOsVersionBlocked bool
  // Whether the partner evaluates compliance for Android devices
  androidEnabled bool
  // Whether the partner evaluates compliance for iOS devices
  iosEnabled bool
  // Whether the partner evaluates compliance for Windows devices
  windowsEnabled bool
  // Whether the partner provides app protection for Android
  androidMobileApplicationManagementEnabled bool
  // Whether the partner provides app protection for iOS
  iosMobileApplicationManagementEnabled bool
  // Whether Android devices are blocked when the partner has no data on them
  androidDeviceBlockedOnMissingPartnerData bool
  // Whether iOS devices are blocked when the partner has no data on them
  iosDeviceBlockedOnMissingPartnerData bool
  // Whether Windows devices are blocked when the partner has no data on them
  windowsDeviceBlockedOnMissingPartnerData bool
  // Whether the Microsoft Defender for Endpoint connector is attached
  microsoftDefenderForEndpointAttachEnabled bool
  // Whether the partner may collect metadata of managed iOS apps
  allowPartnerToCollectIosApplicationMetadata bool
  // Whether the partner may collect metadata of personal iOS apps
  allowPartnerToCollectIosPersonalApplicationMetadata bool
}

// Microsoft Intune compliance management partner
//
// Device compliance management partner connected to Intune, selected by its
// `id`. `partnerState` and `lastHeartbeatDateTime` report connection health,
// and `androidOnboarded`, `iosOnboarded`, and `macOsOnboarded` show which
// platforms the partner has been onboarded for.
private microsoft.devicemanagement.complianceManagementPartner @defaults("displayName partnerState") {
  // Partner ID
  id string
  // Partner display name
  displayName string
  // Partner connection state (unknown, unavailable, enabled, unresponsive)
  partnerState string
  // Date and time the partner last reported a heartbeat
  lastHeartbeatDateTime time
  // Whether the partner is onboarded for Android
  androidOnboarded bool
  // Whether the partner is onboarded for iOS
  iosOnboarded bool
  // Whether the partner is onboarded for macOS
  macOsOnboarded bool
}

// Microsoft Intune assignment filter
//
// Assignment filter used to narrow which devices a policy or app assignment
// targets, selected by its `id`. The `rule` holds the filter
// expression evaluated against device properties, `platform` reports the
// device platform it applies to, and `assignmentFilterManagementType`
// distinguishes device filters from managed-app filters. A policy assignment
// references a filter through `microsoft.devicemanagement.policyAssignment.filter`.
private microsoft.devicemanagement.assignmentFilter @defaults("displayName platform") {
  // Filter ID
  id string
  // Filter display name
  displayName string
  // Filter description
  description string
  // Device platform the filter applies to
  //
  // For example android, androidForWork, iOS, macOS, windowsPhone81,
  // windows81AndLater, windows10AndLater, or androidWorkProfile.
  platform string
  // Filter rule expression evaluated against device properties
  rule string
  // What the filter manages (devices, apps)
  assignmentFilterManagementType string
  // Role scope tags assigned to the filter
  roleScopeTags []string
  // Date and time the filter was created
  createdDateTime time
  // Date and time the filter was last modified
  lastModifiedDateTime time
}

// Microsoft Intune app protection (MAM) policy
//
// Intune mobile application management policy that protects corporate data
// inside managed apps on iOS and Android, selected by its `id`;
// `platformType` reports which platform it targets. The policy governs
// access protection (`pinRequired`, `minimumPinLength`, `maximumPinRetries`,
// `simplePinBlocked`, `fingerprintBlocked`, `periodOfflineBeforeAccessCheck`),
// data containment (`dataBackupBlocked`, `saveAsBlocked`, `printBlocked`,
// `contactSyncBlocked`, `allowedDataStorageLocations`, the inbound/outbound
// data-transfer levels, and `allowedOutboundClipboardSharingLevel`), the
// required `managedBrowser` behavior, and device-health requirements
// (`deviceComplianceRequired`, `minimumRequiredOsVersion`,
// `minimumRequiredAppVersion`). Use `isAssigned` to spot policies that are
// configured but not targeted at anyone.
private microsoft.devicemanagement.appProtectionPolicy @defaults("displayName platformType pinRequired") {
  // Policy ID
  id string
  // Policy display name
  displayName string
  // Policy description
  description string
  // Platform the policy targets (ios, android)
  platformType string
  // Date and time the policy was created
  createdDateTime time
  // Date and time the policy was last modified
  lastModifiedDateTime time
  // Policy version
  version string
  // Whether the policy is assigned to any group
  isAssigned bool
  // Whether an access PIN is required to use the managed app
  pinRequired bool
  // Minimum number of characters required for the app PIN
  minimumPinLength int
  // Number of PIN retries allowed before the configured action is taken
  maximumPinRetries int
  // Whether simple PINs (for example 1234, 1111) are blocked
  simplePinBlocked bool
  // Required PIN character set (numeric, alphanumericAndSymbol)
  pinCharacterSet string
  // Whether biometric (fingerprint) unlock is blocked in place of the PIN
  fingerprintBlocked bool
  // Whether the app PIN is disabled when the device already has a PIN set
  disableAppPinIfDevicePinIsSet bool
  // Whether organizational credentials are required to use the app
  organizationalCredentialsRequired bool
  // Period a managed app may run offline before an access check is required (ISO 8601 duration)
  periodOfflineBeforeAccessCheck string
  // Period a managed app may run online before an access check is required (ISO 8601 duration)
  periodOnlineBeforeAccessCheck string
  // Period of offline use before protected data is wiped (ISO 8601 duration)
  periodOfflineBeforeWipeIsEnforced string
  // Whether app data backup to iTunes, iCloud, or Android Backup is blocked
  dataBackupBlocked bool
  // Whether device compliance is required for the managed app
  deviceComplianceRequired bool
  // Whether app web content must open in the managed browser
  managedBrowserToOpenLinksRequired bool
  // Whether Save As is blocked in the managed app
  saveAsBlocked bool
  // Whether printing organizational data is blocked
  printBlocked bool
  // Whether contact sync to the native address book is blocked
  contactSyncBlocked bool
  // Data storage locations that organizational data may be saved to
  allowedDataStorageLocations []string
  // Sources organizational data may be transferred in from (allApps, managedApps, none)
  allowedInboundDataTransferSources string
  // Destinations organizational data may be transferred out to (allApps, managedApps, none)
  allowedOutboundDataTransferDestinations string
  // Level at which clipboard content may be shared (allApps, managedAppsWithPasteIn, managedApps, blocked)
  allowedOutboundClipboardSharingLevel string
  // Managed browser the policy enforces (notConfigured, microsoftEdge)
  managedBrowser string
  // Minimum OS version required to use the managed app
  minimumRequiredOsVersion string
  // Minimum app version required to use the managed app
  minimumRequiredAppVersion string
}

// Microsoft Device Enrollment Configuration
private microsoft.devicemanagement.deviceEnrollmentConfiguration @defaults("id displayName configurationType") {
  // Unique identifier for the account
  id string
  // The display name of the device enrollment configuration
  displayName string
  // The description of the device enrollment configuration
  description string
  // Priority is used when a user exists in multiple groups that are assigned enrollment configuration
  priority int
  // Created date time in UTC of the device enrollment configuration
  createdDateTime time
  // Last modified date time in UTC of the device enrollment configuration
  lastModifiedDateTime time
  // The version of the device enrollment configuration
  version int
  // Kind of enrollment configuration this entry represents
  //
  // One of `limit`, `platformRestrictions`, `windowsHelloForBusiness`, or `unknown`. Derived from the configuration's `@odata.type`. `limit` caps the number of devices a user can enroll. `platformRestrictions` allows or blocks enrollment per platform (Android, iOS, macOS, Windows, Windows Mobile). `windowsHelloForBusiness` controls Windows Hello PIN, gesture, and biometric requirements.
  configurationType string
  // Subtype-specific settings, keyed by setting name
  //
  // `limit`-type entries populate `limit` (the device cap). `platformRestrictions`-type entries populate per-platform blocks under `iosRestriction`, `androidRestriction`, `macOSRestriction`, `windowsRestriction`, `windowsMobileRestriction`, each with `platformBlocked`, `personalDeviceEnrollmentBlocked`, `osMinimumVersion`, and `osMaximumVersion`. `windowsHelloForBusiness`-type entries populate `state`, `pinMinimumLength`, `pinMaximumLength`, `pinUppercaseCharactersUsage`, `pinLowercaseCharactersUsage`, `pinSpecialCharactersUsage`, `pinExpirationInDays`, `pinPreviousBlockCount`, `securityDeviceRequired`, `unlockWithBiometricsEnabled`, `enhancedBiometricsState`, and `remotePassportEnabled`.
  settings dict
  // Assignments targeting this enrollment configuration, with each target resolved to its kind, group, and any assignment filter
  policyAssignments []microsoft.devicemanagement.policyAssignment
}

// Microsoft managed device
private microsoft.devicemanagement.manageddevice {
  // Managed device ID
  id string
  // Unique identifier for the user associated with the device
  //
  // Deprecated in favor of user.
  userId @maturity("deprecated") string
  // User associated with the device
  user() microsoft.user
  // Name of the device
  name string
  // Operating system of the device
  operatingSystem string
  // Whether the device is jail broken or rooted
  jailBroken string
  // Operating system version of the device
  osVersion string
  // Whether the device is Exchange ActiveSync activated
  easActivated bool
  // Exchange ActiveSync Id of the device
  easDeviceId string
  // Whether the device is Entra ID (previously Azure AD) registered
  azureADRegistered bool
  // Email(s) for the user associated with the device
  emailAddress string
  // The unique identifier for the Entra ID (previously Azure AD) device
  azureActiveDirectoryDeviceId string
  // Device category display name
  deviceCategoryDisplayName string
  // Device supervised status
  isSupervised bool
  // Device encryption status
  isEncrypted bool
  // Device user principal name
  userPrincipalName string
  // Device model
  model string
  // Device manufacturer
  manufacturer string
  // International Mobile Equipment Identity (IMEI)
  imei string
  // Serial number of the device
  serialNumber string
  // Android security patch level
  androidSecurityPatchLevel string
  // User display name
  userDisplayName string
  // Wi-Fi MAC address
  wiFiMacAddress string
  // Mobile Equipment Identifier (MEID)
  meid string
  // Integrated Circuit Card Identifier (ICCID)
  iccid string
  // Unique Device Identifier (UDID) for iOS and macOS devices
  udid string
  // Notes on the device created by IT
  notes string
  // Ethernet MAC address of the device
  ethernetMacAddress string
  // Name of the enrollment profile assigned to the device
  enrollmentProfileName string
  // Windows Defender protection state of the device
  //
  // Keys include `antiMalwareVersion`, `engineVersion`, `signatureVersion`,
  // `deviceState` (WindowsDeviceHealthState), `productStatus`
  // (WindowsDefenderProductStatus), `malwareProtectionEnabled`,
  // `realTimeProtectionEnabled`, `networkInspectionSystemEnabled`,
  // `tamperProtectionEnabled`, `fullScanRequired`, `fullScanOverdue`,
  // `quickScanOverdue`, `signatureUpdateOverdue`, `rebootRequired`,
  // `isVirtualMachine`, `lastFullScanDateTime`, `lastQuickScanDateTime`,
  // `lastReportedDateTime`, and `detectedMalwareState`, a list of detected
  // threats each with `category`, `severity`, `executionState`, `state`, and
  // `threatState`.
  windowsProtectionState dict
  // Compliance state of the device (compliant, noncompliant, conflict, error, unknown, notApplicable)
  complianceState string
  // Device registration state
  //
  // One of: notRegistered, registered, revoked, keyConflict, approvalPending, certificateReset, notRegisteredPendingEnrollment, unknown.
  deviceRegistrationState string
  // Management agent type (eas, mdm, easMdm, intuneClient, easIntuneClient, configurationManagerClient, etc.)
  managementAgent string
  // Last time the device contacted Intune
  lastSyncDateTime time
  // Available storage in bytes
  freeStorageSpaceInBytes int
  // Total storage in bytes
  totalStorageSpaceInBytes int
  // Date and time that the device was enrolled
  enrolledDateTime time
  // Device enrollment type
  //
  // For example: unknown, userEnrollment, deviceEnrollmentManager, appleBulkWithUser, appleBulkWithoutUser, windowsAzureADJoin, windowsBulkUserless, windowsAutoEnrollment, windowsBulkAzureDomainJoin, windowsCoManagement.
  deviceEnrollmentType string
  // Threat state reported by a Mobile Threat Defense partner
  //
  // One of: unknown, activated, deactivated, secured, lowSeverity, mediumSeverity, highSeverity, unresponsive, compromised, misconfigured.
  partnerReportedThreatState string
  // Phone number of the device
  phoneNumber string
  // Subscriber carrier of the device
  subscriberCarrier string
  // Compliance grace period expiration date and time
  complianceGracePeriodExpirationDateTime time
  // Management certificate expiration date
  managementCertificateExpirationDate time
  // Compliance policy evaluation states, one entry per policy that has been evaluated against this device
  compliancePolicyStates() []microsoft.devicemanagement.manageddevice.policyState
  // Configuration profile evaluation states, one entry per profile that has been evaluated against this device
  configurationStates() []microsoft.devicemanagement.manageddevice.policyState
  // Apps detected as installed on this device
  detectedApps() []microsoft.devicemanagement.detectedapp
}

// Microsoft device configuration
private microsoft.devicemanagement.deviceconfiguration @defaults("id displayName") {
  // Device configuration ID
  id string
  // Device configuration last modify date
  lastModifiedDateTime time
  // Device configuration creation date
  createdDateTime time
  // Device configuration description
  description string
  // Device configuration display name
  displayName string
  // Device configuration version
  version int
  // Raw device configuration properties
  //
  // Deprecated in favor of `settings` and `policyAssignments`.
  properties @maturity("deprecated") dict
  // Assignments targeting this configuration profile, with each target resolved to its kind, group, and any assignment filter
  policyAssignments []microsoft.devicemanagement.policyAssignment
  // Platform this configuration profile targets
  //
  // One of `iOS`, `android`, `androidWorkProfile`, `windows10`, `macOS`, or `unknown`. Derived from the profile's `@odata.type`.
  platformType string
  // Configured profile settings, keyed by setting name
  //
  // Union of platform-specific configuration fields exposed by the profile's `@odata.type`. General-device-configuration profiles populate password/passcode requirements (`passwordRequired` / `passcodeRequired`, `passwordMinimumLength` / `passcodeMinimumLength`, `passwordRequiredType` / `passcodeRequiredType`, `passwordBlockSimple` / `passcodeBlockSimple`, `passwordExpirationDays` / `passcodeExpirationDays`, `passwordMinutesOfInactivityBeforeScreenTimeout` / `passcodeMinutesOfInactivityBeforeScreenTimeout`, `passcodeMinutesOfInactivityBeforeLock`, `passwordSignInFailureCountBeforeFactoryReset`, `passcodeSignInFailureCountBeforeWipe`). Android Work Profile adds work-profile-scoped variants (`workProfilePasswordRequiredType`, `workProfilePasswordMinutesOfInactivityBeforeScreenTimeout`). Windows 10 General Configuration also surfaces device-restriction flags. Profile types that are not "general device configuration" (Wi-Fi, VPN, certificates, custom OMA-URI, etc.) leave this empty — use `policyAssignments` and `displayName` to identify them.
  settings dict
}

// Microsoft device compliance policy
private microsoft.devicemanagement.devicecompliancepolicy @defaults("id displayName platformType") {
  // Device compliance policy ID
  id string
  // Device compliance policy creation date
  createdDateTime time
  // Device compliance policy description
  description string
  // Device compliance policy display name
  displayName string
  // Device compliance policy last modified date
  lastModifiedDateTime time
  // Device compliance policy version
  version int
  // Raw assignment entries, each carrying only its assignment `id`
  //
  // For the resolved target of each assignment (kind, group, and any filter),
  // use `policyAssignments`.
  assignments []dict
  // Raw device compliance policy properties
  //
  // Deprecated in favor of `settings` and `policyAssignments`.
  properties @maturity("deprecated") dict
  // Assignments targeting this compliance policy, with each target resolved to its kind, group, and any assignment filter
  policyAssignments []microsoft.devicemanagement.policyAssignment
  // Platform this compliance policy targets
  //
  // One of `iOS`, `android`, `androidWorkProfile`, `windows10`, `windows10Mobile`, `windows81`, `windowsPhone81`, `macOS`, or `unknown`. Derived from the policy's `@odata.type`.
  platformType string
  // Configured compliance rules, keyed by setting name
  //
  // Union of platform-specific rule fields exposed by the policy's `@odata.type`. Common keys include `passcodeRequired` / `passwordRequired`, `passcodeMinimumLength` / `passwordMinimumLength`, `passcodeRequiredType` / `passwordRequiredType`, `passcodeBlockSimple` / `passwordBlockSimple`, `passcodeExpirationDays` / `passwordExpirationDays`, `passcodeMinutesOfInactivityBeforeLock` / `passwordMinutesOfInactivityBeforeLock`, `storageRequireEncryption`, `osMinimumVersion`, `osMaximumVersion`, `securityBlockJailbrokenDevices`, `deviceThreatProtectionEnabled`, `deviceThreatProtectionRequiredSecurityLevel`, `managedEmailProfileRequired`. iOS-specific keys add `passcodeMinimumCharacterSetCount`, `passcodePreviousPasscodeBlockCount`. Android keys add `minAndroidSecurityPatchLevel`, `securityDisableUsbDebugging`, `securityPreventInstallAppsFromUnknownSources`, `securityRequireGooglePlayServices`, `securityRequireSafetyNetAttestationBasicIntegrity`, `securityRequireSafetyNetAttestationCertifiedDevice`, `securityRequireCompanyPortalAppIntegrity`, `securityRequireUpToDateSecurityProviders`, `securityRequireVerifyApps`. Windows 10 keys add `bitLockerEnabled`, `secureBootEnabled`, `codeIntegrityEnabled`, `earlyLaunchAntiMalwareDriverEnabled`, `requireHealthyDeviceReport`, `passwordRequiredToUnlockFromIdle`, `mobileOsMinimumVersion`, `mobileOsMaximumVersion`. macOS keys add `firewallEnabled`, `firewallBlockAllIncoming`, `firewallEnableStealthMode`, `systemIntegrityProtectionEnabled`.
  settings dict
  // Escalation actions evaluated when the policy is out of compliance
  //
  // Each entry has `ruleName` (e.g., `PasswordRequired`) and `scheduledActionConfigurations` — a list of action items with `actionType` (`notification`, `block`, `retire`, `wipe`, `removeResourceAccessProfiles`, `pushNotification`, `remoteLock`), `gracePeriodHours`, `notificationTemplateId`, and `notificationMessageCCList`.
  scheduledActionsForRule []dict
}

// Assignment of an Intune device management policy
//
// Binding of an Intune policy to the groups, devices, or licensed users it
// targets, recording whether each assignment is an include or an exclude.
// `policyAssignment` is used by compliance policies, configuration profiles,
// endpoint security intents, and mobile apps. `targetType` identifies the
// kind of target
// (`groupAssignmentTarget`, `exclusionGroupAssignmentTarget`,
// `allDevicesAssignmentTarget`, `allLicensedUsersAssignmentTarget`); `groupId`
// is populated only when the target is a group.
private microsoft.devicemanagement.policyAssignment @defaults("id targetType") {
  // Assignment ID
  id string
  // Target kind (groupAssignmentTarget, exclusionGroupAssignmentTarget, allDevicesAssignmentTarget, allLicensedUsersAssignmentTarget)
  targetType string
  // Group ID when the target is a group, empty otherwise
  //
  // Deprecated in favor of group.
  groupId @maturity("deprecated") string
  // Group the assignment targets, when targetType is a group
  group() microsoft.group
  // Whether the assignment excludes the target rather than including it
  excluded bool
  // Assignment filter type (none, include, exclude)
  filterType string
  // Assignment filter ID when a filter is applied, empty otherwise
  //
  // Deprecated in favor of filter.
  filterId @maturity("deprecated") string
  // Assignment filter applied to the target, when one is set
  filter() microsoft.devicemanagement.assignmentFilter
}

// Evaluation state of a single Intune policy on a managed device
//
// Compliance and configuration evaluation results for a managed device, one
// entry per policy. The `state` field gives the aggregate result
// (`compliant`, `nonCompliant`, `conflict`, `error`, `notApplicable`,
// `inGracePeriod`), and `settingStates` lists per-setting outcomes that
// rolled up into it. `sourceType` distinguishes compliance from configuration
// evaluations (`deviceCompliancePolicyState`, `deviceConfigurationState`).
private microsoft.devicemanagement.manageddevice.policyState @defaults("displayName state") {
  // State ID, composed of the parent device and policy IDs
  id string
  // Policy or profile display name
  displayName string
  // Aggregate evaluation state (compliant, nonCompliant, conflict, error, notApplicable, inGracePeriod)
  state string
  // Per-setting evaluation states with the setting definition ID and outcome
  settingStates []dict
  // Source of the evaluation (deviceCompliancePolicyState, deviceConfigurationState)
  sourceType string
  // Platform the policy targets (windows10AndLater, iOS, android, etc.)
  platformType string
  // Setting count
  settingCount int
  // Version of the policy that produced this state
  version int
}

// Endpoint security intent
//
// Endpoint security policies created from Intune templates: antivirus, disk
// encryption, firewall, endpoint detection and response, account protection,
// and attack surface reduction. `templateId` and `templateDisplayName`
// identify which template the intent was created from; `settings` returns the
// configured settings; `assignments` returns the groups and devices it
// targets.
private microsoft.devicemanagement.intent @defaults("id displayName templateDisplayName") {
  // Intent ID
  id string
  // Display name
  displayName string
  // Description
  description string
  // Template ID this intent was created from
  templateId string
  // Display name of the source template
  templateDisplayName string
  // Whether the intent has at least one assignment
  isAssigned bool
  // Last modification date
  lastModifiedDateTime time
  // Settings configured on this intent
  settings() []microsoft.devicemanagement.intent.setting
  // Assignments targeting this intent
  assignments() []microsoft.devicemanagement.policyAssignment
}

// Setting configured on an endpoint security intent
private microsoft.devicemanagement.intent.setting @defaults("definitionId valueJson") {
  // Setting ID
  id string
  // Setting definition ID, such as deviceConfiguration--windows10EndpointProtectionConfiguration_defenderRequireRealTimeMonitoring
  definitionId string
  // Configured value, serialized as JSON
  valueJson string
  // Setting value type, the @odata.type of the value wrapper
  valueType string
}

// Mobile app published to the Intune tenant
//
// Apps published to Intune for deployment to managed devices. Apps include
// store apps, line-of-business apps, web apps, and managed Google Play apps.
// `properties` holds subtype-specific fields keyed by `@odata.type` (for
// example `bundleId`, `productCode`, `appStoreUrl`, `installCommandLine`),
// `publishingState` indicates whether the app is ready for deployment, and
// `assignments` returns the groups it targets.
private microsoft.devicemanagement.mobileapp @defaults("id displayName publisher") {
  // Mobile app ID
  id string
  // App display name
  displayName string
  // App description
  description string
  // Publisher
  publisher string
  // Whether the app is featured in the Company Portal
  isFeatured bool
  // Privacy information URL
  privacyInformationUrl string
  // Information URL
  informationUrl string
  // Publishing state (notPublished, processing, published)
  publishingState string
  // Creation date
  createdDateTime time
  // Last modification date
  lastModifiedDateTime time
  // Subtype-discriminated fields keyed by @odata.type — bundleId / productCode for store apps, appStoreUrl, packageId, installCommandLine, and similar
  properties dict
  // Assignments targeting this app
  assignments() []microsoft.devicemanagement.policyAssignment
}

// App detected as installed on managed devices
//
// Application inventory that Intune builds from managed-device reporting.
// `deviceCount` is the number of devices in the tenant on which Intune has
// detected this app at the given `version`.
private microsoft.devicemanagement.detectedapp @defaults("displayName version deviceCount") {
  // Detected app ID
  id string
  // App display name
  displayName string
  // App version
  version string
  // App size in bytes
  sizeInByte int
  // Number of managed devices with this app installed
  deviceCount int
  // Platform the app was detected on (windows, iOS, android, macOS, unknown)
  platform string
  // Publisher
  publisher string
}

// Windows Autopilot deployment profile
//
// Windows Autopilot deployment profiles that drive zero-touch provisioning.
// The profile sets language, locale, device-name template, and
// the out-of-box experience that end users see during first sign-in;
// `deploymentProfileType` distinguishes Azure AD joined, Hybrid Azure AD
// joined, and self-deploying flows.
private microsoft.devicemanagement.windowsAutopilotDeploymentProfile @defaults("id displayName deploymentProfileType") {
  // Deployment profile ID
  id string
  // Display name
  displayName string
  // Description
  description string
  // Language tag applied during provisioning
  language string
  // Locale tag applied during provisioning
  locale string
  // Device name template, with substitutable tokens such as %SERIAL%
  deviceNameTemplate string
  // Deployment profile kind (azureADJoinedDeploymentProfile, activeDirectoryWindowsAutopilotDeploymentProfile, etc.)
  deploymentProfileType string
  // Whether hardware hashes are collected during provisioning
  extractHardwareHash bool
  // Whether the white-glove (pre-provisioning) flow is enabled
  enableWhiteGlove bool
  // Out-of-box experience settings such as user-type, hide-EULA, hide-privacy-settings, and skip-keyboard-selection
  outOfBoxExperienceSettings dict
  // Number of devices currently assigned to this profile
  assignedDeviceCount int
  // Creation date
  createdDateTime time
  // Last modification date
  lastModifiedDateTime time
}

// Intune RBAC role definition
//
// Intune role-based access control catalog: built-in Microsoft roles plus any
// custom roles defined in the tenant. `rolePermissions` lists the Intune
// resource actions the role grants; `roleScopeTagIds` lists the scope tags the
// role is allowed to operate against.
private microsoft.devicemanagement.roleDefinition @defaults("id displayName isBuiltIn") {
  // Role definition ID
  id string
  // Display name
  displayName string
  // Description
  description string
  // Whether the role is built-in (managed by Microsoft) rather than custom
  isBuiltIn bool
  // Permission grants, each entry listing allowed Intune resource actions
  rolePermissions []dict
  // Scope tag IDs this role is constrained to
  roleScopeTagIds []string
}

// Assignment of an Intune RBAC role to members
//
// Binding of an Intune role to the security groups that receive it and the
// scope tags that constrain where they can act. `members` are the groups that
// receive the role; `scopeMembers` are the groups whose objects the role
// applies to; `resourceScopes` is the set of scope-tag IDs the assignment is
// limited to.
private microsoft.devicemanagement.roleAssignment @defaults("id displayName roleDefinitionId") {
  // Role assignment ID
  id string
  // Display name
  displayName string
  // Description
  description string
  // ID of the role definition this assignment grants
  roleDefinitionId string
  // Group IDs that receive the role
  members []string
  // Group IDs whose objects the role applies to
  scopeMembers []string
  // Scope tag IDs the assignment is limited to
  resourceScopes []string
}

// Intune RBAC role scope tag
//
// Scope tags used to partition Intune resources by team or region. Tags are
// attached to managed devices, policies, and apps, and constrain which
// administrators can see and modify which objects.
private microsoft.devicemanagement.roleScopeTag @defaults("id displayName isBuiltIn") {
  // Scope tag ID
  id string
  // Display name
  displayName string
  // Description
  description string
  // Whether the scope tag is built-in (the "Default" tag with ID "0")
  isBuiltIn bool
}

// Microsoft Power BI
//
// Use this namespace to examine tenant-wide Power BI (Microsoft Fabric)
// governance posture. Exposes the tenant feature switches that control
// sharing and export (`tenantSettings`), the `workspaces` provisioned in the
// tenant and who has access to them, the `capacities` backing those
// workspaces, and the reports and dashboards that have broad exposure —
// either `publishedToWeb` or `sharedToWholeOrganization`. Data is collected
// through the Power BI admin REST APIs, which require the service principal to
// be granted read-only admin API access in the Power BI tenant settings.
microsoft.powerbi {
  // Tenant-wide Power BI feature switches
  tenantSettings() []microsoft.powerbi.tenantSetting
  // Workspaces provisioned in the tenant
  workspaces() []microsoft.powerbi.workspace
  // Premium and Fabric capacities
  capacities() []microsoft.powerbi.capacity
  // Reports and dashboards published to the public web
  publishedToWeb() []microsoft.powerbi.artifactAccess
  // Reports and dashboards shared with the entire organization
  sharedToWholeOrganization() []microsoft.powerbi.artifactAccess
}

// Power BI tenant feature switch
//
// Examine a single tenant-level Power BI governance setting — for example
// whether publishing reports to the web is allowed, whether users can export
// data, or whether service principals may call Power BI APIs. The `name`
// field is the API setting name (for example `PublishToWeb`) and selects the
// setting; `enabled` reports whether the feature is turned on; and when a
// setting is scoped to specific security groups, `enabledSecurityGroups`
// lists them.
private microsoft.powerbi.tenantSetting @defaults("name title enabled") {
  // API name of the setting, for example PublishToWeb
  name string
  // Human-readable title of the setting
  title string
  // Whether the feature is enabled
  enabled bool
  // Whether the setting can be scoped to specific security groups
  canSpecifySecurityGroups bool
  // Grouping the setting belongs to in the admin portal
  tenantSettingGroup string
  // Security groups the setting applies to when scoped, each with graphId and name
  enabledSecurityGroups []dict
}

// Power BI workspace
//
// Examine a Power BI workspace (also called a group) provisioned in the
// tenant. Select a workspace by its `id`. Each workspace reports its `name`,
// `type` (Workspace, PersonalGroup, or Group), `state` (Active, Deleted, or
// Orphaned), whether it runs on a dedicated capacity, the `capacity` backing
// it, and the `users` granted access along with their roles.
private microsoft.powerbi.workspace @defaults("id name type state") {
  // Workspace ID
  id string
  // Workspace name
  name string
  // Workspace type
  //
  // One of Workspace, PersonalGroup, or Group.
  type string
  // Workspace state
  //
  // One of Active, Deleted, Orphaned, or Removing.
  state string
  // Whether the workspace is assigned to a dedicated (Premium or Fabric) capacity
  isOnDedicatedCapacity bool
  // Whether the workspace is read-only
  isReadOnly bool
  // Workspace description
  description string
  // Capacity backing the workspace, when assigned to a dedicated capacity
  capacity() microsoft.powerbi.capacity
  // Users and groups granted access to the workspace
  users() []microsoft.powerbi.workspace.user
}

// Power BI workspace access grant
//
// Examine a single user, group, or service principal granted access to a
// Power BI workspace, including the `accessRight` (Admin, Member, Contributor,
// or Viewer) and the `principalType` of the grantee.
private microsoft.powerbi.workspace.user @defaults("emailAddress accessRight principalType") {
  // Display name of the grantee
  displayName string
  // Email address of the grantee, when the grantee is a user
  emailAddress string
  // Identifier of the grantee
  identifier string
  // Type of grantee
  //
  // One of User, Group, or App.
  principalType string
  // Access right granted
  //
  // One of Admin, Member, Contributor, or Viewer.
  accessRight string
  // Microsoft Graph object ID of the grantee
  graphId string
}

// Power BI capacity
//
// Examine a Premium or Fabric capacity provisioned in the tenant. Select a
// capacity by its `id`. Each capacity reports its `displayName`, `sku`,
// `state`, `region`, and the `admins` who manage it.
private microsoft.powerbi.capacity @defaults("id displayName sku state") {
  // Capacity ID
  id string
  // Capacity display name
  displayName string
  // Capacity SKU, for example P1 or F64
  sku string
  // Capacity state, for example Active
  state string
  // Region the capacity is provisioned in
  region string
  // Email addresses of the capacity administrators
  admins []string
}

// Power BI broadly shared artifact
//
// Examine a Power BI report, dashboard, dataset, or other artifact that has
// broad sharing in effect — either published to the public web or shared with
// the entire organization. Each entry reports the artifact's `displayName` and
// `artifactType`, the `accessRight` granted, the `shareType`, and who shared
// it.
private microsoft.powerbi.artifactAccess @defaults("artifactId displayName artifactType shareType") {
  // Artifact ID
  artifactId string
  // Artifact display name
  displayName string
  // Artifact type
  //
  // One of Report, Dashboard, Dataset, Dataflow, or similar.
  artifactType string
  // Access right granted, for example View
  accessRight string
  // Share type, for example Published or Shared
  shareType string
  // Email address of the user who shared the artifact
  sharerEmailAddress string
  // Display name of the user who shared the artifact
  sharerDisplayName string
}

// Microsoft 365 Exchange Online
//
// Exchange Online configuration and security settings for the tenant,
// covering mail filtering policies (`malwareFilterPolicies`,
// `hostedContentFilterPolicies`, `antiPhishPolicies`, `hostedOutboundSpamFilterPolicies`),
// transport rules, Safe Links and Safe Attachments policies, DKIM signing
// configuration, authentication policies, Outlook on the web mailbox policies,
// mailbox audit settings, quarantine policies, retention policies, journal
// rules, report submission policies, Teams protection policies, and
// organization-wide configuration.
ms365.exchangeonline {
  // Malware filter policies as raw dictionaries
  //
  // Deprecated in favor of malwareFilterPolicies.
  malwareFilterPolicy() @maturity("deprecated") []dict
  // Malware filter policies
  //
  // Each policy exposes fields for common-attachment filtering, zero-hour auto purge,
  // and admin notification settings.
  malwareFilterPolicies() []ms365.exchangeonline.malwareFilterPolicyEntry
  // Hosted outbound spam filter policies as raw dictionaries
  //
  // Deprecated in favor of hostedOutboundSpamFilterPolicies.
  hostedOutboundSpamFilterPolicy() @maturity("deprecated") []dict
  // Outbound spam filter policies
  //
  // Each policy exposes fields for the sending limits and the automatic
  // email-forwarding mode.
  hostedOutboundSpamFilterPolicies() []ms365.exchangeonline.hostedOutboundSpamFilterPolicyEntry
  // Hosted content (anti-spam) filter policies as raw dictionaries
  //
  // Deprecated in favor of hostedContentFilterPolicies.
  hostedContentFilterPolicy() @maturity("deprecated") []dict
  // Inbound anti-spam policies
  //
  // Each policy exposes fields for the spam, phishing, and bulk-mail actions and the
  // allowed and blocked sender domains.
  hostedContentFilterPolicies() []ms365.exchangeonline.hostedContentFilterPolicyEntry
  // Transport rules as raw dictionaries
  //
  // Deprecated in favor of transportRules.
  transportRule() @maturity("deprecated") []dict
  // Mail flow (transport) rules
  //
  // Each rule exposes fields for its name, evaluation priority, and
  // enablement state.
  transportRules() []ms365.exchangeonline.transportRuleEntry
  // Remote domains as raw dictionaries
  //
  // Deprecated in favor of remoteDomains.
  remoteDomain() @maturity("deprecated") []dict
  // Remote domain configurations
  //
  // Each configuration exposes fields for the automatic reply, forwarding, and
  // delivery-report settings for mail sent to that domain.
  remoteDomains() []ms365.exchangeonline.remoteDomainEntry
  // Safe Links policies as raw dictionaries
  //
  // Deprecated in favor of safeLinksPolicies.
  safeLinksPolicy() @maturity("deprecated") []dict
  // Defender for Office 365 Safe Links policies
  //
  // Each policy exposes fields for the URL scanning coverage, click tracking, and
  // click-through settings.
  safeLinksPolicies() []ms365.exchangeonline.safeLinksPolicyEntry
  // Safe Attachments policies as raw dictionaries
  //
  // Deprecated in favor of safeAttachmentPolicies.
  safeAttachmentPolicy() @maturity("deprecated") []dict
  // Defender for Office 365 Safe Attachments policies
  //
  // Each policy exposes fields for the malware-detection action and redirect settings.
  safeAttachmentPolicies() []ms365.exchangeonline.safeAttachmentPolicyEntry
  // Organization configurations
  organizationConfig() dict
  // Authentication policies as raw dictionaries
  //
  // Deprecated in favor of authenticationPolicies.
  authenticationPolicy() @maturity("deprecated") []dict
  // Authentication policies
  //
  // Each policy exposes fields for which legacy basic authentication protocols are
  // still allowed.
  authenticationPolicies() []ms365.exchangeonline.authenticationPolicyEntry
  // Anti-phishing policies as raw dictionaries
  //
  // Deprecated in favor of antiPhishPolicies.
  antiPhishPolicy() @maturity("deprecated") []dict
  // Anti-phishing policies
  //
  // Each policy exposes fields for the impersonation protection, spoof intelligence,
  // and phishing threshold settings.
  antiPhishPolicies() []ms365.exchangeonline.antiPhishPolicyEntry
  // DKIM signing configurations as raw dictionaries
  //
  // Deprecated in favor of dkimSigningConfigs.
  dkimSigningConfig() @maturity("deprecated") []dict
  // DKIM signing configurations
  //
  // One configuration per accepted domain, with fields for whether outbound
  // DKIM signing is enabled and its status.
  dkimSigningConfigs() []ms365.exchangeonline.dkimSigningConfigEntry
  // OWA mailbox policies as raw dictionaries
  //
  // Deprecated in favor of owaMailboxPolicies.
  owaMailboxPolicy() @maturity("deprecated") []dict
  // Outlook on the web mailbox policies
  //
  // Each policy exposes fields for the third-party storage availability and direct
  // file-access settings.
  owaMailboxPolicies() []ms365.exchangeonline.owaMailboxPolicyEntry
  // Admin audit log configuration
  adminAuditLogConfig() dict
  // Whether unified audit log ingestion is enabled for the organization
  //
  // When true, admin and user activity is recorded to the unified audit log and
  // available for search in the Microsoft Purview compliance portal.
  unifiedAuditLogIngestionEnabled() bool
  // List of phishing filter policies
  phishFilterPolicy() []dict
  // Quarantine policies as raw dictionaries
  //
  // Deprecated in favor of quarantinePolicies.
  quarantinePolicy() @maturity("deprecated") []dict
  // Quarantine policies
  //
  // Each policy exposes fields for the end-user permission bitmask and whether
  // quarantine notifications are sent.
  quarantinePolicies() []ms365.exchangeonline.quarantinePolicyEntry
  // List of mailbox plans
  mailboxPlans() []ms365.exchangeonline.mailboxPlan
  // List of retention policies
  retentionPolicies() []ms365.exchangeonline.retentionPolicy
  // List of mailboxes
  mailbox() []dict
  // ATP policies for Office 365 as raw dictionaries
  //
  // Deprecated in favor of atpPoliciesForO365.
  atpPolicyForO365() @maturity("deprecated") []dict
  // Defender for Office 365 ATP policies
  //
  // Each policy exposes fields for the Safe Documents and SharePoint, OneDrive, and
  // Teams protection settings.
  atpPoliciesForO365() []ms365.exchangeonline.atpPolicyForO365Entry
  // Sharing policies as raw dictionaries
  //
  // Deprecated in favor of sharingPolicies.
  sharingPolicy() @maturity("deprecated") []dict
  // Calendar and contact sharing policies
  //
  // Each policy exposes fields for whether sharing is enabled and the domains and
  // sharing actions it permits.
  sharingPolicies() []ms365.exchangeonline.sharingPolicyEntry
  // Role assignment policies as raw dictionaries
  //
  // Deprecated in favor of roleAssignmentPolicies.
  roleAssignmentPolicy() @maturity("deprecated") []dict
  // Role assignment policies
  //
  // Each policy exposes fields for the management roles assigned to mailboxes and
  // whether it is the default policy.
  roleAssignmentPolicies() []ms365.exchangeonline.roleAssignmentPolicyEntry
  // List of external sender configurations
  externalInOutlook() []ms365.exchangeonline.externalSender
  // List of shared mailboxes
  sharedMailboxes() []ms365.exchangeonline.exoMailbox
  // List of Teams protection policies
  teamsProtectionPolicies() []ms365.exchangeonline.teamsProtectionPolicy
  // List of report submission policies
  reportSubmissionPolicies() []ms365.exchangeonline.reportSubmissionPolicy
  // List of journal rules
  journalRules() []ms365.exchangeonline.journalRule
  // List of mailboxes with audit settings
  mailboxesWithAudit() []ms365.exchangeonline.mailbox
  // Transport configuration settings
  transportConfig() dict
  // Security and Compliance policies
  securityAndCompliance() ms365.exchangeonline.securityAndCompliance
  // List of mailbox audit bypass associations
  mailboxAuditBypassAssociation() []ms365.exchangeonlineMailboxAuditBypassAssociation
}

// Mailbox audit bypass association
//
// User or computer account that is exempted from mailbox audit logging in
// Exchange Online. When auditBypassEnabled is true, the account's mailbox
// access and actions are excluded from the mailbox audit log, so its
// activity leaves no audit trail. Review these associations to confirm
// that no account has been silently exempted from auditing, since bypass
// entries can conceal privileged or malicious mailbox access. The account
// is identified by name.
private ms365.exchangeonlineMailboxAuditBypassAssociation @defaults("name auditBypassEnabled") {
  // The name of the user or computer account
  name string
  // Whether mailbox audit logging is bypassed for this account
  auditBypassEnabled bool
}

// Microsoft 365 Exchange Online Security and Compliance
private ms365.exchangeonline.securityAndCompliance {
  // Data Loss Prevention (DLP) compliance policies as raw dictionaries
  //
  // Deprecated in favor of dlpPolicies, which models the same policies as
  // typed resources.
  dlpCompliancePolicies() @maturity("deprecated") []dict
  // Data Loss Prevention (DLP) compliance policies
  dlpPolicies() []ms365.exchangeonline.dlpCompliancePolicy
  // Data Loss Prevention (DLP) compliance rules
  dlpRules() []ms365.exchangeonline.dlpComplianceRule
}

// Microsoft 365 Data Loss Prevention compliance rule
//
// Data Loss Prevention (DLP) rule holding the conditions and actions that
// make up a DLP policy, selected by its `name`. `parentPolicyName` links the
// rule to its policy. The rule detects the sensitive information types listed
// in `sensitiveInformationTypes`, and when matched it can block access
// (`blockAccess`, `blockAccessScope`), notify users (`notifyUser`,
// `notifyUserType`), and raise alerts at `reportSeverityLevel`. `disabled`
// reports whether the rule is turned off, `mode` its enforcement level, and
// `isAdvancedRule` whether it uses the advanced (JSON) condition builder.
private ms365.exchangeonline.dlpComplianceRule @defaults("name parentPolicyName disabled blockAccess") {
  // Rule name
  name string
  // Rule GUID
  guid string
  // Name of the DLP policy the rule belongs to
  parentPolicyName string
  // DLP policy the rule belongs to
  parentPolicy() ms365.exchangeonline.dlpCompliancePolicy
  // Whether the rule is disabled
  disabled bool
  // Enforcement mode (Enable, TestWithNotifications, TestWithoutNotifications, Disable)
  mode string
  // Rule priority; lower numbers are evaluated first
  priority int
  // Sensitive information types the rule detects
  sensitiveInformationTypes []string
  // Whether the rule blocks access to matching content
  blockAccess bool
  // Scope of the block action (All, PerUser)
  blockAccessScope string
  // Recipients notified when the rule matches (for example LastModifier, Owner, SiteAdmin, or addresses)
  notifyUser []string
  // Notification delivery type (Email, PolicyTip, or both)
  notifyUserType string
  // Recipients of the incident report when the rule matches
  generateIncidentReport []string
  // Severity level reported for matches (Low, Medium, High)
  reportSeverityLevel string
  // Access scope the rule applies to (InOrganization, NotInOrganization, ...)
  accessScope string
  // Whether the rule uses the advanced (JSON) condition builder
  isAdvancedRule bool
}

// Microsoft 365 Data Loss Prevention compliance policy
//
// Data Loss Prevention (DLP) compliance policy, selected by its
// `name`. `mode` reports the enforcement level (Enable, TestWithNotifications,
// TestWithoutNotifications, or Disable) and `enabled` whether it is on. The
// `workload` lists which services it covers — Exchange, SharePoint,
// OneDriveForBusiness, Teams, or EndpointDevices — and `priority` orders policy
// evaluation. `distributionStatus` reports whether the policy has rolled out to
// the workloads, and `whenCreated` / `whenChanged` frame its history.
private ms365.exchangeonline.dlpCompliancePolicy @defaults("name mode enabled workload") {
  // Policy name
  name string
  // Policy GUID
  guid string
  // Enforcement mode (Enable, TestWithNotifications, TestWithoutNotifications, Disable, PendingDeletion)
  mode string
  // Whether the policy is enabled
  enabled bool
  // Workloads the policy applies to (for example Exchange, SharePoint, OneDriveForBusiness, Teams, EndpointDevices)
  workload string
  // Policy priority; lower numbers are evaluated first
  priority int
  // Administrator comment
  comment string
  // Account that created the policy
  createdBy string
  // Whether the policy is valid
  isValid bool
  // Distribution status of the policy across its workloads
  distributionStatus string
  // Date and time the policy was created
  whenCreated time
  // Date and time the policy was last changed
  whenChanged time
  // Enforcement planes
  //
  // Layers where the policy's actions run. Values include Browser (unmanaged
  // cloud apps in Microsoft Edge for Business), CopilotExperiences (Microsoft
  // 365 Copilot interactions), Application (Entra-registered enterprise
  // applications), and Network.
  enforcementPlanes []string
  // Microsoft 365 Copilot location scope
  //
  // Inclusion and exclusion scoping for the Microsoft 365 Copilot location the
  // policy covers, or null when the policy doesn't apply to Copilot.
  copilot dict
}

// Teams Protection Policy configuration
private ms365.exchangeonline.teamsProtectionPolicy {
  // Whether Zero-hour Auto Purge (ZAP) is enabled
  zapEnabled bool
  // Whether the policy configuration is considered valid
  isValid bool
}

// Report Submission Policy configuration
private ms365.exchangeonline.reportSubmissionPolicy {
  // Whether to report junk to a customized address
  reportJunkToCustomizedAddress bool
  // Whether to report not junk to a customized address
  reportNotJunkToCustomizedAddress bool
  // Whether to report phish to a customized address
  reportPhishToCustomizedAddress bool
  // Addresses to report junk
  reportJunkAddresses []string
  // Addresses to report not junk
  reportNotJunkAddresses []string
  // Addresses to report phish
  reportPhishAddresses []string
  // Whether chat message reporting is enabled
  reportChatMessageEnabled bool
  // Whether to report chat messages to a customized address
  reportChatMessageToCustomizedAddressEnabled bool
  // Whether to send reports to Microsoft
  enableReportToMicrosoft bool
  // Whether to show a message before submission
  preSubmitMessageEnabled bool
  // Whether to show a message after submission
  postSubmitMessageEnabled bool
  // Whether to enable third-party reporting address
  enableThirdPartyAddress bool
  // Custom message shown for phishing review result
  phishingReviewResultMessage string
  // Footer message for notifications
  notificationFooterMessage string
  // Custom message shown for junk review result
  junkReviewResultMessage string
  // Custom message shown for not junk review result
  notJunkReviewResultMessage string
  // Sender addresses for notifications
  notificationSenderAddresses []string
  // Whether to use a custom notification sender
  enableCustomNotificationSender bool
  // Whether to use organization branding in notifications
  enableOrganizationBranding bool
  // Disable the quarantine reporting option
  disableQuarantineReportingOption bool
}

// Journal Rule
private ms365.exchangeonline.journalRule @defaults("name enabled journalEmailAddress scope") {
  // Rule name
  name string
  // Journal recipient email address
  journalEmailAddress string
  // Rule scope
  scope string
  // Whether the rule is enabled
  enabled bool
}

// Microsoft 365 Exchange Online External Sender
private ms365.exchangeonline.externalSender {
  // The identity of the external sender
  identity string
  // The list of specified senders that do not receive the external icon in the area of subject line
  allowList []string
  // Whether the feature is enabled
  enabled bool
}

// Microsoft 365 Exchange Online Mailbox
private ms365.exchangeonline.exoMailbox {
  // The identity of the mailbox
  identity string
  // The user linked to this mailbox
  user() microsoft.user
  // The identity of the external object linked to this mailbox
  externalDirectoryObjectId string
}

// Microsoft 365 Exchange Online Mailbox with Audit Settings
private ms365.exchangeonline.mailbox @defaults("identity displayName auditEnabled") {
  // Mailbox identity
  identity string
  // Display name
  displayName string
  // Primary SMTP address
  primarySmtpAddress string
  // Recipient type details
  recipientTypeDetails string
  // Whether audit logging is enabled
  auditEnabled bool
  // Admin audit actions
  auditAdmin []string
  // Delegate audit actions
  auditDelegate []string
  // Owner audit actions
  auditOwner []string
  // Audit log age limit
  auditLogAgeLimit string
}

// Microsoft 365 SharePoint Online
//
// SharePoint Online and OneDrive governance for the tenant, spanning the
// tenant-wide sharing and security configuration, OneDrive sync client
// access controls, and the inventory of site collections with their
// external-sharing and custom-script settings. Query it to audit how broadly
// content can be shared outside the organization and whether device and
// script protections are enforced.
ms365.sharepointonline {
  // SharePoint Online tenant settings as a raw dictionary
  //
  // Deprecated in favor of tenantConfiguration, which models the
  // security-relevant settings as individual fields.
  spoTenant() @maturity("deprecated") dict
  // SharePoint Online tenant configuration
  tenantConfiguration() ms365.sharepointonline.tenantConfig
  // OneDrive sync client access restrictions for the tenant
  //
  // Raw configuration governing which machines may sync SharePoint and
  // OneDrive content. Keys include `TenantRestrictionEnabled` (whether
  // syncing is limited to domain-joined machines on the safe recipient
  // list), `AllowedDomainList` (the safe recipient domain GUIDs),
  // `BlockMacSync` (whether Mac clients are blocked from syncing), and
  // `GrooveBlockOption` (whether the legacy OneDrive for Business sync
  // client is allowed).
  spoTenantSyncClientRestriction() dict
  // SharePoint Online tenant sites
  spoSites() []ms365.sharepointonline.site
  // The default link permission for the tenant
  defaultLinkPermission() string
}

// Microsoft 365 SharePoint Online tenant configuration
//
// Tenant-wide SharePoint Online and OneDrive sharing and security settings,
// including external sharing capability, domain restrictions, anonymous link
// controls, guest expiration, and access protections that apply across all
// sites in the tenant.
private ms365.sharepointonline.tenantConfig {
  // External sharing capability for the tenant
  //
  // One of Disabled, ExistingExternalUserSharingOnly,
  // ExternalUserSharingOnly, or ExternalUserAndGuestSharing, setting the
  // most permissive sharing allowed across the tenant.
  sharingCapability string
  // Domain restriction mode for external sharing
  //
  // One of None, AllowList, or BlockList, controlling whether external
  // sharing is limited by the allowed or blocked domain lists.
  sharingDomainRestrictionMode string
  // Space-delimited list of domains allowed for external sharing
  sharingAllowedDomainList string
  // Space-delimited list of domains blocked from external sharing
  sharingBlockedDomainList string
  // Default type of sharing link created by users
  //
  // One of None, Direct, Internal, or AnonymousAccess.
  defaultSharingLinkType string
  // Default permission granted by sharing links
  //
  // One of None, View, or Edit.
  defaultLinkPermission string
  // Whether external users must accept invitations with the account they were invited as
  requireAcceptingAccountMatchInvitedAccount bool
  // Whether external users are prevented from resharing content
  preventExternalUsersFromResharing bool
  // Whether guest access expires automatically
  externalUserExpirationRequired bool
  // Number of days before guest access expires
  externalUserExpireInDays int
  // Whether guests must reconfirm their email after a period
  emailAttestationRequired bool
  // Number of days before guests must reattest their email
  emailAttestationReAuthDays int
  // Number of days after which anonymous links expire
  requireAnonymousLinksExpireInDays int
  // Whether the "Everyone" claim is shown in people pickers
  showEveryoneClaim bool
  // Whether the "All Users" claim is shown in people pickers
  showAllUsersClaim bool
  // Whether the "Everyone except external users" claim is shown in people pickers
  showEveryoneExceptExternalUsersClaim bool
  // Whether owners are notified when items are reshared
  notifyOwnersWhenItemsReshared bool
  // Whether legacy authentication protocols are enabled
  legacyAuthProtocolsEnabled bool
  // Conditional access policy applied to SharePoint and OneDrive
  //
  // One of AllowFullAccess, AllowLimitedAccess, BlockAccess, or
  // AuthenticationContext.
  conditionalAccessPolicy string
  // Whether unmanaged devices are restricted from using the sync client
  isUnmanagedSyncClientForTenantRestricted bool
  // Whether downloading files detected as infected is blocked
  disallowInfectedFileDownload bool
}

// Microsoft 365 SharePoint Site
//
// SharePoint Online site collection with its external-sharing capability,
// custom-script permission, conditional access restrictions, and lock state.
// Query the collection to find sites that permit external sharing or allow
// custom script execution, both of which widen the tenant's exposure.
private ms365.sharepointonline.site {
  // The site URL
  url string
  // Whether adding and customizing pages is denied on the site
  //
  // When true, users cannot run custom script on the site, which is the
  // secure setting. A false value permits custom script, which can be used
  // to inject malicious code into pages.
  denyAddAndCustomizePages bool
  // The site title
  title string
  // The site template identifier
  template string
  // External sharing capability for the site
  //
  // One of Disabled, ExistingExternalUserSharingOnly,
  // ExternalUserSharingOnly, or ExternalUserAndGuestSharing, controlling
  // whether and how content can be shared with users outside the organization.
  sharingCapability string
  // Access control for unmanaged devices
  //
  // One of AllowFullAccess, AllowLimitedAccess, BlockAccess, or
  // AuthenticationContext, set when the site is governed by a conditional
  // access policy that restricts access from unmanaged devices.
  conditionalAccessPolicy string
  // The site lock state
  //
  // One of Unlock, ReadOnly, or NoAccess.
  lockState string
  // Whether site collection administrators can upgrade the site
  allowSelfServiceUpgrade bool
  // The site owner
  owner string
  // The site status
  status string
}

// Microsoft 365 Teams
//
// Tenant-wide Microsoft Teams configuration and inventory. Covers the client
// feature controls, external access and federation settings, meeting policy
// (lobby admission, recording, and participant controls), and messaging
// policy (chat and security reporting), plus the teams provisioned in the
// tenant and their channels. Audit these to verify guest access, external
// federation, meeting recording, and lobby screening are governed to policy.
ms365.teams {
  // Teams client configuration as a raw dictionary
  //
  // Deprecated in favor of clientConfiguration, which models the same
  // settings as individual fields.
  csTeamsClientConfiguration() @maturity("deprecated") dict
  // Teams client configuration
  //
  // Tenant-wide Teams client feature controls covering third-party cloud
  // storage providers (Dropbox, Box, Google Drive, ShareFile, Egnyte),
  // guest access, and Skype for Business interoperability.
  clientConfiguration() ms365.teams.clientConfig
  // Teams tenant federated configuration
  csTenantFederationConfiguration() ms365.teams.tenantFederationConfig
  // Teams meeting policy configuration
  csTeamsMeetingPolicy() ms365.teams.teamsMeetingPolicyConfig
  // Teams message policy configuration
  csTeamsMessagingPolicy() ms365.teams.teamsMessagingPolicyConfig
  // Teams (group-backed) provisioned in the tenant
  teams() []ms365.teams.team
}

// Microsoft 365 Teams client configuration
//
// Tenant-wide Teams client feature controls, including which third-party
// cloud storage providers (Dropbox, Box, Google Drive, ShareFile, Egnyte)
// users can attach, whether guest access and Skype for Business
// interoperability are permitted, and email-into-channel behavior. Audit
// these to confirm data-egress paths and guest access match policy.
private ms365.teams.clientConfig {
  // Whether users can send email to a channel email address
  allowEmailIntoChannel bool
  // Whether Dropbox is allowed as a third-party cloud storage provider
  allowDropBox bool
  // Whether Box is allowed as a third-party cloud storage provider
  allowBox bool
  // Whether Google Drive is allowed as a third-party cloud storage provider
  allowGoogleDrive bool
  // Whether ShareFile is allowed as a third-party cloud storage provider
  allowShareFile bool
  // Whether Egnyte is allowed as a third-party cloud storage provider
  allowEgnyte bool
  // Whether the organization tab is allowed
  allowOrganizationTab bool
  // Whether Skype for Business interoperability is allowed
  allowSkypeBusinessInterop bool
  // Whether guest users are allowed in Teams
  allowGuestUser bool
  // PIN requirement for accessing meeting content
  //
  // One of NotRequired, RequiredOutsideScheduleMeeting, or AlwaysRequired.
  contentPin string
  // Whether resource accounts can send messages
  allowResourceAccountSendMessage bool
  // Whether scoped people search and access is allowed
  allowScopedPeopleSearchandAccess bool
}

// Microsoft 365 Teams tenant federation configuration
//
// External access and federation settings that determine which outside
// organizations and consumer (personal) Teams accounts users can
// communicate with. The allowedDomains and blockedDomains lists,
// allowFederatedUsers, and allowTeamsConsumer settings define the tenant's
// external-communication boundary, a key control against data exfiltration.
private ms365.teams.tenantFederationConfig {
  // ID of the collection of tenant federation configuration settings
  identity string
  // Blocked domains
  blockedDomains []string
  // Allowed domains
  allowedDomains []string
  // Whether federated users are allowed
  allowFederatedUsers bool
  // Whether public users are allowed
  allowPublicUsers bool
  // Whether to allow external Teams consumers
  allowTeamsConsumer bool
  // Whether to allow inbound communication with external Teams consumers
  allowTeamsConsumerInbound bool
  // Whether to treat discovered partners as unverified
  treatDiscoveredPartnersAsUnverified bool
  // Whether shared SIP address space is enabled
  sharedSipAddressSpace bool
  // Whether to restrict Teams consumer to external user profiles
  restrictTeamsConsumerToExternalUserProfiles bool
  // Whether external access with trial tenants is allowed (Allowed or Blocked)
  externalAccessWithTrialTenants string
}

// Microsoft 365 Teams meeting policy configuration
//
// Meeting controls that govern who can join and start meetings, lobby
// admission for anonymous and external participants, presenter roles, chat,
// cloud recording and its storage region, transcription, and toll-bypass.
// Audit these to enforce lobby screening and to control meeting recording.
private ms365.teams.teamsMeetingPolicyConfig {
  // Whether anonymous users are allowed to join
  allowAnonymousUsersToJoinMeeting bool
  // Whether anonymous users are allowed to start the meeting
  allowAnonymousUsersToStartMeeting bool
  // Whether external meeting chat is allowed
  allowExternalNonTrustedMeetingChat bool
  // Who can bypass the lobby
  autoAdmittedUsers string
  // Whether public switched telephone network (PSTN) users can bypass the lobby
  allowPSTNUsersToBypassLobby bool
  // Whether meeting chat is enabled
  meetingChatEnabledType string
  // Designated presenter role mode
  designatedPresenterRoleMode string
  // Whether external participants can give or request control of the meeting
  allowExternalParticipantGiveRequestControl bool
  // Whether users can report security concerns
  allowSecurityEndUserReporting bool
  // Whether cloud recording is allowed for calls
  allowCloudRecordingForCalls bool
  // Whether cloud recording is allowed for meetings
  allowCloudRecording bool
  // Whether meeting recordings can be stored outside the data residency region
  allowRecordingStorageOutsideRegion bool
  // Whether live transcription is allowed in meetings
  allowTranscription bool
  // Whether internal participants can give or request control of the meeting
  allowParticipantGiveRequestControl bool
  // Whether dial-in callers are forced to use the conferencing toll number
  preventTollBypass bool
}

// Microsoft 365 Teams messaging policy configuration
//
// Chat and messaging controls covering whether users can chat, edit or
// delete their own messages, whether owners can delete others' messages,
// read-receipt behavior, and end-user security reporting of malicious
// messages.
private ms365.teams.teamsMessagingPolicyConfig {
  // Whether users can report security concerns
  allowSecurityEndUserReporting bool
  // Whether users can use chat
  allowUserChat bool
  // Whether users can delete their own sent messages
  allowUserDeleteMessage bool
  // Whether team owners can delete messages sent by others
  allowOwnerDeleteMessage bool
  // Whether users can delete chats they participate in
  allowUserDeleteChat bool
  // Read receipt control mode
  //
  // One of UserPreference, Everyone, or None, indicating whether read
  // receipts are user-controlled, forced on, or forced off.
  readReceiptsEnabledType string
}

// Microsoft Teams team
//
// A single team provisioned in the tenant, selected by its group id (for
// example ms365.teams.teams.where(id == "...")). Beyond identity and
// lifecycle (display name, visibility, classification, archived state) it
// exposes the team's governance settings: whether members and guests can
// create, update, or delete channels, create private channels, and add apps,
// tabs, and connectors, along with the message-deletion and mention controls
// and the Giphy, stickers, and custom-meme content settings. Use channels to
// enumerate the team's channels.
private ms365.teams.team @defaults("displayName description visibility") {
  // Team (group) ID
  id string
  // Team display name
  displayName string
  // Team description
  description string
  // Team visibility (public, private, hiddenMembership)
  visibility() string
  // Whether the team is archived
  isArchived() bool
  // Team specialization
  //
  // One of none, educationStandard, educationClass,
  // educationProfessionalLearningCommunity, educationStaff,
  // healthcareStandard, or healthcareCareCoordination.
  specialization() string
  // Team data classification
  classification() string
  // Date and time the team was created
  createdDateTime() time
  // URL that opens the team in the Teams client
  webUrl() string
  // Whether members can create and update channels
  allowCreateUpdateChannels() bool
  // Whether members can create private channels
  allowCreatePrivateChannels() bool
  // Whether members can delete channels
  allowDeleteChannels() bool
  // Whether members can add and remove apps
  allowAddRemoveApps() bool
  // Whether members can create, update, and remove tabs
  allowCreateUpdateRemoveTabs() bool
  // Whether members can create, update, and remove connectors
  allowCreateUpdateRemoveConnectors() bool
  // Whether guests can create and update channels
  guestAllowCreateUpdateChannels() bool
  // Whether guests can delete channels
  guestAllowDeleteChannels() bool
  // Whether users can edit their own sent messages
  allowUserEditMessages() bool
  // Whether users can delete their own sent messages
  allowUserDeleteMessages() bool
  // Whether team owners can delete messages sent by others
  allowOwnerDeleteMessages() bool
  // Whether @team mentions are allowed
  allowTeamMentions() bool
  // Whether @channel mentions are allowed
  allowChannelMentions() bool
  // Whether Giphy can be used in conversations
  allowGiphy() bool
  // Giphy content rating (moderate, strict)
  giphyContentRating() string
  // Whether stickers and memes can be used
  allowStickersAndMemes() bool
  // Whether custom memes can be uploaded and used
  allowCustomMemes() bool
  // Channels in the team
  channels() []ms365.teams.channel
}

// Microsoft Teams channel
//
// A single channel within a team, covering the channel display name,
// description, email address, web URL, creation time, and archived state.
// The membershipType field (standard, private, or shared) is a key
// governance signal because private and shared channels narrow who can
// participate.
private ms365.teams.channel @defaults("displayName membershipType") {
  // Channel ID
  id string
  // Channel display name
  displayName string
  // Channel description
  description string
  // Channel membership type (standard, private, shared, unknownFutureValue)
  membershipType string
  // Email address for sending messages to the channel
  email string
  // URL that opens the channel in the Teams client
  webUrl string
  // Date and time the channel was created
  createdDateTime time
  // Whether the channel is archived
  isArchived bool
}

// Mailbox Plan
private ms365.exchangeonline.mailboxPlan @defaults("name alias prohibitSendQuota maxSendSize maxReceiveSize") {
  // Plan name
  name string
  // Plan alias
  alias string
  // Prohibit send quota
  prohibitSendQuota string
  // Maximum send size
  maxSendSize string
  // Maximum receive size
  maxReceiveSize string
}

// Retention Policy
private ms365.exchangeonline.retentionPolicy @defaults("name retentionPolicyTagLinks retentionId") {
  // Policy name
  name string
  // Retention policy tag links
  retentionPolicyTagLinks []string
  // Retention ID
  retentionId string
}

// Exchange Online mail flow transport rule
//
// Single mail flow rule returned by Get-TransportRule, selected by
// `name`. Each rule reports its evaluation `priority` (lower numbers run
// first), enablement `state`, operating `mode`, administrator `comments`, and
// whether it forces outbound TLS via `routeMessageOutboundRequireTls`. The full
// condition and action set of a rule remains available through the deprecated
// `transportRule` dictionary.
private ms365.exchangeonline.transportRuleEntry @defaults("name state priority") {
  // The rule identity
  identity string
  // The rule name
  name string
  // Rule evaluation priority (lower runs first)
  priority int
  // Whether the rule is enabled or disabled
  state string
  // Rule operating mode (Enforce, Audit, or AuditAndNotify)
  mode string
  // Whether the rule forces matching messages to be routed outbound over TLS
  routeMessageOutboundRequireTls bool
  // Administrator comments on the rule
  comments string
  // Sender domains the rule matches on
  senderDomainIs []string
}

// Exchange Online anti-phishing policy
//
// Single anti-phishing policy returned by Get-AntiPhishPolicy,
// selected by `name`. Each policy reports whether it is `enabled`, the
// `phishThresholdLevel` (1-4, where higher is more aggressive), the
// mailbox-intelligence, spoof-intelligence, and impersonation-protection
// toggles, and the actions taken when impersonation is detected or sender
// authentication fails.
private ms365.exchangeonline.antiPhishPolicyEntry @defaults("name enabled phishThresholdLevel") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether the policy is enabled
  enabled bool
  // Phishing detection aggressiveness (1-4, higher is more aggressive)
  phishThresholdLevel int
  // Whether mailbox intelligence is enabled
  enableMailboxIntelligence bool
  // Whether mailbox intelligence impersonation protection is enabled
  enableMailboxIntelligenceProtection bool
  // Whether spoof intelligence is enabled
  enableSpoofIntelligence bool
  // Whether first-contact safety tips are shown
  enableFirstContactSafetyTips bool
  // Whether protected-user impersonation protection is enabled
  enableTargetedUserProtection bool
  // Whether protected-domain impersonation protection is enabled
  enableTargetedDomainsProtection bool
  // Whether impersonation protection covers all organization domains
  enableOrganizationDomainsProtection bool
  // Action for detected user impersonation (for example Quarantine or MoveToJmf)
  targetedUserProtectionAction string
  // Action for detected domain impersonation (for example Quarantine or MoveToJmf)
  targetedDomainProtectionAction string
  // Action when sender authentication (SPF/DKIM/DMARC) fails
  authenticationFailAction string
  // Action applied when the sender's DMARC policy is quarantine
  dmarcQuarantineAction string
  // Action applied when the sender's DMARC policy is reject
  dmarcRejectAction string
  // Whether similar-domains safety tips are shown
  enableSimilarDomainsSafetyTips bool
  // Whether similar-users safety tips are shown
  enableSimilarUsersSafetyTips bool
  // Whether the suspicious safety tip is shown
  enableSuspiciousSafetyTip bool
  // Whether unauthenticated-sender indicators are shown in Outlook
  enableUnauthenticatedSender bool
  // Whether unusual-characters safety tips are shown
  enableUnusualCharactersSafetyTips bool
  // Whether the "via" tag is shown when the sending domain differs from the From domain
  enableViaTag bool
  // Whether the sender's published DMARC policy is honored
  honorDmarcPolicy bool
  // Impersonation protection mode (for example Automatic, Manual, or Off)
  impersonationProtectionState string
  // Action for messages flagged by mailbox intelligence impersonation protection
  mailboxIntelligenceProtectionAction string
}

// Exchange Online Safe Links policy
//
// Single Defender for Office 365 Safe Links policy returned by
// Get-SafeLinksPolicy, selected by `name`. Each policy reports which
// workloads URL scanning covers (email, Teams, and Office apps), whether
// clicks are tracked, whether users may click through to the original URL,
// and whether URL rewriting is disabled.
private ms365.exchangeonline.safeLinksPolicyEntry @defaults("name enableSafeLinksForEmail") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether Safe Links scanning applies to email
  enableSafeLinksForEmail bool
  // Whether Safe Links scanning applies to Microsoft Teams
  enableSafeLinksForTeams bool
  // Whether Safe Links scanning applies to Office apps
  enableSafeLinksForOffice bool
  // Whether user clicks are tracked
  trackClicks bool
  // Whether users can click through to the original URL
  allowClickThrough bool
  // Whether URLs are scanned in real time
  scanUrls bool
  // Whether scanning applies to internal senders
  enableForInternalSenders bool
  // Whether messages are held until scanning completes
  deliverMessageAfterScan bool
  // Whether URL rewriting is disabled
  disableUrlRewrite bool
}

// Exchange Online Safe Attachments policy
//
// Single Defender for Office 365 Safe Attachments policy returned
// by Get-SafeAttachmentPolicy, selected by `name`. Each policy reports
// whether it is enabled, the `action` taken on detected malware (Allow,
// Block, Replace, or DynamicDelivery), and whether and where detected
// messages are redirected.
private ms365.exchangeonline.safeAttachmentPolicyEntry @defaults("name enable action") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether the policy is enabled
  enable bool
  // Action for detected malware (Allow, Block, Replace, or DynamicDelivery)
  action string
  // Whether detected messages are redirected
  redirect bool
  // Address detected messages are redirected to
  redirectAddress string
  // Quarantine policy applied to detected attachments
  quarantineTag string
}

// Exchange Online malware filter policy
//
// Single malware filter policy returned by Get-MalwareFilterPolicy,
// selected by `name`. Each policy reports whether the common-attachment file
// filter is enabled and the `fileTypes` it blocks, whether zero-hour auto
// purge is on, and whether internal- and external-sender admin notifications
// are sent.
private ms365.exchangeonline.malwareFilterPolicyEntry @defaults("name enableFileFilter zapEnabled") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether the common attachment file filter is enabled
  enableFileFilter bool
  // Whether zero-hour auto purge (ZAP) is enabled
  zapEnabled bool
  // Whether internal-sender admin notifications are enabled
  enableInternalSenderAdminNotifications bool
  // Whether external-sender admin notifications are enabled
  enableExternalSenderAdminNotifications bool
  // File extensions blocked by the common attachment filter
  fileTypes []string
  // Whether custom administrator notification text is used
  customNotifications bool
  // Address external-sender admin notifications are sent to
  externalSenderAdminAddress string
  // Action taken on messages matching the common attachment filter
  fileTypeAction string
  // Address internal-sender admin notifications are sent to
  internalSenderAdminAddress string
  // Quarantine policy applied to detected malware
  quarantineTag string
}

// Exchange Online hosted content (anti-spam) filter policy
//
// Single inbound anti-spam policy returned by
// Get-HostedContentFilterPolicy, selected by `name`. Each policy reports the
// actions taken on spam, high-confidence spam, phishing, high-confidence
// phishing, and bulk mail, the `bulkThreshold` (1-9), whether end-user spam
// notifications are sent, and the always-allowed and always-blocked sender
// domains.
private ms365.exchangeonline.hostedContentFilterPolicyEntry @defaults("name spamAction highConfidenceSpamAction") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Action applied to spam
  spamAction string
  // Action applied to high-confidence spam
  highConfidenceSpamAction string
  // Action applied to phishing
  phishSpamAction string
  // Action applied to high-confidence phishing
  highConfidencePhishAction string
  // Action applied to bulk mail
  bulkSpamAction string
  // Bulk complaint level threshold (1-9)
  bulkThreshold int
  // Whether end-user spam notifications are enabled
  enableEndUserSpamNotifications bool
  // Sender domains always treated as allowed
  allowedSenderDomains []string
  // Sender domains always treated as blocked
  blockedSenderDomains []string
}

// Exchange Online hosted outbound spam filter policy
//
// Single outbound spam policy returned by
// Get-HostedOutboundSpamFilterPolicy, selected by `name`. Each policy reports
// the external, internal, and daily recipient limits, the action taken when a
// limit is reached, the automatic email-forwarding mode (Automatic, On, or
// Off), and whether suspicious outbound mail is bcc'd and notified.
private ms365.exchangeonline.hostedOutboundSpamFilterPolicyEntry @defaults("name autoForwardingMode") {
  // The policy identity
  identity string
  // The policy name
  name string
  // External recipient limit per hour
  recipientLimitExternalPerHour int
  // Internal recipient limit per hour
  recipientLimitInternalPerHour int
  // Recipient limit per day
  recipientLimitPerDay int
  // Action taken when a sending limit is reached
  actionWhenThresholdReached string
  // Automatic external email forwarding mode (Automatic, On, or Off)
  autoForwardingMode string
  // Whether suspicious outbound mail is blind-copied to a designated address
  bccSuspiciousOutboundMail bool
  // Whether notifications are sent for outbound spam
  notifyOutboundSpam bool
  // Whether the policy is enabled
  enabled bool
  // Additional recipients blind-copied on suspicious outbound mail
  bccSuspiciousOutboundAdditionalRecipients []string
  // Recipients notified when outbound spam is detected
  notifyOutboundSpamRecipients []string
}

// Exchange Online DKIM signing configuration
//
// DKIM signing configuration for one accepted domain, returned by
// Get-DkimSigningConfig and selected by `domain`. The `enabled` field reports
// whether outbound DKIM signing is on for the domain, and `status` reports its
// current state.
private ms365.exchangeonline.dkimSigningConfigEntry @defaults("domain enabled status") {
  // The configuration identity
  identity string
  // The domain the configuration applies to
  domain string
  // Whether DKIM signing is enabled for the domain
  enabled bool
  // The configuration status
  status string
}

// Exchange Online authentication policy
//
// Single authentication policy returned by Get-AuthenticationPolicy,
// selected by `name`. Each policy exposes one boolean per connection protocol
// (ActiveSync, Autodiscover, IMAP, MAPI, offline address book, the Outlook
// service, POP, remote PowerShell, reporting web services, Outlook RPC,
// authenticated SMTP, and Exchange Web Services) indicating whether legacy
// basic authentication is still allowed for it.
private ms365.exchangeonline.authenticationPolicyEntry @defaults("name allowBasicAuthSmtp") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether basic authentication is allowed for Exchange ActiveSync
  allowBasicAuthActiveSync bool
  // Whether basic authentication is allowed for Autodiscover
  allowBasicAuthAutodiscover bool
  // Whether basic authentication is allowed for IMAP
  allowBasicAuthImap bool
  // Whether basic authentication is allowed for MAPI
  allowBasicAuthMapi bool
  // Whether basic authentication is allowed for the offline address book
  allowBasicAuthOfflineAddressBook bool
  // Whether basic authentication is allowed for the Outlook service
  allowBasicAuthOutlookService bool
  // Whether basic authentication is allowed for POP3
  allowBasicAuthPop bool
  // Whether basic authentication is allowed for remote PowerShell
  allowBasicAuthPowershell bool
  // Whether basic authentication is allowed for reporting web services
  allowBasicAuthReportingWebServices bool
  // Whether basic authentication is allowed for Outlook RPC
  allowBasicAuthRpc bool
  // Whether basic authentication is allowed for authenticated SMTP
  allowBasicAuthSmtp bool
  // Whether basic authentication is allowed for Exchange Web Services
  allowBasicAuthWebServices bool
}

// Exchange Online Outlook on the web mailbox policy
//
// Single Outlook on the web mailbox policy returned by
// Get-OwaMailboxPolicy, selected by `name`. Each policy reports whether
// third-party storage providers are available, whether direct file access is
// enabled on public and private computers, whether forced save applies to
// filtered attachments, and the allowed and blocked attachment file types.
private ms365.exchangeonline.owaMailboxPolicyEntry @defaults("name additionalStorageProvidersAvailable") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether third-party storage providers are available in Outlook on the web
  additionalStorageProvidersAvailable bool
  // Whether direct file access is enabled on public computers
  directFileAccessOnPublicComputersEnabled bool
  // Whether direct file access is enabled on private computers
  directFileAccessOnPrivateComputersEnabled bool
  // Whether forced save is applied to filtered attachments
  forceSaveAttachmentFilteringEnabled bool
  // File types users are allowed to open or save
  allowedFileTypes []string
  // File types users are blocked from opening or saving
  blockedFileTypes []string
  // Whether Exchange ActiveSync integration is enabled in Outlook on the web
  activeSyncIntegrationEnabled bool
  // Whether all address lists are available
  allAddressListsEnabled bool
  // Whether copying contacts to a device address book is allowed
  allowCopyContactsToDeviceAddressBook bool
  // Whether Bookings is enabled
  bookingsEnabled bool
  // Whether users can create Bookings mailboxes
  bookingsMailboxCreationEnabled bool
  // Whether the calendar is enabled
  calendarEnabled bool
  // Whether users can change their password
  changePasswordEnabled bool
  // Whether contacts are enabled
  contactsEnabled bool
  // Whether Facebook integration is enabled
  facebookEnabled bool
  // Whether users can create Microsoft 365 groups
  groupCreationEnabled bool
  // Whether instant messaging is enabled
  instantMessagingEnabled bool
  // Whether interesting calendars are enabled
  interestingCalendarsEnabled bool
  // Whether the journal is enabled
  journalEnabled bool
  // Whether LinkedIn integration is enabled
  linkedInEnabled bool
  // Whether local events are enabled
  localEventsEnabled bool
  // Whether notes are enabled
  notesEnabled bool
  // Whether offline mode is enabled in the web client
  offlineEnabledWeb bool
  // Whether offline mode is enabled in the Windows client
  offlineEnabledWin bool
  // Whether the new Outlook for Windows native client is enabled
  oneWinNativeOutlookEnabled bool
  // Whether Places is enabled
  placesEnabled bool
  // Whether the premium (full-featured) client is enabled
  premiumClientEnabled bool
  // Whether users can recover deleted items
  recoverDeletedItemsEnabled bool
  // Whether reminders and notifications are enabled
  remindersAndNotificationsEnabled bool
  // Whether email signatures are enabled
  signaturesEnabled bool
  // Whether tasks are enabled
  tasksEnabled bool
  // Whether text messaging is enabled
  textMessagingEnabled bool
  // Whether users can select a theme
  themeSelectionEnabled bool
  // Whether SharePoint/WSS document access is allowed on private computers
  wssAccessOnPrivateComputersEnabled bool
  // Whether SharePoint/WSS document access is allowed on public computers
  wssAccessOnPublicComputersEnabled bool
  // Whether weather is enabled
  weatherEnabled bool
}

// Exchange Online remote domain configuration
//
// Mail-handling configuration for one remote domain returned by
// Get-RemoteDomain, selected by `name`. The `domainName` field reports the
// domain it applies to, and further fields report the out-of-office reply type
// allowed and whether automatic replies, automatic forwarding, delivery
// reports, and non-delivery reports are permitted to that domain.
private ms365.exchangeonline.remoteDomainEntry @defaults("name domainName autoForwardEnabled") {
  // The remote domain identity
  identity string
  // The remote domain name
  name string
  // The domain the configuration applies to
  domainName string
  // Out-of-office reply type allowed to the domain (External, ExternalLegacy, or InternalLegacy)
  allowedOOFType string
  // Whether automatic replies are allowed to the domain
  autoReplyEnabled bool
  // Whether automatic forwarding is allowed to the domain
  autoForwardEnabled bool
  // Whether delivery reports are allowed to the domain
  deliveryReportEnabled bool
  // Whether non-delivery reports are allowed to the domain
  ndrEnabled bool
  // Whether the domain is treated as internal
  isInternal bool
  // Message content type allowed to the domain (for example MimeHtmlText, MimeText, or MimeHtml)
  contentType string
  // Whether meeting forward notifications are sent to the domain
  meetingForwardNotificationEnabled bool
}

// Exchange Online quarantine policy
//
// Single quarantine policy returned by Get-QuarantinePolicy,
// selected by `name`. Each policy reports the
// `endUserQuarantinePermissionsValue` bitmask that controls what recipients
// may do with their quarantined messages, and whether end-user spam
// (quarantine) notifications are enabled.
private ms365.exchangeonline.quarantinePolicyEntry @defaults("name esnEnabled") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Bitmask of end-user permissions granted for quarantined messages
  endUserQuarantinePermissionsValue int
  // Whether end-user spam notifications (quarantine notifications) are enabled
  esnEnabled bool
}

// Exchange Online Defender for Office 365 ATP policy
//
// Defender for Office 365 advanced threat protection policy
// returned by Get-AtpPolicyForO365, selected by `name`. It reports whether
// Safe Documents is enabled, whether users may bypass it to open a file, and
// whether ATP protection is enabled for SharePoint, OneDrive, and Teams.
private ms365.exchangeonline.atpPolicyForO365Entry @defaults("name enableSafeDocs") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether Safe Documents is enabled
  enableSafeDocs bool
  // Whether users can bypass Safe Documents and open the file
  allowSafeDocsOpen bool
  // Whether ATP is enabled for SharePoint, OneDrive, and Teams
  enableATPForSPOTeamsODB bool
}

// Exchange Online sharing policy
//
// Single calendar and contact sharing policy returned by
// Get-SharingPolicy, selected by `name`. The `enabled` field reports whether
// the policy is active, `isDefault` reports whether it is the tenant default,
// and the `domains` field lists which external domains may be shared with and
// at what level.
private ms365.exchangeonline.sharingPolicyEntry @defaults("name enabled isDefault") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether the policy is enabled
  enabled bool
  // Whether this is the default sharing policy
  isDefault bool
  // Domains and sharing actions defined by the policy
  domains []string
}

// Exchange Online role assignment policy
//
// Single role assignment policy returned by
// Get-RoleAssignmentPolicy, selected by `name`. Each policy reports whether
// it is the tenant default, its `description`, and the management roles it
// assigns to mailboxes (for example MyProfileInformation or MyBaseOptions),
// which govern the self-service capabilities users have over their own
// mailbox.
private ms365.exchangeonline.roleAssignmentPolicyEntry @defaults("name isDefault") {
  // The policy identity
  identity string
  // The policy name
  name string
  // Whether this is the default role assignment policy
  isDefault bool
  // The policy description
  description string
  // Management roles assigned by the policy
  assignedRoles []string
}

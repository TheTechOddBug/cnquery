  mdmAppId string
  // Model of the device
  model string
  // The type of operating system on the device
  operatingSystem string
  // The version of the operating system on the device
  operatingSystemVersion string
  // Physical IDs
  physicalIds []string
  // Date and time of when the device was registered
  registrationDateTime time
  // List of labels applied to the device by the system
  systemLabels []string
  // Type of trust for the joined device
  trustType string
  // Whether the device account is enabled
  accountEnabled bool
  // Soft-delete timestamp for the device
  deletedDateTime time
  // Whether the device is synced from an on-premises directory
  onPremisesSyncEnabled bool
  // The last time the device was synced from on-premises
  onPremisesLastSyncDateTime time

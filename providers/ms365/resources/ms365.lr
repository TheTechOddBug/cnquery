// Microsoft 365 SharePoint Online
//
// Use this namespace to access SharePoint Online tenant configuration and
// site inventory. Exposes `tenantConfiguration` (tenant-wide sharing and
// security settings), `spoTenantSyncClientRestriction` (sync client access
// controls), `spoSites` (list of site collections with their URL and custom
// script permissions), and `defaultLinkPermission` (the default sharing link
// permission level for the tenant).
ms365.sharepointonline {
  // SharePoint Online tenant settings as a raw dictionary
  //
  // Deprecated in favor of tenantConfiguration, which models the
  // security-relevant settings as individual fields.
  spoTenant() @maturity("deprecated") dict
  // SharePoint Online tenant configuration
  tenantConfiguration() ms365.sharepointonline.tenantConfig
  // SharePoint Online tenant sync client restriction
  spoTenantSyncClientRestriction() dict
  // SharePoint Online tenant sites
  spoSites() []ms365.sharepointonline.site
  // The default link permission for the tenant
  defaultLinkPermission() string
}

// Microsoft 365 SharePoint Online tenant configuration
//
// Examine tenant-wide SharePoint Online and OneDrive sharing and security
// settings, including external sharing capability, domain restrictions,
// anonymous link controls, guest expiration, and access protections that
// apply across all sites in the tenant.
private ms365.sharepointonline.tenantConfig {
  // External sharing capability for the tenant
  //
  // One of Disabled, ExistingExternalUserSharingOnly,
  // ExternalUserSharingOnly, or ExternalUserAndGuestSharing, setting the
  // most permissive sharing allowed across the tenant.
  sharingCapability string
  // Domain restriction mode for external sharing
  //
  // One of None, AllowList, or BlockList, controlling whether external
  // sharing is limited by the allowed or blocked domain lists.
  sharingDomainRestrictionMode string
  // Space-delimited list of domains allowed for external sharing
  sharingAllowedDomainList string
  // Space-delimited list of domains blocked from external sharing
  sharingBlockedDomainList string
  // Default type of sharing link created by users
  //
  // One of None, Direct, Internal, or AnonymousAccess.
  defaultSharingLinkType string
  // Default permission granted by sharing links
  //
  // One of None, View, or Edit.
  defaultLinkPermission string
  // Whether external users must accept invitations with the account they were invited as
  requireAcceptingAccountMatchInvitedAccount bool
  // Whether external users are prevented from resharing content
  preventExternalUsersFromResharing bool
  // Whether guest access expires automatically
  externalUserExpirationRequired bool
  // Number of days before guest access expires
  externalUserExpireInDays int
  // Whether guests must reconfirm their email after a period
  emailAttestationRequired bool
  // Number of days before guests must reattest their email
  emailAttestationReAuthDays int
  // Number of days after which anonymous links expire
  requireAnonymousLinksExpireInDays int
  // Whether the "Everyone" claim is shown in people pickers
  showEveryoneClaim bool
  // Whether the "All Users" claim is shown in people pickers
  showAllUsersClaim bool
  // Whether the "Everyone except external users" claim is shown in people pickers
  showEveryoneExceptExternalUsersClaim bool
  // Whether owners are notified when items are reshared
  notifyOwnersWhenItemsReshared bool
  // Whether legacy authentication protocols are enabled
  legacyAuthProtocolsEnabled bool
  // Conditional access policy applied to SharePoint and OneDrive
  //
  // One of AllowFullAccess, AllowLimitedAccess, BlockAccess, or
  // AuthenticationContext.
  conditionalAccessPolicy string
  // Whether unmanaged devices are restricted from using the sync client
  isUnmanagedSyncClientForTenantRestricted bool
  // Whether downloading files detected as infected is blocked
  disallowInfectedFileDownload bool
}

// Microsoft 365 SharePoint Site
private ms365.sharepointonline.site {
  // The site URL
  url string
  // Whether custom script execution on a particular site allowed
  denyAddAndCustomizePages bool
  // The site title
  title string
  // The site template identifier
  template string
  // External sharing capability for the site
  //
  // One of Disabled, ExistingExternalUserSharingOnly,
  // ExternalUserSharingOnly, or ExternalUserAndGuestSharing, controlling
  // whether and how content can be shared with users outside the organization.
  sharingCapability string
  // Access control for unmanaged devices
  //
  // One of AllowFullAccess, AllowLimitedAccess, BlockAccess, or
  // AuthenticationContext, set when the site is governed by a conditional
  // access policy that restricts access from unmanaged devices.
  conditionalAccessPolicy string
  // The site lock state
  //
  // One of Unlock, ReadOnly, or NoAccess.
  lockState string
  // Whether site collection administrators can upgrade the site
  allowSelfServiceUpgrade bool
  // The site owner
  owner string
  // The site status
  status string
}

// Microsoft 365 Teams
//
// Use this namespace to access Microsoft Teams configuration for the tenant.
// Exposes `clientConfiguration` (client feature controls),
// `csTenantFederationConfiguration` (external access and federation settings),
// `csTeamsMeetingPolicy` (meeting lobby, recording, and participant controls),
// and `csTeamsMessagingPolicy` (messaging and security reporting controls).
ms365.teams {
  // Teams client configuration as a raw dictionary
  //
  // Deprecated in favor of clientConfiguration, which models the same
  // settings as individual fields.
  csTeamsClientConfiguration() @maturity("deprecated") dict
  // Teams client configuration
  //
  // Tenant-wide Teams client feature controls covering third-party cloud
  // storage providers (Dropbox, Box, Google Drive, ShareFile, Egnyte),
  // guest access, and Skype for Business interoperability.
  clientConfiguration() ms365.teams.clientConfig
  // Teams tenant federated configuration
  csTenantFederationConfiguration() ms365.teams.tenantFederationConfig
  // Teams meeting policy configuration
  csTeamsMeetingPolicy() ms365.teams.teamsMeetingPolicyConfig
  // Teams message policy configuration
  csTeamsMessagingPolicy() ms365.teams.teamsMessagingPolicyConfig
  // Teams (group-backed) provisioned in the tenant
  teams() []ms365.teams.team
}

// Microsoft 365 Teams client configuration
//
// Examine tenant-wide Teams client feature controls, including third-party
// cloud storage providers, guest access, and interoperability settings that
// govern what users can do from the Teams client.
private ms365.teams.clientConfig {
  // Whether users can send email to a channel email address
  allowEmailIntoChannel bool
  // Whether Dropbox is allowed as a third-party cloud storage provider
  allowDropBox bool
  // Whether Box is allowed as a third-party cloud storage provider
  allowBox bool
  // Whether Google Drive is allowed as a third-party cloud storage provider
  allowGoogleDrive bool
  // Whether ShareFile is allowed as a third-party cloud storage provider
  allowShareFile bool
  // Whether Egnyte is allowed as a third-party cloud storage provider
  allowEgnyte bool
  // Whether the organization tab is allowed
  allowOrganizationTab bool
  // Whether Skype for Business interoperability is allowed
  allowSkypeBusinessInterop bool
  // Whether guest users are allowed in Teams
  allowGuestUser bool
  // PIN requirement for accessing meeting content
  //
  // One of NotRequired, RequiredOutsideScheduleMeeting, or AlwaysRequired.
  contentPin string
  // Whether resource accounts can send messages
  allowResourceAccountSendMessage bool
  // Whether scoped people search and access is allowed
  allowScopedPeopleSearchandAccess bool
}

// Microsoft 365 Teams tenant federation configuration
private ms365.teams.tenantFederationConfig {
  // ID of the collection of tenant federation configuration settings
  identity string
  // Blocked domains
  blockedDomains []string
  // Allowed domains
  allowedDomains []string
  // Whether federated users are allowed
  allowFederatedUsers bool
  // Whether public users are allowed
  allowPublicUsers bool
  // Whether to allow external Teams consumers
  allowTeamsConsumer bool
  // Whether to allow inbound communication with external Teams consumers
  allowTeamsConsumerInbound bool
  // Whether to treat discovered partners as unverified
  treatDiscoveredPartnersAsUnverified bool
  // Whether shared SIP address space is enabled
  sharedSipAddressSpace bool
  // Whether to restrict Teams consumer to external user profiles
  restrictTeamsConsumerToExternalUserProfiles bool
  // Whether external access with trial tenants is allowed (Allowed or Blocked)
  externalAccessWithTrialTenants string
}

// Microsoft 365 Teams meeting policy configuration
private ms365.teams.teamsMeetingPolicyConfig {
  // Whether anonymous users are allowed to join
  allowAnonymousUsersToJoinMeeting bool
  // Whether anonymous users are allowed to start the meeting
  allowAnonymousUsersToStartMeeting bool
  // Whether external meeting chat is allowed
  allowExternalNonTrustedMeetingChat bool
  // Who can bypass the lobby
  autoAdmittedUsers string
  // Whether public switched telephone network (PSTN) users can bypass the lobby
  allowPSTNUsersToBypassLobby bool
  // Whether meeting chat is enabled
  meetingChatEnabledType string
  // Designated presenter role mode
  designatedPresenterRoleMode string
  // Whether external participants can give or request control of the meeting
  allowExternalParticipantGiveRequestControl bool
  // Whether users can report security concerns
  allowSecurityEndUserReporting bool
  // Whether cloud recording is allowed for calls
  allowCloudRecordingForCalls bool
  // Whether cloud recording is allowed for meetings
  allowCloudRecording bool
  // Whether meeting recordings can be stored outside the data residency region
  allowRecordingStorageOutsideRegion bool
  // Whether live transcription is allowed in meetings
  allowTranscription bool
  // Whether internal participants can give or request control of the meeting
  allowParticipantGiveRequestControl bool
  // Whether dial-in callers are forced to use the conferencing toll number
  preventTollBypass bool
}

// Microsoft 365 Teams messaging policy configuration
private ms365.teams.teamsMessagingPolicyConfig {
  // Whether users can report security concerns
  allowSecurityEndUserReporting bool
  // Whether users can use chat
  allowUserChat bool
  // Whether users can delete their own sent messages
  allowUserDeleteMessage bool
  // Whether team owners can delete messages sent by others
  allowOwnerDeleteMessage bool
  // Whether users can delete chats they participate in
  allowUserDeleteChat bool
  // Read receipt control mode
  //
  // One of UserPreference, Everyone, or None, indicating whether read
  // receipts are user-controlled, forced on, or forced off.
  readReceiptsEnabledType string
}

// Microsoft Teams team
//
// Examine a single team provisioned in the tenant, selected by its group
// `id`. Beyond identity (`displayName`, `description`, `visibility`,
// `classification`, `createdDateTime`, `webUrl`) it exposes the team's
// governance settings: whether members can create, update, or delete
// channels and create private channels (`allowCreateUpdateChannels`,
// `allowCreatePrivateChannels`, `allowDeleteChannels`), add or remove apps,
// tabs, and connectors, what guests are allowed to do
// (`guestAllowCreateUpdateChannels`, `guestAllowDeleteChannels`), the
// messaging controls (`allowUserDeleteMessages`, `allowOwnerDeleteMessages`,
// and mention settings), and the fun settings (`allowGiphy`,
// `giphyContentRating`, `allowStickersAndMemes`, `allowCustomMemes`). Use
// `channels` to enumerate the team's channels and `isArchived` to spot
// archived teams.
private ms365.teams.team @defaults("displayName description visibility") {
  // Team (group) ID
  id string
  // Team display name
  displayName string
  // Team description
  description string
  // Team visibility (public, private, hiddenMembership)
  visibility() string
  // Whether the team is archived
  isArchived() bool
  // Team specialization
  //
  // One of none, educationStandard, educationClass,
  // educationProfessionalLearningCommunity, educationStaff,
  // healthcareStandard, or healthcareCareCoordination.
  specialization() string
  // Team data classification
  classification() string
  // Date and time the team was created
  createdDateTime() time
  // URL that opens the team in the Teams client
  webUrl() string
  // Whether members can create and update channels
  allowCreateUpdateChannels() bool
  // Whether members can create private channels
  allowCreatePrivateChannels() bool
  // Whether members can delete channels
  allowDeleteChannels() bool
  // Whether members can add and remove apps
  allowAddRemoveApps() bool
  // Whether members can create, update, and remove tabs
  allowCreateUpdateRemoveTabs() bool
  // Whether members can create, update, and remove connectors
  allowCreateUpdateRemoveConnectors() bool
  // Whether guests can create and update channels
  guestAllowCreateUpdateChannels() bool
  // Whether guests can delete channels
  guestAllowDeleteChannels() bool
  // Whether users can edit their own sent messages
  allowUserEditMessages() bool
  // Whether users can delete their own sent messages
  allowUserDeleteMessages() bool
  // Whether team owners can delete messages sent by others
  allowOwnerDeleteMessages() bool
  // Whether @team mentions are allowed
  allowTeamMentions() bool
  // Whether @channel mentions are allowed
  allowChannelMentions() bool
  // Whether Giphy can be used in conversations
  allowGiphy() bool
  // Giphy content rating (moderate, strict)
  giphyContentRating() string
  // Whether stickers and memes can be used
  allowStickersAndMemes() bool
  // Whether custom memes can be uploaded and used
  allowCustomMemes() bool
  // Channels in the team
  channels() []ms365.teams.channel
}

// Microsoft Teams channel
//
// Examine a single channel within a team. Exposes the channel
// `displayName`, `description`, `membershipType` (standard, private, or
// shared), `email`, `webUrl`, `createdDateTime`, and whether the channel
// `isArchived`. Private and shared channels narrow who can participate, so
// `membershipType` is a key governance signal.
private ms365.teams.channel @defaults("displayName membershipType") {
  // Channel ID
  id string
  // Channel display name
  displayName string
  // Channel description
  description string
  // Channel membership type (standard, private, shared, unknownFutureValue)
  membershipType string
  // Email address for sending messages to the channel
  email string
  // URL that opens the channel in the Teams client
  webUrl string
  // Date and time the channel was created
  createdDateTime time
  // Whether the channel is archived
  isArchived bool
}

// Mailbox Plan
private ms365.exchangeonline.mailboxPlan @defaults("name alias prohibitSendQuota maxSendSize maxReceiveSize") {
  // Plan name
  name string
  // Plan alias
  alias string
  // Prohibit send quota
  prohibitSendQuota string
  // Maximum send size
  maxSendSize string
  // Maximum receive size
  maxReceiveSize string

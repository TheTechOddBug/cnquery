  // The user's preferred language (ISO 639-1 code)
  preferredLanguage string
  // The two-letter country code for the user's usage location (required for license assignment)
  usageLocation string
  // The state of an external user's invitation (PendingAcceptance, Accepted, etc.)
  externalUserState string
  // Password policies applied to the user (e.g., DisablePasswordExpiration, DisableStrongPassword)
  passwordPolicies string
  // User's most recent sign-in timestamps and request IDs

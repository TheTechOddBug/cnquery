  // Whether the label has protection enabled
  hasProtection bool
  // Whether the label is active
  isActive bool
  // Sensitivity level (lower number = less sensitive)
  sensitivity int
  // Parent label in the hierarchy
  parent microsoft.security.informationProtection.sensitivityLabel
}


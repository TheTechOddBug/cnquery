  // User country
  //
  // Deprecated in favor of `contact.country`.
  country @maturity("deprecated") string
  // User create time
  createdDateTime time
  // User department
  //
  // Deprecated in favor of `job.department`.
  department @maturity("deprecated") string
  // User display name
  displayName string
  // User employee ID
  //
  // Deprecated in favor of `job.employeeId`.
  employeeId @maturity("deprecated") string
  // User given name
  givenName string
  // User job title
  //
  // Deprecated in favor of `job.title`.
  jobTitle @maturity("deprecated") string
  // User email address
  //
  // Deprecated in favor of `contact.email`.
  mail @maturity("deprecated") string
  // User mobile phone number
  //
  // Deprecated in favor of `contact.mobilePhone`.
  mobilePhone @maturity("deprecated") string
  // Additional email addresses for the user
  //
  // Deprecated in favor of `contact.otherMails`.
  otherMails @maturity("deprecated") []string
  // User office location
  //
  // Deprecated in favor of `job.officeLocation`.
  officeLocation @maturity("deprecated") string
  // User postal code
  //
  // Deprecated in favor of `contact.postalCode`.
  postalCode @maturity("deprecated") string
  // User state or province
  //
  // Deprecated in favor of `contact.state`.
  state @maturity("deprecated") string
  // User street address
  //
  // Deprecated in favor of `contact.streetAddress`.
  streetAddress @maturity("deprecated") string
  // User surname
  surname string
  // User service principal name
  userPrincipalName string
  // User type
  userType string
  // User's Office Delve content-discovery settings

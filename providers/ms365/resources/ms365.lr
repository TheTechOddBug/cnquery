  // of `user` or `group`.
  includeTargets []dict
  // Users and groups excluded from the method
  //
  // Each entry has an `id` (the user or group object ID) and a `targetType`
  // of `user` or `group`.
  excludeTargets []dict
  // Default lifetime of a Temporary Access Pass, in minutes
  defaultLifetimeInMinutes int
  // Default length of a generated Temporary Access Pass
  defaultLength int
  // Minimum lifetime of a Temporary Access Pass, in minutes
  minimumLifetimeInMinutes int
  // Maximum lifetime of a Temporary Access Pass, in minutes
  maximumLifetimeInMinutes int
  // Whether a Temporary Access Pass can be used only once
  isUsableOnce bool
}


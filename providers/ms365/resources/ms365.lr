  fido2() microsoft.authenticationMethodsPolicy.fido2
  // Microsoft Authenticator authentication method configuration
  microsoftAuthenticator() microsoft.authenticationMethodsPolicy.microsoftAuthenticator
  // Temporary Access Pass authentication method configuration
  temporaryAccessPass() microsoft.authenticationMethodsPolicy.temporaryAccessPass
  // Email one-time passcode authentication method configuration
  email() microsoft.authenticationMethodsPolicy.email

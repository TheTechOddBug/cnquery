  compartment() oci.compartment
  // Parent vault OCID
  //
  // Deprecated in favor of `vault()`.
  vaultId @maturity("deprecated") string
  // Parent vault containing the key
  vault() oci.kms.vault
  // Key algorithm (AES, RSA, ECDSA)
  algorithm string

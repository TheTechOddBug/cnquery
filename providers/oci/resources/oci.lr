  compartment() oci.compartment
  // Vault type (DEFAULT, VIRTUAL_PRIVATE, EXTERNAL)
  vaultType string
  // Lifecycle state
  //
  // For example: CREATING, ACTIVE, DELETING, DELETED, PENDING_DELETION, SCHEDULING_DELETION, CANCELLING_DELETION, UPDATING, BACKUP_IN_PROGRESS, RESTORING.
  state string

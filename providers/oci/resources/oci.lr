  // API gateways in the tenancy
  gateways() []oci.apigateway.gateway
  // API deployments across all gateways
  deployments() []oci.apigateway.deployment
  // API gateway TLS certificates (in the apigateway service, distinct from oci.certificates.certificate)
  certificates() []oci.apigateway.certificate
}

// Oracle Cloud Infrastructure (OCI) API gateway (regional network appliance)
private oci.apigateway.gateway @defaults("name") {
  // Gateway OCID
  id string
  // Display name
  name string
  // Compartment OCID
  compartmentID string
  // Endpoint type (PUBLIC, PRIVATE)
  endpointType string
  // IP addressing mode (IPV4, IPV6, DUAL_STACK)
  ipMode string
  // Hostname assigned to the gateway
  hostname string
  // Whether a response cache is configured (true for EXTERNAL_RESP_CACHE; false for NONE or unset)
  hasResponseCache bool
  // IP addresses assigned to the gateway
  ipAddresses []string
  // Subnet the gateway is deployed in
  subnet() oci.network.subnet
  // Network Security Groups attached to the gateway
  networkSecurityGroups() []oci.network.networkSecurityGroup
  // TLS certificate used by the gateway (from the apigateway certificates service)
  certificate() oci.apigateway.certificate
  // OCIDs of CA bundles (from the certificatesmanagement service or the apigateway certificates service) used by the gateway for TLS validation
  caBundleIds []string
  // Lifecycle state (e.g., CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED)
  state string
  // Creation time
  created time
  // Last update time
  timeUpdated time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) API gateway deployment
private oci.apigateway.deployment @defaults("name pathPrefix") {
  // Deployment OCID
  id string
  // Display name
  name string
  // Compartment OCID
  compartmentID string
  // Parent gateway
  gateway() oci.apigateway.gateway
  // Path prefix on the gateway that this deployment is deployed to
  pathPrefix string
  // Endpoint URL to reach this deployment
  endpoint string
  // Lifecycle state (e.g., CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED)
  state string
  // Authentication method configured for this deployment: NONE, TOKEN_AUTHENTICATION, JWT_AUTHENTICATION, or CUSTOM_AUTHENTICATION
  authenticationType() string
  // Whether anonymous (unauthenticated) access is allowed
  isAnonymousAccessAllowed() bool
  // JWT audiences accepted when authenticationType is JWT_AUTHENTICATION
  jwtAudiences() []string
  // JWT issuers accepted when authenticationType is JWT_AUTHENTICATION
  jwtIssuers() []string
  // Whether client certificate verification is required on mTLS connections
  mtlsIsVerifiedCertificateRequired() bool
  // Allowed CNs or SANs for client certificates on mTLS connections
  mtlsAllowedSans() []string
  // Allowed origins for CORS (empty if CORS is not configured)
  corsAllowedOrigins() []string
  // Whether CORS requests may include credentials
  corsAllowCredentials() bool
  // Maximum number of requests per second allowed (0 if rate limiting is not configured)
  rateLimitPerSecond() int
  // Rate limiting grouping key (e.g., CLIENT_IP); empty when not configured
  rateLimitKey() string
  // Whether dynamic authentication (multiple auth options selected by request) is configured
  hasDynamicAuthentication() bool
  // Creation time
  created time
  // Last update time
  timeUpdated time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) API gateway TLS certificate (distinct from oci.certificates.certificate; managed by the apigateway service)
private oci.apigateway.certificate @defaults("name") {
  // Certificate OCID
  id string
  // Display name
  name string
  // Compartment OCID
  compartmentID string
  // Subject names secured by the certificate (CN plus SANs)
  subjectNames []string
  // Certificate expiration time
  timeNotValidAfter time
  // Lifecycle state (e.g., CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED)
  state string
  // Creation time
  created time
  // Last update time
  timeUpdated time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) Certificates Management
//
// Use the OCI Certificates namespace to enumerate the tenancy's
// managed PKI material. Iterate `certificates()` for the managed
// TLS certificates (each surfacing the issuer authority, subject and
// SAN list, validity window, KMS-backed key spec, and configuration
// origin — issued by an internal CA, externally managed, or
// imported), `certificateAuthorities()` for the root and subordinate
// CAs, and `caBundles()` for the trust bundles applications import
// to validate peer certificates.
oci.certificates {
  // Managed TLS certificates
  certificates() []oci.certificates.certificate
  // Certificate authorities (root or subordinate)
  certificateAuthorities() []oci.certificates.certificateAuthority
  // CA bundles (collections of trusted CA certificates)
  caBundles() []oci.certificates.caBundle
}

// Oracle Cloud Infrastructure (OCI) managed TLS certificate
private oci.certificates.certificate @defaults("name") {
  // Certificate OCID
  id string
  // Certificate name
  name string
  // Certificate description
  description string
  // Compartment OCID
  compartmentID string
  // Configuration origin (ISSUED_BY_INTERNAL_CA, MANAGED_EXTERNALLY_ISSUED_BY_INTERNAL_CA, IMPORTED)
  configType string
  // Issuing certificate authority (set when configType is ISSUED_BY_INTERNAL_CA or MANAGED_EXTERNALLY_ISSUED_BY_INTERNAL_CA)
  issuerCertificateAuthority() oci.certificates.certificateAuthority
  // Subject common name (CN)
  subject string
  // Subject alternative names (DNS/IP entries from the current certificate version)
  sans []string
  // Start of the certificate's validity period
  validityNotBefore time
  // End of the certificate's validity period
  validityNotAfter time
  // Key algorithm (RSA2048, RSA4096, ECDSA_P256, ECDSA_P384)
  keyAlgorithm string
  // Signature algorithm (e.g., SHA256_WITH_RSA, SHA384_WITH_RSA, SHA512_WITH_RSA, SHA256_WITH_ECDSA, SHA384_WITH_ECDSA, SHA512_WITH_ECDSA)
  signatureAlgorithm string
  // Certificate profile type (e.g., TLS_SERVER_OR_CLIENT, TLS_SERVER, TLS_CLIENT, TLS_CODE_SIGN)
  profileType string
  // Current certificate version number
  currentVersion int
  // Whether auto-renewal is enabled (true when a CERTIFICATE_RENEWAL_RULE is present)
  autoRenewalEnabled bool
  // Renewal interval (ISO 8601 duration, e.g., P365D); empty when auto-renewal is not configured
  renewalInterval string
  // Lifecycle state (e.g., CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED)
  state string
  // Creation time
  created time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) certificate authority
private oci.certificates.certificateAuthority @defaults("name") {
  // CA OCID
  id string
  // CA name
  name string
  // CA description
  description string
  // Compartment OCID
  compartmentID string
  // CA kind inferred from configType (ROOT for ROOT_CA_*, SUBORDINATE for SUBORDINATE_CA_*)
  kind string
  // Configuration origin
  //
  // One of: ROOT_CA_GENERATED_INTERNALLY, SUBORDINATE_CA_ISSUED_BY_INTERNAL_CA, ROOT_CA_MANAGED_EXTERNALLY, SUBORDINATE_CA_MANAGED_INTERNALLY_ISSUED_BY_EXTERNAL_CA.
  configType string
  // Parent CA for subordinate CAs (null for root CAs)
  issuerCertificateAuthority() oci.certificates.certificateAuthority
  // Subject common name (CN)
  subject string
  // Start of the CA certificate's validity period (from the current version)
  validityNotBefore time
  // End of the CA certificate's validity period (from the current version)
  validityNotAfter time
  // Signing algorithm used by this CA to sign certificates (e.g., SHA256_WITH_RSA)
  signingAlgorithm string
  // KMS key used to encrypt this CA's private material
  kmsKey() oci.kms.key
  // Lifecycle state (e.g., CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED, PENDING_DELETION, SCHEDULING_DELETION, CANCELLING_DELETION)
  state string
  // Creation time
  created time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) CA bundle (collection of trusted CA certificates)
private oci.certificates.caBundle @defaults("name") {
  // CA bundle OCID
  id string
  // CA bundle name
  name string
  // CA bundle description
  description string
  // Compartment OCID
  compartmentID string
  // Lifecycle state (e.g., CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED)
  state string
  // Creation time
  created time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) Cache
//
// Use the OCI Cache namespace to enumerate the tenancy's managed
// in-memory cache deployments. Iterate `clusters()` for every cache
// cluster — each cluster surfaces the engine (Redis or Valkey) and
// version, node count and shape, the primary and replicas FQDNs and
// endpoints, attached subnet, NSG bindings, lifecycle state, and
// cluster mode.
oci.redis {
  // OCI Cache clusters
  clusters() []oci.redis.cluster
}

// Oracle Cloud Infrastructure (OCI) Cache cluster (Redis or Valkey)
private oci.redis.cluster @defaults("name softwareVersion state") {
  init(id? string)
  // Cluster OCID
  id string
  // Cluster display name
  name string
  // Compartment OCID containing the cluster
  compartmentID string
  // Cache engine version (e.g., REDIS_7_0, VALKEY_7_2, VALKEY_8_1)
  softwareVersion string
  // Cluster mode (SHARDED or NONSHARDED)
  clusterMode string
  // Number of nodes per shard when sharded; total node count otherwise
  nodeCount int
  // Memory allocated to each node, in gigabytes
  nodeMemoryInGBs float
  // Number of shards (only set when clusterMode is SHARDED)
  shardCount int
  // Subnet the cluster is deployed in
  subnet() oci.network.subnet
  // Network security groups attached to the cluster
  networkSecurityGroups() []oci.network.networkSecurityGroup
  // FQDN of the primary node API endpoint
  primaryFqdn string
  // Private IP of the primary node API endpoint
  primaryEndpointIpAddress string
  // FQDN of the replica nodes API endpoint
  replicasFqdn string
  // Private IP of the replica nodes API endpoint
  replicasEndpointIpAddress string
  // FQDN of the sharded cluster discovery endpoint
  discoveryFqdn string
  // Private IP of the sharded cluster discovery endpoint
  discoveryEndpointIpAddress string
  // Cluster lifecycle state (e.g., CREATING, UPDATING, ACTIVE, DELETING, DELETED, FAILED)
  state string
  // Creation time
  created time
  // Last update time
  timeUpdated time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Data Safe
//
// Use the Data Safe namespace to enumerate Data Safe coverage in the
// tenancy. Iterate `targetDatabases()` for the databases registered
// under Data Safe; `securityAssessments()` and `userAssessments()` for
// the latest configuration-posture and user-risk findings;
// `sensitiveDataModels()` and `sensitiveTypes()` for the
// data-discovery catalog; and `maskingPolicies()` for the masking
// definitions applied during refresh, clone, or export. `configurations`
// reports per-region service enablement.
oci.dataSafe {
  // Per-region Data Safe service enablement records, with the URL, lifecycle state, and global settings of each region where Data Safe has been turned on
  configurations() []oci.dataSafe.configuration
  // Databases registered under Data Safe across every region and compartment in the tenancy
  targetDatabases() []oci.dataSafe.targetDatabase
  // Security assessments (configuration-posture findings) produced by Data Safe
  securityAssessments() []oci.dataSafe.securityAssessment
  // User assessments (user-risk findings) produced by Data Safe
  userAssessments() []oci.dataSafe.userAssessment
  // Sensitive data models — the per-target catalogs of sensitive columns produced by data discovery
  sensitiveDataModels() []oci.dataSafe.sensitiveDataModel
  // Sensitive type definitions (predefined Oracle types and tenant-defined types) used during data discovery
  sensitiveTypes() []oci.dataSafe.sensitiveType
  // Masking policies that define how columns are masked during a sensitive-data masking job
  maskingPolicies() []oci.dataSafe.maskingPolicy
}

// Oracle Data Safe service enablement configuration for a single region
//
// Examine the per-region Data Safe configuration — whether Data Safe is
// turned on in this region, the service URL and lifecycle state, and the
// `globalSettings` block that controls offline retention, online
// retention, and paid-usage flags.
private oci.dataSafe.configuration @defaults("region isEnabled lifecycleState") {
  // OCI region key the configuration was retrieved from (e.g. `us-ashburn-1`)
  region string
  // Whether Data Safe is enabled in this region
  isEnabled bool
  // URL of the Data Safe service in this region
  url string
  // OCID of the tenancy used to enable Data Safe
  compartmentId string
  // Lifecycle state of Data Safe in this region (CREATING, UPDATING, ACTIVE, INACTIVE, DELETING, DELETED, FAILED)
  lifecycleState string
  // NAT Gateway IP address used by Data Safe to reach customer databases in this region
  natGatewayIpAddress string
  // Global settings controlling offline / online retention and paid-usage flags
  globalSettings dict
  // Time Data Safe was enabled in this region
  enabledAt time
  // Free-form tags applied to the configuration
  freeformTags map[string]string
  // Defined tags applied to the configuration
  definedTags map[string]map[string]string
}

// Oracle Data Safe target database
//
// Examine a single registered target database. `infrastructureType`
// distinguishes Oracle DB systems on Exadata, Autonomous DB, base DB,
// or external/on-premises. `databaseType` reflects the deployment model
// (Autonomous Database, DB system, installed DB). `associatedResourceIds`
// lists the connected resources (database, private endpoint).
private oci.dataSafe.targetDatabase @defaults("displayName databaseType lifecycleState region") {
  // OCID of the target database
  id string
  // OCID of the compartment that contains the target database
  compartmentId string
  // OCI region the target is registered in
  region string
  // Display name of the target in Data Safe
  displayName string
  // Description of the target
  description string
  // Infrastructure type (ORACLE_CLOUD, ORACLE_EXADATA_CLOUD_AT_CUSTOMER, ORACLE_EXADATA_CLOUD, ORACLE_EXACC, INSTALLED_DATABASE, NON_ORACLE_CLOUD)
  infrastructureType string
  // Database type (DATABASE_CLOUD_SERVICE, AUTONOMOUS_DATABASE, INSTALLED_DATABASE)
  databaseType string
  // Lifecycle state (CREATING, UPDATING, ACTIVE, INACTIVE, NEEDS_ATTENTION, FAILED, DELETING, DELETED)
  lifecycleState string
  // Details about the current lifecycle state when state is FAILED or NEEDS_ATTENTION
  lifecycleDetails string
  // OCIDs of associated resources like the underlying database, Data Safe private endpoint, etc.
  associatedResourceIds []string
  // Time the target was registered
  created time
  // Free-form tags on the target
  freeformTags map[string]string
  // Defined tags on the target
  definedTags map[string]map[string]string
}

// Oracle Data Safe security assessment
//
// Examine a single security assessment — the configuration-posture
// finding produced by Data Safe against one or more target databases.
// `type` distinguishes LATEST (auto-generated per target), SAVED
// (snapshot), SAVE_SCHEDULE (periodic save config), TEMPLATE (user-defined
// check set), TEMPLATE_BASELINE (template with severity caps), and
// COMPARTMENT (aggregate of every target in a compartment). `targetIds`
// names the targets the assessment covers.
private oci.dataSafe.securityAssessment @defaults("displayName type lifecycleState region") {
  // OCID of the security assessment
  id string
  // OCID of the compartment that contains the assessment
  compartmentId string
  // OCI region the assessment was produced in
  region string
  // Display name of the assessment
  displayName string
  // Lifecycle state (CREATING, SUCCEEDED, UPDATING, FAILED, DELETING, DELETED)
  lifecycleState string
  // Assessment type: LATEST, SAVED, SAVE_SCHEDULE, TEMPLATE, TEMPLATE_BASELINE, COMPARTMENT
  type string
  // OCIDs of the target databases the assessment covers
  targetIds []string
  // Whether this is a baseline assessment used as the comparison reference
  isBaseline bool
  // Whether the assessment deviates from its configured baseline
  isDeviatedFromBaseline bool
  // Time the assessment was created
  created time
  // Time the assessment was last updated
  timeUpdated time
  // Free-form tags on the assessment
  freeformTags map[string]string
  // Defined tags on the assessment
  definedTags map[string]map[string]string
}

// Oracle Data Safe user assessment
//
// Examine a single user assessment — the user-risk finding produced
// against one or more target databases. Inspect `type` to distinguish
// LATEST, SAVED, SAVE_SCHEDULE, TEMPLATE, TEMPLATE_BASELINE, and
// COMPARTMENT (aggregate), and `targetIds` for the targets covered.
private oci.dataSafe.userAssessment @defaults("displayName type lifecycleState region") {
  // OCID of the user assessment
  id string
  // OCID of the compartment that contains the user assessment
  compartmentId string
  // OCI region the assessment was produced in
  region string
  // Display name of the assessment
  displayName string
  // Lifecycle state (CREATING, SUCCEEDED, UPDATING, FAILED, DELETING, DELETED)
  lifecycleState string
  // Assessment type: LATEST, SAVED, SAVE_SCHEDULE, TEMPLATE, TEMPLATE_BASELINE, COMPARTMENT
  type string
  // OCIDs of the target databases the assessment covers
  targetIds []string
  // Whether this is the baseline assessment used as the comparison reference
  isBaseline bool
  // Whether the assessment deviates from its configured baseline
  isDeviatedFromBaseline bool
  // Time the assessment was created
  created time
  // Time the assessment was last updated
  timeUpdated time
  // Free-form tags on the assessment
  freeformTags map[string]string
  // Defined tags on the assessment
  definedTags map[string]map[string]string
}

// Oracle Data Safe sensitive data model
//
// Examine a single sensitive data model — the per-target catalog of
// sensitive columns produced by data discovery. `targetId` is the
// reference database the model was discovered against; `appSuiteName`
// groups models that belong to the same application suite.
private oci.dataSafe.sensitiveDataModel @defaults("displayName lifecycleState appSuiteName region") {
  // OCID of the sensitive data model
  id string
  // OCID of the compartment that contains the sensitive data model
  compartmentId string
  // OCI region the sensitive data model is hosted in
  region string
  // Display name of the model
  displayName string
  // Description of the model
  description string
  // Lifecycle state (CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED)
  lifecycleState string
  // OCID of the reference target database the model was discovered against
  targetId string
  // Application suite name identifying a collection of applications, default GENERIC
  appSuiteName string
  // Time the model was created
  created time
  // Time the model was last updated
  timeUpdated time
  // Free-form tags on the model
  freeformTags map[string]string
  // Defined tags on the model
  definedTags map[string]map[string]string
}

// Oracle Data Safe sensitive type
//
// Examine a single sensitive type definition — either an Oracle
// predefined type or a tenant-defined custom type used during data
// discovery. `entityType` distinguishes a single regex-backed
// sensitive type (SENSITIVE_TYPE) from a sensitive category grouping
// multiple types (SENSITIVE_CATEGORY). `source` reflects whether the
// type ships with Oracle (ORACLE) or was defined by the tenant (USER).
private oci.dataSafe.sensitiveType @defaults("displayName entityType source region") {
  // OCID of the sensitive type
  id string
  // OCID of the compartment that contains the sensitive type
  compartmentId string
  // OCI region the sensitive type is hosted in
  region string
  // Display name of the sensitive type
  displayName string
  // Short name of the sensitive type
  shortName string
  // Lifecycle state (CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED)
  lifecycleState string
  // Whether the sensitive type is shipped by Oracle (ORACLE) or defined by the tenant (USER)
  source string
  // Whether the entry is a single regex-backed sensitive type (SENSITIVE_TYPE) or a sensitive category (SENSITIVE_CATEGORY) grouping multiple types
  entityType string
  // Time the sensitive type was created
  created time
  // Time the sensitive type was last updated
  timeUpdated time
  // Free-form tags on the sensitive type
  freeformTags map[string]string
  // Defined tags on the sensitive type
  definedTags map[string]map[string]string
}

// Oracle Data Safe masking policy
//
// Examine a single masking policy — the definition of how columns
// are masked during a sensitive-data masking job (refresh, clone,
// export). `columnSource` is the dict that names the sensitive data
// model or target the policy's columns are sourced from; its shape
// varies by the configured source type.
private oci.dataSafe.maskingPolicy @defaults("displayName lifecycleState region") {
  // OCID of the masking policy
  id string
  // OCID of the compartment that contains the masking policy
  compartmentId string
  // OCI region the masking policy is hosted in
  region string
  // Display name of the masking policy
  displayName string
  // Description of the masking policy
  description string
  // Lifecycle state (CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED, NEEDS_ATTENTION)
  lifecycleState string
  // Column source for the masking policy. Keys vary by source type: SENSITIVE_DATA_MODEL has `sensitiveDataModelId`; TARGET has `targetId`
  columnSource dict
  // Time the masking policy was created
  created time
  // Time the masking policy was last updated
  timeUpdated time
  // Free-form tags on the masking policy
  freeformTags map[string]string
  // Defined tags on the masking policy
  definedTags map[string]map[string]string
}

// Oracle Cloud Vulnerability Scanning Service
//
// Examine VSS configuration and findings — scan recipes that describe
// what to scan, targets that pin recipes to compute instances or
// container image repositories, and scan results recording per-host
// vulnerabilities, open ports, CIS benchmark scores, endpoint
// protection state, and per-image container vulnerabilities. Also
// surfaces the CVE-deduplicated `vulnerabilities` rollup that
// aggregates a single CVE's impact across every scanned host and
// container in the tenancy.
oci.vulnerabilityScanning {
  // Host scan recipes describing what each agent scan covers
  hostScanRecipes() []oci.vulnerabilityScanning.hostScanRecipe
  // Host scan targets pinning a recipe to a set of compute instances
  hostScanTargets() []oci.vulnerabilityScanning.hostScanTarget
  // Container scan recipes describing what each container image scan covers
  containerScanRecipes() []oci.vulnerabilityScanning.containerScanRecipe
  // Container scan targets pinning a recipe to an OCIR registry
  containerScanTargets() []oci.vulnerabilityScanning.containerScanTarget
  // Per-instance agent vulnerability scan results
  hostAgentScanResults() []oci.vulnerabilityScanning.hostAgentScanResult
  // Per-instance open port scan results
  hostPortScanResults() []oci.vulnerabilityScanning.hostPortScanResult
  // Per-instance CIS benchmark scan results
  hostCisBenchmarkScanResults() []oci.vulnerabilityScanning.hostCisBenchmarkScanResult
  // Per-instance endpoint protection scan results
  hostEndpointProtectionScanResults() []oci.vulnerabilityScanning.hostEndpointProtectionScanResult
  // Per-image container scan results
  containerScanResults() []oci.vulnerabilityScanning.containerScanResult
  // CVE-deduplicated vulnerability rollup across all scanned hosts and containers
  vulnerabilities() []oci.vulnerabilityScanning.vulnerability
}

// Host scan recipe
//
// Examine a host scan recipe — the policy object that defines what
// the agent scans on each host. Surfaces the four sub-scanner
// levels (port, agent CVE, CIS benchmark, endpoint protection), the
// application scan settings (recurrence and the per-OS folder list),
// and the scan schedule (daily or weekly with optional day-of-week).
private oci.vulnerabilityScanning.hostScanRecipe @defaults("name compartmentId portScanLevel agentScanLevel cisBenchmarkScanLevel endpointProtectionScanLevel") {
  // Recipe OCID
  id string
  // Recipe display name
  name string
  // Compartment OCID containing the recipe
  compartmentId string
  // Compartment containing the recipe
  compartment() oci.compartment
  // Lifecycle state (CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED)
  state string
  // Port scan level (NONE, LIGHT, STANDARD)
  portScanLevel string
  // Agent CVE scan level (NONE, STANDARD)
  agentScanLevel string
  // CIS benchmark scan level (NONE, LIGHT, MEDIUM, STRICT)
  cisBenchmarkScanLevel string
  // Endpoint protection scan level (NONE, STANDARD)
  endpointProtectionScanLevel string
  // Whether application scanning is enabled
  applicationScanEnabled bool
  // Application scan recurrence as an ISO-8601 duration
  applicationScanRecurrence string
  // Per-OS folder list scanned for application vulnerabilities
  //
  // Each entry has `operatingSystem` (LINUX, WINDOWS) and `folder`
  // (absolute path scanned on that OS).
  applicationFoldersToScan []dict
  // Scan schedule type (DAILY, WEEKLY)
  scheduleType string
  // Day of week for weekly schedules (MONDAY..SUNDAY)
  scheduleDayOfWeek string
  // Free-form tags on the recipe
  freeformTags map[string]string
}

// Host scan target
//
// Examine a host scan target — pins a host scan recipe to a list of
// compute instances within a compartment subtree. The target's
// recipe determines what gets scanned; the target determines where.
private oci.vulnerabilityScanning.hostScanTarget @defaults("name compartmentId state") {
  // Target OCID
  id string
  // Target display name
  name string
  // Target description
  description string
  // Compartment OCID containing the target
  compartmentId string
  // Compartment containing the target
  compartment() oci.compartment
  // Compartment OCID whose instances this target scans
  targetCompartmentId string
  // Compartment whose instances this target scans
  targetCompartment() oci.compartment
  // Host scan recipe OCID applied by this target
  hostScanRecipeId string
  // Host scan recipe applied by this target
  recipe() oci.vulnerabilityScanning.hostScanRecipe
  // Compute instance OCIDs scanned by this target
  instanceIds []string
  // Compute instances scanned by this target
  instances() []oci.compute.instance
  // Lifecycle state (CREATING, ACTIVE, UPDATING, DELETING, DELETED, FAILED)
  state string
  // Free-form tags on the target
  freeformTags map[string]string
}

// Container scan recipe
//
// Examine a container scan recipe — the policy object that defines
// what each container image scan covers. Surfaces the scan level
// (currently STANDARD only) and the number of images covered.
private oci.vulnerabilityScanning.containerScanRecipe @defaults("name compartmentId scanLevel imageCount") {
  // Recipe OCID
  id string
  // Recipe display name
  name string
  // Compartment OCID containing the recipe
  compartmentId string
  // Compartment containing the recipe
  compartment() oci.compartment
  // Lifecycle state
  state string
  // Container scan level (STANDARD)
  scanLevel string
  // Number of images covered by recipes referencing this scan recipe
  imageCount int
  // Free-form tags on the recipe
  freeformTags map[string]string
}

// Container scan target
//
// Examine a container scan target — pins a container scan recipe to
// a registry. Today only OCIR is supported; `registryUrl` and
// `registryRepositories` describe the registry endpoint and the
// repositories scanned.
private oci.vulnerabilityScanning.containerScanTarget @defaults("name compartmentId registryUrl") {
  // Target OCID
  id string
  // Target display name
  name string
  // Target description
  description string
  // Compartment OCID containing the target
  compartmentId string
  // Compartment containing the target
  compartment() oci.compartment
  // Container scan recipe OCID applied by this target
  containerScanRecipeId string
  // Container scan recipe applied by this target
  recipe() oci.vulnerabilityScanning.containerScanRecipe
  // Registry type (OCIR)
  registryType string
  // Registry URL
  registryUrl string
  // Repositories scanned within the registry
  registryRepositories []string
  // Lifecycle state
  state string
  // Free-form tags on the target
  freeformTags map[string]string
}

// Host agent vulnerability scan result
//
// Examine the most recent agent vulnerability scan for a compute
// instance. Surfaces the operating system and kernel version of the
// scanned host, the highest finding severity, the total problem
// count, and the per-CVE findings under `problems` (each with the
// vulnerable package list and a navigable `vulnerability()` rollup).
private oci.vulnerabilityScanning.hostAgentScanResult @defaults("name instanceId highestProblemSeverity problemCount") {
  // Scan result OCID
  id string
  // Scan result display name
  name string
  // Scanned compute instance OCID
  instanceId string
  // Scanned compute instance
  instance() oci.compute.instance
  // Compartment OCID containing the scan result
  compartmentId string
  // Compartment containing the scan result
  compartment() oci.compartment
  // Highest finding severity (NONE, LOW, MEDIUM, HIGH, CRITICAL)
  highestProblemSeverity string
  // Operating system of the scanned host
  operatingSystem string
  // Kernel version of the scanned host
  kernelVersion() string
  // Scanner vendor (OCI, QUALYS)
  vendor() string
  // Total number of problems found
  problemCount int
  // Lifecycle state
  state string
  // Per-CVE findings from the scan
  problems() []oci.vulnerabilityScanning.hostAgentScanResult.problem
}

// Host agent scan problem
//
// Examine a single CVE finding from a host agent scan — the CVE
// reference, severity, remediation state, and the vulnerable
// packages installed on the host. `vulnerability()` navigates to the
// tenancy-wide rollup for the same CVE.
private oci.vulnerabilityScanning.hostAgentScanResult.problem @defaults("name severity state cveReference") {
  // Vulnerability name (typically the CVE id)
  name string
  // Finding severity (NONE, LOW, MEDIUM, HIGH, CRITICAL)
  severity string
  // Vulnerability state (OPEN, FIXED, NOT_APPLICABLE)
  state string
  // Long-form description of the finding
  description string
  // CVE reference (e.g., CVE-2023-1234)
  cveReference string
  // Internal issue identifier (scanner-specific)
  issueId int
  // Tenancy-wide rollup for the same vulnerability
  vulnerability() oci.vulnerabilityScanning.vulnerability
  // Installed packages affected by this vulnerability
  //
  // Each entry has `name`, `version`, `type` (RPM, DPKG, ...),
  // `cveFixVersion` (empty when no fix is available), and
  // `locations` (file paths where the package is installed).
  vulnerablePackages []dict
}

// Host port scan result
//
// Examine the most recent open-port scan for a compute instance.
// Surfaces the highest severity across open ports and the per-port
// findings under `openPorts` (each pinned to the VNIC that exposes
// the port).
private oci.vulnerabilityScanning.hostPortScanResult @defaults("name instanceId openPortCount highestProblemSeverity") {
  // Scan result OCID
  id string
  // Scan result display name
  name string
  // Scanned compute instance OCID
  instanceId string
  // Scanned compute instance
  instance() oci.compute.instance
  // Compartment OCID containing the scan result
  compartmentId string
  // Compartment containing the scan result
  compartment() oci.compartment
  // Highest severity across open ports
  highestProblemSeverity string
  // Total number of open ports detected
  openPortCount int
  // Lifecycle state
  state string
  // Per-port findings from the scan
  openPorts() []oci.vulnerabilityScanning.hostPortScanResult.openPort
}

// Host port scan open port
//
// Examine a single open port detected on a compute instance —
// the port number, protocol, IP address, and the VNIC that exposes
// the port. `vnic()` navigates to the network interface and its
// security groups.
private oci.vulnerabilityScanning.hostPortScanResult.openPort @defaults("port protocol service severity") {
  // Port number
  port int
  // Protocol (tcp, udp)
  protocol string
  // IP address the port is listening on
  ipAddress string
  // Detected service name (e.g., ssh, http) — empty when unknown
  service string
  // Finding severity for this open port
  severity string
  // VNIC OCID exposing the port
  vnicId string
  // VNIC exposing the port
  vnic() oci.compute.vnic
}

// Host CIS benchmark scan result
//
// Examine the most recent CIS benchmark scan for a compute
// instance. Surfaces the total issue count and the per-control
// pass/fail scores under `scores`.
private oci.vulnerabilityScanning.hostCisBenchmarkScanResult @defaults("name instanceId cisBenchmarkScanIssuesCount") {
  // Scan result OCID
  id string
  // Scan result display name
  name string
  // Scanned compute instance OCID
  instanceId string
  // Scanned compute instance
  instance() oci.compute.instance
  // Compartment OCID containing the scan result
  compartmentId string
  // Compartment containing the scan result
  compartment() oci.compartment
  // Total number of CIS benchmark issues found
  cisBenchmarkScanIssuesCount int
  // Lifecycle state
  state string
  // Per-control benchmark scores
  //
  // Each entry has `benchmarkIdentifier` (e.g., "1.1.1"),
  // `description` (the control statement), and `score` (PASS or
  // FAIL).
  scores []dict
}

// Host endpoint protection scan result
//
// Examine the most recent endpoint protection posture scan for a
// compute instance. Surfaces the overall problem severity, the
// number of endpoint protection services evaluated, and the
// per-service findings.
private oci.vulnerabilityScanning.hostEndpointProtectionScanResult @defaults("name instanceId problemSeverity endpointProtectionsCount") {
  // Scan result OCID
  id string
  // Scan result display name
  name string
  // Scanned compute instance OCID
  instanceId string
  // Scanned compute instance
  instance() oci.compute.instance
  // Compartment OCID containing the scan result
  compartmentId string
  // Compartment containing the scan result
  compartment() oci.compartment
  // Overall endpoint protection problem severity
  problemSeverity string
  // Number of endpoint protection services evaluated
  endpointProtectionsCount int
  // Lifecycle state
  state string
  // Per-service endpoint protection findings
  //
  // Each entry has `service` (the endpoint protection product name),
  // `configurationFinding` (the misconfiguration, if any), and
  // `severity`.
  endpointProtections []dict
}

// Container vulnerability scan result
//
// Examine the most recent container image scan. Surfaces the
// repository, image tag, registry URL, and the per-CVE findings
// under `problems`. `target()` navigates back to the container
// scan target that produced the result.
private oci.vulnerabilityScanning.containerScanResult @defaults("repository image highestProblemSeverity problemCount") {
  // Scan result OCID
  id string
  // Container repository
  repository string
  // Image tag or digest
  image string
  // Registry URL the image was pulled from
  registryUrl() string
  // Compartment OCID containing the scan result
  compartmentId string
  // Compartment containing the scan result
  compartment() oci.compartment
  // Target compartment OCID (where the source image lives)
  targetCompartmentId() string
  // Container scan target OCID
  containerScanTargetId string
  // Container scan target that produced the result
  target() oci.vulnerabilityScanning.containerScanTarget
  // Highest finding severity across the image
  highestProblemSeverity string
  // Total number of problems found
  problemCount int
  // Per-CVE findings from the scan
  problems() []oci.vulnerabilityScanning.containerScanResult.problem
}

// Container scan problem
//
// Examine a single CVE finding from a container image scan — the
// CVE reference, severity, remediation state, and the vulnerable
// packages baked into the image. `vulnerability()` navigates to the
// tenancy-wide rollup for the same CVE.
private oci.vulnerabilityScanning.containerScanResult.problem @defaults("name severity state cveReference") {
  // Vulnerability name (typically the CVE id)
  name string
  // Finding severity
  severity string
  // Vulnerability state (OPEN, FIXED, NOT_APPLICABLE)
  state string
  // Long-form description of the finding
  description string
  // CVE reference
  cveReference string
  // Tenancy-wide rollup for the same vulnerability
  vulnerability() oci.vulnerabilityScanning.vulnerability
  // Image layer packages affected by this vulnerability
  //
  // Each entry has `name`, `version`, `type`, `cveFixVersion`, and
  // `locations` (file paths inside the image where the package
  // resides).
  vulnerablePackages []dict
}

// Vulnerability rollup
//
// Examine a single vulnerability aggregated across every scanned
// host and container in the tenancy. Each row collapses a single
// CVE (or proprietary issue) into the highest observed severity,
// the impacted-resource counts, and the CVE metadata (title,
// impact, threat, solution, exploitability). `impactedHosts()`
// returns the compute instances affected.
private oci.vulnerabilityScanning.vulnerability @defaults("name severity vulnerabilityType state") {
  // Vulnerability identifier (CVE id or proprietary issue id)
  id string
  // Vulnerability name (typically the CVE id)
  name string
  // Compartment OCID owning the rollup row
  compartmentId string
  // Compartment owning the rollup row
  compartment() oci.compartment
  // Highest observed severity
  severity string
  // Vulnerability type (CVE, PROBLEM)
  vulnerabilityType string
  // Remediation state (OPEN, FIXED, NOT_APPLICABLE)
  state string
  // Authentication requirement for exploitation
  authentication string
  // Upstream reference identifier
  vulnerabilityReference string
  // CVE description from the upstream reference
  cveDescription string
  // CVE title
  cveTitle string
  // CVE impact summary
  cveImpact string
  // CVE threat summary
  cveThreat string
  // CVE remediation guidance
  cveSolution string
  // Whether a patch is available (yes, no, unknown)
  cvePatchable string
  // Whether a public exploit is known (yes, no, unknown)
  cveExploitable string
  // Related CVE reference, when applicable
  cveRelatedReference string
  // Upstream URL with full vulnerability details
  cveReferenceUrl string
  // Number of compute instances affected
  impactedHostsCount int
  // Number of container images affected
  impactedContainersCount int
  // Lifecycle state
  lifecycleState string
  // Compute instances affected by this vulnerability
  impactedHosts() []oci.compute.instance
  // Container images affected by this vulnerability
  //
  // Each entry has `image`, `repository`, `registryUrl`, and
  // `compartmentId`.
  impactedContainerImages() []dict
}

// Oracle Cloud Infrastructure (OCI) AI services
//
// Use the OCI AI namespace as the entry point for Oracle's managed AI
// and machine-learning services. Reach `oci.ai.agents` for the
// Generative AI Agents service — the agents, agent endpoints, knowledge
// bases, data sources, and tools that make up retrieval-augmented
// generation (RAG) and agentic applications in the tenancy.
oci.ai {
}

// Oracle Cloud Infrastructure (OCI) Generative AI Agents
//
// Use the Generative AI Agents namespace to enumerate the tenancy's
// agentic AI estate across every subscribed region. Iterate `agents()`
// for the configured agents, `agentEndpoints()` for the endpoints that
// clients connect to (with their content-moderation and guardrail
// settings), `knowledgeBases()` and `dataSources()` for the enterprise
// data wired into retrieval-augmented generation, and `tools()` for the
// tools attached to agents — including the HTTP-endpoint and
// function-calling tools that let an agent reach external APIs.
oci.ai.agents {
  // Generative AI agents
  agents() []oci.ai.agents.agent
  // Agent endpoints
  agentEndpoints() []oci.ai.agents.endpoint
  // Knowledge bases
  knowledgeBases() []oci.ai.agents.knowledgeBase
  // Knowledge base data sources
  dataSources() []oci.ai.agents.dataSource
  // Tools attached to agents
  tools() []oci.ai.agents.tool
}

// Oracle Cloud Infrastructure (OCI) Generative AI agent
//
// Examine a single Generative AI agent — the large-language-model
// application that answers questions over enterprise data. Select an
// agent by its OCID, for example
// `oci.ai.agents.agent(id: "ocid1.genaiagent.oc1...")`. The agent
// exposes its welcome message, the language-model routing configuration,
// and the compartment it lives in. Connect to an agent through one of
// its `oci.ai.agents.endpoint` resources.
private oci.ai.agents.agent @defaults("name state") {
  init(id? string)
  // Agent OCID
  id string
  // Agent display name
  name string
  // Compartment OCID containing the agent
  compartmentID string
  // Compartment containing the agent
  compartment() oci.compartment
  // Description of the agent's purpose
  description string
  // Greeting shown to users at the start of a conversation
  welcomeMessage string
  // Language-model routing and selection configuration
  llmConfig dict
  // Lifecycle state (e.g., CREATING, UPDATING, ACTIVE, DELETING, DELETED, FAILED)
  state string
  // Detail message describing the current lifecycle state
  lifecycleDetails string
  // Creation time
  created time
  // Last update time
  timeUpdated time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) Generative AI agent endpoint
//
// Examine a single Generative AI agent endpoint — the network-reachable
// entry point clients use to chat with an agent. Select an endpoint by
// its OCID, for example
// `oci.ai.agents.endpoint(id: "ocid1.genaiagentendpoint.oc1...")`. The
// endpoint reports whether content moderation runs on input and output,
// the guardrail configuration that screens for content, prompt
// injection, and personally identifiable information, session behavior,
// and whether tracing and citations are returned in chat results — the
// controls that govern how safely the agent can be used.
private oci.ai.agents.endpoint @defaults("name state") {
  init(id? string)
  // Endpoint OCID
  id string
  // Endpoint display name
  name string
  // Compartment OCID containing the endpoint
  compartmentID string
  // Compartment containing the endpoint
  compartment() oci.compartment
  // OCID of the agent this endpoint serves
  agentID string
  // Agent this endpoint serves
  agent() oci.ai.agents.agent
  // Description of the endpoint
  description string
  // Whether content moderation runs on user input
  contentModerationOnInput bool
  // Whether content moderation runs on model output
  contentModerationOnOutput bool
  // Guardrail configuration screening content, prompt injection, and PII
  //
  // Has `contentModerationConfig`, `promptInjectionConfig`, and
  // `personallyIdentifiableInformationConfig`, each reporting whether
  // the guardrail is enabled and the action it takes.
  guardrailConfig dict
  // Idle timeout in seconds before a chat session expires
  sessionIdleTimeoutInSeconds int
  // Whether session-based chat is enabled
  sessionEnabled bool
  // Whether traces are returned in chat results
  traceEnabled bool
  // Whether citations are returned in chat results
  citationEnabled bool
  // Whether multi-language chat is enabled
  multiLanguageEnabled bool
  // Additional endpoint configuration key-value pairs
  metadata map[string]string
  // Lifecycle state (e.g., CREATING, UPDATING, ACTIVE, DELETING, DELETED, FAILED)
  state string
  // Detail message describing the current lifecycle state
  lifecycleDetails string
  // Creation time
  created time
  // Last update time
  timeUpdated time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) Generative AI agent knowledge base
//
// Examine a single knowledge base — the indexed corpus an agent
// retrieves from to answer questions. Select a knowledge base by its
// OCID, for example
// `oci.ai.agents.knowledgeBase(id: "ocid1.genaiagentknowledgebase.oc1...")`.
// Iterate the tenancy's `dataSources` to see which content feeds each
// knowledge base.
private oci.ai.agents.knowledgeBase @defaults("name state") {
  init(id? string)
  // Knowledge base OCID
  id string
  // Knowledge base display name
  name string
  // Compartment OCID containing the knowledge base
  compartmentID string
  // Compartment containing the knowledge base
  compartment() oci.compartment
  // Description of the knowledge base
  description string
  // Lifecycle state (e.g., CREATING, UPDATING, ACTIVE, DELETING, DELETED, FAILED)
  state string
  // Detail message describing the current lifecycle state
  lifecycleDetails string
  // Creation time
  created time
  // Last update time
  timeUpdated time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) Generative AI agent data source
//
// Examine a single data source — the content ingested into a knowledge
// base for retrieval. Select a data source by its OCID, for example
// `oci.ai.agents.dataSource(id: "ocid1.genaiagentdatasource.oc1...")`.
// The data source links back to its parent `knowledgeBase`.
private oci.ai.agents.dataSource @defaults("name state") {
  init(id? string)
  // Data source OCID
  id string
  // Data source display name
  name string
  // Compartment OCID containing the data source
  compartmentID string
  // Compartment containing the data source
  compartment() oci.compartment
  // OCID of the knowledge base this data source feeds
  knowledgeBaseID string
  // Knowledge base this data source feeds
  knowledgeBase() oci.ai.agents.knowledgeBase
  // Description of the data source
  description string
  // Lifecycle state (e.g., CREATING, UPDATING, ACTIVE, DELETING, DELETED, FAILED)
  state string
  // Detail message describing the current lifecycle state
  lifecycleDetails string
  // Creation time
  created time
  // Last update time
  timeUpdated time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) Generative AI agent tool
//
// Examine a single tool attached to an agent — the capability an agent
// can invoke while answering, such as retrieving from a knowledge base,
// querying a database, calling a function, or reaching an external HTTP
// endpoint. Select a tool by its OCID, for example
// `oci.ai.agents.tool(id: "ocid1.genaiagenttool.oc1...")`. The
// `toolType` field identifies the kind of tool — use it to find tools
// that can reach outside the tenancy, for example
// `oci.ai.agents.tools.where(toolType == "HTTP_ENDPOINT_TOOL_CONFIG")`.
private oci.ai.agents.tool @defaults("name toolType state") {
  init(id? string)
  // Tool OCID
  id string
  // Tool display name
  name string
  // Compartment OCID containing the tool
  compartmentID string
  // Compartment containing the tool
  compartment() oci.compartment
  // OCID of the agent this tool is attached to
  agentID string
  // Agent this tool is attached to
  agent() oci.ai.agents.agent
  // Description of the tool
  description string
  // Tool type
  //
  // One of RAG_TOOL_CONFIG, SQL_TOOL_CONFIG, FUNCTION_CALLING_TOOL_CONFIG,
  // HTTP_ENDPOINT_TOOL_CONFIG, or AGENT_TOOL_CONFIG.
  toolType string
  // Full tool configuration, with shape determined by `toolType`
  toolConfig dict
  // Additional tool configuration key-value pairs
  metadata map[string]string
  // Lifecycle state (e.g., CREATING, UPDATING, ACTIVE, DELETING, DELETED, FAILED)
  state string
  // Creation time
  created time
  // Last update time
  timeUpdated time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) Data Science
//
// Use the Data Science namespace to enumerate the tenancy's machine
// learning estate across every subscribed region. Iterate `projects()`
// for the workspaces that organize ML work, `notebookSessions()` for
// the managed JupyterLab environments (with their compute shape, network
// placement, and private-endpoint configuration), `models()` and
// `modelVersionSets()` for the model catalog, `modelDeployments()` for
// the models served as HTTP endpoints (with their endpoint URL and
// logging configuration), and `jobs()` and `pipelines()` for the
// batch and orchestration workloads.
oci.ai.dataScience {
  // Data Science projects
  projects() []oci.ai.dataScience.project
  // Notebook sessions
  notebookSessions() []oci.ai.dataScience.notebookSession
  // Models in the model catalog
  models() []oci.ai.dataScience.model
  // Model version sets
  modelVersionSets() []oci.ai.dataScience.modelVersionSet
  // Model deployments
  modelDeployments() []oci.ai.dataScience.modelDeployment
  // Jobs
  jobs() []oci.ai.dataScience.job
  // Pipelines
  pipelines() []oci.ai.dataScience.pipeline
}

// Oracle Cloud Infrastructure (OCI) Data Science project
//
// Examine a single Data Science project — the workspace that groups
// notebook sessions, models, jobs, and pipelines for a team or
// initiative. Select a project by its OCID, for example
// `oci.ai.dataScience.project(id: "ocid1.datascienceproject.oc1...")`.
private oci.ai.dataScience.project @defaults("name state") {
  init(id? string)
  // Project OCID
  id string
  // Project display name
  name string
  // Compartment OCID containing the project
  compartmentID string
  // Compartment containing the project
  compartment() oci.compartment
  // Description of the project
  description string
  // OCID of the principal that created the project
  createdBy string
  // Lifecycle state (e.g., ACTIVE, DELETING, DELETED, FAILED)
  state string
  // Creation time
  created time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) Data Science notebook session
//
// Examine a single notebook session — the managed JupyterLab environment
// where data scientists develop and train models. Select a session by
// its OCID, for example
// `oci.ai.dataScience.notebookSession(id: "ocid1.datasciencenotebooksession.oc1...")`.
// The session reports its compute shape, the subnet it runs in, the
// optional private endpoint that isolates it from the public internet,
// and its access URL — the controls that determine the session's network
// exposure.
private oci.ai.dataScience.notebookSession @defaults("name state") {
  init(id? string)
  // Notebook session OCID
  id string
  // Notebook session display name
  name string
  // Compartment OCID containing the session
  compartmentID string
  // Compartment containing the session
  compartment() oci.compartment
  // OCID of the project the session belongs to
  projectID string
  // Project the session belongs to
  project() oci.ai.dataScience.project
  // OCID of the principal that created the session
  createdBy string
  // Compute shape backing the session
  shape string
  // OCID of the subnet the session runs in
  subnetID string
  // Subnet the session runs in
  subnet() oci.network.subnet
  // Block storage attached to the session, in gigabytes
  blockStorageSizeInGBs int
  // OCID of the Data Science private endpoint isolating the session, when set
  privateEndpointID string
  // URL used to access the session
  notebookSessionUrl string
  // Lifecycle state (e.g., CREATING, ACTIVE, DELETING, DELETED, FAILED, INACTIVE, UPDATING)
  state string
  // Creation time
  created time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}

// Oracle Cloud Infrastructure (OCI) Data Science model
//
// Examine a single model in the model catalog — a saved, versioned
// machine learning artifact. Select a model by its OCID, for example
// `oci.ai.dataScience.model(id: "ocid1.datasciencemodel.oc1...")`. The
// model reports its version within its model version set, its category,
// and whether its artifact is stored by reference in Object Storage
// rather than in the catalog.
private oci.ai.dataScience.model @defaults("name state") {
  init(id? string)
  // Model OCID
  id string
  // Model display name
  name string
  // Compartment OCID containing the model
  compartmentID string
  // Compartment containing the model
  compartment() oci.compartment
  // OCID of the project the model belongs to
  projectID string
  // Project the model belongs to
  project() oci.ai.dataScience.project
  // OCID of the principal that created the model
  createdBy string
  // OCID of the model version set the model belongs to
  modelVersionSetID string
  // Model version set the model belongs to
  modelVersionSet() oci.ai.dataScience.modelVersionSet
  // Name of the model version set the model belongs to
  modelVersionSetName string
  // Version number of the model within its version set
  versionId int
  // Version label of the model within its version set
  versionLabel string
  // Model category (USER or SERVICE)
  category string
  // Whether the model artifact is stored by reference in Object Storage
  isModelByReference bool
  // Lifecycle state (e.g., ACTIVE, DELETED, FAILED, INACTIVE)
  state string
  // Detail message describing the current lifecycle state
  lifecycleDetails string
  // Creation time
  created time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
}


  // Cloud Guard security zones
  securityZones() []oci.cloudGuard.securityZone
  // Cloud Guard security zone recipes
  securityZoneRecipes() []oci.cloudGuard.securityZoneRecipe
  // Cloud Guard security policies (used in security zone recipes)
  securityPolicies() []oci.cloudGuard.securityPolicy
}


  // NSG creation time
  created time
  // Free-form tags for resource management
  freeformTags map[string]string
  // Defined tags for governance and cost tracking
  definedTags map[string]map[string]string
  // Ingress security rules
  //
  // Each entry: {direction, protocol (IANA number, e.g. "6"=TCP), description, source, sourceType, isStateless, tcpOptions{sourcePortRange{min,max}, destinationPortRange{min,max}}, udpOptions{...}, icmpOptions{type,code}}.
  ingressSecurityRules() []dict
  // Egress security rules; same shape as ingressSecurityRules but with destination/destinationType instead of source/sourceType
  egressSecurityRules() []dict
  // Whether any rule (ingress or egress) is stateless
  hasStatelessRules() bool
  // VNICs this NSG is attached to (from ListNetworkSecurityGroupVnics + GetVnic)
  attachedVnics() []oci.compute.vnic
}


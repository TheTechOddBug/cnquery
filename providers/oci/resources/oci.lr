  protectionMode string
  // Lifecycle state
  //
  // For example: CREATING, ENABLING, ENABLED, DISABLING, DISABLED, DELETING, DELETED, PENDING_DELETION, SCHEDULING_DELETION, CANCELLING_DELETION, UPDATING, BACKUP_IN_PROGRESS, RESTORING.
  state string
  // Whether auto key rotation is enabled
  isAutoRotationEnabled bool

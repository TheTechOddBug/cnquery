option provider = "go.mondoo.com/mql/providers/openai"
option go_package = "go.mondoo.com/mql/v13/providers/openai/resources"

// OpenAI account
//
// Use the `openai` resource to examine an OpenAI account, including
// available models, uploaded files, fine-tuning jobs, vector stores,
// and projects. This resource provides the online API inventory for
// AI Bill of Materials (AIBOM) generation.
openai @defaults("organization") @maturity("preview") {
  // Organization ID associated with the API key
  organization() string
  // Project ID associated with the API key
  projectId() string
  // Available models
  models() []openai.model
  // Uploaded files
  files() []openai.file
  // Fine-tuning jobs
  fineTuningJobs() []openai.fineTuningJob
  // Vector stores
  vectorStores() []openai.vectorStore
  // Projects in the organization
  projects() []openai.project
  // Organization users (requires admin API key)
  users() []openai.organizationUser
  // Pending invites (requires admin API key)
  invites() []openai.invite
  // Audit log entries (requires admin API key)
  auditLogs() []openai.auditLog
}

// OpenAI model
//
// Examine an AI model available in the OpenAI account. Models include
// both base models owned by OpenAI (such as gpt-4o or o3) and
// fine-tuned models owned by the organization. The `id` field is the
// model identifier used in API calls. For fine-tuned models the
// structured ID encodes the base model, organization, and suffix
// which are extracted into `baseModel` and `isFineTuned` for AIBOM
// lineage tracking.
openai.model @defaults("id ownedBy") @maturity("preview") {
  // Model identifier used in API calls (e.g., "gpt-4o", "ft:gpt-4o-mini:my-org:custom:abc123")
  id string
  // Creation timestamp
  createdAt time
  // Entity that owns the model
  //
  // For example system, openai, or an organization identifier for fine-tuned models.
  ownedBy string
  // Whether this is a fine-tuned model
  isFineTuned() bool
  // Base model identifier for fine-tuned models, empty for base models
  //
  // Extracted from the fine-tuned model ID. For example, a model with
  // id "ft:gpt-4o-mini:my-org:custom:abc123" has baseModel "gpt-4o-mini".
  baseModel() string
}

// OpenAI file
//
// Examine a file uploaded to the OpenAI platform. Files are used for
// fine-tuning training data, batch input/output, assistant knowledge
// retrieval, and vision inputs. The `purpose` field indicates the
// intended use of the file.
openai.file @defaults("id filename purpose") @maturity("preview") {
  // File identifier
  id string
  // Original filename
  filename string
  // File size in bytes
  bytes int
  // Upload timestamp
  createdAt time
  // Intended use of the file
  //
  // One of assistants, assistants_output, batch, batch_output, fine-tune, fine-tune-results, or vision.
  purpose string
  // Processing status
  //
  // One of uploaded, processed, or error.
  status string
}

// OpenAI fine-tuning job
//
// Examine a fine-tuning job that customizes a base model on
// organization-provided training data. Tracks the training status,
// hyperparameters, token usage, and the resulting fine-tuned model
// identifier. Use this resource to audit model lineage: which base
// model was fine-tuned, with what training data, and what model was
// produced.
openai.fineTuningJob @defaults("id model status") @maturity("preview") {
  // Job identifier
  id string
  // Base model being fine-tuned
  model string
  // Job status
  //
  // One of validating_files, queued, running, succeeded, failed, or cancelled.
  status string
  // Creation timestamp
  createdAt time
  // Completion timestamp (null if not finished)
  finishedAt time
  // Identifier of the resulting fine-tuned model (empty until succeeded)
  fineTunedModel string
  // Training file
  trainingFile() openai.file
  // Validation file (null if not provided)
  validationFile() openai.file
  // Number of tokens used during training
  trainedTokens int
  // Random seed used for reproducibility
  seed int
  // Organization that owns this job
  organizationId string
  // Training hyperparameters
  hyperparameters dict
  // Error information if the job failed
  error dict
}

// OpenAI vector store
//
// Examine a vector store used for knowledge retrieval in the
// Assistants API. Vector stores hold file embeddings for semantic
// search and are identified by name. The `fileCounts` field reports
// the number of files in each processing state.
openai.vectorStore @defaults("id name status") @maturity("preview") {
  // Vector store identifier
  id string
  // Display name
  name string
  // Processing status
  //
  // One of expired, in_progress, or completed.
  status string
  // Total storage used in bytes
  usageBytes int
  // Creation timestamp
  createdAt time
  // Last active timestamp
  lastActiveAt time
  // File counts by processing state
  fileCounts dict
  // Expiration policy
  expiresAfter dict
  // Expiration timestamp (null if no expiration policy)
  expiresAt time
  // User-defined metadata
  metadata dict
}

// OpenAI project
//
// Examine an organization project in the OpenAI platform. Projects
// provide isolation for API keys, usage limits, and team access.
// Requires an admin API key.
openai.project @defaults("id name status") @maturity("preview") {
  // Project identifier
  id string
  // Project name
  name string
  // Project status
  //
  // One of active or archived.
  status string
  // Creation timestamp
  createdAt time
  // Archive timestamp (null if active)
  archivedAt time
  // API keys in this project (requires admin API key)
  apiKeys() []openai.project.apiKey
  // Service accounts in this project (requires admin API key)
  serviceAccounts() []openai.project.serviceAccount
}

// OpenAI project API key
//
// Examine an API key within an organization project. Each key has an
// owner (user or service account) and a redacted value for
// identification. Use this resource to audit key age, last usage, and
// ownership for security reviews.
openai.project.apiKey @defaults("id name") @maturity("preview") {
  // API key identifier
  id string
  // Display name
  name string
  // Redacted key value for identification
  redactedValue string
  // Creation timestamp
  createdAt time
  // Last usage timestamp
  lastUsedAt time
  // Owner type
  //
  // One of user or service_account.
  ownerType string
  // Owner name (user email or service account name)
  ownerName string
  // Owner identifier
  ownerId string
}

// OpenAI project service account
//
// Examine a service account within an organization project. Service
// accounts are non-human identities used for API automation. Use this
// resource to audit service account roles and creation dates.
openai.project.serviceAccount @defaults("id name role") @maturity("preview") {
  // Service account identifier
  id string
  // Service account name
  name string
  // Assigned role
  //
  // One of owner or member.
  role string
  // Creation timestamp
  createdAt time
}

// OpenAI organization user
//
// Examine a user in the OpenAI organization. Users have roles, email
// addresses, and API key usage tracking. Use this resource to audit
// organization membership, privilege levels, and identify inactive
// accounts by checking API key last usage timestamps.
openai.organizationUser @defaults("id email role") @maturity("preview") {
  // User identifier
  id string
  // User email address
  email string
  // User display name
  name string
  // Organization role
  //
  // One of owner or reader.
  role string
  // Whether this is the default user
  isDefault bool
  // Whether the user is managed through SCIM
  isScimManaged bool
  // Whether the user is a service account
  isServiceAccount bool
  // Timestamp when the user was added to the organization
  addedAt time
  // Account creation timestamp
  createdAt time
  // Last API key usage timestamp
  apiKeyLastUsedAt time
}

// OpenAI organization invite
//
// Examine a pending invitation to the OpenAI organization. Invites
// track the email, assigned role, and acceptance status. Use this
// resource to audit outstanding invitations and ensure timely
// expiration of unclaimed invites.
openai.invite @defaults("id email status") @maturity("preview") {
  // Invite identifier
  id string
  // Invited email address
  email string
  // Assigned role for the invitee
  //
  // One of owner or reader.
  role string
  // Invite status
  //
  // One of accepted, expired, or pending.
  status string
  // Creation timestamp
  createdAt time
  // Acceptance timestamp (null if not accepted)
  acceptedAt time
  // Expiration timestamp
  expiresAt time
}

// OpenAI audit log entry
//
// Examine an audit log entry from the OpenAI organization. Audit logs
// record user actions and configuration changes such as API key
// creation, project updates, login events, and role changes. Use this
// resource to monitor security-relevant activity and support compliance
// requirements.
openai.auditLog @defaults("id type effectiveAt") @maturity("preview") {
  // Log entry identifier
  id string
  // Event type
  //
  // Examples: api_key.created, api_key.deleted, invite.sent,
  // login.succeeded, login.failed, project.created, user.added,
  // service_account.created, role.assignment.created.
  type string
  // Timestamp when the event occurred
  effectiveAt time
  // Actor type
  //
  // One of session or api_key.
  actorType string
  // Actor email (for session actors) or API key ID (for API key actors)
  actorId string
}

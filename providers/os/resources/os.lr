  // Installation scope (user or project)
  scope string
  // Local install path
  installPath string
  // Installation timestamp
  installedAt string
  // Last updated timestamp
  lastUpdated string
  // Git commit SHA of the installed version
  gitCommitSha string
  // Whether the plugin is currently enabled
  enabled bool
}

// Claude Code skill

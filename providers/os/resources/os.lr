  displayName string
  // Feature description
  description string
  // Whether the feature is installed
  installed bool
  // Feature installation state
  installState int
}

// Windows optional feature resource (desktop-only)
private windows.optionalFeature @defaults("name") {
  init(name string)
  // Command ID of optional feature
  name string
  // Feature name

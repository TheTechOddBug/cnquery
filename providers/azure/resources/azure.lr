  // QueryPack name
  name string
  // QueryPack location
  location string
  // Resource type
  type string
  // QueryPack tags
  tags map[string]string
  // Unique ID of the QueryPack (immutable)
  queryPackId string
  // Provisioning state
  provisioningState string
  // QueryPack creation time
  timeCreated time
  // QueryPack last modified time
  timeModified time
  // Saved KQL queries in this QueryPack
  queries() []azure.subscription.monitorService.queryPack.query
}

// Saved KQL query in a Log Analytics QueryPack
private azure.subscription.monitorService.queryPack.query @defaults("id name displayName") {
  // Query resource ID
  id string
  // Query name
  name string
  // Resource type
  type string
  // Display name shown in the QueryPack
  displayName string
  // Description of the query
  description string
  // Query body (KQL)
  body string
  // Object ID of the query author
  author string
  // Query creation time
  timeCreated time
  // Query last modified time
  timeModified time
  // Tags associated with the query
  tags dict
}


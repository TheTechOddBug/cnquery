// Network Security Perimeter configuration for a Log Analytics workspace
private azure.subscription.monitorService.workspace.nspConfiguration @defaults("id name provisioningState") {
  // NSP configuration resource ID
  id string
  // NSP configuration name
  name string
  // Resource type
  type string
  // Provisioning state of the NSP configuration
  provisioningState string
  // ARM resource ID of the network security perimeter
  perimeterId string
  // Location of the network security perimeter
  perimeterLocation string
  // Globally unique identifier of the network security perimeter
  perimeterGuid string
  // Profile name on the perimeter
  profileName string
  // Current access rules version
  accessRulesVersion int
  // Current diagnostic settings version
  diagnosticSettingsVersion int
  // Log categories enabled on the profile
  enabledLogCategories []string
  // Access rules attached to the profile
  //
  // Each entry has keys: name; direction ("Inbound" or "Outbound");
  // addressPrefixes (inbound CIDRs); subscriptions (inbound, each with an
  // ARM subscription id); fullyQualifiedDomainNames (outbound FQDNs); and
  // networkSecurityPerimeters (inbound, each with id, location, perimeterGuid).
  accessRules []dict
  // Resource association name
  associationName string
  // Resource association access mode
  //
  // One of "Learning", "Audit", or "Enforced". "Learning" and "Audit" only
  // log access that violates the perimeter rules; "Enforced" blocks it.
  associationAccessMode string
  // Issues that prevented the configuration from propagating
  //
  // Each entry has keys: name; issueType ("ConfigurationPropagationFailure"
  // or "Unknown"); severity ("Error" or "Warning"); and description.
  provisioningIssues []dict
}


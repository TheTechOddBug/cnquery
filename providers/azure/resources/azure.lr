  publicNetworkAccess string
  // Whether the staticwebapp.config.json file in the repo can update the runtime config
  allowConfigFileUpdates bool
  // Staging environment policy for preview deployments ("Enabled" or "Disabled")
  stagingEnvironmentPolicy string
  // Enterprise-grade CDN status ("Disabled", "Enabling", "Enabled", "Disabling")
  enterpriseGradeCdnStatus string
  // User-assigned managed identity used for Key Vault reference authentication (empty when not configured)
  keyVaultReferenceIdentity string
  // Number of private endpoint connections to the static site
  privateEndpointConnectionCount int
  // Number of user-provided function apps registered with the static site (BYO Functions)
  userProvidedFunctionAppCount int
  // Number of linked backends bound to the static site

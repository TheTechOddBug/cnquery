  // Local network gateway etag
  etag string
  // IP address of the on-premises VPN device
  gatewayIpAddress string
  // FQDN of the on-premises VPN device (alternative to `gatewayIpAddress`)
  fqdn string
  // Address prefixes (CIDR notation) describing the on-premises network reachable through this gateway
  localNetworkAddressSpacePrefixes []string
  // Provisioning state of the local network gateway
  provisioningState string
  // Resource GUID assigned to the local network gateway
  resourceGuid string
  // BGP settings advertised by the on-premises VPN device, if BGP is configured
  bgpSettings() azure.subscription.networkService.bgpSettings
}

// Azure network BGP settings

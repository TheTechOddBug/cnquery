  // Specifies whether the non-ssl Redis server port (6379) is enabled
  enableNonSslPort bool
  // Redis host name
  hostName string
  // publicNetworkAccess possible values are "Enabled" and "Disabled"
  publicNetworkAccess string
  // Redis port (non-SSL)
  port int
  // Redis SSL port
  sslPort int
  // Provisioning state with possible values Creating, Deleting, Failed, Succeeded, Updating
  provisioningState string
  // Redis version
  redisVersion string
  // Number of replicas per master
  replicasPerMaster int
  // Number of replicas per primary
  replicasPerPrimary int

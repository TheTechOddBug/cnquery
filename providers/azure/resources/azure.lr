  // Compute in vCores on each worker node
  nodeVCores int
  // Preferred primary availability zone for all cluster servers
  preferredPrimaryZone string
  // Earliest restore point time for the cluster
  earliestRestoreTime time
  // Azure region of the source cluster for read-replica clusters
  sourceLocation string
  // Resource ID of the source cluster for read-replica clusters
  sourceResourceId string
  // Resource IDs of read-replica clusters
  readReplicas []string
  // Maintenance window of the cluster

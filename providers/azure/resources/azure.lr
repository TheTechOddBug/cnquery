  // Status of the cluster
  clusterStatus string
  // MongoDB server version
  serverVersion string
  // Infrastructure version the cluster is provisioned on
  infrastructureVersion string
  // Whether public network access is enabled ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Compute tier assigned to the cluster (for example "M30" or "M40")
  computeTier string
  // Data-disk size in GB assigned to each server
  storageSizeGb int
  // Storage type provisioned for cluster servers
  storageType string
  // Number of shards provisioned on the cluster
  shardCount int
  // Target high availability mode ("Disabled", "SameZone", or "ZoneRedundantPreferred")
  highAvailabilityMode string
  // Administrator user name configured on the cluster
  administratorLogin string
  // Allowed authentication modes for data access ("NativeAuth", "MicrosoftEntraID")
  authModes []string
  // Mongo Data API access mode ("Enabled" or "Disabled")
  dataApiMode string
  // Earliest restore point time for the cluster
  earliestRestoreTime time
  // Replication role of the cluster ("Primary", "AsyncReplica", or "GeoAsyncReplica")
  replicationRole string
  // Replication link state of a replica cluster
  replicationState string
  // Resource ID of the source cluster for a replica cluster

// Azure Monitor activity log event
//
// Single management-plane event from the subscription activity log. Each
// event records the operation that was performed, the identity that
// initiated it through `caller`, the affected resource, the outcome, and
// the `correlationId` that ties together all events belonging to one
// operation (for example every event emitted by a single deployment).
private azure.subscription.monitorService.activityLog.entry @defaults("operationName caller status eventTimestamp") {
  // Unique event data identifier
  id string
  // When the event was generated
  eventTimestamp time
  // Operation that was performed
  operationName string
  // Identity that initiated the operation (user principal name, object ID, or service principal)
  caller string
  // Event severity level
  //
  // One of Critical, Error, Warning, Informational, or Verbose.
  level string
  // Operation outcome
  //
  // Typical values are Started, In Progress, Succeeded, Failed, and Resolved.
  status string
  // Detailed operation outcome, usually the HTTP status of the underlying REST call
  subStatus string
  // ID of the resource affected by the operation
  resourceId string
  // Name of the resource group containing the affected resource
  resourceGroupName string
  // Type of the resource affected by the operation
  resourceType string
  // Resource provider that handled the operation
  resourceProviderName string
  // Correlation identifier shared by all events of a single operation
  correlationId string
  // Operation identifier
  operationId string
  // Event category
  //
  // One of Administrative, ServiceHealth, ResourceHealth, Alert, Autoscale,
  // Recommendation, Security, or Policy.
  category string
  // Human-readable description of the event
  description string
  // Claims from the token of the identity that initiated the operation
  claims map[string]string
  // Authorization scope, action, and role evaluated for the operation
  authorization dict
  // HTTP request details, including the client IP address, method, and URI
  httpRequest dict
  // Additional event details
  properties map[string]string
}


  identityType string
  // Default autogenerated hostname for the static site (e.g. "happy-flower-12345.azurestaticapps.net")
  defaultHostname string
  // Content distribution endpoint for the static site
  contentDistributionEndpoint string
  // Custom domains bound to the static site

  name string
  // Resource type
  type string
  // Ingestion/billing plan ("Analytics", "Basic", or "Auxiliary")
  plan string
  // Active retention in days (-1 means "use workspace default")
  retentionInDays int
  // Total retention in days including archive (-1 means "default to retentionInDays")
  totalRetentionInDays int
  // Long-term archive retention in days (totalRetentionInDays - retentionInDays)
  archiveRetentionInDays int
  // Whether retentionInDays is inherited from the workspace default
  retentionInDaysAsDefault bool
  // Whether totalRetentionInDays is inherited from the workspace default
  totalRetentionInDaysAsDefault bool
  // Timestamp when the table plan was last modified
  lastPlanModifiedDate string
  // Provisioning state
  provisioningState string

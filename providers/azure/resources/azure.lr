// Azure Virtual Network Manager
//
// A management scope that applies security admin rules and connectivity
// configurations across many virtual networks at once. Its security admin
// rules take precedence over network security group rules, so this is where a
// tenant's enforced network posture is defined. Surfaces the manager's scope
// (subscriptions and management groups), the configuration types it is allowed
// to apply, the network groups it targets, and its security-admin and
// connectivity configurations. Select by the manager's Azure resource ID.
azure.subscription.networkService.networkManager @defaults("id name location") {
  // Network manager ID
  id string
  // Network manager name
  name string
  // Network manager location
  location string
  // Network manager tags
  tags map[string]string
  // Network manager resource type
  type string
  // Network manager etag
  etag string
  // Provisioning state of the manager
  provisioningState string
  // Description of the manager
  description string
  // Resource GUID of the manager
  resourceGuid string
  // Configuration types the manager may apply (SecurityAdmin, Connectivity, Routing)
  scopeAccesses []string
  // Subscriptions in the manager's scope
  scopeSubscriptions []string
  // Management groups in the manager's scope
  scopeManagementGroups []string
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
  // Network groups defined in the manager
  networkGroups() []azure.subscription.networkService.networkManager.networkGroup
  // Security admin configurations defined in the manager
  securityAdminConfigurations() []azure.subscription.networkService.networkManager.securityAdminConfiguration
  // Connectivity configurations defined in the manager
  connectivityConfigurations() []azure.subscription.networkService.networkManager.connectivityConfiguration
}


  // PIM role eligibility schedules: who is eligible to activate which privileged role
  roleEligibilitySchedules() []azure.subscription.authorizationService.roleEligibilitySchedule
  // PIM role assignment schedules: currently active (including time-bound) privileged role assignments
  roleAssignmentSchedules() []azure.subscription.authorizationService.roleAssignmentSchedule
  // PIM role management policies: the rules governing how privileged roles are activated and assigned
  roleManagementPolicies() []azure.subscription.authorizationService.roleManagementPolicy
}

// Azure PIM role management policy
//
// A Privileged Identity Management policy governing how a role is
// activated and assigned at a scope: whether activation requires
// approval, multi-factor authentication, justification, or a ticket,
// how long an activation lasts, and who is notified. The behavior is
// expressed through the policy `rules`. Select by the policy's Azure
// resource ID. Audit these to confirm privileged roles are gated
// rather than freely self-activated.
private azure.subscription.authorizationService.roleManagementPolicy @defaults("displayName scope isOrganizationDefault") {
  // Policy resource ID
  id string
  // Policy name
  name string
  // Scope the policy applies to
  scope string
  // Policy display name
  displayName string
  // Policy description
  description string
  // Whether this is the organization's default policy
  isOrganizationDefault bool
  // When the policy was last modified
  lastModifiedDateTime time
  // Principal that last modified the policy
  //
  // Keys: `id`, `displayName`, `email`, and `type`.
  lastModifiedBy dict
  // Rules governing activation and assignment (approval, enablement, expiration, notification, authentication context)
  rules() []azure.subscription.authorizationService.roleManagementPolicy.rule
}

// PIM role management policy rule
//
// A single rule within a role management policy, identified by
// `ruleType`. Which fields carry values depends on that type: an
// enablement rule populates `enabledRules` (Justification,
// MultiFactorAuthentication, Ticketing) to say what activation demands;
// an expiration rule populates `isExpirationRequired` and
// `maximumDuration`; an approval rule populates `approvalSetting`; an
// authentication context rule populates `isEnabled` and `claimValue`;
// a notification rule populates the notification fields. The `target`
// describes which caller, level, and operations the rule governs.
// Select by the rule's `id`.
private azure.subscription.authorizationService.roleManagementPolicy.rule @defaults("id ruleType") {
  // Rule ID (unique within the policy, e.g. "Enablement_Admin_Eligibility")
  id string
  // Rule type
  //
  // One of RoleManagementPolicyApprovalRule,
  // RoleManagementPolicyAuthenticationContextRule,
  // RoleManagementPolicyEnablementRule,
  // RoleManagementPolicyExpirationRule, or
  // RoleManagementPolicyNotificationRule.
  ruleType string
  // What the rule governs
  //
  // Keys: `caller`, `level`, `operations`, `targetObjects`,
  // `inheritableSettings`, and `enforcedSettings`.
  target dict
  // Enablement rule: activation requirements enabled on the role
  //
  // Any of Justification, MultiFactorAuthentication, or Ticketing.
  // Empty on rule types other than the enablement rule.
  enabledRules []string
  // Expiration rule: whether an expiration is required on the assignment or activation
  isExpirationRequired bool
  // Expiration rule: maximum duration (ISO 8601 duration) of an activation or assignment
  maximumDuration string
  // Approval rule: approval settings
  //
  // Keys: `approvalMode`, `isApprovalRequired`,
  // `isApprovalRequiredForExtension`, `isRequestorJustificationRequired`,
  // and `approvalStages` (each stage listing its approvers).
  approvalSetting dict
  // Authentication context rule: whether the rule is enabled
  isEnabled bool
  // Authentication context rule: the required claim value
  claimValue string
  // Notification rule: notification level (None, Critical, All)
  notificationLevel string
  // Notification rule: delivery mechanism (e.g. Email)
  notificationType string
  // Notification rule: recipient type (Requestor, Approver, Admin)
  recipientType string
  // Notification rule: explicit notification recipients
  notificationRecipients []string
  // Notification rule: whether default recipients also receive the notification
  isDefaultRecipientsEnabled bool
}

// Azure PIM role eligibility schedule
//
// A Privileged Identity Management eligibility: a principal that can activate a
// role at a scope, rather than holding it permanently. Surfaces the eligible
// principal, the role, the scope, the eligibility window, and the activation
// membership type. Select by the schedule's Azure resource ID.
private azure.subscription.authorizationService.roleEligibilitySchedule @defaults("principalDisplayName roleDefinitionName status") {
  // Eligibility schedule ID
  id string
  // Eligibility schedule name
  name string
  // Principal ID (user, group, or service principal) eligible for the role
  principalId string
  // Type of the eligible principal (User, Group, ServicePrincipal)
  principalType string
  // Display name of the eligible principal
  principalDisplayName string
  // Scope the eligibility applies to
  scope string
  // Status of the eligibility schedule
  status string
  // Membership type of the eligibility (Inherited, Direct, Group)
  memberType string
  // When the eligibility window starts
  startDateTime time
  // When the eligibility window ends; null for permanent eligibility
  endDateTime time
  // ABAC condition limiting the eligibility, if any
  condition string
  // Display name of the role the principal is eligible for
  roleDefinitionName string
  // Role the principal is eligible to activate
  roleDefinition() azure.subscription.authorizationService.roleDefinition
}

// Azure PIM role assignment schedule
//
// A Privileged Identity Management active assignment: a role currently granted
// to a principal at a scope, whether permanent, time-bound, or activated from
// an eligibility. Surfaces the principal, role, scope, assignment window, and
// whether the grant is assigned or activated. Select by the schedule's Azure
// resource ID.
private azure.subscription.authorizationService.roleAssignmentSchedule @defaults("principalDisplayName roleDefinitionName assignmentType status") {
  // Assignment schedule ID
  id string
  // Assignment schedule name
  name string
  // Principal ID (user, group, or service principal) holding the role
  principalId string
  // Type of the assigned principal (User, Group, ServicePrincipal)
  principalType string
  // Display name of the assigned principal
  principalDisplayName string
  // Scope the assignment applies to
  scope string
  // How the role was granted (Assigned for a standing assignment, Activated from an eligibility)
  assignmentType string
  // Status of the assignment schedule
  status string
  // Membership type of the assignment (Inherited, Direct, Group)
  memberType string
  // When the assignment window starts
  startDateTime time
  // When the assignment window ends; null for a permanent assignment
  endDateTime time
  // ABAC condition limiting the assignment, if any
  condition string
  // Display name of the assigned role
  roleDefinitionName string
  // Role granted to the principal
  roleDefinition() azure.subscription.authorizationService.roleDefinition
}

// Deny assignment in an Azure subscription
private azure.subscription.authorizationService.denyAssignment @defaults("name doNotApplyToChildScopes type") {
  // Deny assignment ID
  id string
  // Deny assignment name
  name string
  // Resource type
  type string
  // Display name shown in the portal
  denyAssignmentName string
  // Description of the deny assignment
  description string
  // Whether the deny rule does not apply to child scopes
  doNotApplyToChildScopes bool
  // Whether the deny rule is system-protected (cannot be removed by users)
  isSystemProtected bool
  // Scope of the deny assignment (subscription/resource group/resource)
  scope string
  // Denied permissions
  //
  // Each entry has keys `actions`, `dataActions`, `notActions`,
  // `notDataActions`, `condition`, and `conditionVersion`.
  permissions []dict
  // Principals subject to the deny
  //
  // Each entry has keys `id`, `type`, `displayName`, and `email`.
  principals []dict
  // Principals excluded from the deny
  //
  // Each entry has keys `id`, `type`, `displayName`, and `email`.
  excludePrincipals []dict
}


  managedByTenantId string
  // Name of the managing (managedBy) tenant
  managedByTenantName string
  // Provisioning state of the definition
  //
  // One of Running, Ready, Creating, Created, Deleting, Deleted, Canceled,
  // Failed, Succeeded, Updating, or NotSpecified.
  provisioningState string
  // Standing authorizations granting managedBy-tenant principals access
  authorizations []azure.subscription.lighthouseService.registrationDefinition.authorization
  // Just-in-time authorizations activated through Privileged Identity Management

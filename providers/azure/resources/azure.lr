// Microsoft Defender for Cloud security assessment
//
// A security recommendation evaluated against a resource, reporting whether
// the resource is healthy, unhealthy, or not applicable, together with its
// severity, Defender CSPM risk level, affected security categories, associated
// MITRE ATT&CK tactics and techniques, and remediation guidance. Audit
// unhealthy assessments to find the misconfigurations and exposures Microsoft
// Defender for Cloud has flagged, and drill into subAssessments for the
// per-CVE or per-check detail behind a finding.
private azure.subscription.cloudDefenderService.assessment @defaults("displayName status severity riskLevel") {
  // Assessment resource ID
  id string
  // Assessment name (a globally unique identifier)
  name string
  // Human-readable name of the assessment
  displayName string
  // Health status of the assessment (Healthy, Unhealthy, NotApplicable)
  status string
  // Programmatic code for the cause of the assessment result
  statusCause string
  // Human-readable description of the assessment result
  statusDescription string
  // When the assessment was created and first evaluated
  firstEvaluationDate time
  // When the assessment status last changed
  statusChangeDate time
  // Severity of the assessment (Low, Medium, High)
  severity string
  // ARM ID of the resource the assessment was run against
  resourceId string
  // Additional data describing the assessment result
  additionalData dict
  // Risk level of the assessment finding
  //
  // Defender CSPM risk-based prioritization. One of Critical, High, Medium,
  // Low, or None. Empty when the subscription has no Defender CSPM plan
  // enabled, since risk prioritization is a CSPM feature.
  riskLevel string
  // Contributing factors that raise the risk level
  riskFactors []string
  // Attack-path identifiers this finding participates in
  //
  // References into the Defender attack-path graph; the same paths are
  // surfaced in the Microsoft Defender for Cloud portal.
  riskAttackPathReferences []string
  // Attack-path graphs the finding contributes to
  //
  // Each entry is one attack path with shape `{id, nodes, edges}`: `nodes`
  // are `{id, labels}` (the resources along the path) and `edges` are
  // `{id, sourceId, targetId}` (the directed connections between nodes).
  // Populated only when the subscription has a Defender CSPM plan enabled.
  riskAttackPaths []dict
  // Whether the risk is contextual rather than static
  riskIsContextual bool
  // Origin of the assessment definition
  //
  // One of BuiltIn, BuiltInPolicy, Custom, CustomPolicy, CustomerManaged,
  // DynamicBuiltIn, ManualBuiltIn, ManualBuiltInPolicy, ManualCustomPolicy,
  // VerifiedPartner, or Unknown.
  assessmentType string
  // Security domains the assessment covers
  //
  // Values drawn from Compute, Networking, Data, IdentityAndAccess, IoT,
  // Container, and AppServices.
  categories []string
  // Threat outcomes the assessment guards against
  //
  // One or more of accountBreach, dataExfiltration, dataSpillage,
  // denialOfService, elevationOfPrivilege, maliciousInsider, missingCoverage,
  // and threatResistance.
  threats []string
  // MITRE ATT&CK tactics associated with the assessment
  tactics []string
  // MITRE ATT&CK techniques associated with the assessment
  techniques []string
  // Effort required to remediate the finding
  //
  // One of Low, Moderate, or High.
  implementationEffort string
  // User impact of remediating the finding
  //
  // One of Low, Moderate, or High.
  userImpact string
  // Guidance describing how to remediate the finding
  remediationDescription string
  // Whether the assessment is in preview status
  preview bool
  // Description of what the assessment evaluates
  description string
  // Detailed sub-findings underlying the assessment (per-CVE, per-misconfiguration)
  subAssessments() []azure.subscription.cloudDefenderService.assessment.subAssessment
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Microsoft Defender for Cloud sub-assessment
//
// A detailed finding underlying a security assessment, such as a single CVE
// from a vulnerability scan or one failed configuration check. Surfaces the
// finding's status and severity, its category and remediation guidance, the
// assessed resource details, and finding-specific additional data. Select by
// the sub-assessment's Azure resource ID.
private azure.subscription.cloudDefenderService.assessment.subAssessment @defaults("displayName status severity") {
  // Sub-assessment resource ID
  id string
  // Sub-assessment name
  name string
  // Human-readable name of the finding
  displayName string
  // Finding identifier, such as a CVE, when applicable
  vulnerabilityId string
  // Status code of the finding (Healthy, Unhealthy, NotApplicable)
  status string
  // Severity of the finding (Low, Medium, High)
  severity string
  // Programmatic code for the cause of the status
  statusCause string
  // Human-readable description of the status
  statusDescription string
  // Category of the finding
  category string
  // Description of the finding
  description string
  // Description of the impact of the finding
  impact string
  // Guidance on how to remediate the finding
  remediation string
  // When the finding was generated
  timeGenerated time
  // Details of the assessed resource; shape varies by source (Azure, OnPremise, container registry)
  resourceDetails dict
  // Finding-specific details; shape varies by type (SQL, container image, server vulnerability)
  additionalData dict
}

// Microsoft Defender for Cloud security alert
//
// A threat detection raised by Microsoft Defender for Cloud describing
// suspicious or malicious activity observed against a resource. Reports the
// alert severity and status, the compromised entity, the kill-chain intent,
// the time window of the activity, and manual remediation steps. Audit active
// alerts to find in-progress or unresolved threats in the subscription.
private azure.subscription.cloudDefenderService.alert @defaults("displayName severity status") {
  // Alert resource ID
  id string
  // Alert name (a globally unique identifier)
  name string
  // Human-readable name of the alert
  displayName string
  // Severity of the alert (Informational, Low, Medium, High)
  severity string
  // Status of the alert (Active, InProgress, Resolved, Dismissed)
  status string
  // Description of the alert
  description string
  // Type identifier of the alert
  alertType string
  // Kill-chain intent behind the alert (e.g. Execution, Exfiltration)
  intent string
  // Name of the vendor that raised the alert
  vendorName string
  // Display name of the resource most related to the alert
  compromisedEntity string
  // Time the alert activity started
  startTime time
  // Time the alert activity ended
  endTime time
  // Time the alert was generated
  timeGenerated time
  // Manual action steps to remediate the alert
  remediationSteps []string
  // Identifiers of the resources the alert is related to
  resourceIdentifiers []dict
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}


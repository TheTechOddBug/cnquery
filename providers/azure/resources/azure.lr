  workspaceSettings() []azure.subscription.cloudDefenderService.workspaceSetting
}

// Microsoft Defender for Cloud alert suppression rule
//
// A rule that automatically dismisses matching security alerts. Useful for
// auditing detection blind spots: a broad or non-expiring suppression rule can
// hide real alerts. Surfaces the suppressed alert type, the rule state and
// reason, its expiration, and the conditions narrowing which alerts it matches.
// Select by the rule's Azure resource ID.
private azure.subscription.cloudDefenderService.alertSuppressionRule @defaults("name alertType state") {
  // Suppression rule ID
  id string
  // Suppression rule name
  name string
  // Alert type the rule suppresses; "*" suppresses all types
  alertType string
  // State of the rule (Enabled, Disabled, Expired)
  state string
  // Reason the alert is dismissed
  reason string
  // Free-text comment on the rule
  comment string
  // When the rule expires; null for no expiration
  expirationDate time
  // When the rule was last modified
  lastModified time
  // Conditions narrowing which alerts are suppressed
  //
  // Each entry carries the alert entity field and its match values; all
  // conditions must hold for an alert to be suppressed.
  suppressionScope []dict
}

// Microsoft Defender for Cloud workspace setting
//
// The Log Analytics workspace that a scope's security data is sent to. Surfaces
// the scope the setting applies to and the target workspace. Select by the

  // Provisioning state of the cluster
  provisioningState string
  // State of the cluster visible to the user
  state string
  // Major PostgreSQL version on all cluster servers
  postgresqlVersion string
  // Citus extension version on all cluster servers
  citusVersion string
  // Administrator login name of the servers in the cluster
  administratorLogin string
  // Whether high availability (HA) is enabled
  enableHa bool
  // Whether distributed tables are placed on the coordinator
  enableShardsOnCoordinator bool
  // Whether public access is enabled on the coordinator
  coordinatorEnablePublicIpAccess bool
  // Coordinator server edition (for example "GeneralPurpose" or "MemoryOptimized")
  coordinatorServerEdition string
  // Coordinator server storage in MB
  coordinatorStorageQuotaInMb int
  // Coordinator server vCore count
  coordinatorVCores int
  // Worker node count of the cluster (0 indicates a single-node configuration)
  nodeCount int

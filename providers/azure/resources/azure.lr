  managedDiskKeyVaultUri string
  // Managed-disk CMK key name
  managedDiskKeyName string
  // Managed-disk CMK key version
  managedDiskKeyVersion string
  // CMK key source for managed services ("Default" or "Microsoft.Keyvault")
  managedServicesKeySource string
  // Key Vault URI for the managed-services CMK (empty if platform-managed)

  publicIpAddress() azure.subscription.networkService.ipAddress
}

// Azure Virtual Network (VNet) gateway connection
private azure.subscription.networkService.virtualNetworkGateway.connection @defaults("id name connectionType connectionStatus") {
  // VNet gateway connection ID
  id string
  // VNet gateway Connection name
  name string
  // VNet gateway Connection type
  type string
  // VNet gateway Connection etag
  etag string
  // VNet gateway Connection location
  location string
  // VNet gateway Connection properties
  properties dict
  // Connection type (one of: "IPsec", "Vnet2Vnet", "ExpressRoute", "VPNClient")
  connectionType string
  // Current connection status (one of: "Unknown", "Connecting", "Connected", "NotConnected")
  connectionStatus string
  // Connection mode (one of: "Default", "InitiatorOnly", "ResponderOnly")
  connectionMode string
  // Connection protocol (one of: "IKEv1", "IKEv2")
  connectionProtocol string
  // Provisioning state of the connection
  provisioningState string
  // Whether BGP is enabled for this connection
  enableBgp bool
  // Whether policy-based traffic selectors are enabled
  usePolicyBasedTrafficSelectors bool
  // Whether the connection uses a private local Azure IP
  useLocalAzureIpAddress bool
  // Dead-peer-detection timeout, in seconds
  dpdTimeoutSeconds int
  // Routing weight applied to this connection
  routingWeight int
  // Associated and propagated route tables governing routing for this connection
  routingConfiguration dict
  // Total ingress bytes transferred over this connection
  ingressBytesTransferred int
  // Total egress bytes transferred over this connection
  egressBytesTransferred int
  // The local network gateway peered to the primary VNet gateway (only set for IPsec connections)
  localNetworkGateway2() azure.subscription.networkService.localNetworkGateway
  // The peer virtual network gateway (only set for Vnet2Vnet connections)
  virtualNetworkGateway2() azure.subscription.networkService.virtualNetworkGateway
  // Custom IPsec/IKE cryptographic policies negotiated for this connection; empty when the connection uses Azure defaults
  ipsecPolicies() []azure.subscription.networkService.virtualNetworkGateway.connection.ipsecPolicy
}

// IPsec/IKE policy of a virtual network gateway
//
// Custom IPsec/IKE cryptographic policy applied to a
// virtual network gateway. This covers both site-to-site connection
// policies (from `virtualNetworkGateway.connections.ipsecPolicies`) and
// point-to-site client policies (from
// `virtualNetworkGateway.vpnClientIpsecPolicies`). Surfaces the key-exchange
// and data-channel algorithms, `ikeEncryption` and `ikeIntegrity` for IKE,
// `ipsecEncryption` and `ipsecIntegrity` for IPsec, together with the
// `dhGroup` and `pfsGroup` Diffie-Hellman groups and the
// security-association lifetime (`saLifeTimeSeconds`) and payload size
// (`saDataSizeKilobytes`). Use it to assert that tunnels negotiate strong
// cryptographic parameters.
private azure.subscription.networkService.virtualNetworkGateway.connection.ipsecPolicy @defaults("ikeEncryption ipsecEncryption dhGroup pfsGroup") {
  // Policy ID (connection ID + positional index; not stable if policy ordering changes server-side)
  id string
  // IKE encryption algorithm for the key-exchange negotiation (one of: "DES", "DES3", "AES128", "AES192", "AES256", "GCMAES128", "GCMAES256")
  ikeEncryption string
  // IKE integrity algorithm for the key-exchange negotiation (one of: "MD5", "SHA1", "SHA256", "SHA384", "GCMAES128", "GCMAES256")
  ikeIntegrity string
  // IPsec encryption algorithm for the data channel
  //
  // One of: "None", "DES", "DES3", "AES128", "AES192", "AES256", "GCMAES128", "GCMAES192", "GCMAES256".
  ipsecEncryption string
  // IPsec integrity algorithm for the data channel (one of: "MD5", "SHA1", "SHA256", "GCMAES128", "GCMAES192", "GCMAES256")
  ipsecIntegrity string
  // Diffie-Hellman group used in the key-exchange negotiation
  //
  // One of: "None", "DHGroup1", "DHGroup2", "DHGroup14", "DHGroup24", "DHGroup2048", "ECP256", "ECP384".
  dhGroup string
  // Diffie-Hellman group used for perfect forward secrecy in the data channel
  //
  // One of: "None", "PFS1", "PFS2", "PFS14", "PFS24", "PFS2048", "PFSMM", "ECP256", "ECP384".
  pfsGroup string
  // IPsec security association lifetime, in seconds
  saLifeTimeSeconds int
  // IPsec security association payload size, in kilobytes
  saDataSizeKilobytes int
}


private azure.subscription.storageService.account.privateEndpointConnection @defaults("name status provisioningState") {
  // ARM resource ID
  id string
  // Connection name
  name string
  // Resource type
  type string
  // ARM resource ID of the consumer-side private endpoint, when present
  privateEndpointId string
  // Connection status ("Approved", "Pending", "Rejected", "Disconnected")
  status string
  // Reason for the current status
  description string
  // Action required by the consumer to maintain the connection ("None" / a description string)
  actionsRequired string
  // Provisioning state of the connection
  provisioningState string
}

// Azure Storage object replication policy
//
// Examine an object replication policy linking a source storage account
// to a destination account. Selectable by ARM id; fields expose the
// source/destination pair, when replication was enabled, and the
// container-to-container rules with optional prefix and creation-time
// filters.
private azure.subscription.storageService.account.objectReplicationPolicy @defaults("name sourceAccount destinationAccount enabledTime") {
  // ARM resource ID
  id string
  // Policy name
  name string
  // Resource type
  type string
  // Auto-generated unique policy id
  policyId string
  // Source account name or full resource id
  sourceAccount string
  // Destination account name or full resource id
  destinationAccount string
  // When the policy was enabled on the source account
  enabledTime time
  // Replication rules. Each entry has {ruleId, sourceContainer, destinationContainer, prefixMatch, minCreationTime}.
  rules []dict
  // Whether blob index tags are replicated alongside blob data; false when the policy omits tag replication
  tagsReplicationEnabled bool
}

// Network Security Perimeter configuration of an Azure Storage account
//
// Examine how a storage account is associated with an Azure Network Security
// Perimeter, including the enforcement mode that decides whether perimeter
// access rules are logged only or actually blocked. Select a configuration by
// its `id`. The `accessMode` field reports "Learning", "Audit", or "Enforced" —
// only "Enforced" blocks traffic that violates the perimeter rules.
// `accessRules` lists the inbound and outbound rules in effect,
// `enabledLogCategories` the categories shipped to diagnostics, and
// `provisioningIssues` any errors that prevented the configuration from
// propagating.
private azure.subscription.storageService.account.networkSecurityPerimeterConfiguration @defaults("name associationAccessMode provisioningState") {
  // NSP configuration resource ID
  id string
  // NSP configuration name
  name string
  // Resource type
  type string
  // Provisioning state of the NSP configuration ("Accepted", "Canceled", "Deleting", "Failed", or "Succeeded")
  provisioningState string
  // ARM resource ID of the network security perimeter
  perimeterId string
  // Location of the network security perimeter
  perimeterLocation string
  // Universal unique ID of the network security perimeter
  perimeterGuid string
  // Profile name on the perimeter
  profileName string
  // Current access rules version
  accessRulesVersion int
  // Current diagnostic settings version
  diagnosticSettingsVersion int
  // Log categories enabled on the profile
  enabledLogCategories []string
  // Access rules attached to the profile
  //
  // Each entry has keys: name; direction ("Inbound" or "Outbound");
  // addressPrefixes (inbound CIDRs); subscriptions (inbound, each with an
  // ARM subscription id); fullyQualifiedDomainNames (outbound FQDNs); and
  // networkSecurityPerimeters (inbound, each with id, location, perimeterGuid).
  accessRules []dict
  // Resource association name
  associationName string
  // Resource association access mode
  //
  // One of "Learning", "Audit", or "Enforced". "Learning" and "Audit" only
  // log access that violates the perimeter rules; "Enforced" blocks it.
  associationAccessMode string
  // Issues that prevented the configuration from propagating
  //
  // Each entry has keys: name; issueType ("ConfigurationPropagationFailure"
  // or "Unknown"); severity ("Error" or "Warning"); and description.
  provisioningIssues []dict
}

// Azure Storage blob inventory policy
//
// Examine the (singleton) blob inventory policy on a storage account.
// Used to audit whether the account has cataloging enabled and what
// inventory rules are defined (destination container, schema, schedule,
// per-rule filters).
private azure.subscription.storageService.account.blobInventoryPolicy @defaults("enabled lastModifiedTime") {
  // ARM resource ID
  id string
  // Policy name (always "default")
  name string
  // Resource type
  type string
  // Whether the inventory policy is enabled
  enabled bool
  // Last modification time
  lastModifiedTime time
  // Inventory rules. Each entry has {name, enabled, destination, definition: {format, schedule, objectType, schemaFields, filters}}.
  rules []dict
}

// Microsoft Defender for Storage configuration for a single storage account
//
// Examine the per-account Defender for Storage settings. `isEnabled` reports
// whether Defender for Storage is on for this account, and
// `sensitiveDataDiscoveryEnabled` reflects whether the Microsoft Purview-backed
// sensitive data classification engine scans blob containers and surfaces
// findings as security alerts. `overrideSubscriptionLevelSettings` distinguishes
// account-level overrides from inherited subscription-level configuration.
private azure.subscription.storageService.account.defenderForStorageSetting @defaults("isEnabled sensitiveDataDiscoveryEnabled malwareScanningOnUploadEnabled") {
  // ARM resource ID of the Defender for Storage setting (`.../storageAccounts/{name}/providers/Microsoft.Security/defenderForStorageSettings/current`)
  id string
  // Whether Defender for Storage is enabled on this storage account
  isEnabled bool
  // Whether the per-account configuration overrides the subscription-level Defender for Storage settings
  overrideSubscriptionLevelSettings bool
  // Whether the Microsoft Purview-backed Sensitive Data Discovery sub-feature is enabled
  //
  // Scans blob containers for sensitive data (credit cards, credentials, etc.) and emits security alerts.
  sensitiveDataDiscoveryEnabled bool
  // Status of the most recent Sensitive Data Discovery enable/disable operation
  //
  // Dict with keys `code` and `message` (populated only on failure or partial success).
  sensitiveDataDiscoveryStatus dict
  // Whether on-upload malware scanning is enabled — every new blob is scanned for malware before becoming readable
  malwareScanningOnUploadEnabled bool
  // Monthly per-storage-account cap on the GB scanned for on-upload malware scanning. Negative values mean no cap
  malwareScanningCapGBPerMonth int
  // Resource ID of the Event Grid Topic that receives malware scan results, empty when no topic is configured
  malwareScanningResultsEventGridTopicId string
  // Status of the most recent Malware Scanning enable/disable operation, with keys `code` and `message` (populated only on failure or partial success)
  malwareScanningStatus dict
}


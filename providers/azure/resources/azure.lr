  localNetworkAddressSpacePrefixes []string
  // Provisioning state of the local network gateway
  provisioningState string
  // Resource GUID assigned to the local network gateway
  resourceGuid string
  // BGP settings advertised by the on-premises VPN device, if BGP is configured
  bgpSettings() azure.subscription.networkService.bgpSettings

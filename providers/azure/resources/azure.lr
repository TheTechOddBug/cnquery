// Network manager security admin rule
//
// A single security admin rule that allows or denies traffic, taking
// precedence over network security group rules. Surfaces the access
// (Allow, Deny, AlwaysAllow), direction, priority, protocol, and the source
// and destination address prefixes and port ranges. Select by the rule's Azure
// resource ID.
private azure.subscription.networkService.networkManager.securityAdminConfiguration.ruleCollection.rule @defaults("name access direction priority") {
  // Rule ID
  id string
  // Rule name
  name string
  // Rule resource type
  type string
  // Rule etag
  etag string
  // Provisioning state of the rule
  provisioningState string
  // Whether the rule is Custom or Default
  kind string
  // Description of the rule
  description string
  // Access applied to matching traffic (Allow, Deny, AlwaysAllow)
  access string
  // Direction the rule matches (Inbound, Outbound)
  direction string
  // Evaluation priority of the rule; lower numbers are evaluated first
  priority int
  // Network protocol the rule applies to (Tcp, Udp, Icmp, Esp, Ah, Any)
  protocol string
  // Source port ranges the rule matches
  sourcePortRanges []string
  // Destination port ranges the rule matches
  destinationPortRanges []string
  // Source address prefixes; each entry carries addressPrefix and addressPrefixType (IPPrefix, ServiceTag, NetworkGroup)
  sources []dict
  // Destination address prefixes; each entry carries addressPrefix and addressPrefixType (IPPrefix, ServiceTag, NetworkGroup)
  destinations []dict
}


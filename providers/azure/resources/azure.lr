  serviceEndpoints []azure.subscription.networkService.subnet.serviceEndpoint
  // Service delegations configured on the subnet (e.g., Microsoft.ContainerInstance/containerGroups)
  delegations []azure.subscription.networkService.subnet.delegation
  // The NAT gateway this subnet is associated with, if any
  natGateway() azure.subscription.networkService.natGateway
  // Private endpoints deployed in the subnet
  privateEndpoints() []azure.subscription.networkService.privateEndpoint
  // IP allocations reserving address space in the subnet
  ipAllocations() []azure.subscription.networkService.ipAllocation
  // List of IP configurations for the subnet

// Deny assignment in an Azure subscription
private azure.subscription.authorizationService.denyAssignment @defaults("name doNotApplyToChildScopes type") {
  // Deny assignment ID
  id string
  // Deny assignment name
  name string
  // Resource type
  type string
  // Display name shown in the portal
  denyAssignmentName string
  // Description of the deny assignment
  description string
  // Whether the deny rule does not apply to child scopes
  doNotApplyToChildScopes bool
  // Whether the deny rule is system-protected (cannot be removed by users)
  isSystemProtected bool
  // Scope of the deny assignment (subscription/resource group/resource)
  scope string
  // Permissions denied (each: { actions, dataActions, notActions, notDataActions, condition })
  permissions []dict
  // Principals subject to the deny ([{principalId, principalType}])
  principals []dict
  // Principals excluded from the deny ([{principalId, principalType}])
  excludePrincipals []dict
}


  // `protectedItemType` discriminator key (for example
  // "Microsoft.Compute/virtualMachines", "AzureFileShareProtectedItem", or
  // the SQL and SAP HANA workload types). Common keys include
  // `backupManagementType`, `workloadType`, `policyId`, and the time and
  // health status of the most recent backup.
  properties dict
}

// ===== Azure Functions Service =====

// Azure Functions service
private azure.subscription.functionsService {
  // Subscription identifier
  subscriptionId string
  // List of function apps
  functionApps() []azure.subscription.functionsService.functionApp
}

// Azure Function App
//
// Function App, an App Service site configured to run serverless
// functions. Covers runtime state, HTTPS-only enforcement, client
// certificate mode, managed-identity assignments, public network
// access, and regional virtual-network integration. The site
// configuration (minimum TLS version, FTPS state, IP restrictions,
// CORS, always-on) is available through `configuration`, while
// `appSettings` and `connectionStrings` report the configured
// settings without exposing their values, so you can audit for
// plaintext secrets and Azure Key Vault reference usage.
azure.subscription.functionsService.functionApp @defaults("id name location") {
  // Function App resource ID
  id string
  // Function App name
  name string
  // Function App location
  location string
  // Function App tags
  tags map[string]string
  // Function App kind (e.g., "functionapp", "functionapp,linux")
  kind string
  // Function App state (e.g., "Running", "Stopped")
  state string
  // Default hostname of the function app
  defaultHostName string
  // Whether the function app only accepts HTTPS traffic
  httpsOnly bool
  // Whether client certificates are enabled
  clientCertEnabled bool
  // Client certificate mode (Required, Optional, OptionalInteractiveUser)
  clientCertMode string
  // Managed service identity ID
  //
  // Deprecated in favor of principalId and userAssignedIdentities.
  managedServiceIdentityId @maturity("deprecated") string
  // Principal ID of the function app's system-assigned managed identity; empty when no system-assigned identity is enabled
  principalId string
  // System-assigned managed identity of the function app; null when no system-assigned identity is enabled
  //
  // Resolves the system-assigned identity so its role assignments, and their
  // role definitions and permissions, can be traversed, completing the
  // resource-to-privilege leg of an attack path.
  systemAssignedIdentity() azure.subscription.managedIdentity
  // User-assigned managed identities attached to the function app
  userAssignedIdentities() []azure.subscription.managedIdentity
  // Identity used to resolve Key Vault references in app settings and connection strings (resource ID of a user-assigned identity, or "SystemAssigned")
  keyVaultReferenceIdentity string
  // Whether public network access is enabled ("Enabled" or "Disabled")
  publicNetworkAccess string
  // ARM resource ID of the subnet the function app is regionally VNet-integrated with; empty when no regional VNet integration is configured
  virtualNetworkSubnetId string
  // Subnet the function app is regionally VNet-integrated with; null when no regional VNet integration is configured
  virtualNetworkSubnet() azure.subscription.networkService.subnet
  // Raw Azure Resource Manager site properties
  //
  // Full SiteProperties object returned by ARM for the function app,
  // including hosting-plan binding, host names, and site state. Many
  // of these values are surfaced as top-level fields (state,
  // defaultHostName, httpsOnly, publicNetworkAccess); use those for
  // stable audits and this dict for keys not otherwise modeled.
  properties dict
  // Site configuration: minimum TLS version, FTPS state, HTTP/2, always-on, remote debugging, and IP restrictions
  configuration() azure.subscription.webService.appsiteconfig
  // Functions in this function app
  functions() []azure.subscription.functionsService.functionApp.function
  // Application settings configured on the function app
  //
  // Values are not returned — each entry exposes name, slot-stickiness, Key-Vault-reference detection, and a heuristic flag for secret-bearing names.
  appSettings() []azure.subscription.functionsService.functionApp.appSetting
  // Connection strings configured on the function app
  //
  // Each entry has shape {name, type, hasKeyVaultReference, slotSetting}. Connection-string values are not returned.
  connectionStrings() []dict
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Azure Function App application setting
//
// Single application setting on a function app, selectable by its
// composite id. Reports whether the value resolves through Azure Key
// Vault (`hasKeyVaultReference`), whether the setting is sticky across
// slot swaps (`slotSetting`), and a heuristic flag (`isLikelySecret`)
// for setting names that suggest secret content, supporting audits for
// any plaintext secret-like setting that is not a Key Vault reference.
private azure.subscription.functionsService.functionApp.appSetting @defaults("name hasKeyVaultReference isLikelySecret slotSetting") {
  // Composite ID: <functionAppId>/config/appsettings/<name>
  id string
  // Setting name
  name string
  // Whether the setting's value is a Key Vault reference
  //
  // True when the value starts with `@Microsoft.KeyVault(...)`.
  hasKeyVaultReference bool
  // Whether the setting name suggests it carries a secret
  //
  // True when the name (case-insensitively) contains "key", "password", "secret", "token", or a connection-string identifier ending in `str`.
  isLikelySecret bool
  // Whether the setting is "sticky" on slot swaps
  //
  // Configured via the app's slot-config-names list.
  slotSetting bool
  // Whether the setting has a non-empty value (the value itself is not exposed)
  hasValue bool
}

// Azure Function within a Function App
private azure.subscription.functionsService.functionApp.function @defaults("id name") {
  // Function resource ID
  id string
  // Function name
  name string
  // Function configuration (function.json)
  //
  // Raw function.json content: the `bindings` array (trigger and
  // input/output binding definitions with their type, direction, and
  // name), the `disabled` flag, and script settings such as
  // `scriptFile` and `entryPoint`.
  config dict
  // Function language
  language string
  // Whether the function is disabled
  isDisabled bool
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// ===== Azure Service Bus Service =====

// Azure Service Bus service
//
// Service Bus messaging across the subscription. The `namespaces`
// field lists every Service Bus namespace, each exposing its SKU and
// tier, network access controls, encryption settings, and the queues,
// topics, and subscriptions defined inside it.
private azure.subscription.serviceBusService {
  // Subscription identifier
  subscriptionId string
  // List of Service Bus namespaces
  namespaces() []azure.subscription.serviceBusService.namespace
}

// Azure Service Bus namespace
//
// Messaging scope that owns the queues, topics, and subscriptions of
// a Service Bus deployment. The SKU and tier (Basic, Standard,
// Premium) set the available feature set, while `disableLocalAuth`,
// the customer-managed key encryption settings, and the network rule
// set govern how clients authenticate and which networks may reach
// the namespace. Query these to confirm SAS-key access is disabled,
// public reachability is restricted, and encryption uses a managed
// key.
azure.subscription.serviceBusService.namespace @defaults("id name location") {
  // Namespace resource ID
  id string
  // Namespace name
  name string
  // Namespace location
  location string
  // Namespace tags
  tags map[string]string
  // SKU details
  //
  // Keys: `name` and `tier` (Basic, Standard, or Premium) plus
  // `capacity` (messaging unit count, Premium only).
  sku dict
  // Namespace status
  status string
  // Service Bus endpoint
  serviceBusEndpoint string
  // Whether local (SAS key) authentication is disabled
  disableLocalAuth bool
  // Whether the namespace is zone-redundant
  zoneRedundant bool
  // Provisioning state
  provisioningState string
  // CMK key source ("Microsoft.KeyVault" when CMK is configured; empty for platform-managed)
  cmkKeySource string
  // Whether double encryption (infrastructure layer + CMK) is enabled
  requireInfrastructureEncryption bool
  // Customer-managed encryption keys (Key Vault references) configured for this namespace
  //
  // Each entry has keys `keyName`, `keyVaultUri`, `keyVersion`, and
  // `identity` (the user-assigned identity used to reach the vault).
  cmkKeys []dict
  // Raw namespace network rule set
  //
  // Deprecated in favor of `networkRules()`.
  networkRuleSet() @maturity("deprecated") dict
  // Namespace network rules (default action, public network access, IP / VNet rules, trusted-service access)
  networkRules() azure.subscription.serviceBusService.namespace.networkRules
  // Queues in this namespace
  queues() []azure.subscription.serviceBusService.namespace.queue
  // Topics in this namespace
  topics() []azure.subscription.serviceBusService.namespace.topic
  // Shared access signature (SAS) authorization rules on the namespace
  authorizationRules() []azure.subscription.serviceBusService.authorizationRule
  // Private endpoint connections to the namespace
  privateEndpointConnections() []azure.subscription.privateEndpointConnection
  // When the namespace was created
  creationTime time
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Service Bus namespace network rule set
//
// Network access policy governing which traffic may reach a Service
// Bus namespace. `defaultAction` (Allow or Deny) applies to traffic
// that matches no rule, `publicNetworkAccess` toggles public
// reachability, and `trustedServiceAccessEnabled` lets Microsoft-owned
// services bypass the rule set. The `ipRules` and `virtualNetworkRules`
// lists enumerate the allowed IP ranges and subnets.
private azure.subscription.serviceBusService.namespace.networkRules @defaults("defaultAction publicNetworkAccess trustedServiceAccessEnabled") {
  // Default action for traffic that does not match any rule ("Allow" or "Deny")
  defaultAction string
  // Whether traffic is allowed over the public network ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Whether Microsoft-owned trusted services can bypass the rule set
  trustedServiceAccessEnabled bool
  // IP allow rules. Each entry is `{ipMask, action}` where `action` is "Allow".
  ipRules []dict
  // Virtual network rules; each references a subnet
  virtualNetworkRules []azure.subscription.serviceBusService.namespace.networkRules.virtualNetworkRule
}

// Service Bus namespace virtual network rule
//
// Single VNet rule attached to a Service Bus namespace, resolving to
// the referenced `subnet`. The `ignoreMissingVnetServiceEndpoint`
// flag indicates whether the rule permits traffic from the subnet
// even when the subnet has not yet enabled the Microsoft.ServiceBus
// service endpoint.
private azure.subscription.serviceBusService.namespace.networkRules.virtualNetworkRule @defaults("ignoreMissingVnetServiceEndpoint") {
  // Subnet referenced by the rule
  subnet() azure.subscription.networkService.subnet
  // Whether to allow traffic from the subnet even if the Microsoft.ServiceBus service endpoint is not yet enabled on it
  ignoreMissingVnetServiceEndpoint bool
}

// Azure Service Bus queue
//
// First-in-first-out message queue within a Service Bus namespace,
// selected by `name`. The `status` controls whether send and receive
// are enabled, `messageCount` and `deadLetterMessageCount` report
// backlog and poison-message volume, and `requiresSession`,
// `requiresDuplicateDetection`, and `maxDeliveryCount` govern
// delivery semantics.
private azure.subscription.serviceBusService.namespace.queue @defaults("id name") {
  // Queue resource ID
  id string
  // Queue name
  name string
  // Queue status (Active, Disabled, SendDisabled, ReceiveDisabled)
  status string
  // Maximum queue size in megabytes
  maxSizeInMegabytes int
  // Number of messages in the queue
  messageCount int
  // Number of messages in the dead-letter sub-queue
  deadLetterMessageCount int
  // Maximum delivery count before dead-lettering
  maxDeliveryCount int
  // Lock duration (ISO 8601 duration)
  lockDuration string
  // Default time-to-live for messages (ISO 8601 duration)
  defaultMessageTimeToLive string
  // Whether duplicate detection is required
  requiresDuplicateDetection bool
  // Whether sessions are required
  requiresSession bool
  // Whether partitioning is enabled
  enablePartitioning bool
  // When the queue was created
  creationTime time
  // Shared access signature (SAS) authorization rules on the queue
  authorizationRules() []azure.subscription.serviceBusService.authorizationRule
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Azure Service Bus topic
//
// Publish-subscribe messaging entity within a Service Bus namespace,
// selected by `name`. Messages sent to the topic fan out to its
// `subscriptions`. The `status`, `enablePartitioning`,
// `supportOrdering`, and `requiresDuplicateDetection` fields describe
// its availability and delivery behavior.
private azure.subscription.serviceBusService.namespace.topic @defaults("id name") {
  // Topic resource ID
  id string
  // Topic name
  name string
  // Topic status (Active, Disabled, SendDisabled)
  status string
  // Maximum topic size in megabytes
  maxSizeInMegabytes int
  // Number of subscriptions on the topic
  subscriptionCount int
  // Whether partitioning is enabled
  enablePartitioning bool
  // Whether ordering is supported
  supportOrdering bool
  // Whether duplicate detection is required
  requiresDuplicateDetection bool
  // Default time-to-live for messages (ISO 8601 duration)
  defaultMessageTimeToLive string
  // When the topic was created
  creationTime time
  // Subscriptions on this topic
  subscriptions() []azure.subscription.serviceBusService.namespace.topic.subscription
  // Shared access signature (SAS) authorization rules on the topic
  authorizationRules() []azure.subscription.serviceBusService.authorizationRule
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Azure Service Bus topic subscription
//
// Named subscription attached to a Service Bus topic, selected by
// `name`, that receives a copy of the topic's messages. The `status`,
// `messageCount`, `deadLetterMessageCount`, `maxDeliveryCount`, and
// `requiresSession` fields describe its delivery state and semantics.
private azure.subscription.serviceBusService.namespace.topic.subscription @defaults("id name") {
  // Subscription resource ID
  id string
  // Subscription name
  name string
  // Subscription status (Active, Disabled, ReceiveDisabled)
  status string
  // Number of messages in the subscription
  messageCount int
  // Number of messages in the dead-letter sub-queue
  deadLetterMessageCount int
  // Maximum delivery count before dead-lettering
  maxDeliveryCount int
  // Lock duration (ISO 8601 duration)
  lockDuration string
  // Default time-to-live for messages (ISO 8601 duration)
  defaultMessageTimeToLive string
  // Whether sessions are required
  requiresSession bool
  // When the subscription was created
  creationTime time
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Service Bus shared access signature authorization rule
//
// Shared access signature (SAS) policy attached to a Service Bus
// namespace, queue, or topic, selected by `name`. The `rights` list
// enumerates the granted permissions: Listen, Send, or Manage. A rule
// that grants Manage (including the default RootManageSharedAccessKey)
// confers full control of the entity, so audit these to find
// over-privileged keys and to confirm SAS access is scoped to the
// minimum each client needs.
private azure.subscription.serviceBusService.authorizationRule @defaults("name rights") {
  // Authorization rule resource ID
  id string
  // Authorization rule name
  name string
  // Granted rights (Listen, Send, Manage)
  rights []string
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// ===== Azure Event Hubs Service =====

// Azure Event Hubs service
private azure.subscription.eventHubService {
  // Subscription identifier
  subscriptionId string
  // List of Event Hub namespaces
  namespaces() []azure.subscription.eventHubService.namespace
}

// Azure Event Hubs namespace
//
// Streaming-ingestion entity scope that owns Event Hubs and their
// consumer groups. The namespace determines the security posture of
// everything inside it: SAS-key authentication can be disabled in
// favor of Entra ID via disableLocalAuth, a minimum TLS version
// enforced, public network access restricted, network rule sets
// applied, and customer-managed keys used for encryption at rest.
// Audit these settings to confirm a namespace is not reachable over
// unauthenticated or plaintext paths.
azure.subscription.eventHubService.namespace @defaults("id name location") {
  // Namespace resource ID
  id string
  // Namespace name
  name string
  // Namespace location
  location string
  // Namespace tags
  tags map[string]string
  // SKU tier and capacity
  //
  // Keys: `name` and `tier` (one of Basic, Standard, or Premium), and
  // `capacity` (the provisioned throughput or premium units).
  sku dict
  // Namespace status
  status string
  // Whether auto-inflate is enabled
  isAutoInflateEnabled bool
  // Maximum throughput units when auto-inflate is enabled
  maximumThroughputUnits int
  // Whether Kafka is enabled
  kafkaEnabled bool
  // Whether local (SAS key) authentication is disabled
  disableLocalAuth bool
  // Minimum TLS version (e.g., "1.0", "1.1", "1.2")
  minimumTlsVersion string
  // Whether public network access is enabled ("Enabled", "Disabled", or "SecuredByPerimeter")
  publicNetworkAccess string
  // Whether the namespace is zone-redundant
  zoneRedundant bool
  // CMK key source ("Microsoft.KeyVault" when CMK is configured; empty for platform-managed)
  cmkKeySource string
  // Whether double encryption (infrastructure layer + CMK) is enabled
  requireInfrastructureEncryption bool
  // Customer-managed encryption keys
  //
  // Key Vault references used to encrypt data at rest. Each entry has
  // `keyName`, `keyVaultUri`, `keyVersion`, and an `identity` used to
  // reach the key.
  cmkKeys []dict
  // Raw namespace network rule set
  //
  // Deprecated in favor of `networkRules()`.
  networkRuleSet() @maturity("deprecated") dict
  // Namespace network rules (default action, public network access, IP / VNet rules, trusted-service access)
  networkRules() azure.subscription.eventHubService.namespace.networkRules
  // Event Hubs in this namespace
  eventHubs() []azure.subscription.eventHubService.namespace.eventHub
  // Shared access signature (SAS) authorization rules on the namespace
  authorizationRules() []azure.subscription.eventHubService.authorizationRule
  // Private endpoint connections to the namespace
  privateEndpointConnections() []azure.subscription.privateEndpointConnection
  // When the namespace was created
  creationTime time
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Event Hubs namespace network rule set
//
// Namespace-level network access policy. The defaultAction (Allow or
// Deny) applies to traffic that matches no rule, publicNetworkAccess
// controls whether the public endpoint is reachable at all,
// trustedServiceAccessEnabled lets Microsoft-owned services bypass
// the rule set, and ipRules and virtualNetworkRules enumerate the
// explicitly permitted sources. A defaultAction of Allow leaves the
// namespace open to any network.
private azure.subscription.eventHubService.namespace.networkRules @defaults("defaultAction publicNetworkAccess trustedServiceAccessEnabled") {
  // Default action for traffic that does not match any rule ("Allow" or "Deny")
  defaultAction string
  // Whether traffic is allowed over the public network ("Enabled", "Disabled", or "SecuredByPerimeter")
  publicNetworkAccess string
  // Whether Microsoft-owned trusted services can bypass the rule set
  trustedServiceAccessEnabled bool
  // IP allow rules. Each entry is `{ipMask, action}` where `action` is "Allow".
  ipRules []dict
  // Virtual network rules; each references a subnet
  virtualNetworkRules []azure.subscription.eventHubService.namespace.networkRules.virtualNetworkRule
}

// Event Hubs namespace virtual network rule
//
// Single virtual-network rule attached to an Event Hubs namespace,
// resolving to the referenced subnet. The
// ignoreMissingVnetServiceEndpoint flag indicates whether the rule
// permits traffic from the subnet even when the subnet has not yet
// enabled the Microsoft.EventHub service endpoint.
private azure.subscription.eventHubService.namespace.networkRules.virtualNetworkRule @defaults("ignoreMissingVnetServiceEndpoint") {
  // Subnet referenced by the rule
  subnet() azure.subscription.networkService.subnet
  // Whether to allow traffic from the subnet even if the Microsoft.EventHub service endpoint is not yet enabled on it
  ignoreMissingVnetServiceEndpoint bool
}

// Azure Event Hub
private azure.subscription.eventHubService.namespace.eventHub @defaults("id name") {
  // Event Hub resource ID
  id string
  // Event Hub name
  name string
  // Number of partitions
  partitionCount int
  // Message retention period in days
  messageRetentionInDays int
  // Event Hub status (Active, Disabled, SendDisabled)
  status string
  // List of partition IDs
  partitionIds []string
  // Consumer groups for this Event Hub
  consumerGroups() []azure.subscription.eventHubService.namespace.eventHub.consumerGroup
  // Shared access signature (SAS) authorization rules on the Event Hub
  authorizationRules() []azure.subscription.eventHubService.authorizationRule
  // When the Event Hub was created
  creationTime time
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Azure Event Hub consumer group
private azure.subscription.eventHubService.namespace.eventHub.consumerGroup @defaults("id name") {
  // Consumer group resource ID
  id string
  // Consumer group name
  name string
  // User-defined metadata
  userMetadata string
  // When the consumer group was created
  creationTime time
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Event Hubs shared access signature authorization rule
//
// Shared access signature (SAS) policy attached to an Event Hubs
// namespace or an individual Event Hub, selected by `name`. The
// `rights` list enumerates the granted permissions: Listen, Send, or
// Manage. A rule that grants Manage (including the default
// RootManageSharedAccessKey) confers full control, so audit these to
// find over-privileged keys and to confirm SAS access is scoped to the
// minimum each client needs.
private azure.subscription.eventHubService.authorizationRule @defaults("name rights") {
  // Authorization rule resource ID
  id string
  // Authorization rule name
  name string
  // Granted rights (Listen, Send, Manage)
  rights []string
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// ===== Azure Event Grid Service =====

// Azure Event Grid service
private azure.subscription.eventGridService {
  // Subscription identifier
  subscriptionId string
  // Event Grid custom topics in the subscription
  topics() []azure.subscription.eventGridService.topic
  // Event Grid system topics in the subscription
  systemTopics() []azure.subscription.eventGridService.systemTopic
  // Event Grid domains in the subscription
  domains() []azure.subscription.eventGridService.domain
}

// Azure Event Grid custom topic
//
// User-created event ingestion endpoint that clients publish events to.
// Custom topics are the primary control point for publish security:
// `disableLocalAuth` governs whether key-based publishing is allowed,
// `publicNetworkAccess` and `inboundIpRules` gate network reachability,
// and `minimumTlsVersionAllowed` sets the transport floor for
// publishers. Audit these together to confirm a topic is not publicly
// writable over weak transport or shared access keys.
azure.subscription.eventGridService.topic @defaults("name location publicNetworkAccess provisioningState") {
  // Topic resource ID
  id string
  // Topic name
  name string
  // Topic location
  location string
  // Topic tags
  tags map[string]string
  // Provisioning state ("Succeeded", "Canceled", "Creating", "Deleting", "Failed", "Updating")
  provisioningState string
  // Endpoint URL clients publish events to
  endpoint string
  // Metric resource ID for the topic
  metricResourceId string
  // Whether local (key) authentication is disabled
  disableLocalAuth bool
  // Public network access setting ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Input schema for events ("EventGridSchema", "CustomEventSchema", "CloudEventSchemaV1_0")
  inputSchema string
  // Minimum TLS version enforced on publishers ("1.0", "1.1", "1.2")
  minimumTlsVersionAllowed string
  // Data residency boundary ("WithinGeopair" or "WithinRegion")
  dataResidencyBoundary string
  // Inbound IP rules; each entry has ipMask and action ("Allow")
  inboundIpRules []dict
  // Identity type ("None", "SystemAssigned", "UserAssigned", "SystemAssigned, UserAssigned")
  identityType string
  // Number of private endpoint connections to the topic
  privateEndpointConnectionCount int
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Azure Event Grid system topic
//
// Auto-generated topic through which an Azure resource (storage account,
// key vault, container registry, and similar) publishes its own events.
// The `source` field points back to the originating resource and
// `topicType` identifies the publisher category (for example
// "Microsoft.Storage.StorageAccounts" or "Microsoft.KeyVault.vaults"),
// which together reveal which resources are wired into event routing and
// under what identity.
azure.subscription.eventGridService.systemTopic @defaults("name location topicType source provisioningState") {
  // System topic resource ID
  id string
  // System topic name
  name string
  // System topic location
  location string
  // System topic tags
  tags map[string]string
  // Provisioning state
  provisioningState string
  // Source resource ID (the Azure resource that publishes events through this system topic)
  source string
  // Topic type (e.g. "Microsoft.Storage.StorageAccounts", "Microsoft.KeyVault.vaults")
  topicType string
  // Metric resource ID for the system topic
  metricResourceId string
  // Identity type ("None", "SystemAssigned", "UserAssigned", "SystemAssigned, UserAssigned")
  identityType string
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Azure Event Grid domain
//
// Multi-tenant topic container that scopes thousands of topics under a
// single publishing endpoint. As with a custom topic, its publish
// surface is governed by `disableLocalAuth`, `publicNetworkAccess`,
// `inboundIpRules`, and `minimumTlsVersionAllowed`, while
// `autoCreateTopicWithFirstSubscription` and
// `autoDeleteTopicWithLastSubscription` control the lifecycle of the
// domain topics beneath it. Audit these to confirm the shared endpoint
// is not publicly writable over weak transport or shared access keys.
azure.subscription.eventGridService.domain @defaults("name location publicNetworkAccess provisioningState") {
  // Domain resource ID
  id string
  // Domain name
  name string
  // Domain location
  location string
  // Domain tags
  tags map[string]string
  // Provisioning state
  provisioningState string
  // Endpoint URL clients publish events to
  endpoint string
  // Metric resource ID for the domain
  metricResourceId string
  // Whether local (key) authentication is disabled
  disableLocalAuth bool
  // Public network access setting ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Input schema for events ("EventGridSchema", "CustomEventSchema", "CloudEventSchemaV1_0")
  inputSchema string
  // Minimum TLS version enforced on publishers ("1.0", "1.1", "1.2")
  minimumTlsVersionAllowed string
  // Data residency boundary ("WithinGeopair" or "WithinRegion")
  dataResidencyBoundary string
  // Whether domain topics are auto-created when the first subscription is created
  autoCreateTopicWithFirstSubscription bool
  // Whether domain topics are auto-deleted when the last subscription is deleted
  autoDeleteTopicWithLastSubscription bool
  // Inbound IP rules; each entry has ipMask and action ("Allow")
  inboundIpRules []dict
  // Identity type ("None", "SystemAssigned", "UserAssigned", "SystemAssigned, UserAssigned")
  identityType string
  // Number of private endpoint connections to the domain
  privateEndpointConnectionCount int
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// ===== Azure DNS Service =====

// Azure DNS service
private azure.subscription.dnsService {
  // Subscription identifier
  subscriptionId string
  // List of public DNS zones
  zones() []azure.subscription.dnsService.zone
  // List of private DNS zones
  privateZones() []azure.subscription.dnsService.privateZone
}

// Azure public DNS zone
//
// Public DNS zone that hosts authoritative records for a domain and
// answers queries from the internet. Reports the assigned authoritative
// name servers, the current record-set count against the
// maxNumberOfRecordSets cap, and the individual recordSets hosted in
// the zone. For internal-only zones resolved from linked virtual
// networks, query azure.subscription.dnsService.privateZone.
azure.subscription.dnsService.zone @defaults("id name") {
  // DNS zone resource ID
  id string
  // DNS zone name
  name string
  // DNS zone location
  location string
  // DNS zone tags
  tags map[string]string
  // Number of record sets in the zone
  numberOfRecordSets int
  // Maximum number of record sets allowed
  maxNumberOfRecordSets int
  // Name servers for the zone
  nameServers []string
  // Record sets in the zone
  recordSets() []azure.subscription.dnsService.zone.recordSet
}

// Azure DNS record set
private azure.subscription.dnsService.zone.recordSet @defaults("id name type") {
  // Record set resource ID
  id string
  // Record set name
  name string
  // Record type (A, AAAA, CNAME, MX, NS, PTR, SOA, SRV, TXT, CAA)
  type string
  // Time-to-live in seconds
  ttl int
  // Fully qualified domain name
  fqdn string
  // Record set properties
  //
  // Raw record-set properties keyed by record type. The type-specific
  // record array present depends on the record type: aRecords,
  // aaaaRecords, cnameRecord, mxRecords, nsRecords, ptrRecords,
  // srvRecords, txtRecords, caaRecords, and soaRecord. Also carries
  // fqdn, TTL, metadata, provisioningState, and targetResource.
  properties dict
}

// Azure Private DNS zone
//
// Private DNS zone whose records resolve only from the virtual networks
// linked to it, keeping internal name resolution off the public
// internet. Reports the provisioning state, the current record-set and
// virtual-network-link counts against their maximums, and the record
// sets hosted in the zone. Linked virtual networks, including which
// ones auto-register VM records, are reached through
// virtualNetworkLinks.
azure.subscription.dnsService.privateZone @defaults("id name") {
  // Private DNS zone resource ID
  id string
  // Private DNS zone name
  name string
  // Private DNS zone location
  location string
  // Private DNS zone tags
  tags map[string]string
  // Number of record sets in the zone
  numberOfRecordSets int
  // Maximum number of record sets allowed
  maxNumberOfRecordSets int
  // Number of virtual network links
  numberOfVirtualNetworkLinks int
  // Virtual network links for this private zone
  virtualNetworkLinks() []azure.subscription.dnsService.privateZone.virtualNetworkLink
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}

// Azure private DNS zone virtual network link
private azure.subscription.dnsService.privateZone.virtualNetworkLink @defaults("id name") {
  // Virtual network link resource ID
  id string
  // Virtual network link name
  name string
  // Virtual network link location
  location string
  // Virtual network link tags
  tags map[string]string
  // Whether auto-registration of VM records is enabled
  registrationEnabled bool
  // Provisioning state
  provisioningState string
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}


  // Sync window duration (ISO 8601, e.g. "PT3H")
  syncWindow string
  // Last successful sync time
  syncLastSyncTime time
  // Sync message TTL (ISO 8601 duration)
  syncMessageTtl string
  // ACR token resource IDs used to authenticate clients connecting to this registry
  clientTokenIds []string
  // Notification subscriptions
  notificationsList []string
  // Provisioning state
  provisioningState string
}


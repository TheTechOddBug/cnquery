  ipConfigurations []dict
  // Resource IDs of load balancer frontend IP configurations the service is fronted by
  loadBalancerFrontendIpConfigurationIds []string
  // Resource IDs of network interfaces auto-created for this Private Link service
  networkInterfaceIds []string
  // Endpoint connections to this Private Link service
  privateEndpointConnections() []azure.subscription.networkService.privateLinkService.privateEndpointConnection
}

// Endpoint connection to a Private Link service (provider's view of an incoming consumer request)
private azure.subscription.networkService.privateLinkService.privateEndpointConnection @defaults("id name connectionStatus") {
  // Connection ID
  id string
  // Connection name
  name string
  // Connection resource type
  type string
  // Connection etag
  etag string
  // Consumer link identifier
  linkIdentifier string
  // Resource ID of the consumer's private endpoint

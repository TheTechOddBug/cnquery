  // Latest registered version of the model
  latestVersion string
  // Version the next registration will receive
  nextVersion string
  // Whether the model is archived
  isArchived bool
  // Model tags
  tags map[string]string
  // Provisioning state of the model container
  provisioningState string
}

// App Configuration
//
// Use the App Configuration namespace to enumerate the App Configuration
// stores in the subscription. Each store centralizes application settings
// and feature flags — content that routinely includes references to
// secrets — so the namespace is the entry point for auditing their
// public-network exposure, customer-managed-key encryption, and
// authentication posture. Iterate `configurationStores()` for the
// per-store records.
private azure.subscription.appConfigurationService {
  // Subscription identifier
  subscriptionId string
  // App Configuration stores in the subscription
  configurationStores() []azure.subscription.appConfigurationService.configurationStore
}

// App Configuration store
//
// Examine a single App Configuration store — the managed key-value service
// that holds application settings and feature flags. Use `publicNetworkAccess`
// to confirm whether the store is reachable from the public internet,
// `disableLocalAuth` for whether access-key authentication is turned off in
// favor of Microsoft Entra ID, `cmkKeyIdentifier` for the customer-managed
// key encrypting the store (empty when Microsoft-managed keys are used),
// `softDeleteRetentionInDays` and `enablePurgeProtection` for the
// data-recovery guarantees, and `endpoint` for the data-plane URL.
azure.subscription.appConfigurationService.configurationStore @defaults("id name location publicNetworkAccess") {
  // Configuration store resource ID
  id string
  // Configuration store name
  name string
  // Configuration store location
  location string
  // Configuration store tags
  tags map[string]string
  // SKU details (name: free or standard)
  sku dict
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Whether the store is reachable from the public internet ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Whether access-key (local) authentication is disabled, leaving Microsoft Entra ID as the only method
  disableLocalAuth bool
  // Key Vault key identifier of the customer-managed key encrypting the store; empty when Microsoft-managed keys are used
  cmkKeyIdentifier string
  // Client ID of the user-assigned identity used to access the customer-managed key
  cmkIdentityClientId string
  // Number of days a soft-deleted store is retained before permanent deletion
  softDeleteRetentionInDays int
  // Whether purge protection is enabled, preventing permanent deletion during the soft-delete retention period
  enablePurgeProtection bool
  // The data-plane endpoint where the configuration store API is reachable
  endpoint string
  // Provisioning state of the store
  provisioningState string
  // Creation mode of the store ("Default" or "Recover")
  createMode string
  // Default retention period (seconds) for revisions of every key-value, controlling how far back point-in-time queries can read
  defaultKeyValueRevisionRetentionPeriodInSeconds int
}

// Azure AI Services
//
// Use the Cognitive Services namespace to enumerate the Azure AI Services
// (formerly Cognitive Services) accounts in the subscription, backed by the
// `Microsoft.CognitiveServices` resource provider. Each account exposes AI
// APIs — OpenAI, Speech, Vision, Language, and others — whose prompts and
// responses can carry sensitive data, so the namespace is the entry point
// for auditing their public-network exposure, network ACLs, customer-managed-key
// encryption, and authentication posture. Iterate `accounts()` for the
// per-account records.
private azure.subscription.cognitiveServicesService {
  // Subscription identifier
  subscriptionId string
  // Azure AI Services accounts in the subscription
  accounts() []azure.subscription.cognitiveServicesService.account
}

// Azure AI Services account
//
// Examine a single Azure AI Services account — the resource that exposes
// one or more AI APIs identified by `kind` (for example "OpenAI",
// "SpeechServices", or "CognitiveServices"). Use `publicNetworkAccess` to
// confirm whether the account is reachable from the public internet,
// `networkAcls` for the IP and virtual-network firewall rules,
// `disableLocalAuth` for whether API-key authentication is turned off in
// favor of Microsoft Entra ID, `restrictOutboundNetworkAccess` for
// data-exfiltration controls, `cmkKeyName` and `cmkKeyVaultUri` for the
// customer-managed key encrypting the account, and `customSubDomainName`
// for the subdomain required by token-based authentication and private
// endpoints.
azure.subscription.cognitiveServicesService.account @defaults("id name location kind publicNetworkAccess") {
  // Account resource ID
  id string
  // Account name
  name string
  // Account location
  location string
  // Kind of AI service the account exposes (e.g., "OpenAI", "SpeechServices", "CognitiveServices")
  kind string
  // Account tags
  tags map[string]string
  // SKU details (e.g., name "S0", "F0")
  sku dict
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Whether the account is reachable from the public internet ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Whether API-key (local) authentication is disabled, leaving Microsoft Entra ID as the only method
  disableLocalAuth bool
  // Whether outbound network access is restricted to the allowed FQDN list, limiting data exfiltration
  restrictOutboundNetworkAccess bool
  // Custom subdomain name; required for token-based authentication and private endpoints
  customSubDomainName string
  // Network rule set: default action, IP rules, virtual-network rules, and trusted-service bypass
  networkAcls dict
  // Action applied when no IP or virtual-network rule matches ("Allow" or "Deny"); "Deny" denies public traffic by default
  networkAclsDefaultAction string
  // Trusted-service bypass for the network rule set ("AzureServices" or "None")
  networkAclsBypass string
  // Encryption key source ("Microsoft.KeyVault" when a customer-managed key is configured; "Microsoft.CognitiveServices" for platform-managed keys)
  cmkKeySource string
  // Name of the customer-managed Key Vault key encrypting the account; empty when platform-managed keys are used
  cmkKeyName string
  // URI of the Key Vault holding the customer-managed key
  cmkKeyVaultUri string
  // The endpoint URL of the account
  endpoint string
  // Provisioning state of the account
  provisioningState string
  // Whether stored completions (request/response logging used for fine-tuning and evaluation) are disabled
  storedCompletionsDisabled bool
  // Whether Microsoft Defender for AI threat detection is enabled on the account
  defenderForAIEnabled() bool
  // Responsible AI content-filter policies configured on the account
  raiPolicies() []azure.subscription.cognitiveServicesService.account.raiPolicy
  // Responsible AI custom topics registered on the account
  raiTopics() []azure.subscription.cognitiveServicesService.account.raiTopic
  // Model deployments hosted on the account
  deployments() []azure.subscription.cognitiveServicesService.account.deployment
  // Azure AI Foundry projects hosted on the account
  projects() []azure.subscription.cognitiveServicesService.account.project
  // Account-scoped connections to external resources, model providers, data sources, and tool servers
  connections() []azure.subscription.cognitiveServicesService.account.connection
}

// Model deployment on an Azure AI Services account
//
// Examine a single model deployment — the concrete model an application
// calls through the account, identified by `name` (for example
// `azure.subscription.cognitiveServices.accounts.where(kind == "OpenAI")[0].deployments.where(name == "gpt-4o")`).
// Use `modelName` and `modelVersion` to confirm which model and version
// is served (and `modelFormat`/`modelPublisher` for non-OpenAI models),
// `versionUpgradeOption` to audit whether the deployment is pinned to a
// version that may be retiring or set to auto-upgrade, `skuName` for the
// deployment type (for example "Standard", "GlobalStandard", or
// "ProvisionedManaged") and `skuCapacity`/`currentCapacity` for the
// provisioned throughput, `raiPolicyName` (resolved by `raiPolicy`) for
// the content-filter policy applied to the model, `dynamicThrottlingEnabled`
// for automatic throughput throttling, and `capabilities` for the
// model's advertised features.
azure.subscription.cognitiveServicesService.account.deployment @defaults("name modelName modelVersion skuName versionUpgradeOption") {
  // Deployment resource ID
  id string
  // Deployment name, used by clients as the model identifier in API calls
  name string
  // Deployment tags
  tags map[string]string
  // Provisioning state of the deployment (e.g., "Succeeded", "Creating", "Failed")
  provisioningState string
  // Deployment type controlling how capacity is allocated and billed
  //
  // Common values include "Standard", "GlobalStandard", "DataZoneStandard", "ProvisionedManaged", and "GlobalProvisionedManaged".
  skuName string
  // Provisioned capacity for the deployment (throughput units for Standard SKUs, PTUs for provisioned SKUs)
  skuCapacity int
  // Currently active capacity, which may differ from skuCapacity shortly after a capacity change
  currentCapacity int
  // Model family format (e.g., "OpenAI")
  modelFormat string
  // Model name being served (e.g., "gpt-4o", "text-embedding-3-large", "dall-e-3")
  modelName string
  // Model version being served (e.g., "2024-11-20"); empty when the account uses the model's default version
  modelVersion string
  // Model publisher; empty for first-party Azure OpenAI models
  modelPublisher string
  // ARM resource ID of the source model for fine-tuned or custom deployments; empty for catalog models
  modelSource string
  // Version upgrade behavior
  //
  // One of "NoAutoUpgrade" (pinned to modelVersion), "OnceCurrentVersionExpired" (upgrades only when the version retires), or "OnceNewDefaultVersionAvailable" (auto-upgrades to each new default).
  versionUpgradeOption string
  // Whether dynamic throttling is enabled, letting the service smooth bursts above the provisioned rate
  dynamicThrottlingEnabled bool
  // Advertised model capabilities, keyed by capability name (e.g., "chatCompletion", "jsonObjectResponse")
  capabilities map[string]string
  // Name of the Responsible AI content-filter policy applied to the deployment; empty when none is attached
  raiPolicyName string
  // Responsible AI content-filter policy applied to the deployment (null when none is attached)
  raiPolicy() azure.subscription.cognitiveServicesService.account.raiPolicy
}

// Azure AI Foundry project
//
// Examine a single Azure AI Foundry project — a workspace under an AI
// Services account that scopes agents, deployments, and connections for
// a team or application, selected by `name`. Use `isDefault` to identify
// the account's default project, `displayName` and `description` for the
// human-facing labels, `endpoints` for the project's data-plane URLs,
// and `connections` for the project-scoped links to model providers,
// data sources, and tool (MCP) servers an agent can reach.
azure.subscription.cognitiveServicesService.account.project @defaults("name displayName isDefault provisioningState") {
  // Project resource ID
  id string
  // Project name, used as the selection key
  name string
  // Project location
  location string
  // Project tags
  tags map[string]string
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Human-facing display name of the project
  displayName string
  // Project description
  description string
  // Whether this is the account's default project
  isDefault bool
  // Provisioning state of the project (e.g., "Succeeded", "Creating", "Failed")
  provisioningState string
  // Data-plane endpoint URLs for the project, keyed by endpoint name
  endpoints map[string]string
  // Project-scoped connections to external resources, model providers, data sources, and tool servers
  connections() []azure.subscription.cognitiveServicesService.account.project.connection
}

// Connection on an Azure AI Foundry project
//
// Examine a single project-scoped connection — the link an agent or
// application uses to reach an external resource, identified by `name`.
// Use `category` to see what the connection points to (for example
// "AzureOpenAI", "CognitiveSearch", "Serverless", "ManagedOnlineEndpoint",
// or "CustomKeys" — the category used for Model Context Protocol tool
// servers), `target` for the endpoint URL, `authType` for how the
// connection authenticates, `isSharedToAll` for whether every member can
// use it, `useWorkspaceManagedIdentity` for managed-identity access,
// `peRequirement`/`peStatus` for private-endpoint posture, and `metadata`
// for connection-specific settings (an MCP connection records its server
// label and URL here).
private azure.subscription.cognitiveServicesService.account.project.connection @defaults("name category authType target") {
  // Connection resource ID
  id string
  // Connection name, used as the selection key
  name string
  // What the connection points to
  //
  // Examples include "AzureOpenAI", "OpenAI", "Serverless", "ManagedOnlineEndpoint", "CognitiveSearch", "CognitiveService", "ApiKey", and "CustomKeys" (the category used for Model Context Protocol tool servers).
  category string
  // Authentication type
  //
  // One of "AAD", "ApiKey", "AccessKey", "AccountKey", "CustomKeys", "ManagedIdentity", "None", "OAuth2", "PAT", "SAS", "ServicePrincipal", or "UsernamePassword".
  authType string
  // Endpoint URL the connection targets
  target string
  // Connection grouping by category ("Azure", "AzureAI", "Database", "File", "GenericProtocol", "NoSQL", or "ServicesAndApps")
  group string
  // Whether the connection is shared with every member of the project
  isSharedToAll bool
  // Whether the connection authenticates using the workspace managed identity
  useWorkspaceManagedIdentity bool
  // Private-endpoint requirement ("Required", "NotRequired", or "NotApplicable")
  peRequirement string
  // Private-endpoint status ("Active", "Inactive", or "NotApplicable")
  peStatus string
  // Connection-specific metadata; for MCP connections this carries the server label and URL
  metadata map[string]string
  // Error message when the connection is in a failed state; empty when healthy
  error string
  // When the connection's credentials expire (null when they do not expire)
  expiryTime time
}

// Connection on an Azure AI Services account
//
// Examine a single account-scoped connection — the link, shared across
// the account's projects, used to reach an external resource, identified
// by `name`. Use `category` to see what the connection points to (for
// example "AzureOpenAI", "CognitiveSearch", "Serverless",
// "ManagedOnlineEndpoint", or "CustomKeys" — the category used for Model
// Context Protocol tool servers), `target` for the endpoint URL,
// `authType` for how the connection authenticates, `isSharedToAll` for
// whether every member can use it, `useWorkspaceManagedIdentity` for
// managed-identity access, `peRequirement`/`peStatus` for private-endpoint
// posture, and `metadata` for connection-specific settings (an MCP
// connection records its server label and URL here).
private azure.subscription.cognitiveServicesService.account.connection @defaults("name category authType target") {
  // Connection resource ID
  id string
  // Connection name, used as the selection key
  name string
  // What the connection points to
  //
  // Examples include "AzureOpenAI", "OpenAI", "Serverless", "ManagedOnlineEndpoint", "CognitiveSearch", "CognitiveService", "ApiKey", and "CustomKeys" (the category used for Model Context Protocol tool servers).
  category string
  // Authentication type
  //
  // One of "AAD", "ApiKey", "AccessKey", "AccountKey", "CustomKeys", "ManagedIdentity", "None", "OAuth2", "PAT", "SAS", "ServicePrincipal", or "UsernamePassword".
  authType string
  // Endpoint URL the connection targets
  target string
  // Connection grouping by category ("Azure", "AzureAI", "Database", "File", "GenericProtocol", "NoSQL", or "ServicesAndApps")
  group string
  // Whether the connection is shared with every member of the account
  isSharedToAll bool
  // Whether the connection authenticates using the workspace managed identity
  useWorkspaceManagedIdentity bool
  // Private-endpoint requirement ("Required", "NotRequired", or "NotApplicable")
  peRequirement string
  // Private-endpoint status ("Active", "Inactive", or "NotApplicable")
  peStatus string
  // Connection-specific metadata; for MCP connections this carries the server label and URL
  metadata map[string]string
  // Error message when the connection is in a failed state; empty when healthy
  error string
  // When the connection's credentials expire (null when they do not expire)
  expiryTime time
}

// Responsible AI content-filter policy on a Cognitive Services account
//
// Examine the policy mode, the content filters it enforces (per category
// and source), the custom blocklists it references, and the custom RAI
// topics it applies. Use this to audit which accounts have content
// filtering active, whether filters block or only warn, and at what
// severity threshold each category trips.
private azure.subscription.cognitiveServicesService.account.raiPolicy @defaults("name mode policyType") {
  // ARM resource ID
  id string
  // Policy name
  name string
  // Filter mode: "Default", "Deferred", "Blocking", or "Asynchronous_filter"
  mode string
  // Policy type: "UserManaged" or "SystemManaged"
  policyType string
  // Base policy this one inherits from; empty when not inheriting
  basePolicyName string
  // Content filters configured on the policy, one per (category × source)
  contentFilters []azure.subscription.cognitiveServicesService.account.raiPolicy.contentFilter
  // Custom blocklist references. Each entry has {blocklistName, source, blocking}.
  customBlocklists []dict
  // Custom RAI topic references attached to the policy
  customTopics []azure.subscription.cognitiveServicesService.account.raiPolicy.topicRef
}

// Content filter on a Responsible AI policy
//
// Examine a single content-filter rule keyed by content category and
// source. Rules describe which severity threshold trips the filter,
// whether the filter is active, and whether matches block the request
// or only flag it. Audit queries typically scope by (name, source) to
// confirm coverage of sensitive categories.
private azure.subscription.cognitiveServicesService.account.raiPolicy.contentFilter @defaults("name source enabled blocking severityThreshold") {
  // Content category name (e.g., "Hate", "Sexual", "Violence", "Selfharm", "Jailbreak", "ProtectedMaterialText", "ProtectedMaterialCode")
  name string
  // Where the filter applies: "Prompt" (user input) or "Completion" (model output)
  source string
  // Whether the filter is enabled
  enabled bool
  // Whether matches block the request; when false, matches are only flagged
  blocking bool
  // Severity level at which the filter trips ("Low", "Medium", or "High"); empty when not set
  severityThreshold string
}

// Custom RAI topic reference on a Responsible AI policy
//
// Examine the link between a policy and a custom topic registered on
// the same account. Carries the per-attachment scalars (source the
// topic applies to, whether matches block) and resolves to the
// underlying [[azure.subscription.cognitiveServicesService.account.raiTopic]].
private azure.subscription.cognitiveServicesService.account.raiPolicy.topicRef @defaults("topicName source blocking") {
  // Name of the custom topic
  topicName string
  // Where the topic filter applies: "Prompt" or "Completion"
  source string
  // Whether matches block the request
  blocking bool
  // The referenced custom topic on the account
  topic() azure.subscription.cognitiveServicesService.account.raiTopic
}

// Responsible AI custom topic on a Cognitive Services account
//
// Examine a custom RAI topic and its lifecycle: status, sample data
// location, creation/last-modified times, and a failure reason when the
// topic has failed to train. Topics referenced by an [[azure.subscription.cognitiveServicesService.account.raiPolicy]]
// add custom blocked-content detection beyond the built-in categories.
private azure.subscription.cognitiveServicesService.account.raiTopic @defaults("name status topicName") {
  // ARM resource ID
  id string
  // Resource name
  name string
  // Custom topic name (the policy-facing identifier)
  topicName string
  // Stable identifier of the custom topic
  topicId string
  // Description of the custom topic
  description string
  // Lifecycle status of the topic (e.g., "Succeeded", "Failed", "Running")
  status string
  // Reason the topic is in a failed state; empty when not failed
  failedReason string
  // URL of the sample blob used to train the topic
  sampleBlobUrl string
  // When the topic was created
  createdAt time
  // When the topic was last modified
  lastModifiedAt time
}

// Microsoft Sentinel
//
// Examine Microsoft Sentinel onboarding and analytics surface in a
// subscription. Sentinel is layered on a Log Analytics workspace via
// the SecurityInsights solution; a Log Analytics workspace appears
// under `workspaces` only when Sentinel has been onboarded on it. Use
// this to audit which subscriptions have Sentinel coverage, which
// analytics rules are active, and which data connectors are ingesting
// telemetry.
private azure.subscription.sentinelService @defaults("subscriptionId") {
  // ID of the subscription
  subscriptionId string
  // Sentinel-onboarded Log Analytics workspaces in the subscription
  workspaces() []azure.subscription.sentinelService.workspace
}

// Microsoft Sentinel onboarded Log Analytics workspace
//
// Examine a Log Analytics workspace that has Sentinel enabled.
// Surfaces the workspace identity plus the analytics rules and data
// connectors configured on it. The underlying Log Analytics workspace
// is reachable via `workspace()` for retention, network, and access
// settings.
private azure.subscription.sentinelService.workspace @defaults("name resourceGroup subscriptionId") {
  // ARM resource ID of the underlying Log Analytics workspace
  id string
  // Workspace name
  name string
  // Resource group containing the workspace
  resourceGroup string
  // Subscription that owns the workspace
  subscriptionId string
  // The underlying Log Analytics workspace
  workspace() azure.subscription.monitorService.workspace
  // Sentinel analytics rules configured on the workspace
  alertRules() []azure.subscription.sentinelService.alertRule
  // Data connectors ingesting telemetry into the workspace
  //
  // Each entry is a kind-specific dict with `name`, `kind`, and `properties` describing the connector configuration. Kinds include `OfficeATP`, `AzureActiveDirectory`, `AzureSecurityCenter`, `MicrosoftDefenderAdvancedThreatProtection`, and many others.
  dataConnectors() []dict
}

// Microsoft Sentinel analytics rule
//
// Examine a single Sentinel analytics rule. Rules detect threats by
// running KQL queries on workspace data (Scheduled), correlating
// alerts across data sources (Fusion), or forwarding alerts from
// other Microsoft security products (MicrosoftSecurityIncidentCreation).
// Use `kind` to filter by rule type and `enabled` to identify active
// detection coverage. Kind-specific configuration (KQL query, trigger
// thresholds, source product filters) is in `properties`.
private azure.subscription.sentinelService.alertRule @defaults("name kind enabled severity displayName") {
  // ARM resource ID
  id string
  // Rule name
  name string
  // Rule kind ("Scheduled", "Fusion", "MicrosoftSecurityIncidentCreation", "MLBehaviorAnalytics", "NRT", "ThreatIntelligence")
  kind string
  // Whether the rule is enabled
  enabled bool
  // Display name shown on alerts created by this rule
  displayName string
  // Severity assigned to alerts created by this rule ("Informational", "Low", "Medium", "High"); empty when the kind has no severity
  severity string
  // MITRE ATT&CK tactics the rule maps to (e.g., "Persistence", "PrivilegeEscalation", "Exfiltration")
  tactics []string
  // Description of the rule
  description string
  // Kind-specific properties (e.g., for Scheduled rules: query, queryFrequency, queryPeriod, triggerThreshold)
  properties dict
}

// Azure SignalR Service
//
// Use this namespace to iterate the Azure SignalR Service instances in
// the subscription. SignalR provides real-time messaging (WebSockets)
// for applications; each instance is reached through `instances()`.
private azure.subscription.signalRService {
  // Subscription identifier
  subscriptionId string
  // Azure SignalR Service instances in the subscription
  instances() []azure.subscription.signalRService.signalR
}

// Azure SignalR Service instance
//
// Examine a single Azure SignalR Service instance. Use
// `publicNetworkAccess` to confirm whether the instance is reachable
// from the public internet, `disableLocalAuth` and `disableAadAuth` for
// the enabled authentication methods, `clientCertEnabled` for whether
// mutual TLS client certificates are required, and
// `networkAclsDefaultAction` for the default network rule applied when
// no ACL matches.
azure.subscription.signalRService.signalR @defaults("id name location publicNetworkAccess") {
  // SignalR resource ID
  id string
  // SignalR resource name
  name string
  // SignalR resource location
  location string
  // SignalR resource tags
  tags map[string]string
  // Service mode kind ("SignalR" or "RawWebSockets")
  kind string
  // SKU details (name, tier, capacity)
  sku dict
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Public hostname clients connect to
  hostName string
  // External IP of the instance
  externalIp string
  // Service software version
  version string
  // Whether the instance is reachable from the public internet ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Whether access-key (local) authentication is disabled
  disableLocalAuth bool
  // Whether Microsoft Entra ID (AAD) authentication is disabled
  disableAadAuth bool
  // Whether mutual TLS client certificate authentication is required
  clientCertEnabled bool
  // Default action applied when no network ACL matches ("Allow" or "Deny")
  networkAclsDefaultAction string
  // Provisioning state
  provisioningState string
}

// Azure Web PubSub Service
//
// Use this namespace to iterate the Azure Web PubSub Service instances
// in the subscription. Web PubSub provides real-time publish/subscribe
// messaging over WebSockets; each instance is reached through
// `instances()`.
private azure.subscription.webPubSubService {
  // Subscription identifier
  subscriptionId string
  // Azure Web PubSub Service instances in the subscription
  instances() []azure.subscription.webPubSubService.webPubSub
}

// Azure Web PubSub Service instance
//
// Examine a single Azure Web PubSub Service instance. Use
// `publicNetworkAccess` to confirm whether the instance is reachable
// from the public internet, `disableLocalAuth` and `disableAadAuth` for
// the enabled authentication methods, `clientCertEnabled` for whether
// mutual TLS client certificates are required, and
// `networkAclsDefaultAction` for the default network rule applied when
// no ACL matches.
azure.subscription.webPubSubService.webPubSub @defaults("id name location publicNetworkAccess") {
  // Web PubSub resource ID
  id string
  // Web PubSub resource name
  name string
  // Web PubSub resource location
  location string
  // Web PubSub resource tags
  tags map[string]string
  // Service kind ("WebPubSub" or "SocketIO")
  kind string
  // SKU details (name, tier, capacity)
  sku dict
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Public hostname clients connect to
  hostName string
  // External IP of the instance
  externalIp string
  // Service software version
  version string
  // Whether the instance is reachable from the public internet ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Whether access-key (local) authentication is disabled
  disableLocalAuth bool
  // Whether Microsoft Entra ID (AAD) authentication is disabled
  disableAadAuth bool
  // Whether mutual TLS client certificate authentication is required
  clientCertEnabled bool
  // Default action applied when no network ACL matches ("Allow" or "Deny")
  networkAclsDefaultAction string
  // Provisioning state
  provisioningState string
}

// Azure Data Explorer (Kusto)
//
// Use this namespace to iterate the Azure Data Explorer clusters in the
// subscription. Each cluster is reached through `clusters()`.
private azure.subscription.kustoService {
  // Subscription identifier
  subscriptionId string
  // Azure Data Explorer clusters in the subscription
  clusters() []azure.subscription.kustoService.cluster
}

// Azure Data Explorer cluster
//
// Examine a single Azure Data Explorer (Kusto) cluster. Use
// `publicNetworkAccess` and `publicIpType` to confirm internet exposure,
// `restrictOutboundNetworkAccess` for data-exfiltration control,
// `allowedIpRangeList`/`allowedFqdnList` for the inbound/outbound
// allow-lists, `enableDiskEncryption` and `enableDoubleEncryption` for
// encryption at rest, `cmkKeyName`/`cmkKeyVaultUri` for the
// customer-managed key, `trustedExternalTenants` for which external
// Microsoft Entra tenants may authenticate, and `enablePurge` for
// whether hard-delete is allowed.
azure.subscription.kustoService.cluster @defaults("id name location publicNetworkAccess state") {
  // Cluster resource ID
  id string
  // Cluster name
  name string
  // Cluster location
  location string
  // Cluster tags
  tags map[string]string
  // SKU details (name, tier, capacity)
  sku dict
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Cluster query endpoint URI
  uri string
  // Cluster data ingestion URI
  dataIngestionUri string
  // Cluster lifecycle state (e.g., "Running", "Stopped", "Starting")
  state string
  // Provisioning state
  provisioningState string
  // Whether the cluster is reachable from the public internet ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Public IP exposure type ("IPv4" or "DualStack")
  publicIpType string
  // Whether outbound network access is restricted ("Enabled" or "Disabled")
  restrictOutboundNetworkAccess string
  // Whether disk encryption is enabled on the cluster
  enableDiskEncryption bool
  // Whether infrastructure (double) encryption is enabled
  enableDoubleEncryption bool
  // Whether streaming ingestion is enabled
  enableStreamingIngest bool
  // Whether hard-delete (purge) of data is permitted
  enablePurge bool
  // Inbound IP/CIDR allow-list applied to the cluster
  allowedIpRangeList []string
  // Outbound FQDN allow-list applied to the cluster
  allowedFqdnList []string
  // External Microsoft Entra tenant IDs trusted to authenticate to the cluster
  trustedExternalTenants []string
  // Name of the customer-managed Key Vault key encrypting the cluster; empty for platform-managed keys
  cmkKeyName string
  // Key Vault URI holding the customer-managed encryption key
  cmkKeyVaultUri string
  // Version of the customer-managed encryption key; empty means the latest version is used
  cmkKeyVersion string
  // Databases hosted on the cluster
  databases() []azure.subscription.kustoService.cluster.database
  // Microsoft Entra principals granted cluster-wide access
  principalAssignments() []azure.subscription.kustoService.cluster.principalAssignment
  // Outbound callout policies governing which external endpoints the cluster may reach
  calloutPolicies() []azure.subscription.kustoService.cluster.calloutPolicy
  // Private endpoint connections terminating on the cluster
  privateEndpointConnections() []azure.subscription.kustoService.cluster.privateEndpointConnection
  // Managed private endpoints created by the cluster toward other Azure services
  managedPrivateEndpoints() []azure.subscription.kustoService.cluster.managedPrivateEndpoint
}

// Azure Data Explorer database
//
// Examine a single database hosted on an Azure Data Explorer cluster. Use
// `kind` to distinguish a read-write database from a read-only follower,
// `hotCachePeriod` and `softDeletePeriod` for the cache and retention
// windows, `cmkKeyName`/`cmkKeyVaultUri` for a database-scoped
// customer-managed encryption key, and `leaderClusterResourceId` with
// `originalDatabaseName` to trace a follower back to its source. Iterate
// `principalAssignments` to audit who can read or administer the database
// and `dataConnections` to see which external sources feed ingestion.
azure.subscription.kustoService.cluster.database @defaults("name kind hotCachePeriod softDeletePeriod") {
  // Database resource ID
  id string
  // Database name
  name string
  // Database location
  location string
  // Database kind, either "ReadWrite" or "ReadOnlyFollowing"
  kind string
  // Hot-cache retention window as an ISO 8601 duration; data within it stays on local SSD for fast queries
  hotCachePeriod string
  // Soft-delete retention window as an ISO 8601 duration for which data remains queryable and recoverable
  softDeletePeriod string
  // Provisioning state
  provisioningState string
  // Name of the customer-managed Key Vault key encrypting the database; empty for cluster- or platform-managed keys
  cmkKeyName string
  // Key Vault URI holding the database's customer-managed encryption key
  cmkKeyVaultUri string
  // Version of the database's customer-managed encryption key; empty means the latest version is used
  cmkKeyVersion string
  // For a read-only following database, the resource ID of the leader cluster sharing the data
  leaderClusterResourceId string
  // For a read-only following database, the database name as it exists on the leader cluster
  originalDatabaseName string
  // For a read-only following database, the leader cluster sharing the data
  leaderCluster() azure.subscription.kustoService.cluster
  // Microsoft Entra principals granted access to the database
  principalAssignments() []azure.subscription.kustoService.cluster.database.principalAssignment
  // Ingestion data connections feeding the database
  dataConnections() []azure.subscription.kustoService.cluster.database.dataConnection
}

// Azure Data Explorer cluster principal assignment
//
// Examine a Microsoft Entra principal granted cluster-wide access to an
// Azure Data Explorer cluster. Use `role` to see the level of access
// (`AllDatabasesAdmin`, `AllDatabasesViewer`, or `AllDatabasesMonitor`),
// `principalType` for whether the principal is an `App`, `Group`, or
// `User`, and `principalId`/`principalName` to identify it.
private azure.subscription.kustoService.cluster.principalAssignment @defaults("principalName role principalType") {
  // Assignment resource ID
  id string
  // Assignment name
  name string
  // Microsoft Entra object ID of the assigned principal
  principalId string
  // Display name of the assigned principal
  principalName string
  // Principal category, one of "App", "Group", or "User"
  principalType string
  // Cluster-wide role granted, one of "AllDatabasesAdmin", "AllDatabasesViewer", or "AllDatabasesMonitor"
  role string
  // Microsoft Entra tenant ID of the principal
  tenantId string
  // Provisioning state of the assignment
  provisioningState string
}

// Azure Data Explorer database principal assignment
//
// Examine a Microsoft Entra principal granted access to a single Azure
// Data Explorer database. Use `role` for the database-scoped permission
// (`Admin`, `Ingestor`, `Monitor`, `UnrestrictedViewer`, `User`, or
// `Viewer`), `principalType` for whether the principal is an `App`,
// `Group`, or `User`, and `principalId`/`principalName` to identify it.
private azure.subscription.kustoService.cluster.database.principalAssignment @defaults("principalName role principalType") {
  // Assignment resource ID
  id string
  // Assignment name
  name string
  // Microsoft Entra object ID of the assigned principal
  principalId string
  // Display name of the assigned principal
  principalName string
  // Principal category, one of "App", "Group", or "User"
  principalType string
  // Database-scoped role granted, one of "Admin", "Ingestor", "Monitor", "UnrestrictedViewer", "User", or "Viewer"
  role string
  // Microsoft Entra tenant ID of the principal
  tenantId string
  // Provisioning state of the assignment
  provisioningState string
}

// Azure Data Explorer cluster callout policy
//
// Examine an outbound callout policy that governs which external endpoints
// an Azure Data Explorer cluster may reach from queries and plugins. Use
// `calloutType` for the external service category (for example `kusto`,
// `sql`, `cosmosdb`, `azure_openai`, `webapi`, or `external_data`),
// `calloutUriRegex` for the destination pattern the policy matches, and
// `outboundAccess` for whether matching calls are allowed or denied —
// the key control for limiting data exfiltration paths.
private azure.subscription.kustoService.cluster.calloutPolicy @defaults("calloutType outboundAccess calloutUriRegex") {
  // Identifier of the callout policy
  calloutId string
  // External service category the policy governs
  //
  // One of "kusto", "sql", "cosmosdb", "azure_openai", "external_data",
  // "genevametrics", "mysql", "postgresql", "sandbox_artifacts",
  // "azure_digital_twins", or "webapi".
  calloutType string
  // Regular expression matched against the destination URI the policy applies to
  calloutUriRegex string
  // Whether matching outbound calls are allowed, one of "Allow" or "Deny"
  outboundAccess string
}

// Azure Data Explorer cluster private endpoint connection
//
// Examine a private endpoint connection terminating on an Azure Data
// Explorer cluster. Use `status` for the approval state (`Approved`,
// `Pending`, or `Rejected`), `groupId` for the targeted sub-resource, and
// `privateEndpointId` for the resource ID of the connecting private
// endpoint.
private azure.subscription.kustoService.cluster.privateEndpointConnection @defaults("name status groupId") {
  // Connection resource ID
  id string
  // Connection name
  name string
  // Sub-resource (group ID) the private endpoint targets on the cluster
  groupId string
  // Connection approval status, one of "Approved", "Pending", or "Rejected"
  status string
  // Description accompanying the connection status
  statusDescription string
  // The connecting private endpoint
  privateEndpoint() azure.subscription.networkService.privateEndpoint
  // Provisioning state
  provisioningState string
}

// Azure Data Explorer cluster managed private endpoint
//
// Examine a managed private endpoint created by an Azure Data Explorer
// cluster to reach another Azure resource over a private link. Use
// `privateLinkResourceId` for the target resource, `groupId` for the
// sub-resource it connects to, and `requestMessage` for the approval
// message sent to the resource owner.
private azure.subscription.kustoService.cluster.managedPrivateEndpoint @defaults("name groupId provisioningState") {
  // Managed private endpoint resource ID
  id string
  // Managed private endpoint name
  name string
  // Sub-resource (group ID) targeted on the linked resource
  groupId string
  // Resource ID of the Azure resource the endpoint connects to
  privateLinkResourceId string
  // Region of the linked private-link resource
  privateLinkResourceRegion string
  // Request message sent to the resource owner for approval
  requestMessage string
  // Provisioning state
  provisioningState string
}

// Azure Data Explorer database data connection
//
// Examine an ingestion data connection feeding an Azure Data Explorer
// database. Use `kind` for the source type (`EventHub`, `EventGrid`,
// `IotHub`, or `CosmosDb`), `sourceResourceId` for the Azure resource
// supplying the data, `tableName`/`dataFormat`/`mappingRuleName` for the
// ingestion target and shape, and `managedIdentityResourceId` for the
// identity used to authenticate to the source.
private azure.subscription.kustoService.cluster.database.dataConnection @defaults("name kind tableName") {
  // Data connection resource ID
  id string
  // Data connection name
  name string
  // Data connection location
  location string
  // Source kind, one of "EventHub", "EventGrid", "IotHub", or "CosmosDb"
  kind string
  // Target table the connection ingests into
  tableName string
  // Ingestion data format, for example "JSON", "MULTIJSON", "CSV", or "AVRO"
  dataFormat string
  // Name of the ingestion mapping rule applied to incoming data
  mappingRuleName string
  // Event consumer group, for Event Hub, IoT Hub, and Event Grid sources
  consumerGroup string
  // How ingestion routes across databases, one of "Single" or "Multi"
  databaseRouting string
  // Resource ID of the source feeding ingestion — the Event Hub, IoT Hub, Event Grid topic, or Cosmos DB account, depending on kind
  sourceResourceId string
  // Managed identity used to authenticate to the source, if any
  managedIdentity() azure.subscription.managedIdentity
  // Provisioning state
  provisioningState string
}

// Azure Automation
//
// Use this namespace to iterate the Azure Automation accounts in the
// subscription. Each account is reached through `accounts()`.
private azure.subscription.automationService {
  // Subscription identifier
  subscriptionId string
  // Azure Automation accounts in the subscription
  accounts() []azure.subscription.automationService.account
}

// Azure Automation account
//
// Examine a single Azure Automation account. Use `publicNetworkAccess`
// to confirm internet exposure, `disableLocalAuth` for whether key-based
// authentication is disabled in favor of Microsoft Entra ID,
// `cmkKeySource`/`cmkKeyName` for customer-managed-key encryption, and
// iterate `variables`, `credentials`, and `certificates` to audit the
// secrets the account stores (for example unencrypted variables, or
// expiring or exportable certificates).
azure.subscription.automationService.account @defaults("id name location publicNetworkAccess") {
  // Account resource ID
  id string
  // Account name
  name string
  // Account location
  location string
  // Account tags
  tags map[string]string
  // SKU details (name)
  sku dict
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Account lifecycle state ("Ok", "Unavailable", "Suspended")
  state string
  // Whether the account is reachable from the public internet
  publicNetworkAccess bool
  // Whether key-based (local) authentication is disabled
  disableLocalAuth bool
  // Encryption key source ("Microsoft.Keyvault" for customer-managed keys; "Microsoft.Automation" for platform-managed)
  cmkKeySource string
  // Name of the customer-managed Key Vault key encrypting the account; empty for platform-managed keys
  cmkKeyName string
  // Key Vault URI holding the customer-managed encryption key
  cmkKeyVaultUri string
  // When the account was created
  creationTime time
  // When the account was last modified
  lastModifiedTime time
  // Variables stored in the account
  variables() []azure.subscription.automationService.account.variable
  // Credentials stored in the account
  credentials() []azure.subscription.automationService.account.credential
  // Certificates stored in the account
  certificates() []azure.subscription.automationService.account.certificate
}

// Azure Automation account variable
private azure.subscription.automationService.account.variable @defaults("name isEncrypted") {
  // Variable resource ID
  id string
  // Variable name
  name string
  // Whether the variable value is stored encrypted; a false result means the value is readable in plaintext
  isEncrypted bool
  // Variable description
  description string
  // When the variable was created
  creationTime time
  // When the variable was last modified
  lastModifiedTime time
}

// Azure Automation account credential
private azure.subscription.automationService.account.credential @defaults("name userName") {
  // Credential resource ID
  id string
  // Credential name
  name string
  // User name stored by the credential
  userName string
  // Credential description
  description string
  // When the credential was created
  creationTime time
  // When the credential was last modified
  lastModifiedTime time
}

// Azure Automation account certificate
private azure.subscription.automationService.account.certificate @defaults("name expiryTime isExportable") {
  // Certificate resource ID
  id string
  // Certificate name
  name string
  // Certificate thumbprint
  thumbprint string
  // When the certificate expires
  expiryTime time
  // Whether the certificate's private key can be exported
  isExportable bool
  // Certificate description
  description string
  // When the certificate was created
  creationTime time
}

// Azure Virtual Desktop
//
// Use this namespace to iterate the Azure Virtual Desktop host pools in
// the subscription. Each host pool is reached through `hostPools()`.
private azure.subscription.desktopVirtualizationService {
  // Subscription identifier
  subscriptionId string
  // Azure Virtual Desktop host pools in the subscription
  hostPools() []azure.subscription.desktopVirtualizationService.hostPool
}

// Azure Virtual Desktop host pool
//
// Examine a single Azure Virtual Desktop host pool. Use
// `customRdpProperty` to audit the RDP session settings (clipboard,
// drive, and device redirection), `validationEnvironment` for whether
// the pool receives pre-release agent updates, `startVMOnConnect` and
// `maxSessionLimit` for session behavior, `loadBalancerType` and
// `hostPoolType` for the pool model, and `ssoadfsAuthority` for the
// single-sign-on configuration.
azure.subscription.desktopVirtualizationService.hostPool @defaults("id name location hostPoolType") {
  // Host pool resource ID
  id string
  // Host pool name
  name string
  // Host pool location
  location string
  // Host pool tags
  tags map[string]string
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Host pool type ("Personal", "Pooled", or "BYODesktop")
  hostPoolType string
  // Load-balancing algorithm ("BreadthFirst", "DepthFirst", or "Persistent")
  loadBalancerType string
  // Preferred application group type ("Desktop", "RailApplications", or "None")
  preferredAppGroupType string
  // Raw custom RDP property string applied to sessions (redirection and device-access settings)
  customRdpProperty string
  // Maximum number of concurrent sessions allowed per session host
  maxSessionLimit int
  // Assignment model for personal host pools ("Automatic" or "Direct")
  personalDesktopAssignmentType string
  // Whether session-host VMs are started automatically when a user connects
  startVMOnConnect bool
  // Whether the host pool is a validation environment receiving pre-release agent updates
  validationEnvironment bool
  // AD FS authority URL used for single sign-on, if configured
  ssoadfsAuthority string
  // Update ring the host pool belongs to
  ring int
  // Whether the host pool is reachable from the public internet ("Enabled", "Disabled", "EnabledForSessionHostsOnly", or "EnabledForClientsOnly")
  publicNetworkAccess string
  // How the single-sign-on secret is stored ("SharedKey", "Certificate", "SharedKeyInKeyVault", or "CertificateInKeyVault")
  ssoSecretType string
  // Number of approved private endpoint connections to the host pool
  privateEndpointConnectionCount int
}

option provider = "go.mondoo.com/cnquery/v9/providers/azure"
option go_package = "go.mondoo.com/mql/v13/providers/azure/resources"

// Azure resource
azure {
}

// Azure subscription
azure.subscription @defaults ("name") {
  // Full resource identifier of the subscription
  id string
  // Name of the subscription
  name string
  // Subscription identifier
  subscriptionId string
  // Subscription tenant identifier
  tenantId string
  // List of tenants that manage the subscription
  managedByTenants []string
  // Subscription tags
  tags map[string]string
  // Subscription state
  state string
  // Subscription authorization source
  authorizationSource string
  // Subscription policies
  subscriptionsPolicies dict
  // All resources in a subscription
  resources() []azure.subscription.resource
  // Resource groups in the subscription
  resourceGroups() []azure.subscription.resourcegroup
  // Compute resources in the subscription
  compute() azure.subscription.computeService
  // Batch resources in the subscription
  batch() azure.subscription.batchService
  // Databricks resources in the subscription
  databricks() azure.subscription.databricksService
  // Network resources in the subscription
  network() azure.subscription.networkService
  // Storage resources in the subscription
  storage() azure.subscription.storageService
  // Web resources in the subscription
  web() azure.subscription.webService
  // SQL resources in the subscription
  sql() azure.subscription.sqlService
  // MySQL resources inside the subscription
  mySql() azure.subscription.mySqlService
  // PostgreSQL resources in the subscription
  postgreSql() azure.subscription.postgreSqlService
  // Cosmos DB resources in the subscription
  cosmosDb() azure.subscription.cosmosDbService
  // Azure Key Vault resources in the subscription
  keyVault() azure.subscription.keyVaultService
  // Authorization resources in the subscription
  iam() azure.subscription.authorizationService
  // Monitor resources in the subscription
  monitor() azure.subscription.monitorService
  // Cloud defender resources in the subscription
  cloudDefender() azure.subscription.cloudDefenderService
  // AKS resources in the subscription
  aks() azure.subscription.aksService
  // Advisor resources in the subscription
  advisor() azure.subscription.advisorService
  // Policy service in the subscription
  policy azure.subscription.policy
  // IoT resources in the subscription
  iot() azure.subscription.iotService
  // Cache resources in the subscription
  cache() azure.subscription.cacheService
  // Data Factory resources in the subscription
  dataFactory() azure.subscription.dataFactoryService
  // Synapse Analytics resources in the subscription
  synapse() azure.subscription.synapseService
  // Container Registry resources in the subscription
  containerRegistry() azure.subscription.containerRegistryService
  // Recovery Services resources in the subscription
  recoveryServices() azure.subscription.recoveryServicesService
  // Azure Functions resources in the subscription
  functions() azure.subscription.functionsService
  // Service Bus resources in the subscription
  serviceBus() azure.subscription.serviceBusService
  // Event Hubs resources in the subscription
  eventHub() azure.subscription.eventHubService
  // DNS resources in the subscription
  dns() azure.subscription.dnsService
  // Front Door and CDN resources in the subscription
  frontDoor() azure.subscription.frontDoorService
  // Azure Container Apps resources in the subscription
  containerApp() azure.subscription.containerAppService
  // Azure Container Instances resources in the subscription
  containerInstance() azure.subscription.containerInstanceService
  // Logic Apps resources in the subscription
  logic() azure.subscription.logicService
}

// Azure function
private azure.subscription.webService.function @defaults("name type") {
  // ID of the function
  id string
  // Name of the function
  name string
  // Type of function
  type string
  // Kind of function
  kind string
  // Properties for the function
  properties dict
}

// Azure resource group
private azure.subscription.resourcegroup @defaults("name location") {
  // Resource group ID
  id string
  // Resource group name
  name string
  // Resource group location
  location string
  // Resource group tags
  tags map[string]string
  // Resource group type
  type string
  // ID of the resource that manages this resource group
  managedBy string
  // Resource group provisioning state
  provisioningState string
}

// Azure resource
private azure.subscription.resource @defaults("id name location") {
  // Resource ID
  id string
  // Resource name
  name string
  // Resource kind
  kind string
  // Resource location
  location string
  // Resource tags
  tags map[string]string
  // Resource type
  type string
  // ID of the resource that manages this resource
  managedBy string
  // Resource SKU
  sku dict
  // Resource plan
  plan dict
  // Resource identity
  identity dict
  // Resource provisioning state
  provisioningState string
  // When the resource was created
  createdTime time
  // When the resource was last changed
  changedTime time
}

// Azure Compute
private azure.subscription.computeService {
  // Subscription identifier
  subscriptionId string
  // All compute instances under a subscription
  vms() []azure.subscription.computeService.vm
  // All the disks under a subscription
  disks() []azure.subscription.computeService.disk
  // All disk encryption sets under a subscription
  diskEncryptionSets() []azure.subscription.computeService.diskEncryptionSet
  // All disk access resources under a subscription
  diskAccesses() []azure.subscription.computeService.diskAccess
  // All managed disk snapshots under a subscription
  snapshots() []azure.subscription.computeService.snapshot
  // All Virtual Machine Scale Sets under a subscription
  vmScaleSets() []azure.subscription.computeService.vmScaleSet
  // All dedicated host groups under a subscription
  dedicatedHostGroups() []azure.subscription.computeService.dedicatedHostGroup
  // All proximity placement groups under a subscription
  proximityPlacementGroups() []azure.subscription.computeService.proximityPlacementGroup
  // All managed images under a subscription
  images() []azure.subscription.computeService.image
  // All Compute Galleries (Shared Image Galleries) under a subscription
  galleries() []azure.subscription.computeService.gallery
  // All Azure Arc-enabled servers (Microsoft.HybridCompute/machines) under a subscription
  hybridMachines() []azure.subscription.computeService.hybridMachine
}

// Azure Compute virtual machine
azure.subscription.computeService.vm @defaults("name location properties.hardwareProfile.vmSize properties.storageProfile.osDisk.osType") {
  // VM ID
  id string
  // VM name
  name string
  // VM location
  location string
  // VM zones
  zones []string
  // VM state
  state() string
  // Whether the VM is running
  isRunning() bool
  // VM tags
  tags map[string]string
  // VM type
  type string
  // VM properties
  properties dict
  // VM extension
  extensions() []dict
  // VM compute disk
  osDisk() azure.subscription.computeService.disk
  // VM compute data disk
  dataDisks() []azure.subscription.computeService.disk
  // VM network interfaces (NICs) attached via the VM's networkProfile
  networkInterfaces() []azure.subscription.networkService.interface
  // VM public IP addresses
  publicIpAddresses() []azure.subscription.networkService.ipAddress
  // Whether encryption at host is enabled for all VM disks
  encryptionAtHost bool
  // Security type of the VM ("ConfidentialVM" or "TrustedLaunch")
  securityType string
  // Whether UEFI Secure Boot is enabled
  secureBootEnabled bool
  // Whether virtual Trusted Platform Module (vTPM) is enabled
  vtpmEnabled bool
  // Whether ProxyAgent is enabled on the VM
  proxyAgentEnabled bool
  // ProxyAgent execution mode ("Audit", "Enforce")
  proxyAgentMode string
  // Whether to implicitly install the ProxyAgent extension (Linux only)
  proxyAgentAddExtension bool
  // Whether FIPS 140-3 compliant cryptography is enabled for extension protectedSettings
  fipsEncryptionEnabled bool
  // Resiliency profile (zone movement configuration)
  resiliencyProfile dict
  // Scheduled-events policy (UserInitiatedReboot, UserInitiatedRedeploy, additional publishing targets)
  scheduledEventsPolicy dict
  // Azure Resource Manager system metadata (createdBy, createdAt, lastModifiedBy)
  systemData dict
  // VM computer name (OS hostname)
  computerName string
  // VM admin username
  adminUsername string
  // Azure Hybrid Benefit license type. Null if using standard Azure licensing. Possible values: "Windows_Client", "Windows_Server", "RHEL_BYOS", "SLES_BYOS"
  licenseType string
  // ID of the resource that manages this VM (e.g. VMSS ARM resource ID)
  managedBy string
  // Unique 128-bit VM identifier
  vmId string
  // Provisioning state of the VM (e.g. Succeeded, Failed, Creating, Updating, Deleting)
  provisioningState string
  // When the VM was created
  timeCreated time
  // SSH public keys configured on the Linux VM (key path + key data); empty for Windows or password-auth VMs
  sshPublicKeys []dict
  // Whether password authentication is disabled for SSH on the Linux VM
  disablePasswordAuthentication bool
  // Whether the VM agent is provisioned (Linux/Windows)
  provisionVMAgent bool
  // Whether automatic OS upgrades by the platform are enabled (WindowsConfiguration.EnableAutomaticUpdates)
  enableAutomaticUpdates bool
  // Patch mode for the OS ("Manual", "AutomaticByOS", "AutomaticByPlatform", "ImageDefault")
  patchMode string
  // Virtual Machine Scale Set that manages this VM, if any (resolved from managedBy)
  vmScaleSet() azure.subscription.computeService.vmScaleSet
}

// Azure Arc-enabled server (Microsoft.HybridCompute/machines)
azure.subscription.computeService.hybridMachine @defaults("name location osName osVersion status") {
  // ARM resource ID
  id string
  // Machine name (Azure resource name)
  name string
  // Location
  location string
  // Tags
  tags map[string]string
  // ARM resource type (Microsoft.HybridCompute/machines)
  type string
  // Connection status of the Arc agent. Possible values: "Connected", "Disconnected", "Error", "Expired"
  status string
  // Last time the Arc agent reported in
  lastStatusChange time
  // Connected Machine agent version
  agentVersion string
  // OS name reported by the agent (e.g. "windows", "linux")
  osName string
  // OS product SKU (e.g. "Windows Server 2019 Datacenter")
  osSku string
  // OS edition (e.g. "Datacenter", "Standard")
  osEdition string
  // OS version reported by the agent
  osVersion string
  // OS type as Azure classifies it ("Windows" / "Linux")
  osType string
  // Azure-side display name for the machine
  displayName string
  // Hybrid machine FQDN
  machineFqdn string
  // DNS-resolvable FQDN
  dnsFqdn string
  // AD domain the machine is joined to (Windows only)
  domainName string
  // AD fully qualified display name
  adFqdn string
  // Hybrid machine unique ID (Arc-assigned)
  vmId string
  // Arc Machine's unique SMBIOS UUID
  vmUuid string
  // Provisioning state of the ARM resource
  provisioningState string
  // Resource ID of the parent Azure HCI cluster, if any
  parentClusterResourceId string
  // Resource ID of the private link scope this machine is assigned to, if any
  privateLinkScopeResourceId string
  // Detected agent-reported properties (azureResourceId, manufacturer, model, etc.)
  detectedProperties map[string]string
  // Detected cloud environment metadata (Azure/GCP/AWS/OCI provider, account, region) when applicable
  cloudMetadata dict
  // Windows license / ESU attestation profile
  licenseProfile dict
  // Raw HybridCompute machine properties
  properties dict
  // Azure Resource Manager system metadata (createdBy, createdAt, lastModifiedBy)
  systemData dict
  // Installed Arc machine extensions
  extensions() []azure.subscription.computeService.hybridMachine.extension
}

// Extension installed on an Azure Arc-enabled server (Microsoft.HybridCompute/machines/extensions)
private azure.subscription.computeService.hybridMachine.extension @defaults("name extensionType publisher provisioningState") {
  // ARM resource ID
  id string
  // Extension name
  name string
  // ARM resource type (Microsoft.HybridCompute/machines/extensions)
  type string
  // Geo-location
  location string
  // Resource tags
  tags map[string]string
  // Extension handler publisher (e.g. "Microsoft.Azure.Monitor")
  publisher string
  // Extension type (e.g. "AzureMonitorLinuxAgent")
  extensionType string
  // Version of the extension handler
  typeHandlerVersion string
  // Whether the extension uses a newer minor version if one is available at deployment time
  autoUpgradeMinorVersion bool
  // Whether the platform automatically upgrades the extension to a newer version
  enableAutomaticUpgrade bool
  // Provisioning state of the extension
  provisioningState string
  // Public JSON settings passed to the extension handler
  settings dict
  // Tag used to trigger a re-run of the extension handler even when settings are unchanged
  forceUpdateTag string
  // Azure Resource Manager system metadata (createdBy, createdAt, lastModifiedBy)
  systemData dict
  // Latest extension instance view reported by the handler (status code, level, display status, message)
  instanceView dict
}

// Azure compute disk resource
azure.subscription.computeService.disk @defaults("name location properties.osType properties.diskSizeGB properties.diskState") {
  // Disk resource ID
  id string
  // Disk resource name
  name string
  // Disk resource location
  location string
  // Disk resource tags
  tags map[string]string
  // Disk resource type
  type string
  // A relative URI containing the ID of the VM that has the disk attached
  managedBy string
  // List of relative URIs containing the IDs of the VMs that have the disk attached
  managedByExtended []string
  // The logical zone list for disk
  zones []string
  // The disk SKU name and tier
  sku dict
  // Disk resource properties
  properties dict
  // Disk network access policy (AllowAll, AllowPrivate, DenyAll)
  networkAccessPolicy string
  // Whether public network access is enabled for the disk
  publicNetworkAccess string
  // Disk encryption type (EncryptionAtRestWithPlatformKey, EncryptionAtRestWithCustomerKey, EncryptionAtRestWithPlatformAndCustomerKeys)
  encryptionType string
  // ID of the disk encryption set used for customer-managed key encryption
  diskEncryptionSetId string
  // Disk encryption set used for customer-managed key encryption
  diskEncryptionSet() azure.subscription.computeService.diskEncryptionSet
  // Data access authentication mode (AzureActiveDirectory, None)
  dataAccessAuthMode string
  // Current state of the disk (Unattached, Attached, Reserved, ActiveSAS, ReadyToUpload, ActiveUpload, ActiveSASFrozen)
  diskState string
  // Provisioning state of the disk
  provisioningState string
  // When the disk was created
  timeCreated time
  // Unique identifier of the disk (128-bit GUID)
  uniqueId string
  // Whether on-demand bursting is enabled for the disk
  burstingEnabled bool
  // Exact size of the disk in bytes
  diskSizeBytes int
  // Number of IOPS allowed for read/write operations
  diskIopsReadWrite int
  // Bandwidth in MB/s allowed for read/write operations
  diskMbpsReadWrite int
  // Number of IOPS allowed for read-only operations on shared disks
  diskIopsReadOnly int
  // Bandwidth in MB/s allowed for read-only operations on shared disks
  diskMbpsReadOnly int
  // Maximum number of VMs that can attach to the disk concurrently
  maxShares int
  // Hyper-V generation of the disk (V1, V2)
  hyperVGeneration string
  // Performance tier of the disk (P4, P6, P10, P15, P20, P30, P40, P50, P60, P70, P80)
  tier string
  // Whether the disk supports hibernation
  supportsHibernation bool
  // ARM ID of the DiskAccess resource for private endpoint access
  diskAccessId string
  // Behavior when the disk experiences slow I/O (AutomaticReattach)
  availabilityPolicy dict
  // Azure Resource Manager system metadata (createdBy, createdAt, lastModifiedBy)
  systemData dict
}

// Azure disk encryption set
azure.subscription.computeService.diskEncryptionSet @defaults("name location encryptionType") {
  // Disk encryption set ID
  id string
  // Disk encryption set name
  name string
  // Disk encryption set location
  location string
  // Disk encryption set tags
  tags map[string]string
  // Disk encryption set type
  type string
  // Encryption type (EncryptionAtRestWithCustomerKey, EncryptionAtRestWithPlatformAndCustomerKeys, ConfidentialVmEncryptedWithCustomerKey)
  encryptionType string
  // Active key vault key URL
  activeKeyUrl string
  // Active key source vault ID
  activeKeySourceVaultId string
  // Whether auto key rotation to latest key version is enabled
  rotationToLatestKeyVersionEnabled bool
  // Last key rotation timestamp
  lastKeyRotationTimestamp time
  // Provisioning state
  provisioningState string
  // Identity configuration
  identity dict
}

// Azure disk access resource (private endpoint for managed disks)
azure.subscription.computeService.diskAccess @defaults("name location") {
  // Disk access ID
  id string
  // Disk access name
  name string
  // Disk access location
  location string
  // Disk access tags
  tags map[string]string
  // Disk access type
  type string
  // Provisioning state
  provisioningState string
  // When the disk access was created
  timeCreated time
  // Private endpoint connections
  privateEndpointConnections() []azure.subscription.privateEndpointConnection
}

// Azure managed disk snapshot
azure.subscription.computeService.snapshot @defaults("name location diskSizeBytes diskState incremental") {
  // Snapshot ID
  id string
  // Snapshot name
  name string
  // Snapshot location
  location string
  // Snapshot tags
  tags map[string]string
  // Snapshot type
  type string
  // The snapshot SKU name and tier
  sku dict
  // Snapshot resource properties
  properties dict
  // Disk creation source information (createOption, sourceResourceId, sourceUri, etc.)
  creationData dict
  // Provisioning state of the snapshot
  provisioningState string
  // When the snapshot was created
  timeCreated time
  // Unique identifier of the snapshot (128-bit GUID)
  uniqueId string
  // Exact size of the snapshot in bytes
  diskSizeBytes int
  // Hyper-V generation of the snapshot (V1, V2)
  hyperVGeneration string
  // Operating system type of the source disk (Windows, Linux)
  osType string
  // Current state of the snapshot (Unattached, Attached, Reserved, ActiveSAS, ReadyToUpload, ActiveUpload, ActiveSASFrozen)
  diskState string
  // Whether this is an incremental snapshot
  incremental bool
  // Family ID shared by incremental snapshots of the same disk
  incrementalSnapshotFamilyId string
  // Whether the source disk supports hibernation
  supportsHibernation bool
  // Network access policy (AllowAll, AllowPrivate, DenyAll)
  networkAccessPolicy string
  // Whether public network access is enabled (Enabled, Disabled)
  publicNetworkAccess string
  // Snapshot encryption type (EncryptionAtRestWithPlatformKey, EncryptionAtRestWithCustomerKey, EncryptionAtRestWithPlatformAndCustomerKeys)
  encryptionType string
  // Data access authentication mode (AzureActiveDirectory, None)
  dataAccessAuthMode string
  // ARM ID of the DiskAccess resource for private endpoint access
  diskAccessId string
  // Snapshot access state determining availability (Unknown, Pending, Available)
  snapshotAccessState string
  // For snapshots of Premium SSD v2 or Ultra disks, time in minutes the snapshot is retained for instant access
  instantAccessDurationMinutes int
  // Azure Resource Manager system metadata (createdBy, createdAt, lastModifiedBy)
  systemData dict
  // Source disk for this snapshot (resolved from creationData.sourceResourceId when it points to a managed disk)
  sourceDisk() azure.subscription.computeService.disk
  // Disk encryption set used for customer-managed key encryption
  diskEncryptionSet() azure.subscription.computeService.diskEncryptionSet
}

// Azure Virtual Machine Scale Set
azure.subscription.computeService.vmScaleSet @defaults("name location orchestrationMode sku") {
  // VMSS ARM resource ID
  id string
  // VMSS name
  name string
  // VMSS location
  location string
  // VMSS tags
  tags map[string]string
  // VMSS resource type
  type string
  // Availability zones for the VMSS
  zones []string
  // VMSS SKU (name, tier, capacity)
  sku dict
  // VMSS resource properties
  properties dict
  // Orchestration mode ("Uniform" or "Flexible")
  orchestrationMode string
  // Provisioning state
  provisioningState string
  // When the scale set was created
  timeCreated time
  // Unique identifier of the scale set
  uniqueId string
  // Whether the scale set is limited to a single placement group of max 100 VMs
  singlePlacementGroup bool
  // Whether the scale set should be overprovisioned
  overprovision bool
  // Fault Domain count for each placement group
  platformFaultDomainCount int
  // Upgrade policy for the scale set
  upgradePolicy dict
  // Automatic repairs policy for the scale set
  automaticRepairsPolicy dict
  // Resiliency policy (operation recovery, zone allocation, automatic zone rebalancing, resilient VM creation/deletion)
  resiliencyPolicy dict
  // Scheduled-events policy (UserInitiatedReboot, UserInitiatedRedeploy, additional publishing targets)
  scheduledEventsPolicy dict
  // Spot/Regular priority mix policy for Flex VMSS
  priorityMixPolicy dict
  // Spot-Try-Restore policy (whether evicted Spot instances are restored opportunistically)
  spotRestorePolicy dict
  // SKU profile listing the candidate VM sizes and allocation strategy
  skuProfile dict
  // Security posture reference applied to the scale set (community gallery security posture)
  securityPostureReference dict
  // Align mode between VMSS compute and storage Fault Domain count
  zonalPlatformFaultDomainAlignMode string
  // Azure Resource Manager system metadata (createdBy, createdAt, lastModifiedBy)
  systemData dict
  // VMs that belong to this scale set
  instances() []azure.subscription.computeService.vmScaleSet.instance
  // Extensions installed on the scale set (each dict describes one extension)
  extensions() []dict
}

// Azure Virtual Machine Scale Set virtual machine instance
azure.subscription.computeService.vmScaleSet.instance @defaults("name instanceId provisioningState") {
  // Instance ARM resource ID
  id string
  // Instance ID within the scale set (e.g. "0", "1", ...)
  instanceId string
  // Instance name
  name string
  // Instance location
  location string
  // Instance tags
  tags map[string]string
  // Availability zones
  zones []string
  // Whether the latest model has been applied to this instance
  latestModelApplied bool
  // Provisioning state
  provisioningState string
  // Whether the model applied to the VM is the scale set's model or a customized model
  modelDefinitionApplied string
  // Azure VM unique 128-bit identifier
  vmId string
  // When the instance was created
  timeCreated time
  // Instance properties
  properties dict
  // Instance SKU (name, tier, capacity)
  sku dict
}

// Azure Dedicated Host Group — single-tenant placement scope for dedicated hosts
azure.subscription.computeService.dedicatedHostGroup @defaults("name location platformFaultDomainCount") {
  // Dedicated host group ARM resource ID
  id string
  // Dedicated host group name
  name string
  // Dedicated host group location
  location string
  // Dedicated host group tags
  tags map[string]string
  // Dedicated host group resource type
  type string
  // Availability zones for the dedicated host group (single zone supported)
  zones []string
  // Unmodeled resource properties returned by the Azure API
  properties dict
  // Number of fault domains used by the host group
  platformFaultDomainCount int
  // Whether the group supports automatic placement of VMs and scale set instances
  supportAutomaticPlacement bool
  // Additional capabilities (e.g. UltraSSDEnabled)
  additionalCapabilities dict
  // Instance view (status of hosts in the group)
  instanceView dict
  // Dedicated hosts in this group
  hosts() []azure.subscription.computeService.dedicatedHost
}

// Azure Dedicated Host — physical server reserved for a single tenant
azure.subscription.computeService.dedicatedHost @defaults("name sku.name provisioningState") {
  // Dedicated host ARM resource ID
  id string
  // Dedicated host name
  name string
  // Dedicated host location
  location string
  // Dedicated host tags
  tags map[string]string
  // Dedicated host resource type
  type string
  // Dedicated host SKU (name, tier, family)
  sku dict
  // Unmodeled resource properties returned by the Azure API
  properties dict
  // The fault domain of the host within its group
  platformFaultDomain int
  // Whether Azure should replace the host on failure
  autoReplaceOnFailure bool
  // Unique ID generated by Azure for the host
  hostId string
  // License type (None, WindowsServerHybrid, WindowsServerPerpetual)
  licenseType string
  // When the host was first provisioned
  provisioningTime time
  // Provisioning state
  provisioningState string
  // When the host was created
  timeCreated time
  // Instance view (host availability + assets)
  instanceView dict
}

// Azure Proximity Placement Group — co-location scope for compute resources
azure.subscription.computeService.proximityPlacementGroup @defaults("name location proximityPlacementGroupType") {
  // Proximity placement group ARM resource ID
  id string
  // Proximity placement group name
  name string
  // Proximity placement group location
  location string
  // Proximity placement group tags
  tags map[string]string
  // Proximity placement group resource type
  type string
  // Availability zones (Ultra type only — Standard does not support zones)
  zones []string
  // Unmodeled resource properties returned by the Azure API
  properties dict
  // Group type: Standard (latency-sensitive) or Ultra (lowest-latency)
  proximityPlacementGroupType string
  // Intent (e.g. supported VM sizes)
  intent dict
  // ARM IDs of VMs in this group (references)
  virtualMachineIds []string
  // ARM IDs of VMSS in this group (references)
  virtualMachineScaleSetIds []string
  // ARM IDs of availability sets in this group (references)
  availabilitySetIds []string
}

// Azure managed image — custom VM image stored as a single resource
azure.subscription.computeService.image @defaults("name location hyperVGeneration provisioningState") {
  // Image ARM resource ID
  id string
  // Image name
  name string
  // Image location
  location string
  // Image tags
  tags map[string]string
  // Image resource type
  type string
  // Unmodeled resource properties returned by the Azure API
  properties dict
  // Source VM ARM ID this image was captured from
  sourceVirtualMachineId string
  // Storage profile (OS disk + data disks)
  storageProfile dict
  // Provisioning state
  provisioningState string
  // Hyper-V generation (V1, V2)
  hyperVGeneration string
}

// Azure Compute Gallery (Shared Image Gallery) — versioned image distribution
azure.subscription.computeService.gallery @defaults("name location description") {
  // Gallery ARM resource ID
  id string
  // Gallery name
  name string
  // Gallery location
  location string
  // Gallery tags
  tags map[string]string
  // Gallery resource type
  type string
  // Unmodeled resource properties returned by the Azure API
  properties dict
  // Gallery description
  description string
  // Unique gallery name (used in URLs)
  uniqueName string
  // Provisioning state
  provisioningState string
  // Sharing profile — Private, Groups, or Community
  sharingProfile dict
  // Soft-delete policy
  softDeletePolicy dict
  // Sharing status (replication state across regions)
  sharingStatus dict
  // Image definitions in this gallery
  images() []azure.subscription.computeService.gallery.image
}

// Azure Compute Gallery image definition — versioned VM image template
azure.subscription.computeService.gallery.image @defaults("name osType osState hyperVGeneration") {
  // Image definition ARM resource ID
  id string
  // Image definition name
  name string
  // Image definition location
  location string
  // Image definition tags
  tags map[string]string
  // Image definition resource type
  type string
  // Unmodeled resource properties returned by the Azure API
  properties dict
  // Description of the image definition
  description string
  // OS type (Linux, Windows)
  osType string
  // OS state (Generalized, Specialized)
  osState string
  // Hyper-V generation (V1, V2)
  hyperVGeneration string
  // Architecture (x64, Arm64)
  architecture string
  // Image identifier — publisher, offer, sku
  identifier dict

  connectionStatus string
  // Message passed to the service owner with this connection request
  requestMessage string
}

// Azure Private Link service (provider-side resource that exposes a service via Private Link)
private azure.subscription.networkService.privateLinkService @defaults("id name location alias") {
  // Private Link service ID

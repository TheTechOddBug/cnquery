  childPolicies() []azure.subscription.networkService.firewallPolicy
  // List of firewalls the policy is associated with
  firewalls() []azure.subscription.networkService.firewall
  // Intrusion detection mode (Off, Alert, Deny)
  intrusionDetectionMode() string
  // Intrusion detection profile (Basic, Standard, Advanced)
  intrusionDetectionProfile() string
  // IDPS signature overrides (signatures with non-default modes)
  intrusionDetectionSignatureOverrides() []dict
  // IDPS bypass traffic rules
  intrusionDetectionBypassRules() []azure.subscription.networkService.firewallPolicy.idpsBypassRule
  // Rule collection groups that hold the policy's network, NAT, and application rules
  ruleCollectionGroups() []azure.subscription.networkService.firewallPolicy.ruleCollectionGroup
}

// Azure Firewall policy rule collection group
//
// A named, priority-ordered group of rule collections within a firewall
// policy. Each rule collection applies an allow or deny action (filter
// collections) or a DNAT or SNAT translation (NAT collections) to the
// network, application, and NAT rules it holds, so this is where a
// policy's effective traffic rules live. Select by the group's Azure
// resource ID.
private azure.subscription.networkService.firewallPolicy.ruleCollectionGroup @defaults("name priority") {
  // Rule collection group ID
  id string
  // Rule collection group name
  name string
  // Rule collection group etag
  etag string
  // Evaluation priority of the group; lower numbers are evaluated first
  priority int
  // Provisioning state of the rule collection group
  provisioningState string
  // Rule collections in the group
  //
  // Each entry carries ruleCollectionType (FirewallPolicyFilterRuleCollection
  // or FirewallPolicyNatRuleCollection), name, priority, and action, plus a
  // rules list whose shape varies by ruleType: network rules carry
  // ipProtocols, source/destination addresses, and destination ports;
  // application rules carry protocols, source addresses, target FQDNs, and
  // web categories; NAT rules carry the translated address and port.
  ruleCollections []dict
}

// Azure Firewall Policy IDPS bypass traffic rule
private azure.subscription.networkService.firewallPolicy.idpsBypassRule @defaults("name protocol") {
  // Unique ID (firewallPolicyId + rule name)
  id string
  // Rule name
  name string
  // Description of the bypass rule
  description string
  // Protocol (TCP, UDP, ICMP, ANY)
  protocol string
  // Source IP addresses or ranges
  sourceAddresses []string
  // Source IP group IDs
  //
  // Deprecated in favor of sourceIpGroupRefs, which resolves each IP group to
  // its typed resource.
  sourceIpGroups @maturity("deprecated") []string
  // Source IP groups referenced by the bypass rule
  sourceIpGroupRefs() []azure.subscription.networkService.ipGroup
  // Destination IP addresses or ranges
  destinationAddresses []string
  // Destination IP group IDs
  //
  // Deprecated in favor of destinationIpGroupRefs, which resolves each IP
  // group to its typed resource.
  destinationIpGroups @maturity("deprecated") []string
  // Destination IP groups referenced by the bypass rule
  destinationIpGroupRefs() []azure.subscription.networkService.ipGroup
  // Destination ports or ranges
  destinationPorts []string
}


// Single service endpoint configured on a subnet. Service
// endpoints route traffic from the subnet to a PaaS service over the
// Azure backbone instead of the public internet, scoped to the
// service and optionally to specific locations. Audit queries
// typically look for unexpected services (e.g., a database subnet
// with `Microsoft.Storage` enabled) or endpoints whose
// `provisioningState` has fallen out of `Succeeded`.
private azure.subscription.networkService.subnet.serviceEndpoint @defaults("service provisioningState") {
  // Service the endpoint routes traffic to (e.g., "Microsoft.Storage", "Microsoft.Sql", "Microsoft.KeyVault")
  service string

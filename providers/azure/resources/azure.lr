  type string
  // Protocols enabled on the share ("SMB" or "NFS")
  enabledProtocols string
  // Access tier ("TransactionOptimized", "Hot", "Cool", "Premium")
  accessTier string
  // Status of any pending access-tier transition; empty when none
  accessTierStatus string
  // Time the access tier was last changed
  accessTierChangeTime time
  // Provisioned share quota in GiB
  shareQuotaGiB int
  // Provisioned IOPS (Files Provisioned v2 only); zero otherwise
  provisionedIops int
  // Provisioned bandwidth in MiB/s (Files Provisioned v2 only); zero otherwise
  provisionedBandwidthMibps int
  // NFS root squash policy ("NoRootSquash", "RootSquash", "AllSquash"); empty for SMB
  rootSquash string
  // Number of stored access policies (signed identifiers) on the share
  signedIdentifierCount int
  // Whether the share is in the soft-deleted state
  deleted bool
  // When the share was soft-deleted, if applicable
  deletedTime time
  // Snapshot timestamp; empty when this is the live share
  snapshotTime time
  // Last modification time
  lastModifiedTime time
  // Lease state ("available", "leased", "expired", "breaking", "broken")
  leaseState string
  // Lease status ("locked", "unlocked")
  leaseStatus string
  // Lease duration ("Infinite", "Fixed"); empty when unleased
  leaseDuration string
  // User-defined metadata
  metadata map[string]string
  // Creation and last-modification provenance recorded by Azure Resource Manager
  systemMetadata() azure.subscription.systemData
}


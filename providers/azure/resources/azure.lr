private azure.subscription.cloudDefenderService.jitNetworkAccessPolicy.virtualMachine @defaults("vm.name publicIpAddress") {
  // Virtual machine the just-in-time rules apply to
  vm() azure.subscription.computeService.vm
  // Public IP of the Azure Firewall linked to the policy for this VM; empty when none

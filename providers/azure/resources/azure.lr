  privateIpAddress string
  // Private IP address allocation method (Static, Dynamic)
  privateIpAllocationMethod string
  // Private IP address version (IPv4, IPv6)
  privateIpAddressVersion string
  // Subnet the IP configuration is bound to
  subnet() azure.subscription.networkService.subnet
  // Public IP address bound to the IP configuration; null when the configuration has no public IP
  publicIpAddress() azure.subscription.networkService.ipAddress
  // Application security groups the IP configuration is a member of
  applicationSecurityGroups() []azure.subscription.networkService.appSecurityGroup
  // Virtual network taps mirroring this IP configuration's traffic
  virtualNetworkTaps() []azure.subscription.networkService.virtualNetworkTap
}

// Azure network IP address
private azure.subscription.networkService.ipAddress @defaults("name location ipAddress") {
  // IP address ID
  id string
  // IP address name
  name string
  // IP address location
  location string
  // IP address tags

// Azure Container Apps
//
// Examine Azure Container Apps managed environments, the Container Apps
// running in them, and Container Apps jobs. Use this resource to audit
// ingress posture, image pinning, identity-vs-secret registry auth,
// Easy Auth configuration, and revision history.
private azure.subscription.containerAppService {
  // Subscription identifier
  subscriptionId string
  // Managed environments (network/log boundary for Container Apps)
  managedEnvironments() []azure.subscription.containerAppService.managedEnvironment
  // All Container Apps in the subscription
  containerApps() []azure.subscription.containerAppService.containerApp
  // Container Apps jobs (run-to-completion workloads)
  jobs() []azure.subscription.containerAppService.job
}

// Azure Container Apps managed environment
//
// Examine the network, logging, and TLS boundary that hosts a set of
// Container Apps. Selectable by ARM id; fields cover VNET delegation,
// public-network access, peer-traffic mTLS, zone redundancy, and the
// linked Log Analytics workspace.
azure.subscription.containerAppService.managedEnvironment @defaults("name location provisioningState internalLoadBalancerEnabled") {
  // ARM resource ID
  id string
  // Environment name
  name string
  // Azure region
  location string
  // Resource tags
  tags map[string]string
  // Provisioning state ("Succeeded", "Failed", "Canceled", "InProgress", "Waiting")
  provisioningState string
  // Kind (e.g., "serverless", null for standard)
  kind string
  // VNET configuration: infrastructureSubnetId, dockerBridgeCidr, platformReservedCidr, platformReservedDnsIP, internal
  vnetConfiguration dict
  // Workload profiles (Consumption + Dedicated D4/D8/E4/...)
  workloadProfiles []dict
  // Static outbound IP for the environment
  staticIp string
  // Default DNS suffix for apps in this environment
  defaultDomain string
  // Whether the env's load balancer is internal-only (no public DNS)
  internalLoadBalancerEnabled bool
  // Whether zone redundancy is enabled
  zoneRedundant bool
  // Peer authentication (mTLS) configuration
  peerAuthentication dict
  // Peer traffic configuration (cluster-internal encryption)
  peerTrafficConfiguration dict
  // Custom domain configuration (dnsSuffix + cert thumbprint)
  customDomainConfiguration dict
  // App-logs destination ("log-analytics", "azure-monitor", "none", or null)
  logAnalyticsDestination string
  // Log Analytics workspace customer ID, when destination is "log-analytics"
  logAnalyticsCustomerId string
  // Whether public network access is enabled ("Enabled", "Disabled", or empty when not set)
  publicNetworkAccess string
  // Free-form error string set by ARM when deployment or validation failed
  deploymentErrors string
  // Env-wide ingress configuration (workloadProfileName, terminationGracePeriodSeconds, requestIdleTimeout, headerCountLimit)
  ingressConfiguration dict
  // Dapr components configured at the environment scope
  daprComponents() []azure.subscription.containerAppService.managedEnvironment.daprComponent
  // Certificates uploaded to the environment
  certificates() []azure.subscription.containerAppService.managedEnvironment.certificate
  // Private endpoint connections approved on this environment
  privateEndpointConnections() []azure.subscription.containerAppService.managedEnvironment.privateEndpointConnection
  // Env-scoped HTTP route configs (routing tables that span multiple container apps)
  httpRouteConfigs() []azure.subscription.containerAppService.managedEnvironment.httpRouteConfig
  // Env-scoped maintenance window configurations
  maintenanceConfigurations() []azure.subscription.containerAppService.managedEnvironment.maintenanceConfiguration
}

// Private endpoint connection on a Container Apps managed environment
private azure.subscription.containerAppService.managedEnvironment.privateEndpointConnection @defaults("name status provisioningState") {
  // ARM resource ID
  id string
  // Connection name within the environment
  name string
  // Approval status ("Approved", "Pending", "Rejected", "Disconnected")
  status string
  // Reason / description supplied with the status
  description string
  // Actions required by the consumer (e.g., "None")
  actionsRequired string
  // Provisioning state ("Succeeded", "Failed", "Canceled", "Creating", "Deleting", "Updating")
  provisioningState string
  // Private endpoint group IDs this connection covers
  groupIds []string
  // ARM resource ID of the private endpoint on the consumer side
  privateEndpointId string
}

// HTTP route config attached to a Container Apps managed environment
//
// Examine an env-scoped routing table that fans traffic across multiple
// container apps by path/prefix. The `name` field selects the route
// config within an environment.
private azure.subscription.containerAppService.managedEnvironment.httpRouteConfig @defaults("name fqdn provisioningState") {
  // ARM resource ID
  id string
  // Route config name within the environment
  name string
  // FQDN this route config serves
  fqdn string
  // Provisioning state ("Succeeded", "Failed", "Canceled", "Pending", "Updating", "Waiting", "Deleting")
  provisioningState string
  // Custom domain bindings on this route config
  customDomains []dict
  // Routing rules — each entry has `description`, `routes` (match + action), and `targets` (container apps / revisions / labels)
  rules []dict
  // Errors encountered while reconciling routes
  provisioningErrors []dict
}

// Maintenance configuration on a Container Apps managed environment
//
// Examine the maintenance window schedule for a managed environment.
// Container Apps applies infrastructure-level patches during the listed
// scheduled entries. The `name` field selects the configuration; a
// managed environment typically has at most one.
private azure.subscription.containerAppService.managedEnvironment.maintenanceConfiguration @defaults("name") {
  // ARM resource ID
  id string
  // Configuration name within the environment
  name string
  // Scheduled maintenance windows — each entry has `weekDay`, `startHourUtc`, `durationHours`
  scheduledEntries []dict
}

// Dapr component configured at the managed environment scope
private azure.subscription.containerAppService.managedEnvironment.daprComponent @defaults("name componentType version") {
  // ARM resource ID
  id string
  // Component name
  name string
  // Component type (e.g., "state.azure.cosmosdb", "secretstores.azure.keyvault")
  componentType string
  // Component version (e.g., "v1")
  version string
  // Whether secret values are referenced (vs inline)
  secretsConfigured bool
  // Names of declared secrets (values are not returned by ARM on read)
  secretNames []string
  // Container Apps allowed to use this component
  scopes []string
  // Whether component init failure is silently ignored
  ignoreErrors bool
  // Provisioning state ("Succeeded", "Failed", "Canceled", "InProgress", "Deleting")
  provisioningState string
  // Free-form error string set by ARM when deployment or validation failed
  deploymentErrors string
}

// Certificate uploaded to a Container Apps managed environment
private azure.subscription.containerAppService.managedEnvironment.certificate @defaults("name notAfter valid") {
  // ARM resource ID
  id string
  // Certificate name within the environment
  name string
  // Subject name on the cert
  subjectName string
  // SHA-1 thumbprint
  thumbprint string
  // Issue time
  issueDate time
  // Expiration time
  notAfter time
  // Whether the cert is currently valid (according to ARM)
  valid bool
  // Provisioning state
  provisioningState string
  // Free-form error string set by ARM when deployment or validation failed
  deploymentErrors string
  // Certificate issuer (CN of the issuing authority)
  issuer string
  // SHA-256 hash of the certificate's public key
  publicKeyHash string
  // Subject alternative names declared on the cert
  subjectAlternativeNames []string
}

// Azure Container App
//
// Examine a single Container App workload. The resource exposes ingress
// posture (external vs internal, transport, allowed origins, IP rules,
// client-cert mode), revision strategy, scale bounds, secrets/registry
// auth, and the per-container image and resource definitions.
azure.subscription.containerAppService.containerApp @defaults("name location provisioningState ingressExternal httpsOnly") {
  // ARM resource ID
  id string
  // Container App name
  name string
  // Azure region
  location string
  // Resource tags
  tags map[string]string
  // Provisioning state ("Succeeded", "Failed", "Canceled", "InProgress", "Deleting")
  provisioningState string
  // Running status of the container app ("Running", "Stopped", "Progressing", "Suspended", "Ready")
  runningStatus string
  // Container app variant ("Functionapp", "Workflowapp", or empty for a plain container app)
  kind string
  // Eventstream endpoint URL for log streaming
  eventStreamEndpoint string
  // Outbound IP addresses used by the container app
  outboundIpAddresses []string
  // ARM resource ID of the parent managed environment
  managedEnvironmentId string
  // Active revision mode ("Single" or "Multiple")
  revisionMode string
  // Latest revision name
  latestRevisionName string
  // Latest revision FQDN (where ingress lands)
  latestRevisionFqdn string
  // Whether ingress is enabled at all
  ingressEnabled bool
  // External ingress (true) vs internal-only (false)
  //
  // Only meaningful when `ingressEnabled == true` — defaults to false when ingress is disabled.
  ingressExternal bool
  // Target port for ingress
  targetPort int
  // Allowed transport ("Auto", "Http", "Http2", "Tcp" — Azure SDK casing)
  transport string
  // Whether HTTPS-only is enforced (insecureAllowed == false)
  httpsOnly bool
  // Sticky sessions affinity ("none" or "sticky")
  stickySessions string
  // Client-certificate mode ("ignore", "accept", "require")
  clientCertificateMode string
  // CORS allowed origins on ingress
  corsAllowedOrigins []string
  // IP security restrictions on ingress
  ipSecurityRestrictions []dict
  // Workload profile name in the parent environment ("Consumption" by default)
  workloadProfileName string
  // Min replica count
  minReplicas int
  // Max replica count
  maxReplicas int
  // Scale rules
  //
  // Each entry has `name` plus exactly one of `http`, `tcp`,
  // `azureQueue`, or `custom` (KEDA), and an optional `auth []` of
  // `{triggerParameter, secretRef}` entries pointing at names in `secretNames`.
  //   http:       {metadata: {concurrentRequests}}
  //   tcp:        {metadata: {concurrentConnections}}
  //   azureQueue: {queueName, queueLength}
  //   custom:     {type, metadata, identity}
  scaleRules []dict
  // Identity block (system + user-assigned principal IDs)
  identity dict
  // Container registry references (server, identity, passwordSecretRef)
  registries []dict
  // Whether any registry credential uses managed identity
  registryAuthUsesIdentity bool
  // Names of declared secrets (values are not returned by ARM on read)
  secretNames []string
  // Containers running in each replica
  containers() []azure.subscription.containerAppService.containerApp.container
  // Init containers
  initContainers() []azure.subscription.containerAppService.containerApp.container
  // Volumes referenced by containers (azureFile / emptyDir / secret)
  volumes []dict
  // Easy Auth (authConfigs) children
  authConfigs() []azure.subscription.containerAppService.containerApp.authConfig
  // Revision history
  revisions() []azure.subscription.containerAppService.containerApp.revision
}

// Container definition inside a Container App
private azure.subscription.containerAppService.containerApp.container @defaults("name image imagePinned") {
  // Composite id: <containerAppId>/containers/<name>
  id string
  // Container name (within the app)
  name string
  // Image reference (e.g., "myacr.azurecr.io/api:1.2.3" or "...@sha256:...")
  image string
  // Whether the image reference is digest-pinned (contains "@sha256:")
  imagePinned bool
  // Container start command
  command []string
  // Container start args
  args []string
  // Environment variables — each entry has {name, value, secretRef}
  env []dict
  // CPU cores (e.g., 0.25, 0.5, 1.0)
  cpuCores float
  // Memory string as returned by ARM (e.g., "0.5Gi", "1Gi", "2Gi")
  memory string
  // Liveness/readiness/startup probes
  probes []dict
  // Volume mounts (volumeName, mountPath, subPath)
  volumeMounts []dict
}

// Container App revision
private azure.subscription.containerAppService.containerApp.revision @defaults("name active trafficWeight provisioningState") {
  // ARM resource ID
  id string
  // Revision name
  name string
  // Whether this is currently active
  active bool
  // Traffic weight (% routed in Multiple-revision mode)
  trafficWeight int
  // Replicas currently running
  replicas int
  // Provisioning state
  provisioningState string
  // Health state ("Healthy", "Unhealthy", "None")
  healthState string
  // Running state ("Running", "Processing", "Stopped", "Degraded", "Failed", "Unknown")
  runningState string
  // Platform error message (when provisioning failed)
  provisioningError string
  // Creation time
  createdTime time
  // Last active time
  lastActiveTime time
}

// Container App Easy Auth (authConfig) configuration
private azure.subscription.containerAppService.containerApp.authConfig @defaults("name unauthenticatedClientAction") {
  // ARM resource ID
  id string
  // AuthConfig name (always "current" for the active config)
  name string
  // Whether Easy Auth is enabled at all (Platform.Enabled)
  enabled bool
  // Action when an unauthenticated request arrives ("RedirectToLoginPage", "AllowAnonymous", "Return401", "Return403")
  unauthenticatedClientAction string
  // Configured providers (e.g., "azureActiveDirectory", "github", "google", "facebook", "twitter", "apple", "customOpenIdConnect")
  identityProviders []string
  // Login config (token store enabled, token refresh extension hours, allowed external redirect URLs)
  login dict
  // HTTP settings (requireHttps, route configuration, forward proxy)
  httpSettings dict
}

// Azure Container Apps Job
//
// Examine a Container Apps Job — the run-to-completion sibling of
// Azure Container Apps. Surfaces the `triggerType` (Manual,
// Schedule, or Event), the configuration block (replica timeout,
// retry limit, parallelism, replica completion count, registries,
// secrets, identity), the per-trigger schedule or event-trigger
// configuration, the template (containers, init containers, volumes),
// the linked managed environment, and the workload profile the job
// runs on.
azure.subscription.containerAppService.job @defaults("name location triggerType provisioningState") {
  // ARM resource ID
  id string
  // Job name
  name string
  // Azure region
  location string
  // Resource tags
  tags map[string]string
  // ARM resource ID of the parent managed environment
  managedEnvironmentId string
  // Provisioning state
  provisioningState string
  // Eventstream endpoint URL for log streaming
  eventStreamEndpoint string
  // Trigger type ("Manual", "Schedule", "Event")
  triggerType string
  // Cron expression (when triggerType == "Schedule")
  cronExpression string
  // Event-driven scaling rules (KEDA-based) when triggerType == "Event"
  eventTriggerConfig dict
  // Replica timeout (seconds)
  replicaTimeoutSeconds int
  // Replica retry limit
  replicaRetryLimit int
  // Identity (system + user-assigned)
  identity dict
  // Container definitions (image, env, resources, probes); flattened
  containers []dict
  // Workload profile name in the parent environment
  workloadProfileName string
  // Container registry references
  registries []dict
  // Whether any registry credential uses managed identity
  registryAuthUsesIdentity bool
  // Names of declared secrets (values are not returned by ARM on read)
  secretNames []string
}

// Azure Container Instances
//
// Examine Azure Container Instances container groups and the containers
// within them. Use this resource to audit OS type, restart policy, image
// pinning, registry auth, VNET delegation, security context (privileged,
// runAsUser), and confidential-ACI usage.
private azure.subscription.containerInstanceService {
  // Subscription identifier
  subscriptionId string
  // All container groups in the subscription
  containerGroups() []azure.subscription.containerInstanceService.containerGroup
}

// Azure Container Instances container group
//
// Examine a container group — the unit of deployment in ACI, holding one
// or more containers that share lifecycle, network, and storage. Selectable
// by ARM id.
azure.subscription.containerInstanceService.containerGroup @defaults("name location osType sku ipAddressType") {
  // ARM resource ID
  id string
  // Container group name
  name string
  // Azure region
  location string
  // Resource tags
  tags map[string]string
  // Provisioning state ("Succeeded", "Pending", "Failed", "Canceled")
  provisioningState string
  // OS type ("Linux" or "Windows")
  osType string
  // Restart policy ("Always", "OnFailure", "Never")
  restartPolicy string
  // SKU ("Standard", "Dedicated", "Confidential")
  sku string
  // Convenience: sku == "Confidential"
  confidential bool
  // SHA-256 hash of the CCE policy (Confidential ACI only)
  ccePolicyHash string
  // Identity block (system + user-assigned principal IDs)
  identity dict
  // IP address type ("Public", "Private", or null)
  ipAddressType string
  // Public IP address, if any
  publicIp string
  // FQDN, if a DNS name label was set
  fqdn string
  // Auto-generated domain name label scope ("Unsecure", "TenantReuse", "SubscriptionReuse", "ResourceGroupReuse", "Noreuse")
  dnsNameLabelReusePolicy string
  // Exposed ports at the group level — each entry has {port, protocol}
  exposedPorts []dict
  // Subnet ARM resource IDs the group is delegated into (Private only)
  subnetIds []string
  // DNS configuration (nameServers, searchDomains, options)
  dnsConfig dict
  // Image registry credentials — each entry has {server, username?, identity?, identityUrl?}
  imageRegistryCredentials []dict
  // Whether any registry credential uses managed identity (vs username/password)
  registryAuthUsesIdentity bool
  // Volumes mounted into containers — entries are azureFile / emptyDir / secret / gitRepo
  volumes []dict
  // Convenience: any volume of type "secret"
  hasSecretVolume bool
  // Diagnostics: log analytics workspace ID linked to this group, if any
  logAnalyticsWorkspaceId string
  // CMK encryption properties (vaultBaseUrl, keyName, keyVersion, identity)
  encryption dict
  // Priority ("Regular" or "Spot")
  priority string
  // Availability zones the group is pinned to
  zones []string
  // Containers in the group
  containers() []azure.subscription.containerInstanceService.containerGroup.container
  // Init containers
  initContainers() []azure.subscription.containerInstanceService.containerGroup.container
}

// Single container inside a container group
private azure.subscription.containerInstanceService.containerGroup.container @defaults("name image imagePinned") {
  // Composite id: <containerGroupId>/containers/<name>
  id string
  // Container name (within the group)
  name string
  // Image reference
  image string
  // Whether the image reference is digest-pinned (contains "@sha256:")
  imagePinned bool
  // Container start command
  command []string
  // Environment variables — each entry has {name, value, secureValue}
  env []dict
  // CPU cores requested
  cpuCores float
  // Memory in GB requested
  memoryGB float
  // GPU count (zero when no GPU)
  gpuCount int
  // GPU SKU ("K80", "P100", "V100"), or null
  gpuSku string
  // Ports exposed by this container — each entry has {port, protocol}
  ports []dict
  // Volume mounts (volumeName, mountPath, readOnly)
  volumeMounts []dict
  // Liveness probe
  livenessProbe dict
  // Readiness probe
  readinessProbe dict
  // Raw security context
  //
  // Deprecated in favor of privileged, allowPrivilegeEscalation,
  // runAsUser, runAsGroup, seccompProfile, addedCapabilities, and
  // droppedCapabilities.
  securityContext @maturity("deprecated") dict
  // Whether the container runs in privileged mode (full host access)
  privileged bool
  // Whether a process can gain more privileges than its parent
  allowPrivilegeEscalation bool
  // UID the container process runs as; null when not pinned (may default to root, UID 0)
  runAsUser int
  // GID the container process runs as; null when not pinned
  runAsGroup int
  // Seccomp profile applied to the container, or null when none is set
  seccompProfile string
  // Linux capabilities added to the container beyond the default set
  addedCapabilities []string
  // Linux capabilities dropped from the container's default set
  droppedCapabilities []string
  // Current state (state, startTime, exitCode, finishTime, detailStatus)
  currentState dict
  // Restart count
  restartCount int
}

// Azure Logic Apps
//
// Examine Azure Logic Apps Consumption-tier workflows in the subscription.
// Use this resource to audit workflow state, access-control policies,
// secret-typed parameters, and the trigger and action set defined in
// each workflow's JSON definition.
private azure.subscription.logicService {
  // Subscription identifier
  subscriptionId string
  // Consumption-tier workflows
  workflows() []azure.subscription.logicService.workflow
}

// Azure Logic Apps Consumption workflow
//
// Examine a single Consumption-tier Logic App. Selectable by ARM id;
// fields cover lifecycle state, SKU, integration-account binding,
// access-control policies (per-policy IP allow lists and OAuth
// authentication policies), parameters (with secure-string detection),
// and the trigger and action lists parsed from the workflow definition.
azure.subscription.logicService.workflow @defaults("name location state provisioningState") {
  // ARM resource ID
  id string
  // Workflow name
  name string
  // Azure region
  location string
  // Resource tags
  tags map[string]string
  // Workflow state ("Enabled", "Disabled", "Suspended", "Completed", "Deleted", "NotSpecified")
  state string
  // Provisioning state ("Succeeded", "Failed", "Canceled", ...)
  provisioningState string
  // SKU name ("Free", "Shared", "Basic", "Standard", "Premium")
  skuName string
  // Workflow version (changes when the definition changes)
  version string
  // Public access endpoint, when ingress is exposed
  accessEndpoint string
  // Identity (system + user-assigned)
  identity dict
  // ARM id of the linked integration account, if any
  integrationAccountId string
  // ARM id of the linked integration service environment (ISE), if any
  integrationServiceEnvironmentId string
  // Created time
  createdTime time
  // Last changed time
  changedTime time
  // Outgoing connector / workflow / access-endpoint IPs reported for the workflow
  endpointsConfiguration dict
  // Access-control policy for inbound triggers
  //
  // Has `allowedCallerIpAddresses []` and `openAuthenticationPolicies {}`. Empty IP list means no IP restriction.
  accessControlTriggers dict
  // Access-control policy for reading workflow run contents
  accessControlContents dict
  // Access-control policy for invoking workflow actions
  accessControlActions dict
  // Access-control policy for workflow management operations
  accessControlWorkflowManagement dict
  // Whether at least one access-control policy has an IP allow list configured
  hasIpRestrictions bool
  // Workflow parameters
  //
  // Each entry has {name, type, hasDefaultValue, isSecure}.
  // `isSecure` is true when type is `SecureString` or `SecureObject`.
  parameters []dict
  // Names of parameters whose type is `SecureString` or `SecureObject`
  secureParameterNames []string
  // Triggers parsed from the workflow definition
  //
  // Each entry has {name, type, kind?}.
  // `type` examples: "Request" (HTTP), "Recurrence", "ApiConnection", "ApiConnectionWebhook".
  triggers []dict
  // Actions parsed from the workflow definition
  //
  // Each entry has {name, type}.
  // `type` examples: "Http", "ApiConnection", "Compose", "Workflow", "If", "Foreach", "Until".
  actions []dict
  // Names of API connections referenced by triggers and actions (i.e., `parameters.$connections` keys)
  connectionNames []string
}

// ===== Azure API Management Service =====

// Azure API Management
//
// Use this namespace to enumerate the API Management gateway instances
// configured in the subscription via `services()`. The returned
// `azure.subscription.apiManagementService.service` resources expose
// SKU, virtual-network integration mode, public network access,
// gateway TLS / cipher policy, identity, endpoints, and private
// endpoint connection state.
private azure.subscription.apiManagementService {
  // Subscription identifier
  subscriptionId string
  // API Management service instances
  services() []azure.subscription.apiManagementService.service
}

// Azure API Management service instance
//
// Examine an API Management gateway service — the multi-tenant API
// gateway that fronts backend APIs with auth, rate limiting, transforms,
// and a developer portal. Surfaces the SKU and capacity, virtual-network
// integration mode (None / External / Internal), public network access
// state, the NAT gateway toggle, gateway / management / portal /
// developer-portal / SCM endpoint URLs, the `disableGateway` flag, the
// `enableClientCertificate` flag for Consumption SKU mTLS, status of
// the developer and legacy portals, platform version, the custom
// properties map that encodes the gateway TLS / cipher policy
// (`Microsoft.WindowsAzure.ApiManagement.Gateway.Security.Protocols.Tls10`
// etc.), publisher email and name, identity, public / private /
// outbound IP addresses, the count of private endpoint connections, and
// the availability zones.
azure.subscription.apiManagementService.service @defaults("name location skuName provisioningState") {
  // Resource ID of the API Management service
  id string
  // Service name
  name string
  // Resource location
  location string
  // Resource tags
  tags map[string]string
  // SKU name ("Developer", "Basic", "Standard", "Premium", "Consumption", "BasicV2", "StandardV2", "PremiumV2", "Isolated")
  skuName string
  // Number of deployed units of the SKU
  skuCapacity int
  // Provisioning state ("Created", "Activating", "Succeeded", "Updating", "Failed", "Stopped", "Terminating", "TerminationFailed", "Deleted")
  provisioningState string
  // Target provisioning state for any in-flight long-running operation (empty when none)
  targetProvisioningState string
  // Publisher email address used as the From address for notifications
  publisherEmail string
  // Publisher display name
  publisherName string
  // Notification sender email address
  notificationSenderEmail string
  // Gateway URL clients use to call APIs hosted on the service
  gatewayUrl string
  // Gateway URL in the default region (set on multi-region deployments)
  gatewayRegionalUrl string
  // Management API endpoint URL
  managementApiUrl string
  // Publisher portal endpoint URL (legacy portal)
  portalUrl string
  // Developer portal endpoint URL
  developerPortalUrl string
  // SCM (source-control management) endpoint URL
  scmUrl string
  // Virtual network integration mode ("None", "External", or "Internal")
  virtualNetworkType string
  // Public network access ("Enabled" or "Disabled")
  publicNetworkAccess string
  // NAT gateway state ("Enabled" or "Disabled")
  natGatewayState string
  // Whether the gateway is disabled in the master region (multi-region deployments only)
  disableGateway bool
  // Whether clients are required to present a TLS certificate on every request (Consumption SKU only)
  enableClientCertificate bool
  // Developer portal status ("Enabled" or "Disabled")
  developerPortalStatus string
  // Legacy portal status ("Enabled" or "Disabled")
  legacyPortalStatus string
  // Compute platform version running the service (e.g. "stv2", "stv1", "mtv1")
  platformVersion string
  // Custom properties controlling gateway TLS protocol / cipher policy
  //
  // Keys like `Microsoft.WindowsAzure.ApiManagement.Gateway.Security.Protocols.Tls10` map to "True"/"False" string values.
  customProperties map[string]string
  // Identity type ("None", "SystemAssigned", "UserAssigned", "SystemAssigned, UserAssigned")
  identityType string
  // Public load-balanced IPv4 addresses of the service in its primary region (Basic / Standard / Premium / Isolated SKUs)
  publicIpAddresses []string
  // Private load-balanced IPv4 addresses of the service in its primary region when deployed in an Internal VNet
  privateIpAddresses []string
  // Outbound public IPv4 prefixes associated with NAT Gateway-deployed services (Premium SKU on stv2)
  outboundPublicIpAddresses []string
  // Number of private endpoint connections to the service
  privateEndpointConnectionCount int
  // Availability zones the service is spread across
  zones []string
  // Public IP address attached to the service (null when not configured)
  publicIpAddress() azure.subscription.networkService.ipAddress
  // Service creation time
  createdAt time
}

// Microsoft Purview
//
// Use the Purview namespace to enumerate the Microsoft Purview accounts
// in the subscription. Each account is a tenant-scoped data-governance
// and sensitive-data-discovery hub that catalogs data assets across
// Azure (Storage, SQL, Synapse, Cosmos DB, Power BI) and external clouds.
// Iterate `accounts()` for the per-region Purview accounts and inspect
// their public-network-access posture, managed-resource-group bindings,
// SKU, and public endpoints.
private azure.subscription.purviewService {
  // Subscription identifier
  subscriptionId string
  // Microsoft Purview accounts in the subscription
  accounts() []azure.subscription.purviewService.account
}

// Microsoft Purview account
//
// Examine a single Purview account — the tenant-scoped governance hub
// that hosts the data catalog, scanning, classification, and lineage
// surfaces. Use `publicNetworkAccess` to confirm whether the account is
// reachable from the public internet; `managedResourceGroupName` and
// `managedResources` to find the Purview-managed Storage and Event Hub
// resources backing the account; `endpoints` for the catalog/scan/guardian
// URIs; and `privateEndpointConnections` for the approved private-link
// bindings.
private azure.subscription.purviewService.account @defaults("name location publicNetworkAccess provisioningState") {
  // Full resource ID
  id string
  // Name of the Purview account
  name string
  // Location of the account
  location string
  // Resource type
  type string
  // Tags on the account
  tags map[string]string
  // Account SKU (name, capacity)
  sku dict
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Friendly display name for the account
  friendlyName string
  // Provisioning state: Succeeded, Failed, Creating, Deleting, Moving, Unknown
  provisioningState string
  // Whether the account is reachable from the public internet: Enabled, NotConfigured, or Disabled
  publicNetworkAccess string
  // Name of the Purview-managed resource group that backs this account
  managedResourceGroupName string
  // Resource identifiers of the managed resources (storage account, event hub namespace, resource group ID)
  managedResources dict
  // Public endpoints of the account, with keys `catalog`, `guardian`, `scan`
  endpoints dict
  // Approved private-endpoint connections for the account
  privateEndpointConnections []dict
  // Cloud connectors for external (AWS) scanning, with the externally surfaced AWS external ID
  cloudConnectors dict
  // When the account was created
  createdAt time
  // Object ID of the principal that created the account
  createdByObjectId string
  // Principal name that created the account
  createdBy string
  // Unmodeled raw properties returned by the Azure API
  properties dict
}

// Azure AI Search
//
// Use the search namespace to enumerate the Azure AI Search services in
// the subscription. Each service hosts search indexes that frequently
// hold sensitive or business-critical content, so the namespace is the
// entry point for auditing their public-network exposure, customer-managed-key
// encryption, and authentication posture. Iterate `services()` for the
// per-service records.
private azure.subscription.searchService {
  // Subscription identifier
  subscriptionId string
  // Azure AI Search services in the subscription
  services() []azure.subscription.searchService.service
}

// Azure AI Search service
//
// Examine a single Azure AI Search service — the managed service that
// hosts search indexes, indexers, and data sources. Use `publicNetworkAccess`
// to confirm whether the service is reachable from the public internet,
// `cmkEnforcement` for the customer-managed-key compliance policy and
// `cmkEncryptionComplianceStatus` for whether any indexes remain
// platform-encrypted, `disableLocalAuth` for whether API-key authentication
// is turned off in favor of Microsoft Entra ID, `replicaCount` and
// `partitionCount` for the provisioned capacity, `hostingMode` for the
// high-density option, and `networkRuleSet` for the IP firewall rules.
azure.subscription.searchService.service @defaults("id name location publicNetworkAccess") {
  // Search service resource ID
  id string
  // Search service name
  name string
  // Search service location
  location string
  // Search service tags
  tags map[string]string
  // SKU details (name: free, basic, standard, standard2, standard3, storage_optimized_l1, storage_optimized_l2)
  sku dict
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Whether the service is reachable from the public internet ("enabled" or "disabled")
  publicNetworkAccess string
  // Whether API-key (local) authentication is disabled, leaving Microsoft Entra ID as the only method
  disableLocalAuth bool
  // Customer-managed-key encryption enforcement policy ("Enabled", "Disabled", or "Unspecified")
  cmkEnforcement string
  // Compliance status for customer-managed-key encryption of indexes ("Compliant" or "NonCompliant")
  cmkEncryptionComplianceStatus string
  // Number of replicas, which determine query throughput and high availability
  replicaCount int
  // Number of partitions, which determine index size and document-count limits
  partitionCount int
  // Capacity mode for the service ("default" or "highDensity"); "highDensity" applies only to the standard3 SKU
  hostingMode string
  // The endpoint URL of the search service
  endpoint string
  // Provisioning state of the service ("succeeded", "provisioning", or "failed")
  provisioningState string
  // Operational status of the service ("running", "provisioning", "deleting", "degraded", "disabled", "error", or "stopped")
  status string
  // Network rule set: IP firewall rules and the bypass setting governing public access
  networkRuleSet dict
}

// Azure Machine Learning
//
// Use the Machine Learning namespace to enumerate the Azure Machine Learning
// workspaces in the subscription, backed by the
// `Microsoft.MachineLearningServices` resource provider. A workspace is the
// top-level container for ML assets — experiments, models, compute, and
// datastores — and binds to a Key Vault, Storage account, Application Insights
// component, and Container Registry, so the namespace is the entry point for
// auditing their public-network exposure, network isolation,
// customer-managed-key encryption, and authentication posture. Iterate
// `workspaces()` for the per-workspace records.
private azure.subscription.machineLearningService {
  // Subscription identifier
  subscriptionId string
  // Azure Machine Learning workspaces in the subscription
  workspaces() []azure.subscription.machineLearningService.workspace
}

// Azure Machine Learning workspace
//
// Examine a single Azure Machine Learning workspace — the top-level container
// for ML experiments, models, compute, and datastores. Use
// `publicNetworkAccess` to confirm whether the workspace is reachable from the
// public internet, `managedNetworkIsolationMode` for the managed-VNet outbound
// policy, `hbiWorkspace` for whether it is flagged high-business-impact (which
// restricts the diagnostic data Microsoft collects),
// `allowPublicAccessWhenBehindVnet` for whether public access is permitted
// despite a private endpoint, `v1LegacyMode` for whether the older v1 API
// surface is still enabled, `encryptionKey` for the customer-managed key
// encrypting workspace data (null when platform-managed), and `keyVault`,
// `storageAccount`, `applicationInsights`, and `containerRegistry` for the
// linked resources whose own posture the workspace inherits. Select a
// workspace by `name` — for example
// `azure.subscription.machineLearning.workspaces.where(name == "my-ws")`.
azure.subscription.machineLearningService.workspace @defaults("id name location publicNetworkAccess") {
  // Workspace resource ID
  id string
  // Workspace name
  name string
  // Workspace location
  location string
  // Workspace tags
  tags map[string]string
  // Workspace kind (e.g., Default, Hub, Project, FeatureStore)
  kind string
  // SKU details (name and tier)
  sku dict
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Immutable workspace identifier assigned by Azure
  workspaceId string
  // Friendly (display) name of the workspace
  friendlyName string
  // Workspace description
  description string
  // Provisioning state of the workspace
  provisioningState string
  // Whether the workspace is reachable from the public internet ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Outbound isolation mode of the managed virtual network
  //
  // One of "Disabled", "AllowInternetOutbound", or "AllowOnlyApprovedOutbound".
  managedNetworkIsolationMode string
  // Whether the workspace is flagged high-business-impact, which limits the diagnostic data Microsoft collects
  hbiWorkspace bool
  // Whether public network access is allowed even when the workspace is behind a virtual network
  allowPublicAccessWhenBehindVnet bool
  // Whether the legacy v1 API surface (v1LegacyMode) is enabled
  v1LegacyMode bool
  // URL of the discovery service that clients use to resolve workspace-scoped endpoints
  discoveryUrl string
  // MLflow tracking URI for the workspace
  mlFlowTrackingUri string
  // Compute resource (by name) used to build environment images; empty when the default managed build compute is used
  imageBuildCompute string
  // Whether workspace data is encrypted with a customer-managed key ("Enabled") or a Microsoft-managed key ("Disabled")
  encryptionStatus string
  // Private endpoint connections to the workspace
  privateEndpointConnections []dict
  // Customer-managed Key Vault key encrypting workspace data (null when Microsoft-managed)
  encryptionKey() azure.subscription.keyVaultService.key
  // Resource ID of the linked Key Vault
  keyVaultId string
  // Key Vault linked to the workspace, holding its secrets
  keyVault() azure.subscription.keyVaultService.vault
  // Resource ID of the linked Storage account
  storageAccountId string
  // Storage account linked to the workspace, holding its datastores
  storageAccount() azure.subscription.storageService.account
  // Resource ID of the linked Application Insights component
  applicationInsightsId string
  // Application Insights component linked to the workspace for telemetry
  applicationInsights() azure.subscription.monitorService.applicationInsight
  // Resource ID of the linked Container Registry
  containerRegistryId string
  // Container Registry linked to the workspace, holding its environment images
  containerRegistry() azure.subscription.containerRegistryService.registry
  // Real-time inference (online) endpoints serving models from the workspace
  onlineEndpoints() []azure.subscription.machineLearningService.workspace.onlineEndpoint
  // Serverless (Models-as-a-Service) endpoints in the workspace
  serverlessEndpoints() []azure.subscription.machineLearningService.workspace.serverlessEndpoint
  // Compute targets attached to or managed by the workspace
  computes() []azure.subscription.machineLearningService.workspace.compute
  // Models registered in the workspace
  models() []azure.subscription.machineLearningService.workspace.model
}

// Real-time inference endpoint in an Azure Machine Learning workspace
//
// Examine a single online endpoint — the HTTPS endpoint that serves one
// or more model deployments for real-time scoring, selected by `name`.
// Use `authMode` to see how callers authenticate ("Key" or "AMLToken"),
// `scoringUri` for the inference URL, `publicNetworkAccess` for whether
// the endpoint is reachable from the public internet, `traffic` for how
// live traffic is split across deployments, and `deployments` for the
// model deployments behind the endpoint.
azure.subscription.machineLearningService.workspace.onlineEndpoint @defaults("name authMode provisioningState publicNetworkAccess") {
  // Online endpoint resource ID
  id string
  // Endpoint name, used as the selection key
  name string
  // Endpoint location
  location string
  // Endpoint tags
  tags map[string]string
  // Resource kind metadata used by tooling
  kind string
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Description of the endpoint
  description string
  // Authentication mode: "Key" (non-expiring keys) or "AMLToken" (expiring Azure Machine Learning tokens)
  authMode string
  // Whether the endpoint allows public access when Private Link is enabled ("Enabled" or "Disabled")
  publicNetworkAccess string
  // Scoring (inference) URL of the endpoint
  scoringUri string
  // Swagger (OpenAPI) URL of the endpoint
  swaggerUri string
  // Live-traffic split percentage per deployment name (values sum to 100)
  traffic map[string]int
  // Mirror-traffic percentage per deployment name, sent without returning scores (values sum to at most 50)
  mirrorTraffic map[string]int
  // Compute serving the endpoint (null for managed compute, where Azure provisions the infrastructure)
  compute() azure.subscription.machineLearningService.workspace.compute
  // Provisioning state of the endpoint
  provisioningState string
  // Model deployments behind the endpoint
  deployments() []azure.subscription.machineLearningService.workspace.onlineEndpoint.deployment
}

// Model deployment behind an online endpoint
//
// Examine a single online deployment — the model, environment, and
// compute that serve a share of an online endpoint's traffic, selected
// by `name`. Use `model` for the registered model being served,
// `instanceType` and `skuCapacity` for the compute size and instance
// count, `endpointComputeType` for the hosting type ("Managed",
// "Kubernetes", or "AzureMLCompute"), `environmentId` for the inference
// environment, and `egressPublicNetworkAccess` for whether the container
// has unrestricted outbound network access.
azure.subscription.machineLearningService.workspace.onlineEndpoint.deployment @defaults("name model instanceType provisioningState") {
  // Online deployment resource ID
  id string
  // Deployment name, used as the selection key
  name string
  // Deployment location
  location string
  // Deployment tags
  tags map[string]string
  // Description of the deployment
  description string
  // Hosting compute type: "Managed", "Kubernetes", or "AzureMLCompute"
  endpointComputeType string
  // URI or asset ID of the registered model being served
  model string
  // ARM resource ID or asset ID of the inference environment
  environmentId string
  // Compute instance type (VM size) backing the deployment
  instanceType string
  // SKU name for autoscaling (e.g., "Default")
  skuName string
  // Number of provisioned instances
  skuCapacity int
  // Whether Application Insights logging is enabled for the deployment
  appInsightsEnabled bool
  // Whether the container has unrestricted outbound (egress) public network access ("Enabled" or "Disabled")
  egressPublicNetworkAccess string
  // Provisioning state of the deployment
  provisioningState string
}

// Serverless (Models-as-a-Service) endpoint in an Azure Machine Learning workspace
//
// Examine a single serverless endpoint — a pay-as-you-go model API
// consumed without provisioning compute, selected by `name`. Use
// `modelId` for the model being served, `inferenceUri` for the inference
// URL, `authMode` and `endpointState` for the authentication mode and
// lifecycle state, `marketplaceSubscriptionId` for the backing
// Marketplace subscription, and `contentSafetyStatus` for whether
// content safety filtering is enabled.
azure.subscription.machineLearningService.workspace.serverlessEndpoint @defaults("name modelId endpointState provisioningState") {
  // Serverless endpoint resource ID
  id string
  // Endpoint name, used as the selection key
  name string
  // Endpoint location
  location string
  // Endpoint tags
  tags map[string]string
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Authentication mode for the endpoint (e.g., "Key")
  authMode string
  // Lifecycle state of the endpoint (e.g., "Creating", "Online", "Deleting", "Failed")
  endpointState string
  // Unique model identifier served by the endpoint
  modelId string
  // Inference URL to target when calling the endpoint
  inferenceUri string
  // ARM resource ID of the Marketplace subscription backing the endpoint
  marketplaceSubscriptionId string
  // Content-safety filtering status ("Enabled" or "Disabled")
  contentSafetyStatus string
  // Provisioning state of the endpoint
  provisioningState string
}

// Compute target in an Azure Machine Learning workspace
//
// Examine a single compute target — the cluster, instance, or attached
// resource that runs jobs and model deployments, selected by `name`. Use
// `computeType` for the kind of compute ("AmlCompute", "ComputeInstance",
// "Kubernetes", "AKS", and others), `disableLocalAuth` for whether SSH /
// local authentication is turned off in favor of Microsoft Entra ID,
// `isAttachedCompute` for whether the resource was brought from outside
// the workspace, and `resourceId` for the underlying ARM compute it maps
// to.
azure.subscription.machineLearningService.workspace.compute @defaults("name computeType provisioningState disableLocalAuth") {
  // Compute resource ID
  id string
  // Compute name, used as the selection key
  name string
  // Compute location
  location string
  // Compute tags
  tags map[string]string
  // Identity configuration (SystemAssigned, UserAssigned, principalId, tenantId)
  identity dict
  // Kind of compute
  //
  // Examples include "AmlCompute", "ComputeInstance", "Kubernetes", "AKS", "VirtualMachine", "DataFactory", "Databricks", "HDInsight", and "SynapseSpark".
  computeType string
  // Description of the compute
  description string
  // Whether local (SSH) authentication is disabled, leaving Microsoft Entra ID as the only method
  disableLocalAuth bool
  // Whether the compute was provisioned outside the workspace and attached, rather than created by the workspace
  isAttachedCompute bool
  // ARM resource ID of the underlying compute resource
  resourceId string
  // Location of the underlying compute resource
  computeLocation string
  // Provisioning state of the compute (e.g., "Succeeded", "Provisioning", "Failed")
  provisioningState string
  // When the compute was created
  createdOn time
  // When the compute was last modified
  modifiedOn time
}

// Registered model in an Azure Machine Learning workspace
//
// Examine a single registered model container — the named entry that
// groups all versions of a model, selected by `name`. Use `latestVersion`
// for the most recent registered version, `nextVersion` for the version
// the next registration will receive, `isArchived` for whether the model
// is archived, and `description`/`tags` for the model's metadata.
azure.subscription.machineLearningService.workspace.model @defaults("name latestVersion provisioningState") {
  // Model container resource ID

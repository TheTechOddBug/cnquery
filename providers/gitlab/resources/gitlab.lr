  commit dict
  // Release evidence collected at publish time (tamper-evidence)
  //
  // Each entry is a dict with sha, filepath, and collectedAt keys.
  evidences []dict
  // Downloadable assets attached to the release
  //
  // A dict with count, sources (format/url), and links (id/name/url/linkType/
  // external) keys.
  assets dict
}

